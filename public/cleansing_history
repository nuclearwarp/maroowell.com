    [
      "week",
      "camp",
      "wave",
      "route",
      "vendor",
      "biz",
      "reason",
      "limit",
      "q"
    ].forEach(id => {
      const v = val(id);
      if (v) p.set(id, v);
    });

    let data = null;

    try {
      data = await api("/api/cleansing-history?" + p.toString());
