    }

    $("pointListCount").textContent = `${rows.length}개`;

    list.innerHTML = rows.map(row => {
      const active = selectedPoint?.id === row.id ? "active" : "";
      const title = row.title || pointTypeLabel(row.point_type) || "배송 포인트";

      return `
        <div class="pointCard ${active}" data-point-id="${esc(row.id)}">
          <b>${esc(title)}</b>
          <div>${esc(pointTypeLabel(row.point_type))} · ${esc(routeCodeForPoint(row))}</div>
          <div>${esc([row.delivery_tip, row.entrance_note, row.password_note].filter(Boolean)[0] || "")}</div>
        </div>
