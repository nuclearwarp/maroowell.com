      setRouteBaseStatus("라우트 삭제는 최고관리자만 가능합니다.", "bad");
      return;
    }

    if (!selectedRoute) {
      setRouteBaseStatus("선택된 라우트가 없습니다.", "bad");
      return;
    }

    const camp = selectedRoute.camp;
    const code = routeCodeOf(selectedRoute);

    const relatedPolygons = polygonRows.filter(row => {
      return row.is_active !== false && row.camp === camp && polygonCodeOf(row) === code;
    });

    const relatedPoints = pointRows.filter(row => {
      return row.is_active !== false
        && (
          row.route_info_id === selectedRoute.id ||
          (row.camp === camp && normalizeRoute(row.route_code || row.route_norm) === code)
        );
    });

    const ok = confirm(
      [
        "이 라우트를 삭제 처리할까요?",
        "",
        `${camp} / ${code}`,
        "",
        `연결 폴리곤: ${relatedPolygons.length}건`,
        `연결 포인트: ${relatedPoints.length}건`,
        "",
        "실제 삭제가 아니라 is_active=false 처리됩니다.",
        "잘못 등록된 엑셀 데이터 정리용입니다."
      ].join("\n")
    );

    if (!ok) return;

    setRouteBaseStatus("라우트 삭제 처리 중...", "warn");

    for (const poly of relatedPolygons) {
      const { error } = await supabaseClient
        .from(TABLE_POLYGON)
        .update({ is_active:false })
        .eq("id", poly.id);

      if (error) throw error;
    }

    for (const point of relatedPoints) {
      const { error } = await supabaseClient
        .from(TABLE_POINT)
        .update({ is_active:false })
        .eq("id", point.id);

      if (error) throw error;
    }

    const { error } = await supabaseClient
      .from(TABLE_ROUTE)
      .update({ is_active:false })
      .eq("id", selectedRoute.id);

    if (error) throw error;

    routeRows = routeRows.filter(row => row.id !== selectedRoute.id);
    polygonRows = polygonRows.map(row => {
      return relatedPolygons.some(poly => poly.id === row.id) ? { ...row, is_active:false } : row;
    });
    pointRows = pointRows.map(row => {
      return relatedPoints.some(point => point.id === row.id) ? { ...row, is_active:false } : row;
    }).filter(row => row.is_active !== false);

    selectedRoute = null;
    selectedPoint = null;
    selectedPolygonId = null;

    cancelDrawModeSilently();
    clearAttachmentsState();
    renderRouteList();
    renderPointList();
    clearRouteDetail();
    fillPointForm(null);
    renderMapFeatures();
    renderCounts();

    setStatus("라우트 삭제 처리 완료", "ok");
  }

