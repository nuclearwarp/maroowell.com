      function showAccessDenied(email,detail){dom.accessDenied.classList.add("show");dom.accessDeniedText.textContent=detail||"이 페이지는 마루웰 소속 관리자만 접근할 수 있습니다.";dom.accessDeniedEmail.textContent=email?"현재 로그인: "+email:"현재 로그인 이메일을 확인할 수 없습니다.";document.documentElement.style.visibility="visible"}async function signOutAndMove(){try{await supabase?.auth?.signOut()}catch{}location.replace(LOGIN_PATH)}async function requireAuth(){if(!supabase||!supabase.auth){alert("Supabase 설정을 확인하세요.");return false}try{const {data:{session}}=await supabase.auth.getSession();if(!session){const next=safeNextPath(location.pathname+location.search+location.hash);location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);return false}state.session=session;state.viewerEmail=normalizeText(session.user?.email||"");state.viewerUserId=normalizeText(session.user?.id||"");dom.userPill.textContent=state.viewerEmail||state.viewerUserId||"로그인";supabase.auth.onAuthStateChange((evt,s)=>{if(evt==="SIGNED_OUT"||!s){const next=safeNextPath(location.pathname+location.search+location.hash);location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`)}});if(!state.viewerUserId){showAccessDenied(state.viewerEmail,"로그인 사용자 ID를 확인할 수 없습니다.");return false}document.documentElement.style.visibility="visible";return true}catch(e){console.error(e);const next=safeNextPath(location.pathname+location.search+location.hash);location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);return false}}async function routeApi(path,body={}){if(!state.session?.access_token){const ok=await requireAuth();if(!ok)throw new Error("로그인이 필요합니다.")}const res=await fetch(API_BASE+path,{method:"POST",headers:{"Content-Type":"application/json","Authorization":"Bearer "+state.session.access_token},body:JSON.stringify(body),cache:"no-store"});const text=await res.text();let data=null;if(text){try{data=JSON.parse(text)}catch{data=text}}if(!res.ok||data?.ok===false){const msg=(data&&typeof data==="object"&&(data.error||data.me