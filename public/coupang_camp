<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}
    /* =========================================================
       문경감홍사과체 과굵음 보정
       - 기능 로직 변경 없음
       - 가짜 bold/900/1000 느낌 제거
       ========================================================= */
    body{
      font-weight:400 !important;
    }

    .titleBox b{
      font-weight:700 !important;
    }

    .titleBox small,
    .helper,
    .statusText,
    .toggle,
    .pill{
      font-weight:500 !important;
    }

    .btn,
    .rowActionBtn{
      font-weight:650 !important;
    }

    thead th{
      font-weight:650 !important;
    }

    .filterInput,
    .filterSelect{
      font-weight:500 !important;
    }

    .cellInput,
    .cellSelect{
      font-weight:500 !important;
    }

    .cellInput:disabled,
    .cellSelect:disabled{
      font-weight:500 !important;
    }

    .emptyDataRow td{
      font-weight:500 !important;
    }

    .accessCard h2{
      font-weight:700 !important;
    }

    .accessCard p,
    .accessMeta{
      font-weight:500 !important;
    }

  </style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>쿠팡 캠프 조회</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    @font-face{
      font-family:"문경사과감홍체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --surface:#ffffff;
      --surface2:#f8fafc;
      --line:#d8e0ee;
      --line2:#d4dbe5;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --green:#16a34a;
      --yellow:#b77900;
      --red:#dc2626;

      --sheetBg:#eef3f8;
      --headBg:#dce8f5;
      --filterBg:#edf3fb;
      --cellBg:#ffffff;
      --cellAlt:#f8fbff;
      --cellTxt:#0f172a;
      --dirtyBg:#e0eeff;
      --dirtyBorder:#60a5fa;

      --topbarH:56px;
      --toolbarH:58px;
      --statusH:44px;
      --font-mw:"문경감홍사과체","문경사과감홍체","Mungyeong Apple Gamhong","MungyeongGamhong","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      --shadow:0 8px 24px rgba(15,23,42,.08);
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      height:100%;
      font-family:var(--font-mw);
      background:
        radial-gradient(circle at 16% 0%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 86% 0%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,var(--bg) 100%);
      color:var(--txt);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
    }

    body{overflow:hidden}

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--topbarH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:rgba(255,255,255,.94);
      backdrop-filter:blur(12px);
      box-shadow:0 1px 0 rgba(255,255,255,.8);
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:28px;
      height:28px;
      display:block;
      filter:drop-shadow(0 4px 8px rgba(15,23,42,.10));
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
      letter-spacing:-.02em;
      font-weight:1000;
      color:#0f172a;
      white-space:nowrap;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .spacer{flex:1}

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#ffffff;
      color:#0f172a;
      cursor:pointer;
      font-weight:950;
      font-size:13px;
      white-space:nowrap;
      font-family:var(--font-mw);
      box-shadow:0 1px 0 rgba(255,255,255,.85), 0 4px 12px rgba(15,23,42,.04);
    }

    .btn:hover{
      background:#f8fbff;
      border-color:#93c5fd;
    }

    .btn.ok{
      background:linear-gradient(180deg,#22c55e,#16a34a);
      border-color:#16a34a;
      color:#ffffff;
      box-shadow:0 8px 18px rgba(22,163,74,.18);
    }

    .btn.warn{
      background:#fffbeb;
      border-color:#fde68a;
      color:#9a5c00;
    }

    .btn.danger{
      background:#fff5f5;
      border-color:#fecaca;
      color:#dc2626;
    }

    .btn:disabled{
      opacity:.6;
      cursor:not-allowed;
    }

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:rgba(255,255,255,.92);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .group{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .group:last-child{
      border-right:none;
      padding-right:0;
    }

    .toggle{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#fff;
      font-size:12px;
      font-weight:900;
      color:#334155;
      white-space:nowrap;
    }

    .toggle input{
      margin:0;
      width:16px;
      height:16px;
      accent-color:#2563eb;
      cursor:pointer;
    }

    .helper{
      color:#64748b;
      font-size:12px;
      white-space:nowrap;
      font-weight:850;
    }

    .sheetWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .sheetInner{
      min-width:1490px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
    }

    th,td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child,td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:4;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:13px;
      font-weight:1000;
      white-space:nowrap;
      color:#0f172a;
    }

    thead tr.filterRow th{
      top:43px;
      z-index:3;
      background:var(--filterBg);
      padding:6px;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    td.dirty-cell{
      box-shadow:inset 0 0 0 2px var(--dirtyBorder);
      background:var(--dirtyBg) !important;
    }

    .cellInput,
    .cellSelect,
    .cellTextarea{
      width:100%;
      min-height:44px;
      border:none;
      outline:none;
      background:transparent;
      color:var(--cellTxt);
      padding:10px 8px;
      font:inherit;
      font-size:13px;
      font-weight:850;
      line-height:1.35;
      border-radius:0;
    }

    .cellInput.center,
    .cellSelect.center,
    .cellTextarea.center{
      text-align:center;
    }

    .cellInput.left,
    .cellSelect.left,
    .cellTextarea.left{
      text-align:left;
    }

    .cellInput.right,
    .cellTextarea.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .cellInput::placeholder,
    .cellTextarea::placeholder{
      color:#94a3b8;
    }

    .cellSelect{
      cursor:pointer;
      text-align:center;
    }

    .cellTextarea{
      display:block;
      resize:none;
      overflow:hidden;
      white-space:pre-wrap;
      word-break:keep-all;
      overflow-wrap:anywhere;
      line-height:1.42;
    }

    .cellTextarea.addressCell{
      min-height:44px;
      height:44px;
    }

    tbody td.addressTd{
      vertical-align:top;
    }

    .cellInput:disabled,
    .cellSelect:disabled,
    .cellTextarea:disabled{
      color:#0f172a;
      opacity:1;
      cursor:default;
    }

    .filterInput,
    .filterSelect{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      font-family:var(--font-mw);
      font-weight:850;
      outline:none;
    }

    .filterInput:focus,
    .filterSelect:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.10);
    }

    .rowActionBtn{
      width:34px;
      height:34px;
      border-radius:10px;
      border:1px solid #d4dbe5;
      background:#fff;
      color:#64748b;
      cursor:pointer;
      font-size:16px;
      font-weight:900;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-family:var(--font-mw);
    }

    .rowActionBtn:hover{
      background:#f8fafc;
      border-color:#cbd5e1;
    }

    .rowActionBtn.delete{
      color:#b91c1c;
      border-color:#fecaca;
      background:#fff5f5;
    }

    .emptyDataRow td{
      padding:20px 14px;
      text-align:center;
      color:#64748b;
      font-weight:800;
      background:#f8fbff !important;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#ffffff;
      font-size:12px;
      box-shadow:0 -1px 0 rgba(255,255,255,.8);
    }

    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#f8fafc;
      font-weight:900;
      white-space:nowrap;
      color:#334155;
    }

    .pill.ok{
      color:#15803d;
      border-color:#bbf7d0;
      background:#f0fdf4;
    }

    .pill.warn{
      color:#a16207;
      border-color:#fde68a;
      background:#fffbeb;
    }

    .pill.err{
      color:#b91c1c;
      border-color:#fecaca;
      background:#fff5f5;
    }

    .statusText{
      color:#64748b;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      font-weight:850;
    }


    .campCellWrap{
      position:relative;
      min-height:44px;
      display:flex;
      align-items:stretch;
    }

    .campCellWrap .cellInput{
      padding-right:42px;
    }

    .campQrBtn{
      position:absolute;
      top:6px;
      right:6px;
      width:30px;
      height:30px;
      border-radius:10px;
      border:1px solid #bfdbfe;
      background:#eff6ff;
      color:#1d4ed8;
      cursor:pointer;
      font-family:var(--font-mw);
      font-size:10px;
      font-weight:650;
      line-height:1;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 1px 0 rgba(255,255,255,.8);
    }

    .campQrBtn:hover{
      background:#dbeafe;
      border-color:#60a5fa;
    }

    .qrModal{
      position:fixed;
      inset:0;
      z-index:1200;
      display:none;
      align-items:center;
      justify-content:center;
      padding:18px;
      background:rgba(15,23,42,.36);
      backdrop-filter:blur(8px);
    }

    .qrModal.show{
      display:flex;
    }

    .qrCard{
      width:min(440px,100%);
      border-radius:24px;
      border:1px solid #d8e0ee;
      background:#ffffff;
      box-shadow:0 22px 60px rgba(15,23,42,.22);
      overflow:hidden;
    }

    .qrHead{
      display:flex;
      align-items:flex-start;
      gap:12px;
      padding:20px 22px 14px;
      border-bottom:1px solid #e2e8f0;
      background:linear-gradient(180deg,#ffffff,#f8fbff);
    }

    .qrHeadText{
      min-width:0;
      flex:1;
    }

    .qrHeadText h2{
      margin:0;
      font-size:19px;
      line-height:1.15;
      font-weight:750;
      letter-spacing:-.03em;
      color:#0f172a;
    }

    .qrHeadText p{
      margin:6px 0 0;
      font-size:12px;
      line-height:1.35;
      color:#64748b;
      font-weight:500;
    }

    .qrCloseBtn{
      flex:0 0 auto;
      width:36px;
      height:36px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      cursor:pointer;
      font-size:18px;
      font-weight:700;
      font-family:var(--font-mw);
    }

    .qrBody{
      padding:18px 22px 22px;
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:12px;
    }

    .qrCodeBox{
      width:252px;
      height:252px;
      border-radius:22px;
      border:1px solid #d8e0ee;
      background:#ffffff;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 20px rgba(15,23,42,.06);
    }

    .qrCodeBox canvas,
    .qrCodeBox img{
      width:188px!important;
      height:188px!important;
      image-rendering:pixelated;
    }

    .qrCopyLabel{
      width:252px;
      min-height:38px;
      padding:9px 12px;
      border:1px solid #e2e8f0;
      border-radius:14px;
      background:#ffffff;
      color:#0f172a;
      font-size:16px;
      line-height:1.2;
      font-weight:700;
      letter-spacing:-.03em;
      text-align:center;
      display:flex;
      align-items:center;
      justify-content:center;
      word-break:keep-all;
      overflow-wrap:anywhere;
      box-shadow:0 4px 12px rgba(15,23,42,.04);
    }

    .qrInfoGrid{
      width:100%;
      display:grid;
      gap:8px;
      margin-top:2px;
    }

    .qrInfoRow{
      display:grid;
      grid-template-columns:88px minmax(0,1fr);
      gap:8px;
      align-items:center;
      padding:9px 11px;
      border:1px solid #e2e8f0;
      border-radius:14px;
      background:#f8fafc;
      font-size:12px;
      line-height:1.25;
    }

    .qrInfoRow b{
      color:#64748b;
      font-weight:600;
      white-space:nowrap;
    }

    .qrInfoRow span{
      color:#0f172a;
      font-weight:600;
      min-width:0;
      white-space:normal;
      overflow-wrap:anywhere;
      word-break:keep-all;
    }

    .qrActions{
      width:100%;
      display:flex;
      gap:8px;
      justify-content:flex-end;
      margin-top:4px;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:rgba(15,23,42,.36);
      backdrop-filter:blur(10px);
      z-index:9999;
    }

    .accessDenied.show{
      display:flex;
    }

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid #d8e0ee;
      border-radius:22px;
      background:#fff;
      box-shadow:0 24px 70px rgba(15,23,42,.18);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
      color:#0f172a;
    }

    .accessCard p{
      margin:0;
      color:#475569;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
      font-weight:850;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid #d8e0ee;
      background:#f8fafc;
      color:#0f172a;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width:980px){
      :root{
        --topbarH:64px;
        --toolbarH:88px;
      }

      .topbar{
        gap:8px;
        padding:0 10px;
      }

      .titleBox b{
        font-size:17px;
      }

      .titleBox small{
        max-width:48vw;
      }

      .toolbar{
        padding:8px;
        align-items:flex-start;
      }

      .btn{
        padding:0 10px;
        font-size:12px;
      }

      .helper{
        white-space:normal;
        max-width:520px;
      }

      .sheetInner{
        min-width:1320px;
      }
    }

    @media (max-width:560px){
      .topbar img{
        width:26px;
        height:26px;
      }

      .titleBox small{
        display:none;
      }

      .btn{
        height:36px;
        font-size:11px;
      }

      .group{
        gap:6px;
        padding-right:8px;
      }
    }
  </style>
</head>

<body>
  <div class="app">
    <div class="topbar">
      <a id="mwBoardMenuToggle" href="/index.html" title="게시판">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>

      <div class="titleBox">
        <b>쿠팡 캠프 조회</b>
        <small>캠프 기본 정보 / MB 캠프 / 좌표 / 설명 조회</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnAddRow" class="btn warn" type="button">행 추가</button>
      <button id="btnSaveAll" class="btn ok" type="button">저장</button>
      <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="group">
        <label class="toggle" for="toggleOnlyChanged">
          <input id="toggleOnlyChanged" type="checkbox" />
          <span>변경 행만 보기</span>
        </label>
      </div>

      <div class="group">
        <button id="btnClearFilters" class="btn" type="button">필터 초기화</button>
      </div>

      <div class="group">
        <span class="helper">
          조회는 사이트 접근자 전체 가능 / 추가·수정·삭제는 최고관리자만 가능
        </span>
      </div>

      <div class="group">
        <span class="helper">
          필터칸에서 <b>!키워드</b> 또는 <b>-키워드</b> 입력 시 제외 검색
        </span>
      </div>
    </div>

    <div class="sheetWrap">
      <div class="sheetInner">
        <table>
          <colgroup>
            <col style="width:96px" />
            <col style="width:128px" />
            <col style="width:128px" />
            <col style="width:300px" />
            <col style="width:96px" />
            <col style="width:110px" />
            <col style="width:132px" />
            <col style="width:132px" />
            <col style="width:300px" />
            <col style="width:68px" />
          </colgroup>

          <thead>
            <tr>
              <th>구분</th>
              <th>캠프명</th>
              <th>MB캠프</th>
              <th>주소</th>
              <th>지역</th>
              <th>코드</th>
              <th>위도</th>
              <th>경도</th>
              <th>설명</th>
              <th>삭제</th>
            </tr>

            <tr class="filterRow">
              <th><input class="filterInput" data-filter="camp_type" placeholder="구분 / !직영" /></th>
              <th><input class="filterInput" data-filter="camp" placeholder="캠프명 / !일산2" /></th>
              <th><input class="filterInput" data-filter="mb_camp" placeholder="MB캠프 / !M_익산1" /></th>
              <th><input class="filterInput" data-filter="address" placeholder="주소 / !군산" /></th>
              <th>
                <select class="filterSelect" data-filter="region">
                  <option value="">지역 전체</option>
                  <option value="East">East</option>
                  <option value="South">South</option>
                  <option value="West">West</option>
                </select>
              </th>
              <th><input class="filterInput" data-filter="code" placeholder="코드 / !WC03" /></th>
              <th><input class="filterInput" data-filter="latitude" placeholder="위도" /></th>
              <th><input class="filterInput" data-filter="longitude" placeholder="경도" /></th>
              <th><input class="filterInput" data-filter="description" placeholder="설명 / !임시" /></th>
              <th></th>
            </tr>
          </thead>

          <tbody id="sheetBody"></tbody>
        </table>
      </div>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillDirty" class="pill warn">변경 0</span>
      <span id="statusText" class="statusText">데이터를 불러오는 중...</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>오류</h2>
      <p id="accessDeniedText">페이지를 불러올 수 없습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>


  <div id="qrModal" class="qrModal" aria-hidden="true">
    <div class="qrCard" role="dialog" aria-modal="true" aria-labelledby="qrTitle">
      <div class="qrHead">
        <div class="qrHeadText">
          <h2 id="qrTitle">캠프 QR 코드</h2>
          <p id="qrSubtitle">본캠프 코드 기준으로 QR을 생성합니다.</p>
        </div>
        <button id="btnQrClose" class="qrCloseBtn" type="button" title="닫기">×</button>
      </div>
      <div class="qrBody">
        <div class="qrCodeBox">
          <canvas id="qrCanvas" width="188" height="188"></canvas>
          <img id="qrFallbackImg" alt="QR 코드" style="display:none" />
        </div>
        <div id="qrCopyLabel" class="qrCopyLabel">-</div>
        <div class="qrInfoGrid">
          <div class="qrInfoRow"><b>캠프명</b><span id="qrCampName">-</span></div>
          <div class="qrInfoRow"><b>생성 코드</b><span id="qrCodeText">-</span></div>
          <div class="qrInfoRow"><b>기준 행</b><span id="qrSourceText">-</span></div>
          <div class="qrInfoRow"><b>주소</b><span id="qrAddressText">-</span></div>
        </div>
        <div class="qrActions">
          <button id="btnQrCopy" class="btn" type="button">QR 이미지 복사</button>
          <button id="btnQrCloseBottom" class="btn danger" type="button">닫기</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const cfg = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = cfg.SUPABASE_URL;
      const SUPABASE_ANON_KEY = cfg.SUPABASE_ANON_KEY;
      const INDEX_PATH = cfg.PATHS?.index || "/index.html";
      const LOGIN_PATH = cfg.PATHS?.login || "/login.html";

      /*
        Cloudflare Worker URL
        config.js에 아래 중 하나를 넣으면 그 값을 우선 사용합니다.
        - MARUWELL_CONFIG.BACKENDS.coupangCamp
        - MARUWELL_CONFIG.COUPANG_CAMP_API

        기본값은 현재 배포된 Worker 주소:
        https://coupangcamp.brain-0f6.workers.dev
      */
      const API_BASE = String(
        cfg.BACKENDS?.coupangCamp ||
        cfg.COUPANG_CAMP_API ||
        "https://coupangcamp.brain-0f6.workers.dev"
      ).replace(/\/+$/, "");

      const REGION_OPTIONS = ["", "East", "South", "West"];

      const DATA_COLUMNS = [
        "camp_type",
        "camp",
        "mb_camp",
        "address",
        "region",
        "code",
        "latitude",
        "longitude",
        "description"
      ];

      const NUMERIC_COLUMNS = new Set(["latitude", "longitude"]);

      const COLUMN_CONFIG = [
        { key: "camp_type", className: "center", type: "text" },
        { key: "camp", className: "center", type: "text" },
        { key: "mb_camp", className: "center", type: "text" },
        { key: "address", className: "left wrap", type: "textarea" },
        { key: "region", className: "center", type: "select", options: REGION_OPTIONS },
        { key: "code", className: "center", type: "text" },
        { key: "latitude", className: "right", type: "text" },
        { key: "longitude", className: "right", type: "text" },
        { key: "description", className: "left", type: "text" }
      ];

      const $ = (sel) => document.querySelector(sel);

      const dom = {
        sheetBody: $("#sheetBody"),
        btnReload: $("#btnReload"),
        btnAddRow: $("#btnAddRow"),
        btnSaveAll: $("#btnSaveAll"),
        btnExportCsv: $("#btnExportCsv"),
        btnClearFilters: $("#btnClearFilters"),
        btnLogout: $("#btnLogout"),
        toggleOnlyChanged: $("#toggleOnlyChanged"),
        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillDirty: $("#pillDirty"),
        statusText: $("#statusText"),
        filterInputs: Array.from(document.querySelectorAll(".filterInput, .filterSelect")),
        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout"),
        qrModal: $("#qrModal"),
        qrCanvas: $("#qrCanvas"),
        qrFallbackImg: $("#qrFallbackImg"),
        qrCampName: $("#qrCampName"),
        qrCodeText: $("#qrCodeText"),
        qrCopyLabel: $("#qrCopyLabel"),
        qrSourceText: $("#qrSourceText"),
        qrAddressText: $("#qrAddressText"),
        btnQrClose: $("#btnQrClose"),
        btnQrCloseBottom: $("#btnQrCloseBottom"),
        btnQrCopy: $("#btnQrCopy")
      };

      const state = {
        rows: [],
        filteredRows: [],
        deletedIds: new Set(),
        tempId: 0,
        viewerEmail: "",
        viewerUserId: "",
        accessToken: "",
        canEdit: false,
        loggedIn: false,
        loading: false,
        activeQrCode: "",
        activeQrLabel: ""
      };

      const authStorage = (() => {
        try { return window.sessionStorage; } catch { return undefined; }
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";

        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnAddRow.disabled = !!on || !state.canEdit;
        dom.btnSaveAll.disabled = !!on || !state.canEdit;
        dom.btnExportCsv.disabled = !!on;
        dom.btnClearFilters.disabled = !!on;

        if (on) setStatus(text || "처리 중...", "warn");
      }

      function updatePills() {
        const visibleCount = state.filteredRows.length;
        const dirtyCount = state.rows.filter(row => row.__dirty).length + state.deletedIds.size;

        dom.pillRows.textContent = "행 " + visibleCount;
        dom.pillDirty.textContent = "변경 " + dirtyCount;
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "페이지를 불러올 수 없습니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "로그인 정보 없음";
        document.documentElement.style.visibility = "visible";
      }

      function hideAccessDenied() {
        dom.accessDenied.classList.remove("show");
      }

      function formatCoord(v) {
        const s = String(v ?? "").trim();
        if (!s) return "";
        const n = Number(s);
        if (!Number.isFinite(n)) return s;
        return String(n);
      }

      function normalizeLoadedRow(row) {
        const out = { ...(row || {}) };

        for (const key of DATA_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }

        out.latitude = formatCoord(out.latitude);
        out.longitude = formatCoord(out.longitude);
        out.__dirty = false;
        out.__isNew = false;
        out.__dirtyFields = {};
        return out;
      }

      function rowId(row) {
        return row.id ?? row.__temp_id;
      }

      function blankRow() {
        const row = {
          __temp_id: "new_" + (++state.tempId),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {}
        };

        for (const key of DATA_COLUMNS) {
          row[key] = "";
        }

        return row;
      }

      function hasAnyValue(row) {
        return DATA_COLUMNS.some(key => normalizeText(row[key]));
      }

      function parseNumericOrNull(value, key) {
        const s = String(value ?? "").trim();
        if (!s) return null;

        const n = Number(s);

        if (!Number.isFinite(n)) {
          throw new Error(`${key} 값이 숫자가 아닙니다: ${value}`);
        }

        return n;
      }

      function valueForSave(key, value) {
        const v = String(value ?? "").trim();
        if (!v) return null;
        if (NUMERIC_COLUMNS.has(key)) return parseNumericOrNull(v, key);
        return v;
      }

      function rowMatchesFilter(row, key, rawFilter) {
        const filter = normalizeText(rawFilter);
        if (!filter) return true;

        const isExclude = filter.startsWith("!") || filter.startsWith("-");
        const needle = normalizeLower(isExclude ? filter.slice(1) : filter);
        const hay = normalizeLower(row[key]);

        if (!needle) return true;

        const matched = hay.includes(needle);
        return isExclude ? !matched : matched;
      }

      function applyFilters() {
        const filters = {};

        for (const input of dom.filterInputs) {
          const key = input.dataset.filter;
          if (!key) continue;
          filters[key] = input.value;
        }

        const onlyChanged = dom.toggleOnlyChanged.checked;

        state.filteredRows = state.rows.filter(row => {
          if (state.deletedIds.has(rowId(row))) return false;
          if (onlyChanged && !row.__dirty) return false;

          for (const [key, value] of Object.entries(filters)) {
            if (!rowMatchesFilter(row, key, value)) return false;
          }

          return true;
        });

        renderRows();
        updatePills();
      }

      function makeInput(row, col) {
        const id = rowId(row);
        const value = row[col.key] ?? "";
        const disabled = !state.canEdit;

        if (col.type === "select") {
          const options = (col.options || []).map(opt => {
            const label = opt || "";
            return `<option value="${escapeHtml(opt)}" ${String(value) === String(opt) ? "selected" : ""}>${escapeHtml(label || "선택")}</option>`;
          }).join("");

          return `
            <select
              class="cellSelect ${escapeHtml(col.className || "")}"
              data-id="${escapeHtml(id)}"
              data-key="${escapeHtml(col.key)}"
              ${disabled ? "disabled" : ""}
            >${options}</select>
          `;
        }

        if (col.type === "textarea") {
          return `
            <textarea
              class="cellTextarea addressCell ${escapeHtml(col.className || "")}"
              data-id="${escapeHtml(id)}"
              data-key="${escapeHtml(col.key)}"
              rows="1"
              ${disabled ? "disabled" : ""}
            >${escapeHtml(value)}</textarea>
          `;
        }

        const inputHtml = `
          <input
            class="cellInput ${escapeHtml(col.className || "")}"
            data-id="${escapeHtml(id)}"
            data-key="${escapeHtml(col.key)}"
            value="${escapeHtml(value)}"
            ${disabled ? "disabled" : ""}
          />
        `;

        if (col.key === "camp") {
          return `
            <div class="campCellWrap">
              ${inputHtml}
              <button class="campQrBtn" type="button" data-qr-id="${escapeHtml(id)}" title="본캠프 코드 QR 생성">QR</button>
            </div>
          `;
        }

        return inputHtml;
      }

      function renderRows() {
        if (!state.filteredRows.length) {
          dom.sheetBody.innerHTML = `
            <tr class="emptyDataRow">
              <td colspan="10">표시할 데이터가 없습니다.</td>
            </tr>
          `;
          return;
        }

        dom.sheetBody.innerHTML = state.filteredRows.map(row => {
          const id = rowId(row);

          const cells = COLUMN_CONFIG.map(col => {
            const dirtyClass = row.__dirtyFields?.[col.key] ? "dirty-cell" : "";
            const extraClass = col.key === "address" ? "addressTd" : "";
            return `<td class="${dirtyClass} ${extraClass}">${makeInput(row, col)}</td>`;
          }).join("");

          const deleteCell = state.canEdit
            ? `
              <button
                class="rowActionBtn delete"
                type="button"
                title="삭제"
                data-delete-id="${escapeHtml(id)}"
              >×</button>
            `
            : "";

          return `
            <tr data-row-id="${escapeHtml(id)}">
              ${cells}
              <td style="text-align:center">${deleteCell}</td>
            </tr>
          `;
        }).join("");
        requestAnimationFrame(resizeAllTextareas);
      }

      function resizeTextarea(el) {
        if (!el || !el.classList?.contains("cellTextarea")) return;
        el.style.height = "44px";
        el.style.height = Math.max(44, el.scrollHeight) + "px";
      }

      function resizeAllTextareas() {
        dom.sheetBody.querySelectorAll(".cellTextarea").forEach(resizeTextarea);
      }


      function isMainCampRow(row) {
        const mb = normalizeText(row?.mb_camp).replace(/\s+/g, "");
        return mb === "본캠프";
      }

      function findQrSourceRow(clickedRow) {
        const campName = normalizeText(clickedRow?.camp);
        if (!campName) return null;

        const candidates = state.rows.filter(row => {
          if (state.deletedIds.has(rowId(row))) return false;
          return normalizeText(row.camp) === campName;
        });

        return (
          candidates.find(row => isMainCampRow(row) && normalizeText(row.code)) ||
          candidates.find(row => normalizeText(row.code)) ||
          null
        );
      }

      // QR 생성은 외부 라이브러리/서버 이미지에 의존하지 않고, 로컬 canvas에 즉시 그립니다.
      // 이미지 복사는 QR 생성과 별도 로직으로 export canvas를 만들어 QR + 라벨을 한 번에 복사합니다.
      const QR_VERSION = 2;
      const QR_SIZE = 17 + QR_VERSION * 4; // version 2 => 25 modules
      const QR_DATA_CODEWORDS = 28;        // version 2, EC level M
      const QR_ECC_CODEWORDS = 16;
      const QR_MASK = 0;

      function qrUtf8Bytes(text) {
        return Array.from(new TextEncoder().encode(String(text || "")));
      }

      function qrAppendBits(bits, val, len) {
        for (let i = len - 1; i >= 0; i--) {
          bits.push((val >>> i) & 1);
        }
      }

      function qrGfMul(x, y) {
        let z = 0;
        for (let i = 7; i >= 0; i--) {
          z = (z << 1) ^ ((z >>> 7) * 0x11D);
          if (((y >>> i) & 1) !== 0) z ^= x;
        }
        return z & 0xFF;
      }

      function qrReedSolomonDivisor(degree) {
        const result = Array(degree).fill(0);
        result[degree - 1] = 1;
        let root = 1;

        for (let i = 0; i < degree; i++) {
          for (let j = 0; j < result.length; j++) {
            result[j] = qrGfMul(result[j], root);
            if (j + 1 < result.length) result[j] ^= result[j + 1];
          }
          root = qrGfMul(root, 0x02);
        }

        return result;
      }

      function qrReedSolomonRemainder(data, divisor) {
        const result = Array(divisor.length).fill(0);

        for (const b of data) {
          const factor = b ^ result.shift();
          result.push(0);
          for (let i = 0; i < divisor.length; i++) {
            result[i] ^= qrGfMul(divisor[i], factor);
          }
        }

        return result;
      }

      function qrEncodeDataCodewords(value) {
        const bytes = qrUtf8Bytes(value);
        if (bytes.length > 24) {
          throw new Error("QR 코드로 만들 텍스트가 너무 깁니다. 캠프 코드를 확인해주세요.");
        }

        const bits = [];
        qrAppendBits(bits, 0x4, 4);          // byte mode
        qrAppendBits(bits, bytes.length, 8); // character count for versions 1-9
        bytes.forEach(b => qrAppendBits(bits, b, 8));

        const capacityBits = QR_DATA_CODEWORDS * 8;
        qrAppendBits(bits, 0, Math.min(4, capacityBits - bits.length));
        while (bits.length % 8 !== 0) bits.push(0);

        const data = [];
        for (let i = 0; i < bits.length; i += 8) {
          let b = 0;
          for (let j = 0; j < 8; j++) b = (b << 1) | bits[i + j];
          data.push(b);
        }

        for (let pad = 0xEC; data.length < QR_DATA_CODEWORDS; pad ^= 0xEC ^ 0x11) {
          data.push(pad);
        }

        return data;
      }

      function qrNewMatrix(size) {
        return {
          modules: Array.from({ length:size }, () => Array(size).fill(false)),
          func: Array.from({ length:size }, () => Array(size).fill(false))
        };
      }

      function qrSetFunction(m, x, y, dark) {
        if (x < 0 || y < 0 || y >= m.modules.length || x >= m.modules.length) return;
        m.modules[y][x] = !!dark;
        m.func[y][x] = true;
      }

      function qrDrawFinder(m, x, y) {
        for (let dy = -1; dy <= 7; dy++) {
          for (let dx = -1; dx <= 7; dx++) {
            const xx = x + dx;
            const yy = y + dy;
            if (xx < 0 || yy < 0 || xx >= QR_SIZE || yy >= QR_SIZE) continue;

            const dark =
              dx >= 0 && dx <= 6 && dy >= 0 && dy <= 6 &&
              (dx === 0 || dx === 6 || dy === 0 || dy === 6 ||
                (dx >= 2 && dx <= 4 && dy >= 2 && dy <= 4));

            qrSetFunction(m, xx, yy, dark);
          }
        }
      }

      function qrDrawAlignment(m, cx, cy) {
        for (let dy = -2; dy <= 2; dy++) {
          for (let dx = -2; dx <= 2; dx++) {
            const dist = Math.max(Math.abs(dx), Math.abs(dy));
            qrSetFunction(m, cx + dx, cy + dy, dist !== 1);
          }
        }
      }

      function qrReserveFormat(m) {
        for (let i = 0; i <= 8; i++) {
          if (i !== 6) {
            qrSetFunction(m, 8, i, false);
            qrSetFunction(m, i, 8, false);
          }
        }
        for (let i = 0; i < 8; i++) qrSetFunction(m, QR_SIZE - 1 - i, 8, false);
        for (let i = 0; i < 8; i++) qrSetFunction(m, 8, QR_SIZE - 8 + i, false);
      }

      function qrDrawFunctionPatterns(m) {
        qrDrawFinder(m, 0, 0);
        qrDrawFinder(m, QR_SIZE - 7, 0);
        qrDrawFinder(m, 0, QR_SIZE - 7);

        for (let i = 8; i < QR_SIZE - 8; i++) {
          qrSetFunction(m, i, 6, i % 2 === 0);
          qrSetFunction(m, 6, i, i % 2 === 0);
        }

        qrDrawAlignment(m, 18, 18);
        qrSetFunction(m, 8, QR_SIZE - 8, true);
        qrReserveFormat(m);
      }

      function qrMaskBit(x, y) {
        return ((x + y) & 1) === 0; // mask 0
      }

      function qrDrawCodewords(m, codewords) {
        const bits = [];
        codewords.forEach(cw => qrAppendBits(bits, cw, 8));

        let bitIndex = 0;
        let upward = true;

        for (let right = QR_SIZE - 1; right >= 1; right -= 2) {
          if (right === 6) right--;

          for (let vert = 0; vert < QR_SIZE; vert++) {
            const y = upward ? QR_SIZE - 1 - vert : vert;

            for (let j = 0; j < 2; j++) {
              const x = right - j;
              if (m.func[y][x]) continue;

              let dark = bitIndex < bits.length ? bits[bitIndex] === 1 : false;
              if (qrMaskBit(x, y)) dark = !dark;
              m.modules[y][x] = dark;
              bitIndex++;
            }
          }

          upward = !upward;
        }
      }

      function qrFormatBits() {
        // EC level M => format bits 00, mask 0
        const data = QR_MASK;
        let rem = data;
        for (let i = 0; i < 10; i++) {
          rem = (rem << 1) ^ (((rem >>> 9) & 1) ? 0x537 : 0);
        }
        return ((data << 10) | rem) ^ 0x5412;
      }

      function qrGetBit(value, index) {
        return ((value >>> index) & 1) !== 0;
      }

      function qrDrawFormatBits(m) {
        const bits = qrFormatBits();

        for (let i = 0; i <= 5; i++) qrSetFunction(m, 8, i, qrGetBit(bits, i));
        qrSetFunction(m, 8, 7, qrGetBit(bits, 6));
        qrSetFunction(m, 8, 8, qrGetBit(bits, 7));
        qrSetFunction(m, 7, 8, qrGetBit(bits, 8));
        for (let i = 9; i < 15; i++) qrSetFunction(m, 14 - i, 8, qrGetBit(bits, i));

        for (let i = 0; i < 8; i++) qrSetFunction(m, QR_SIZE - 1 - i, 8, qrGetBit(bits, i));
        for (let i = 8; i < 15; i++) qrSetFunction(m, 8, QR_SIZE - 15 + i, qrGetBit(bits, i));
        qrSetFunction(m, 8, QR_SIZE - 8, true);
      }

      function makeQrMatrix(value) {
        const data = qrEncodeDataCodewords(value);
        const ecc = qrReedSolomonRemainder(data, qrReedSolomonDivisor(QR_ECC_CODEWORDS));
        const allCodewords = data.concat(ecc);
        const matrix = qrNewMatrix(QR_SIZE);

        qrDrawFunctionPatterns(matrix);
        qrDrawCodewords(matrix, allCodewords);
        qrDrawFormatBits(matrix);

        return matrix.modules;
      }

      function drawQrMatrixToCanvas(canvas, value, options = {}) {
        const size = Number(options.size || canvas.width || 188);
        const quiet = Number(options.quiet || 5);
        const dark = options.dark || "#0f172a";
        const light = options.light || "#ffffff";
        const matrix = makeQrMatrix(value);
        const moduleCount = matrix.length;
        const moduleSize = Math.floor(size / (moduleCount + quiet * 2));
        const actual = moduleSize * (moduleCount + quiet * 2);
        const offset = Math.floor((size - actual) / 2) + quiet * moduleSize;

        canvas.width = size;
        canvas.height = size;

        const ctx = canvas.getContext("2d");
        ctx.imageSmoothingEnabled = false;
        ctx.fillStyle = light;
        ctx.fillRect(0, 0, size, size);
        ctx.fillStyle = dark;

        for (let y = 0; y < moduleCount; y++) {
          for (let x = 0; x < moduleCount; x++) {
            if (matrix[y][x]) {
              ctx.fillRect(offset + x * moduleSize, offset + y * moduleSize, moduleSize, moduleSize);
            }
          }
        }
      }

      function renderQrCode(value) {
        const qrValue = normalizeText(value);
        if (!qrValue) return;

        dom.qrFallbackImg.style.display = "none";
        dom.qrCanvas.style.display = "block";
        drawQrMatrixToCanvas(dom.qrCanvas, qrValue, { size:188, quiet:5 });
      }

      function openQrForRow(id) {
        const clickedRow = findRow(id);
        if (!clickedRow) return;

        const sourceRow = findQrSourceRow(clickedRow);
        const qrCode = normalizeText(sourceRow?.code);

        if (!qrCode) {
          setStatus("QR 생성 실패: 같은 캠프의 본캠프 코드가 없습니다.", "err");
          alert("같은 캠프의 본캠프 코드가 없어 QR을 만들 수 없습니다.");
          return;
        }

        const campLabel = normalizeText(sourceRow.camp) || normalizeText(clickedRow.camp) || "-";
        const descLabel = normalizeText(sourceRow.description) || normalizeText(sourceRow.camp_type) || qrCode;
        const copyLabel = `${campLabel} / ${descLabel}`;

        state.activeQrCode = qrCode;
        state.activeQrLabel = copyLabel;
        dom.qrCampName.textContent = campLabel;
        dom.qrCopyLabel.textContent = copyLabel;
        dom.qrCodeText.textContent = qrCode;
        dom.qrSourceText.textContent = `${normalizeText(sourceRow.mb_camp) || "-"} / ${descLabel}`;
        dom.qrAddressText.textContent = normalizeText(sourceRow.address) || "-";
        dom.qrModal.classList.add("show");
        dom.qrModal.setAttribute("aria-hidden", "false");

        renderQrCode(qrCode);
        setStatus(`${normalizeText(clickedRow.camp)} QR 생성: ${qrCode}`, "ok");
      }

      function closeQrModal() {
        dom.qrModal.classList.remove("show");
        dom.qrModal.setAttribute("aria-hidden", "true");
      }

      function canvasToPngBlob(canvas) {
        return new Promise((resolve, reject) => {
          canvas.toBlob(blob => {
            if (blob) resolve(blob);
            else reject(new Error("PNG 생성 실패"));
          }, "image/png");
        });
      }

      function drawCenteredLabel(ctx, text, x, y, maxWidth) {
        const label = normalizeText(text);
        ctx.fillStyle = "#0f172a";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.font = "700 23px system-ui, -apple-system, BlinkMacSystemFont, 'Noto Sans KR', sans-serif";

        if (ctx.measureText(label).width > maxWidth) {
          ctx.font = "700 20px system-ui, -apple-system, BlinkMacSystemFont, 'Noto Sans KR', sans-serif";
        }
        if (ctx.measureText(label).width > maxWidth) {
          ctx.font = "700 18px system-ui, -apple-system, BlinkMacSystemFont, 'Noto Sans KR', sans-serif";
        }

        ctx.fillText(label, x, y, maxWidth);
      }

      function buildQrExportCanvas(code, labelText) {
        const exportWidth = 300;
        const exportHeight = 360;
        const qrBoxSize = 252;
        const qrSize = 184;
        const out = document.createElement("canvas");
        out.width = exportWidth;
        out.height = exportHeight;

        const ctx = out.getContext("2d");
        ctx.imageSmoothingEnabled = false;
        ctx.fillStyle = "#ffffff";
        ctx.fillRect(0, 0, exportWidth, exportHeight);

        const boxX = Math.round((exportWidth - qrBoxSize) / 2);
        const boxY = 22;
        ctx.fillStyle = "#ffffff";
        ctx.fillRect(boxX, boxY, qrBoxSize, qrBoxSize);

        const qrCanvas = document.createElement("canvas");
        drawQrMatrixToCanvas(qrCanvas, code, { size:qrSize, quiet:5 });

        const qrX = Math.round((exportWidth - qrSize) / 2);
        const qrY = boxY + Math.round((qrBoxSize - qrSize) / 2);
        ctx.drawImage(qrCanvas, qrX, qrY, qrSize, qrSize);

        ctx.imageSmoothingEnabled = true;
        drawCenteredLabel(ctx, normalizeText(labelText) || code, exportWidth / 2, 306, exportWidth - 32);

        return out;
      }

      async function copyQrImageToClipboard() {
        const code = normalizeText(state.activeQrCode);
        if (!code) return;
        const label = normalizeText(state.activeQrLabel) || code;

        const out = buildQrExportCanvas(code, label);
        const blob = await canvasToPngBlob(out);

        if (navigator.clipboard?.write && window.ClipboardItem) {
          await navigator.clipboard.write([
            new ClipboardItem({ "image/png": blob })
          ]);
          setStatus(`QR 이미지 복사 완료: ${label}`, "ok");
          return;
        }

        if (navigator.canShare && navigator.share) {
          const safeName = label.replace(/[\\/:*?"<>|\s]+/g, "_").slice(0, 60) || code;
          const file = new File([blob], `${safeName}_qr.png`, { type: "image/png" });
          if (navigator.canShare({ files: [file] })) {
            await navigator.share({
              files: [file],
              title: `${label} QR`,
              text: `${label} QR 이미지`
            });
            setStatus(`QR 이미지 공유 완료: ${label}`, "ok");
            return;
          }
        }

        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `${(label || code).replace(/[\\/:*?"<>|\s]+/g, "_").slice(0, 60)}_qr.png`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        setStatus(`QR 이미지 다운로드 완료: ${label}`, "ok");
      }

      function sortRows(rows) {
        return rows.slice().sort((a, b) => {
          return (
            normalizeText(a.camp).localeCompare(normalizeText(b.camp), "ko", { numeric:true }) ||
            normalizeText(a.mb_camp).localeCompare(normalizeText(b.mb_camp), "ko", { numeric:true }) ||
            normalizeText(a.code).localeCompare(normalizeText(b.code), "ko", { numeric:true })
          );
        });
      }

      async function getSessionAndAccess() {
        state.loggedIn = false;
        state.viewerEmail = "";
        state.viewerUserId = "";
        state.accessToken = "";
        state.canEdit = false;

        if (supabase) {
          try {
            const { data } = await supabase.auth.getSession();
            const session = data?.session;
            const user = session?.user;

            if (session?.access_token && user) {
              state.loggedIn = true;
              state.accessToken = session.access_token;
              state.viewerEmail = user.email || "";
              state.viewerUserId = user.id || "";
            }
          } catch {}
        }

        if (!state.loggedIn) {
          state.canEdit = false;
          dom.btnLogout.style.display = "none";
          dom.btnAddRow.style.display = "none";
          dom.btnSaveAll.style.display = "none";
          return;
        }

        dom.btnLogout.style.display = "inline-block";

        try {
          const j = await apiFetch("/access", { method: "GET", auth: true });
          state.canEdit = j?.canEdit === true;
        } catch {
          state.canEdit = false;
        }

        if (!state.canEdit) {
          dom.btnAddRow.style.display = "none";
          dom.btnSaveAll.style.display = "none";
        } else {
          dom.btnAddRow.style.display = "inline-block";
          dom.btnSaveAll.style.display = "inline-block";
        }
      }

      async function apiFetch(path, options = {}) {
        const headers = {
          "Content-Type": "application/json",
          ...(options.headers || {})
        };

        if (options.auth && state.accessToken) {
          headers.Authorization = "Bearer " + state.accessToken;
        }

        const res = await fetch(API_BASE + path, {
          method: options.method || "GET",
          headers,
          body: options.body ? JSON.stringify(options.body) : undefined,
          cache: "no-store"
        });

        const text = await res.text();
        let data = null;

        if (text) {
          try {
            data = JSON.parse(text);
          } catch {
            data = text;
          }
        }

        if (!res.ok) {
          const msg =
            (data && typeof data === "object" && (data.error || data.message || data.detail)) ||
            (typeof data === "string" ? data : "") ||
            `HTTP ${res.status}`;
          throw new Error(String(msg));
        }

        return data;
      }

      async function loadRows() {
        setLoading(true, "캠프 데이터를 불러오는 중...");

        try {
          const data = await apiFetch("/camps", { method: "GET" });
          const rows = Array.isArray(data) ? data : (data?.rows || []);

          state.rows = sortRows(rows.map(normalizeLoadedRow));
          state.deletedIds.clear();

          applyFilters();
          setStatus(`불러오기 완료: ${state.rows.length.toLocaleString()}건`, "ok");
        } catch (e) {
          console.error(e);
          setStatus(e.message || String(e), "err");
        } finally {
          setLoading(false);
        }
      }

      function findRow(id) {
        return state.rows.find(row => String(rowId(row)) === String(id));
      }

      function handleCellChange(e) {
        const el = e.target.closest(".cellInput, .cellSelect, .cellTextarea");
        if (!el) return;
        if (!state.canEdit) return;
        if (e.type === "input" && e.isComposing) return;

        const id = el.dataset.id;
        const key = el.dataset.key;
        const row = findRow(id);

        if (!row || !key) return;

        let next = el.value;

        if (NUMERIC_COLUMNS.has(key)) {
          next = next.trim();
        }

        if (String(row[key] ?? "") === String(next ?? "")) return;

        row[key] = next;
        row.__dirty = true;
        row.__dirtyFields = row.__dirtyFields || {};
        row.__dirtyFields[key] = true;

        const td = el.closest("td");
        if (td) td.classList.add("dirty-cell");
        resizeTextarea(el);

        updatePills();
        setStatus("수정됨. 저장을 누르면 DB에 반영됩니다.", "warn");
      }

      function addRow() {
        if (!state.canEdit) {
          setStatus("행 추가는 최고관리자만 가능합니다.", "err");
          return;
        }

        const row = blankRow();
        state.rows.unshift(row);

        applyFilters();
        setStatus("새 행을 추가했습니다. 입력 후 저장을 누르세요.", "warn");
      }

      function deleteRowById(id) {
        if (!state.canEdit) {
          setStatus("삭제는 최고관리자만 가능합니다.", "err");
          return;
        }

        const row = findRow(id);
        if (!row) return;

        const campName = row.camp || row.mb_camp || row.code || id;
        const ok = confirm(`${campName}\n\n이 행을 삭제할까요?\n저장을 눌러야 DB에 반영됩니다.`);

        if (!ok) return;

        if (row.__isNew) {
          state.rows = state.rows.filter(item => String(rowId(item)) !== String(id));
        } else {
          state.deletedIds.add(id);
        }

        applyFilters();
        setStatus("삭제 표시 완료. 저장을 누르면 DB에 반영됩니다.", "warn");
      }

      function buildPayload(row) {
        const payload = {};

        for (const key of DATA_COLUMNS) {
          payload[key] = valueForSave(key, row[key]);
        }

        return payload;
      }

      async function saveAll() {
        if (!state.canEdit) {
          setStatus("저장은 최고관리자만 가능합니다.", "err");
          return;
        }

        const dirtyRows = state.rows.filter(row => row.__dirty && !state.deletedIds.has(rowId(row)));
        const deletedIds = Array.from(state.deletedIds).filter(id => !String(id).startsWith("new_"));

        if (!dirtyRows.length && !deletedIds.length) {
          setStatus("저장할 변경사항이 없습니다.", "ok");
          return;
        }

        setLoading(true, "저장 중...");

        try {
          const inserts = [];
          const updates = [];

          for (const row of dirtyRows) {
            if (!hasAnyValue(row)) continue;

            const payload = buildPayload(row);

            if (row.__isNew) {
              inserts.push(payload);
            } else {
              updates.push({
                id: row.id,
                payload
              });
            }
          }

          const result = await apiFetch("/camps/batch", {
            method: "POST",
            auth: true,
            body: {
              inserts,
              updates,
              deletes: deletedIds
            }
          });

          setStatus(
            `저장 완료: 추가 ${Number(result?.inserted || 0).toLocaleString()} / 수정 ${Number(result?.updated || 0).toLocaleString()} / 삭제 ${Number(result?.deleted || 0).toLocaleString()}`,
            "ok"
          );

          await loadRows();
        } catch (e) {
          console.error(e);
          setStatus(e.message || String(e), "err");
        } finally {
          setLoading(false);
        }
      }

      function clearFilters() {
        for (const input of dom.filterInputs) {
          input.value = "";
        }

        dom.toggleOnlyChanged.checked = false;
        applyFilters();
        setStatus("필터 초기화 완료", "ok");
      }

      function csvEscape(value) {
        const s = String(value ?? "");
        if (/[",\n\r]/.test(s)) {
          return '"' + s.replaceAll('"', '""') + '"';
        }
        return s;
      }

      function exportCsv() {
        const headers = [
          "구분",
          "캠프명",
          "MB캠프",
          "주소",
          "지역",
          "코드",
          "위도",
          "경도",
          "설명"
        ];

        const lines = [headers.map(csvEscape).join(",")];

        for (const row of state.filteredRows) {
          lines.push(DATA_COLUMNS.map(key => csvEscape(row[key])).join(","));
        }

        const csv = "\ufeff" + lines.join("\n");
        const blob = new Blob([csv], { type:"text/csv;charset=utf-8" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = `coupang_camps_${new Date().toISOString().slice(0,10)}.csv`;
        a.click();

        URL.revokeObjectURL(url);
        setStatus("CSV 다운로드 완료", "ok");
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
        } catch {}

        location.href = LOGIN_PATH;
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", loadRows);
        dom.btnAddRow.addEventListener("click", addRow);
        dom.btnSaveAll.addEventListener("click", saveAll);
        dom.btnExportCsv.addEventListener("click", exportCsv);
        dom.btnClearFilters.addEventListener("click", clearFilters);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.btnDeniedHome.addEventListener("click", () => {
          location.href = INDEX_PATH;
        });

        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        dom.toggleOnlyChanged.addEventListener("change", applyFilters);

        for (const input of dom.filterInputs) {
          input.addEventListener("input", applyFilters);
          input.addEventListener("change", applyFilters);
        }

        dom.sheetBody.addEventListener("change", handleCellChange);
        dom.sheetBody.addEventListener("input", handleCellChange);

        dom.sheetBody.addEventListener("click", e => {
          const qrBtn = e.target.closest("[data-qr-id]");
          if (qrBtn) {
            openQrForRow(qrBtn.dataset.qrId);
            return;
          }

          const btn = e.target.closest("[data-delete-id]");
          if (!btn) return;
          deleteRowById(btn.dataset.deleteId);
        });

        dom.btnQrClose.addEventListener("click", closeQrModal);
        dom.btnQrCloseBottom.addEventListener("click", closeQrModal);
        dom.qrModal.addEventListener("click", e => {
          if (e.target === dom.qrModal) closeQrModal();
        });
        dom.btnQrCopy.addEventListener("click", async () => {
          try {
            await copyQrImageToClipboard();
          } catch (e) {
            const msg = e?.message || String(e);
            setStatus(`QR 이미지 복사 실패: ${msg}`, "err");
            alert(msg);
          }
        });

        document.addEventListener("keydown", e => {
          if (e.key === "Escape" && dom.qrModal.classList.contains("show")) {
            closeQrModal();
          }
        });
      }

      bindEvents();

      try {
        await getSessionAndAccess();
        hideAccessDenied();
        document.documentElement.style.visibility = "visible";

        await loadRows();

        if (state.canEdit) {
          setStatus("캠프 데이터 조회/수정 가능 상태입니다.", "ok");
        } else {
          setStatus("캠프 데이터 조회 전용 상태입니다.", "ok");
        }
      } catch (e) {
        console.error(e);
        showAccessDenied(state.viewerEmail, e.message || String(e));
      }
    })();
  </script>

  <script src="/board-menu.js"></script>
</body>
</html>
