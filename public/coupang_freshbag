<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>프레시백 현황 조회</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    :root{
      --bg:#0b1220;
      --card:#121a2d;
      --line:rgba(255,255,255,.12);
      --txt:#e6eefc;
      --muted:#9fb0d2;
      --blue:#60a5fa;
      --red:#ef4444;
      --green:#22c55e;
      --yellow:#f59e0b;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      min-height:100vh;
      background:linear-gradient(180deg,#0b1220,#070b13);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    .wrap{
      max-width:1720px;
      margin:0 auto;
      padding:22px 18px 44px;
    }

    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:18px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .brand img{
      width:34px;
      height:34px;
    }

    .title{
      font-size:28px;
      font-weight:950;
      letter-spacing:-.6px;
      line-height:1.15;
    }

    .sub{
      color:var(--muted);
      font-size:14px;
      margin-top:5px;
      line-height:1.45;
    }

    .card{
      background:rgba(18,26,45,.9);
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 18px 60px rgba(0,0,0,.25);
    }

    .row{
      display:flex;
      gap:10px;
      align-items:flex-end;
      flex-wrap:wrap;
    }

    .presetRow{
      display:flex;
      gap:10px;
      align-items:flex-end;
      flex-wrap:wrap;
      margin-top:12px;
      padding-top:12px;
      border-top:1px solid rgba(255,255,255,.08);
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    .field label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-left:2px;
    }

    input,select{
      height:42px;
      border-radius:12px;
      border:1px solid var(--line);
      background:rgba(0,0,0,.25);
      color:var(--txt);
      padding:0 12px;
      outline:none;
      min-width:150px;
    }

    .presetNameField input{
      min-width:240px;
    }

    .presetSelectField select{
      min-width:300px;
    }

    select option{
      background:#111827;
      color:#fff;
    }

    input:focus,select:focus{
      border-color:rgba(96,165,250,.55);
      box-shadow:0 0 0 2px rgba(96,165,250,.12);
    }

    button{
      min-height:42px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(59,130,246,.24);
      color:#fff;
      padding:0 18px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
    }

    button:hover{
      background:rgba(59,130,246,.36);
    }

    button.secondary{
      background:rgba(255,255,255,.07);
    }

    button.secondary:hover{
      background:rgba(255,255,255,.12);
    }

    button.ok{
      background:rgba(34,197,94,.18);
      border-color:rgba(34,197,94,.32);
    }

    button.ok:hover{
      background:rgba(34,197,94,.28);
    }

    button.danger{
      background:rgba(239,68,68,.18);
      border-color:rgba(239,68,68,.32);
    }

    button.danger:hover{
      background:rgba(239,68,68,.28);
    }

    button.small{
      min-height:30px;
      padding:0 10px;
      font-size:12px;
      border-radius:999px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      min-height:32px;
      padding:0 12px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.06);
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .pill strong{
      color:#fff;
      margin-left:5px;
    }

    .status{
      font-size:13px;
      color:var(--muted);
      margin-top:10px;
      line-height:1.55;
    }

    .status.ok{color:#bbf7d0}
    .status.bad{color:#fecaca}
    .status.warn{color:#fde68a}

    .summary{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .hint{
      color:var(--muted);
      font-size:13px;
      line-height:1.55;
      margin-top:10px;
    }

    .tableWrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:rgba(0,0,0,.18);
      max-height:calc(100vh - 360px);
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:max-content;
      min-width:100%;
      table-layout:fixed;
      font-size:13px;
    }

    th,td{
      border-right:1px solid rgba(255,255,255,.12);
      border-bottom:1px solid rgba(255,255,255,.12);
      padding:8px 10px;
      text-align:center;
      white-space:nowrap;
      min-width:82px;
      max-width:160px;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    th{
      position:sticky;
      top:0;
      z-index:5;
      background:#263247;
      color:#fff;
      font-weight:950;
    }

    th.actionCol,td.actionCol{
      position:sticky;
      left:0;
      z-index:4;
      width:76px;
      min-width:76px;
      max-width:76px;
      background:#111827;
    }

    th.actionCol{
      z-index:7;
      background:#263247;
    }

    th.sticky1,td.sticky1{
      position:sticky;
      left:76px;
      z-index:4;
      width:96px;
      min-width:96px;
      max-width:96px;
    }

    th.sticky1{z-index:7}

    td.sticky1{
      background:#111827;
      color:#e6eefc;
      font-weight:900;
    }

    th.sticky2,td.sticky2{
      position:sticky;
      left:172px;
      z-index:4;
      width:120px;
      min-width:120px;
      max-width:120px;
    }

    th.sticky2{z-index:7}

    td.sticky2{
      background:#111827;
      color:#e6eefc;
      font-weight:900;
    }

    th.sticky3,td.sticky3{
      position:sticky;
      left:292px;
      z-index:4;
      width:110px;
      min-width:110px;
      max-width:110px;
    }

    th.sticky3{z-index:7}

    td.sticky3{
      background:#111827;
      color:#bfdbfe;
      font-weight:950;
    }

    th.monthHead{
      width:92px;
      min-width:92px;
      max-width:92px;
    }

    td.editable{
      cursor:cell;
    }

    td.editable:hover,
    td.editable:focus{
      outline:2px solid rgba(96,165,250,.45);
      outline-offset:-2px;
      background-color:rgba(96,165,250,.12);
    }

    tr.dirty td{
      box-shadow:inset 0 0 0 1px rgba(245,158,11,.28);
    }

    .yes{
      background:#7dd3fc;
      color:#082f49;
      font-weight:950;
    }

    .no{
      background:#fff;
      color:#ef4444;
      font-weight:950;
    }

    .empty{
      color:#6b7280;
      background:rgba(255,255,255,.03);
    }

    .tableWrap input.editorInput,
    .tableWrap select.editorSelect{
      width:100% !important;
      min-width:0 !important;
      max-width:100% !important;
      height:28px !important;
      border-radius:8px;
      padding:0 6px;
      font-size:13px;
      box-shadow:none;
    }

    .readonlyMark{
      color:#fca5a5;
      font-weight:900;
    }

    @media(max-width:900px){
      .top{
        flex-direction:column;
        align-items:flex-start;
      }

      .row,
      .presetRow{
        flex-direction:column;
        align-items:stretch;
      }

      input,select,button,
      .presetNameField input,
      .presetSelectField select{
        width:100%;
        min-width:0;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <a href="#" id="mwBoardMenuToggle"><img src="/favicon.ico" alt="MarooWell"></a>
        <div>
          <div class="title">프레시백 현황 조회</div>
          <div class="sub">연도 / 캠프 / 주야간 / 라우트 행 기준으로 월별 가중요인 표를 조회하고, 조회조건을 프리셋으로 저장할 수 있습니다.</div>
        </div>
      </div>
      <div class="pill" id="userPill">세션 확인 중</div>
    </div>

    <div class="card">
      <div class="row">
        <div class="field">
          <label>연도</label>
          <select id="yearFilter"></select>
        </div>

        <div class="field">
          <label>Camp</label>
          <input id="campFilter" placeholder="예: 일산2" />
        </div>

        <div class="field">
          <label>주야간</label>
          <select id="waveFilter">
            <option value="">선택 (주/야)</option>
            <option value="W2">주간</option>
            <option value="W1">야간</option>
          </select>
        </div>

        <div class="field">
          <label>가중1</label>
          <select id="g1Filter">
            <option value="">전체</option>
            <option value="해당">해당</option>
            <option value="미해당">미해당</option>
          </select>
        </div>

        <div class="field">
          <label>가중2</label>
          <select id="g2Filter">
            <option value="">전체</option>
            <option value="해당">해당</option>
            <option value="미해당">미해당</option>
          </select>
        </div>

        <button id="loadBtn">조회</button>
        <button id="addRowBtn" class="ok">행 추가</button>
        <button id="saveBtn" class="ok">변경 저장</button>
        <button id="clearBtn" class="secondary">초기화</button>
        <button id="copyBtn" class="secondary">이미지 복사</button>
      </div>

      <div class="presetRow">
        <div class="field presetNameField">
          <label>프리셋 이름</label>
          <input id="presetNameInput" placeholder="예: 일산2 주간 126/130" />
        </div>

        <div class="field presetSelectField">
          <label>저장된 프리셋</label>
          <select id="savedPresetSelect">
            <option value="">저장된 프리셋 없음</option>
          </select>
        </div>

        <button id="savePresetBtn" class="secondary" type="button">프리셋 저장</button>
        <button id="loadPresetBtn" class="secondary" type="button">불러와서 조회</button>
        <button id="deletePresetBtn" class="danger" type="button">프리셋 삭제</button>
        <button id="loadLastPresetBtn" class="secondary" type="button">최근 조회</button>
      </div>

      <div class="hint">
        조회는 아래 표에 입력된 행만 가져옵니다.
        Route는 <b>126_A</b>로 입력해도 <b>126A</b>로 정규화됩니다.
        프리셋은 현재 브라우저의 localStorage에 여러 개 저장됩니다.
      </div>

      <div class="status" id="statusText">대기 중</div>

      <div class="summary">
        <span class="pill">DB 조회 row <strong id="rawCount">0</strong></span>
        <span class="pill">표시 행 <strong id="routeCount">0</strong></span>
        <span class="pill">캠프 <strong id="campCount">0</strong></span>
        <span class="pill">월 데이터 <strong id="monthCount">0</strong></span>
        <span class="pill">미저장 <strong id="dirtyCount">0</strong></span>
      </div>
    </div>

    <div class="card">
      <div class="tableWrap">
        <table id="resultTable">
          <thead></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};

  let supabaseClient = null;
  let currentUser = null;
  let canEdit = false;
  let rawRows = [];
  let tableRows = [];
  let localSeq = 1;

  const PRESET_STORAGE_KEY = "mw:coupang_freshbag:query_presets:v2";
  const LAST_QUERY_STORAGE_KEY = "mw:coupang_freshbag:last_query:v2";

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg;
    $("statusText").className = type ? "status " + type : "status";
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function waveLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "W2") return "주간";
    if (s === "W1") return "야간";
    return "";
  }

  function waveValueFromLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "주간") return "W2";
    if (s === "야간") return "W1";
    if (s === "W2") return "W2";
    if (s === "W1") return "W1";
    return "";
  }

  function valueClass(v) {
    const s = clean(v);
    if (s === "해당") return "yes";
    if (s === "미해당") return "no";
    if (!s) return "empty";
    return "";
  }

  function effectiveWave(row) {
    return waveValueFromLabel(row.wave) || clean($("waveFilter").value).toUpperCase();
  }

  function effectiveCamp(row) {
    return clean(row.camp) || clean($("campFilter").value);
  }

  function effectiveRoute(row) {
    return normalizeRoute(row.route);
  }

  function rowKey(row) {
    return `${effectiveWave(row)}||${effectiveCamp(row)}||${effectiveRoute(row)}`;
  }

  function originalKey(row) {
    return `${row.original.wave}||${row.original.camp}||${row.original.route}`;
  }

  function isRowKeyChanged(row) {
    if (row.isNew) return false;
    return rowKey(row) !== originalKey(row);
  }

  function initYearOptions() {
    const now = new Date().getFullYear();
    const years = [];

    for (let y = now + 1; y >= now - 6; y--) {
      years.push(y);
    }

    $("yearFilter").innerHTML =
      years.map(y => `<option value="${y}">${y}</option>`).join("");

    $("yearFilter").value = String(now);
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  async function checkSessionAndAccess() {
    if (!supabaseClient) initSupabase();

    const { data, error } = await supabaseClient.auth.getSession();
    if (error) throw error;

    currentUser = data?.session?.user;
    if (!currentUser) throw new Error("로그인이 필요합니다.");

    $("userPill").textContent = currentUser.email || currentUser.id;

    try {
      const { data: access } = await supabaseClient
        .rpc("mw_my_access")
        .maybeSingle();

      canEdit =
        access?.is_maroowell === true &&
        access?.is_admin === true &&
        Number(access?.max_role_level || 0) >= 90;
    } catch {
      canEdit = false;
    }

    if (!canEdit) {
      $("addRowBtn").style.display = "none";
      $("saveBtn").style.display = "none";
      setStatus("조회 전용입니다. 수정/추가는 최고관리자만 가능합니다.", "warn");
    }
  }

  function createBlankRow() {
    return {
      localId: `row_${localSeq++}`,
      isNew: true,
      dirty: false,
      deleted: false,
      wave: "",
      camp: "",
      route: "",
      original: { wave: "", camp: "", route: "" },
      months: {}
    };
  }

  function initDefaultRows() {
    tableRows = [];

    for (let i = 0; i < 4; i++) {
      tableRows.push(createBlankRow());
    }

    renderTable();
    renderSummary();
  }

  function addRow() {
    tableRows.push(createBlankRow());
    renderTable();
    renderSummary();
    setStatus("행이 추가되었습니다. Camp/주야간은 상단값을 기본으로 사용하고, Route는 행에 입력하세요.", "ok");
  }

  function safeLocalStorageGet(key, fallback) {
    try {
      const raw = localStorage.getItem(key);
      if (!raw) return fallback;
      return JSON.parse(raw);
    } catch {
      return fallback;
    }
  }

  function safeLocalStorageSet(key, value) {
    try {
      localStorage.setItem(key, JSON.stringify(value));
      return true;
    } catch {
      return false;
    }
  }

  function getSavedPresets() {
    const list = safeLocalStorageGet(PRESET_STORAGE_KEY, []);
    return Array.isArray(list) ? list : [];
  }

  function setSavedPresets(list) {
    return safeLocalStorageSet(PRESET_STORAGE_KEY, Array.isArray(list) ? list : []);
  }

  function makePresetId() {
    return "preset_" + Date.now().toString(36) + "_" + Math.random().toString(36).slice(2, 8);
  }

  function getPresetRowsFromTable() {
    const rows = tableRows
      .filter(row => !row.deleted)
      .map(row => ({
        wave: effectiveWave(row),
        camp: effectiveCamp(row),
        route: effectiveRoute(row)
      }))
      .filter(row => row.route);

    const seen = new Set();
    const out = [];

    for (const row of rows) {
      const key = `${row.wave}||${row.camp}||${row.route}`;
      if (seen.has(key)) continue;
      seen.add(key);
      out.push(row);
    }

    return out;
  }

  function makeDefaultPresetName(preset) {
    const year = preset.year || $("yearFilter").value || "";
    const camp = preset.camp || preset.rows?.[0]?.camp || "Camp";
    const wave = preset.wave
      ? waveLabel(preset.wave)
      : preset.rows?.length
        ? "주/야"
        : "";
    const routes = (preset.rows || [])
      .map(row => row.route)
      .filter(Boolean)
      .slice(0, 8)
      .join("/");

    return [year, camp, wave, routes].filter(Boolean).join(" / ");
  }

  function buildCurrentPreset(nameOverride = "") {
    const rows = getPresetRowsFromTable();

    if (!rows.length) {
      throw new Error("저장할 Route 행이 없습니다. Route를 먼저 입력하거나 조회 후 저장하세요.");
    }

    const preset = {
      id: "",
      name: clean(nameOverride),
      updatedAt: new Date().toISOString(),
      year: $("yearFilter").value || "",
      camp: clean($("campFilter").value),
      wave: clean($("waveFilter").value).toUpperCase(),
      gajoong1: $("g1Filter").value || "",
      gajoong2: $("g2Filter").value || "",
      rows
    };

    if (!preset.name) {
      preset.name = makeDefaultPresetName(preset);
    }

    return preset;
  }

  function renderPresetOptions(selectedId = "") {
    const select = $("savedPresetSelect");
    if (!select) return;

    const presets = getSavedPresets()
      .slice()
      .sort((a, b) => String(b.updatedAt || "").localeCompare(String(a.updatedAt || "")));

    if (!presets.length) {
      select.innerHTML = `<option value="">저장된 프리셋 없음</option>`;
      return;
    }

    select.innerHTML = [
      `<option value="">저장된 프리셋 선택</option>`,
      ...presets.map(preset => {
        const date = String(preset.updatedAt || "").slice(0, 10);
        const count = Array.isArray(preset.rows) ? preset.rows.length : 0;
        const label = `${preset.name || "이름 없음"} · ${count}행 · ${date}`;
        return `<option value="${esc(preset.id)}">${esc(label)}</option>`;
      })
    ].join("");

    if (selectedId) {
      select.value = selectedId;
    }
  }

  function saveCurrentPreset() {
    const name = clean($("presetNameInput").value);

    if (!name) {
      throw new Error("프리셋 이름을 입력하세요. 예: 일산2 주간 126/130");
    }

    const preset = buildCurrentPreset(name);
    const presets = getSavedPresets();

    const selectedId = $("savedPresetSelect").value;
    const selectedIndex = presets.findIndex(item => item.id === selectedId);
    const sameNameIndex = presets.findIndex(item => item.name === preset.name);

    if (selectedIndex >= 0) {
      const ok = confirm(`선택된 프리셋을 덮어쓸까요?\n\n${presets[selectedIndex].name}`);
      if (!ok) return;

      preset.id = selectedId;
      presets[selectedIndex] = {
        ...presets[selectedIndex],
        ...preset,
        updatedAt: new Date().toISOString()
      };
    } else if (sameNameIndex >= 0) {
      const ok = confirm(`같은 이름의 프리셋이 있습니다. 덮어쓸까요?\n\n${preset.name}`);
      if (!ok) return;

      preset.id = presets[sameNameIndex].id;
      presets[sameNameIndex] = {
        ...presets[sameNameIndex],
        ...preset,
        updatedAt: new Date().toISOString()
      };
    } else {
      preset.id = makePresetId();
      presets.unshift(preset);
    }

    setSavedPresets(presets);
    renderPresetOptions(preset.id);

    $("presetNameInput").value = preset.name;
    setStatus(`프리셋 저장 완료: ${preset.name}`, "ok");
  }

  function makeRowFromPresetItem(item) {
    const row = createBlankRow();

    row.isNew = false;
    row.dirty = false;
    row.deleted = false;
    row.wave = waveValueFromLabel(item.wave);
    row.camp = clean(item.camp);
    row.route = normalizeRoute(item.route);
    row.original = {
      wave: row.wave,
      camp: row.camp,
      route: row.route
    };
    row.months = {};

    return row;
  }

  function applyPresetToScreen(preset) {
    if (!preset) throw new Error("불러올 프리셋이 없습니다.");

    if (preset.year) {
      const exists = Array.from($("yearFilter").options).some(opt => opt.value === String(preset.year));

      if (!exists) {
        const option = document.createElement("option");
        option.value = String(preset.year);
        option.textContent = String(preset.year);
        $("yearFilter").appendChild(option);
      }

      $("yearFilter").value = String(preset.year);
    }

    $("campFilter").value = preset.camp || "";
    $("waveFilter").value = preset.wave || "";
    $("g1Filter").value = preset.gajoong1 || "";
    $("g2Filter").value = preset.gajoong2 || "";
    $("presetNameInput").value = preset.name || "";

    const rows = Array.isArray(preset.rows) ? preset.rows : [];

    tableRows = rows
      .map(makeRowFromPresetItem)
      .filter(row => effectiveRoute(row));

    while (tableRows.length < 4) {
      tableRows.push(createBlankRow());
    }

    rawRows = [];
    renderTable();
    renderSummary();
  }

  async function loadSelectedPresetAndQuery() {
    const selectedId = $("savedPresetSelect").value;

    if (!selectedId) {
      throw new Error("불러올 프리셋을 선택하세요.");
    }

    const preset = getSavedPresets().find(item => item.id === selectedId);

    if (!preset) {
      throw new Error("저장된 프리셋을 찾을 수 없습니다.");
    }

    applyPresetToScreen(preset);
    setStatus(`프리셋 불러오기 완료: ${preset.name}. 조회 중...`, "warn");
    await loadData();
  }

  function deleteSelectedPreset() {
    const selectedId = $("savedPresetSelect").value;

    if (!selectedId) {
      setStatus("삭제할 프리셋을 선택하세요.", "bad");
      return;
    }

    const presets = getSavedPresets();
    const preset = presets.find(item => item.id === selectedId);

    if (!preset) {
      setStatus("삭제할 프리셋을 찾을 수 없습니다.", "bad");
      return;
    }

    const ok = confirm(`저장된 프리셋을 삭제할까요?\n\n${preset.name}`);

    if (!ok) return;

    setSavedPresets(presets.filter(item => item.id !== selectedId));
    renderPresetOptions();

    $("presetNameInput").value = "";
    setStatus("프리셋 삭제 완료", "ok");
  }

  function saveLastQueryPreset() {
    try {
      const preset = buildCurrentPreset("최근 조회");
      preset.id = "last_query";
      preset.updatedAt = new Date().toISOString();
      safeLocalStorageSet(LAST_QUERY_STORAGE_KEY, preset);
    } catch {}
  }

  async function loadLastQueryPresetAndQuery() {
    const preset = safeLocalStorageGet(LAST_QUERY_STORAGE_KEY, null);

    if (!preset) {
      throw new Error("최근 조회조건이 없습니다.");
    }

    applyPresetToScreen(preset);
    setStatus("최근 조회조건 불러오기 완료. 조회 중...", "warn");
    await loadData();
  }

  function getCriteriaRows() {
    return tableRows
      .filter(row => !row.deleted)
      .map(row => ({
        row,
        wave: effectiveWave(row),
        camp: effectiveCamp(row),
        route: effectiveRoute(row)
      }))
      .filter(item => item.route);
  }

  function validateCriteria() {
    const criteria = getCriteriaRows();

    if (!criteria.length) {
      throw new Error("조회할 Route 행을 입력하세요. 기본 4행의 Route 칸에 126A, 126B처럼 입력하면 됩니다.");
    }

    const missingWave = criteria.find(item => !item.wave);
    if (missingWave) {
      throw new Error("주야간을 선택하세요. 상단에서 주간/야간을 선택하거나 행의 주야간 셀을 입력하세요.");
    }

    const missingCamp = criteria.find(item => !item.camp);
    if (missingCamp) {
      throw new Error("Camp를 입력하세요. 상단 Camp에 입력하거나 행의 Camp 셀을 입력하세요.");
    }

    return criteria;
  }

  function unique(arr) {
    return Array.from(new Set(arr.filter(Boolean)));
  }

  async function fetchRowsByCriteria(criteria) {
    const year = Number($("yearFilter").value);
    const waves = unique(criteria.map(x => x.wave));
    const camps = unique(criteria.map(x => x.camp));
    const routes = unique(criteria.map(x => x.route));
    const g1 = $("g1Filter").value;
    const g2 = $("g2Filter").value;

    let q = supabaseClient
      .from("coupang_freshbag")
      .select(`
        id,
        data_year,
        month_no,
        data_month,
        period_label,
        wave,
        camp,
        route,
        route_norm,
        gajoong1,
        gajoong2,
        source_file_name,
        created_at,
        updated_at
      `)
      .eq("data_year", year)
      .in("wave", waves)
      .in("camp", camps)
      .in("route_norm", routes)
      .order("camp", { ascending: true })
      .order("wave", { ascending: true })
      .order("route_norm", { ascending: true })
      .order("month_no", { ascending: true });

    if (g1) q = q.eq("gajoong1", g1);
    if (g2) q = q.eq("gajoong2", g2);

    const { data, error } = await q;
    if (error) throw error;

    const criteriaSet = new Set(criteria.map(x => `${x.wave}||${x.camp}||${x.route}`));

    return (Array.isArray(data) ? data : []).filter(row => {
      const wave = clean(row.wave).toUpperCase();
      const camp = clean(row.camp);
      const route = normalizeRoute(row.route_norm || row.route);
      return criteriaSet.has(`${wave}||${camp}||${route}`);
    });
  }

  async function loadData() {
    setStatus("조건 행 기준으로 조회 중...");

    const criteria = validateCriteria();
    rawRows = await fetchRowsByCriteria(criteria);

    applyFetchedRowsToTable(criteria, rawRows);

    renderTable();
    renderSummary();

    saveLastQueryPreset();
    setStatus(`조회 완료: DB row ${rawRows.length.toLocaleString()}건 / 표시 행 ${tableRows.filter(r => !r.deleted).length.toLocaleString()}행`, "ok");
  }

  function applyFetchedRowsToTable(criteria, rows) {
    const rowMap = new Map();

    for (const item of criteria) {
      const key = `${item.wave}||${item.camp}||${item.route}`;
      rowMap.set(key, item.row);

      item.row.wave = item.wave;
      item.row.camp = item.camp;
      item.row.route = item.route;
      item.row.original = { wave: item.wave, camp: item.camp, route: item.route };
      item.row.isNew = false;
      item.row.dirty = false;
      item.row.deleted = false;
      item.row.months = {};
    }

    for (const row of rows) {
      const wave = clean(row.wave).toUpperCase();
      const camp = clean(row.camp);
      const route = normalizeRoute(row.route_norm || row.route);
      const month = Number(row.month_no || 0);

      if (month < 1 || month > 12) continue;

      const key = `${wave}||${camp}||${route}`;
      const target = rowMap.get(key);
      if (!target) continue;

      target.months[month] = {
        id: row.id || null,
        gajoong1: row.gajoong1 || "",
        gajoong2: row.gajoong2 || "",
        originalGajoong1: row.gajoong1 || "",
        originalGajoong2: row.gajoong2 || "",
        period: row.period_label || row.data_month || "",
        source_file_name: row.source_file_name || ""
      };
    }

    for (const item of criteria) {
      for (let m = 1; m <= 12; m++) {
        if (!item.row.months[m]) {
          item.row.months[m] = {
            id: null,
            gajoong1: "",
            gajoong2: "",
            originalGajoong1: "",
            originalGajoong2: "",
            period: "",
            source_file_name: ""
          };
        }
      }
    }
  }

  function renderSummary() {
    const visibleRows = tableRows.filter(row => !row.deleted);
    const campSet = new Set();
    const monthSet = new Set();
    const dirty = tableRows.filter(row => row.dirty || row.deleted).length;

    for (const row of rawRows) {
      if (row.camp) campSet.add(row.camp);
      if (row.month_no) monthSet.add(row.month_no);
    }

    $("rawCount").textContent = rawRows.length.toLocaleString();
    $("routeCount").textContent = visibleRows.length.toLocaleString();
    $("campCount").textContent = campSet.size.toLocaleString();
    $("monthCount").textContent = monthSet.size.toLocaleString();
    $("dirtyCount").textContent = dirty.toLocaleString();
  }

  function renderTable() {
    const thead = $("resultTable").querySelector("thead");
    const tbody = $("resultTable").querySelector("tbody");

    const headers = [];
    for (let m = 1; m <= 12; m++) {
      headers.push(`<th class="monthHead">${m}월 가중1</th>`);
      headers.push(`<th class="monthHead">${m}월 가중2</th>`);
    }

    thead.innerHTML = `
      <tr>
        <th class="actionCol">작업</th>
        <th class="sticky1">주야간</th>
        <th class="sticky2">Camp</th>
        <th class="sticky3">Route</th>
        ${headers.join("")}
      </tr>
    `;

    const visibleRows = tableRows.filter(row => !row.deleted);

    if (!visibleRows.length) {
      tbody.innerHTML = `<tr><td colspan="28" class="empty">데이터 없음</td></tr>`;
      return;
    }

    tbody.innerHTML = visibleRows.map(row => {
      const rowWave = effectiveWave(row);
      const rowCamp = effectiveCamp(row);
      const rowRoute = effectiveRoute(row);

      const cells = [];

      for (let m = 1; m <= 12; m++) {
        const month = row.months[m] || {
          id: null,
          gajoong1: "",
          gajoong2: "",
          originalGajoong1: "",
          originalGajoong2: ""
        };

        cells.push(`
          <td
            tabindex="0"
            class="editable ${valueClass(month.gajoong1)}"
            data-row="${esc(row.localId)}"
            data-month="${m}"
            data-field="gajoong1"
            title="클릭해서 수정"
          >${esc(month.gajoong1 || "")}</td>
        `);

        cells.push(`
          <td
            tabindex="0"
            class="editable ${valueClass(month.gajoong2)}"
            data-row="${esc(row.localId)}"
            data-month="${m}"
            data-field="gajoong2"
            title="클릭해서 수정"
          >${esc(month.gajoong2 || "")}</td>
        `);
      }

      return `
        <tr class="${row.dirty ? "dirty" : ""}" data-row="${esc(row.localId)}">
          <td class="actionCol">
            ${canEdit ? `<button class="small danger" data-action="delete" data-row="${esc(row.localId)}">삭제</button>` : `<span class="readonlyMark">조회</span>`}
          </td>
          <td tabindex="0" class="sticky1 editable" data-row="${esc(row.localId)}" data-meta="wave" title="클릭해서 수정">${esc(waveLabel(rowWave))}</td>
          <td tabindex="0" class="sticky2 editable" data-row="${esc(row.localId)}" data-meta="camp" title="클릭해서 수정">${esc(rowCamp)}</td>
          <td tabindex="0" class="sticky3 editable" data-row="${esc(row.localId)}" data-meta="route" title="클릭해서 수정">${esc(rowRoute)}</td>
          ${cells.join("")}
        </tr>
      `;
    }).join("");
  }

  function getRowById(localId) {
    return tableRows.find(row => row.localId === localId);
  }

  function markDirty(row) {
    row.dirty = true;
    renderSummary();
  }

  function getEditableCells() {
    return Array.from(document.querySelectorAll("#resultTable td.editable"));
  }

  function focusNextEditableCell(currentTd, backwards = false) {
    const cells = getEditableCells();
    const index = cells.indexOf(currentTd);
    if (index < 0) return;

    const nextIndex = backwards
      ? Math.max(0, index - 1)
      : Math.min(cells.length - 1, index + 1);

    const next = cells[nextIndex];

    if (next && next !== currentTd) {
      next.focus({ preventScroll: false });
      startEditCell(next, { fromKeyboard: true });
    }
  }

  function startEditCell(td, options = {}) {
    if (!canEdit) {
      setStatus("수정은 최고관리자만 가능합니다.", "bad");
      return;
    }

    if (td.querySelector("input,select")) return;

    const row = getRowById(td.dataset.row);
    if (!row) return;

    const meta = td.dataset.meta;
    const monthNo = Number(td.dataset.month || 0);
    const field = td.dataset.field;

    if (meta) {
      editMetaCell(td, row, meta, options);
      return;
    }

    if (monthNo && field) {
      editMonthCell(td, row, monthNo, field, options);
    }
  }

  function editMetaCell(td, row, meta, options = {}) {
    if (meta === "wave") {
      const select = document.createElement("select");
      select.className = "editorSelect";
      select.innerHTML = `
        <option value=""></option>
        <option value="W2">주간</option>
        <option value="W1">야간</option>
      `;

      select.value = row.wave || "";

      td.textContent = "";
      td.appendChild(select);
      select.focus();

      let committed = false;

      const commit = (moveDirection = null) => {
        if (committed) return;
        committed = true;

        const next = select.value;

        if ((row.wave || "") !== next) {
          row.wave = next;
          markDirty(row);
        }

        renderTable();

        if (moveDirection) {
          const newTd = document.querySelector(`[data-row="${CSS.escape(row.localId)}"][data-meta="${meta}"]`);
          if (newTd) focusNextEditableCell(newTd, moveDirection === "prev");
        }
      };

      select.addEventListener("blur", () => commit(), { once:true });
      select.addEventListener("keydown", e => {
        if (e.key === "Enter") {
          e.preventDefault();
          select.blur();
        }
        if (e.key === "Tab") {
          e.preventDefault();
          commit(e.shiftKey ? "prev" : "next");
        }
        if (e.key === "Escape") {
          e.preventDefault();
          committed = true;
          renderTable();
        }
      });

      return;
    }

    const input = document.createElement("input");
    input.className = "editorInput";

    if (meta === "camp") input.value = row.camp || "";
    if (meta === "route") input.value = row.route || "";

    td.textContent = "";
    td.appendChild(input);
    input.focus();
    input.select();

    let committed = false;

    const commit = (moveDirection = null) => {
      if (committed) return;
      committed = true;

      let next = clean(input.value);

      if (meta === "route") {
        next = normalizeRoute(next);
      }

      if ((row[meta] || "") !== next) {
        row[meta] = next;
        markDirty(row);
      }

      renderTable();

      if (moveDirection) {
        const newTd = document.querySelector(`[data-row="${CSS.escape(row.localId)}"][data-meta="${meta}"]`);
        if (newTd) focusNextEditableCell(newTd, moveDirection === "prev");
      }
    };

    input.addEventListener("blur", () => commit(), { once:true });
    input.addEventListener("keydown", e => {
      if (e.key === "Enter") {
        e.preventDefault();
        input.blur();
      }
      if (e.key === "Tab") {
        e.preventDefault();
        commit(e.shiftKey ? "prev" : "next");
      }
      if (e.key === "Escape") {
        e.preventDefault();
        committed = true;
        renderTable();
      }
    });
  }

  function editMonthCell(td, row, monthNo, field, options = {}) {
    if (!row.months[monthNo]) {
      row.months[monthNo] = {
        id: null,
        gajoong1: "",
        gajoong2: "",
        originalGajoong1: "",
        originalGajoong2: ""
      };
    }

    const month = row.months[monthNo];

    const select = document.createElement("select");
    select.className = "editorSelect";
    select.innerHTML = `
      <option value=""></option>
      <option value="해당">해당</option>
      <option value="미해당">미해당</option>
    `;

    select.value = month[field] || "";

    td.textContent = "";
    td.appendChild(select);
    select.focus();

    let committed = false;

    const commit = (moveDirection = null) => {
      if (committed) return;
      committed = true;

      const next = select.value;

      if ((month[field] || "") !== next) {
        month[field] = next;
        markDirty(row);
      }

      renderTable();

      if (moveDirection) {
        const newTd = document.querySelector(`[data-row="${CSS.escape(row.localId)}"][data-month="${monthNo}"][data-field="${field}"]`);
        if (newTd) focusNextEditableCell(newTd, moveDirection === "prev");
      }
    };

    select.addEventListener("blur", () => commit(), { once:true });
    select.addEventListener("keydown", e => {
      if (e.key === "Enter") {
        e.preventDefault();
        select.blur();
      }
      if (e.key === "Tab") {
        e.preventDefault();
        commit(e.shiftKey ? "prev" : "next");
      }
      if (e.key === "Escape") {
        e.preventDefault();
        committed = true;
        renderTable();
      }
    });
  }

  function deleteRow(localId) {
    if (!canEdit) {
      setStatus("삭제는 최고관리자만 가능합니다.", "bad");
      return;
    }

    const row = getRowById(localId);
    if (!row) return;

    const wave = effectiveWave(row);
    const camp = effectiveCamp(row);
    const route = effectiveRoute(row);

    const ok = confirm(`${waveLabel(wave)} / ${camp} / ${route}\n\n이 행을 삭제할까요?\n변경 저장을 눌러야 DB에 반영됩니다.`);

    if (!ok) return;

    if (row.isNew && !row.original.route) {
      tableRows = tableRows.filter(item => item.localId !== localId);
    } else {
      row.deleted = true;
      row.dirty = true;
    }

    renderTable();
    renderSummary();
    setStatus("행 삭제 표시 완료. 변경 저장을 누르면 DB에 반영됩니다.", "warn");
  }

  function validateRowForSave(row) {
    const wave = effectiveWave(row);
    const camp = effectiveCamp(row);
    const route = effectiveRoute(row);

    if (!wave || !["W1","W2"].includes(wave)) {
      throw new Error("주야간 값이 올바르지 않습니다.");
    }

    if (!camp) {
      throw new Error("Camp가 비어 있습니다.");
    }

    if (!route) {
      throw new Error("Route가 비어 있습니다.");
    }

    return { wave, camp, route };
  }

  function hasAnyMonthValue(row) {
    for (let m = 1; m <= 12; m++) {
      const month = row.months[m];
      if (!month) continue;
      if (clean(month.gajoong1) || clean(month.gajoong2)) return true;
    }
    return false;
  }

  function rowsToUpsertPayload(row) {
    const year = Number($("yearFilter").value);
    const key = validateRowForSave(row);
    const out = [];

    for (let m = 1; m <= 12; m++) {
      const month = row.months[m];
      if (!month) continue;

      const g1 = clean(month.gajoong1);
      const g2 = clean(month.gajoong2);
      const hadOriginal = Boolean(month.id || month.originalGajoong1 || month.originalGajoong2);

      if (!g1 && !g2 && !hadOriginal) continue;

      out.push({
        data_year: year,
        month_no: m,
        data_month: `${year}-${String(m).padStart(2, "0")}`,
        period_label: `${year}-${String(m).padStart(2, "0")}`,
        wave: key.wave,
        camp: key.camp,
        route: key.route,
        route_norm: key.route,
        gajoong1: g1 || null,
        gajoong2: g2 || null,
        source_file_name: "manual-edit"
      });
    }

    return out;
  }

  async function saveChanges() {
    if (!canEdit) {
      setStatus("저장은 최고관리자만 가능합니다.", "bad");
      return;
    }

    const dirtyRows = tableRows.filter(row => row.dirty || row.deleted);

    if (!dirtyRows.length) {
      setStatus("저장할 변경사항이 없습니다.", "ok");
      return;
    }

    setStatus(`저장 중... ${dirtyRows.length}행`);

    for (const row of dirtyRows) {
      if (!row.isNew) {
        if (row.deleted || isRowKeyChanged(row)) {
          await deleteOriginalRows(row);
        }
      }

      if (row.deleted) continue;

      validateRowForSave(row);

      if (!hasAnyMonthValue(row)) continue;

      const payload = rowsToUpsertPayload(row);
      if (!payload.length) continue;

      const { error } = await supabaseClient
        .from("coupang_freshbag")
        .upsert(payload, {
          onConflict: "data_year,month_no,wave,camp,route_norm"
        });

      if (error) throw error;
    }

    setStatus("저장 완료. 현재 조건으로 다시 조회합니다.", "ok");
    await loadData();
  }

  async function deleteOriginalRows(row) {
    const year = Number($("yearFilter").value);
    const original = row.original || {};

    if (!original.wave || !original.camp || !original.route) return;

    const { error } = await supabaseClient
      .from("coupang_freshbag")
      .delete()
      .eq("data_year", year)
      .eq("wave", original.wave)
      .eq("camp", original.camp)
      .eq("route_norm", original.route);

    if (error) throw error;
  }

  function getLastMonthWithData() {
    const visibleRows = tableRows.filter(row => !row.deleted);
    let maxMonth = 0;

    for (const row of visibleRows) {
      for (let m = 1; m <= 12; m++) {
        const month = row.months[m] || {};
        const g1 = clean(month.gajoong1);
        const g2 = clean(month.gajoong2);

        if (g1 || g2) {
          maxMonth = Math.max(maxMonth, m);
        }
      }
    }

    return maxMonth;
  }

  function fitText(ctx, text, maxWidth) {
    let s = String(text ?? "");

    if (ctx.measureText(s).width <= maxWidth) return s;

    while (s.length > 0 && ctx.measureText(s + "…").width > maxWidth) {
      s = s.slice(0, -1);
    }

    return s ? s + "…" : "";
  }

  function drawCell(ctx, x, y, w, h, options = {}) {
    const {
      text = "",
      bg = "#111827",
      color = "#e6eefc",
      border = "#334155",
      font = "700 14px Arial, 'Noto Sans KR', sans-serif",
      align = "center"
    } = options;

    ctx.fillStyle = bg;
    ctx.fillRect(x, y, w, h);

    ctx.strokeStyle = border;
    ctx.lineWidth = 1;
    ctx.strokeRect(x, y, w, h);

    ctx.fillStyle = color;
    ctx.font = font;
    ctx.textBaseline = "middle";

    const safeText = fitText(ctx, text, w - 12);

    if (align === "left") {
      ctx.textAlign = "left";
      ctx.fillText(safeText, x + 8, y + h / 2);
    } else {
      ctx.textAlign = "center";
      ctx.fillText(safeText, x + w / 2, y + h / 2);
    }
  }

  function valueStyle(v) {
    const s = clean(v);

    if (s === "해당") {
      return {
        bg: "#7dd3fc",
        color: "#082f49"
      };
    }

    if (s === "미해당") {
      return {
        bg: "#ffffff",
        color: "#ef4444"
      };
    }

    return {
      bg: "#111827",
      color: "#6b7280"
    };
  }

  function canvasToBlob(canvas) {
    return new Promise(resolve => {
      canvas.toBlob(blob => resolve(blob), "image/png");
    });
  }

  async function copyTableImage() {
    const visibleRows = tableRows.filter(row => !row.deleted);
    const lastMonth = getLastMonthWithData();

    if (!visibleRows.length) {
      setStatus("복사할 행이 없습니다.", "bad");
      return;
    }

    if (!lastMonth) {
      setStatus("데이터가 있는 월이 없습니다. 먼저 조회하거나 값을 입력하세요.", "bad");
      return;
    }

    const fixedColumns = [
      { key: "wave", label: "주야간", width: 90 },
      { key: "camp", label: "Camp", width: 120 },
      { key: "route", label: "Route", width: 110 }
    ];

    const monthColumns = [];

    for (let m = 1; m <= lastMonth; m++) {
      monthColumns.push({ month: m, field: "gajoong1", label: `${m}월 가중1`, width: 96 });
      monthColumns.push({ month: m, field: "gajoong2", label: `${m}월 가중2`, width: 96 });
    }

    const columns = [...fixedColumns, ...monthColumns];

    const titleHeight = 52;
    const headerHeight = 36;
    const rowHeight = 34;
    const padding = 18;

    const tableWidth = columns.reduce((sum, col) => sum + col.width, 0);
    const canvasWidth = tableWidth + padding * 2;
    const canvasHeight = titleHeight + headerHeight + visibleRows.length * rowHeight + padding * 2;

    const scale = 2;
    const canvas = document.createElement("canvas");
    canvas.width = canvasWidth * scale;
    canvas.height = canvasHeight * scale;

    const ctx = canvas.getContext("2d");
    ctx.scale(scale, scale);

    ctx.fillStyle = "#0b1220";
    ctx.fillRect(0, 0, canvasWidth, canvasHeight);

    const titleParts = [
      $("yearFilter").value || "",
      clean($("campFilter").value) || "Camp",
      clean($("waveFilter").value) === "W2" ? "주간" : clean($("waveFilter").value) === "W1" ? "야간" : "주/야"
    ].filter(Boolean);

    ctx.fillStyle = "#e6eefc";
    ctx.font = "900 22px Arial, 'Noto Sans KR', sans-serif";
    ctx.textAlign = "left";
    ctx.textBaseline = "middle";
    ctx.fillText("프레시백 현황 조회", padding, padding + 14);

    ctx.fillStyle = "#9fb0d2";
    ctx.font = "700 13px Arial, 'Noto Sans KR', sans-serif";
    ctx.fillText(titleParts.join(" / "), padding, padding + 38);

    let y = padding + titleHeight;
    let x = padding;

    for (const col of columns) {
      drawCell(ctx, x, y, col.width, headerHeight, {
        text: col.label,
        bg: "#263247",
        color: "#ffffff",
        border: "#475569",
        font: "900 13px Arial, 'Noto Sans KR', sans-serif"
      });

      x += col.width;
    }

    y += headerHeight;

    for (const row of visibleRows) {
      x = padding;

      const fixedValues = {
        wave: waveLabel(effectiveWave(row)),
        camp: effectiveCamp(row),
        route: effectiveRoute(row)
      };

      for (const col of fixedColumns) {
        drawCell(ctx, x, y, col.width, rowHeight, {
          text: fixedValues[col.key],
          bg: "#111827",
          color: col.key === "route" ? "#bfdbfe" : "#e6eefc",
          border: "#334155",
          font: "900 13px Arial, 'Noto Sans KR', sans-serif"
        });

        x += col.width;
      }

      for (const col of monthColumns) {
        const month = row.months[col.month] || {};
        const value = clean(month[col.field]);
        const style = valueStyle(value);

        drawCell(ctx, x, y, col.width, rowHeight, {
          text: value,
          bg: style.bg,
          color: style.color,
          border: "#334155",
          font: "900 13px Arial, 'Noto Sans KR', sans-serif"
        });

        x += col.width;
      }

      y += rowHeight;
    }

    const blob = await canvasToBlob(canvas);

    if (!blob) {
      setStatus("이미지 생성에 실패했습니다.", "bad");
      return;
    }

    try {
      await navigator.clipboard.write([
        new ClipboardItem({
          "image/png": blob
        })
      ]);

      setStatus(`이미지 복사 완료: ${lastMonth}월까지 캡쳐`, "ok");
    } catch (e) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `freshbag_${Date.now()}.png`;
      a.click();
      URL.revokeObjectURL(url);

      setStatus("브라우저가 이미지 클립보드 복사를 막아서 PNG 파일로 다운로드했습니다.", "warn");
    }
  }

  function clearAll() {
    const now = new Date().getFullYear();

    $("yearFilter").value = String(now);
    $("campFilter").value = "";
    $("waveFilter").value = "";
    $("g1Filter").value = "";
    $("g2Filter").value = "";
    $("presetNameInput").value = "";
    $("savedPresetSelect").value = "";

    rawRows = [];
    initDefaultRows();
    setStatus("초기화 완료. 기본 4행에 Route를 입력한 뒤 조회하세요.", "ok");
  }

  function handleError(e) {
    console.error(e);
    setStatus(e.message || String(e), "bad");
  }

  function run(fn) {
    fn().catch(handleError);
  }

  initYearOptions();

  $("loadBtn").addEventListener("click", () => run(loadData));
  $("addRowBtn").addEventListener("click", addRow);
  $("saveBtn").addEventListener("click", () => run(saveChanges));
  $("clearBtn").addEventListener("click", clearAll);
  $("copyBtn").addEventListener("click", () => run(copyTableImage));

  $("savePresetBtn").addEventListener("click", () => run(async () => {
    saveCurrentPreset();
  }));

  $("loadPresetBtn").addEventListener("click", () => run(loadSelectedPresetAndQuery));
  $("deletePresetBtn").addEventListener("click", deleteSelectedPreset);
  $("loadLastPresetBtn").addEventListener("click", () => run(loadLastQueryPresetAndQuery));

  $("savedPresetSelect").addEventListener("change", () => {
    const selectedId = $("savedPresetSelect").value;
    const preset = getSavedPresets().find(item => item.id === selectedId);

    if (preset) {
      $("presetNameInput").value = preset.name || "";
    }
  });

  $("resultTable").addEventListener("click", e => {
    const td = e.target.closest("td.editable");
    if (!td) return;
    startEditCell(td);
  });

  $("resultTable").addEventListener("keydown", e => {
    const td = e.target.closest("td.editable");
    if (!td) return;

    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      startEditCell(td, { fromKeyboard: true });
    }
  });

  $("resultTable").addEventListener("click", e => {
    const btn = e.target.closest("[data-action='delete']");
    if (!btn) return;
    deleteRow(btn.dataset.row);
  });

  ["yearFilter", "waveFilter", "g1Filter", "g2Filter"].forEach(id => {
    $(id).addEventListener("change", () => {
      if (rawRows.length > 0) run(loadData);
      else renderTable();
    });
  });

  $("campFilter").addEventListener("keydown", e => {
    if (e.key === "Enter") run(loadData);
  });

  try {
    initSupabase();
    run(async () => {
      await checkSessionAndAccess();
      initDefaultRows();
      renderPresetOptions();

      if (canEdit) {
        setStatus("기본 4행이 준비되었습니다. Camp / 주야간 선택 후 Route를 입력하고 조회하거나 프리셋을 불러오세요.", "ok");
      }
    });
  } catch (e) {
    handleError(e);
  }
})();
</script>
<script src="/board-menu.js"></script>
</body>
</html>
