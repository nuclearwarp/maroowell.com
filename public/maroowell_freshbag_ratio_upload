      padding:0 12px;
      border:1px solid #d8e0ee;
      border-radius:999px;
      background:#f8fafc;
      font-size:12px;
      color:#64748b;
      white-space:nowrap;
    }

    .summary{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:12px;
    }

    .summary .pill strong{
      color:#0f172a;
      margin-left:5px;
      font-weight:520;
    }

    pre{
      white-space:pre-wrap;
      word-break:break-word;
      background:#f8fafc;
      border:1px solid var(--line);
      border-radius:14px;
      padding:14px;
      max-height:420px;
      overflow:auto;
      font:12px/1.5 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      color:#334155;
      margin:0;
    }

    .tableWrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:#fff;
      max-height:620px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.7);
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:100%;
      min-width:980px;
      font-size:13px;
      color:#0f172a;
      background:#fff;
    }

    th,td{
      border-right:1px solid #d8e0ee;
      border-bottom:1px solid #d8e0ee;
      padding:7px 9px;
      text-align:center;
      white-space:nowrap;
    }

    th{
      position:sticky;
      top:0;
      background:#dbeafe;
      color:#0f172a;
      font-weight:520 !important;
      z-index:2;
    }

    td{background:#fff}
    tbody tr:nth-child(even) td{background:#f8fafc}

    .percent{color:#075985;font-weight:520 !important}
    .kindDaily{color:#1d4ed8;font-weight:520 !important}
    .kindTotal{color:#15803d;font-weight:520 !important}
    .badCell{color:#dc2626;font-weight:520 !important}

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(246,248,252,.96), rgba(255,255,255,.98));
      z-index:9999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid #d8e0ee;
      border-radius:22px;
      background:#fff;
      box-shadow:0 24px 60px rgba(15,23,42,.16);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
      font-weight:560;
    }

    .accessCard p{
      margin:0;
      color:#64748b;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid #d8e0ee;
      background:#f8fafc;
      color:#0f172a;
      font-size:13px;
      font-weight:450;
      word-break:break-word;
      line-height:1.6;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    html.mw-embed,
    html.mw-embed body{
      min-height:100%;
      background:transparent !important;
    }

    html.mw-embed .wrap{
      max-width:none !important;
      padding:0 !important;
      margin:0 !important;
    }

    html.mw-embed .top{
      display:none !important;
    }

    html.mw-embed .card:first-child{
      margin-top:0 !important;
    }

    html.mw-embed .grid{
      grid-template-columns:minmax(330px,430px) 1fr;
    }

    @media(max-width:980px){
      .wrap{padding:12px 10px 30px}
      .grid{grid-template-columns:1fr}
      .top{align-items:stretch;flex-direction:column;padding:13px 14px;border-radius:20px}
      .title{font-size:22px}
      .sub{font-size:12px}
      .card{border-radius:18px;padding:13px}
      .row{flex-direction:column;align-items:stretch}
      .row button{width:100%}
      table{font-size:12px;min-width:760px}
      th,td{padding:6px 7px}
      html.mw-embed .grid{grid-template-columns:1fr}
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <a href="#" id="mwBoardMenuToggle"><img src="/favicon.ico" alt="MarooWell"></a>
        <div>
          <div class="title">마루웰 회수율 업로드</div>
          <div class="sub">엑셀/CSV에서 일자별 회수율과 월 누적 회수율을 추출해 백엔드로 저장합니다. 최고관리자만 접근 가능합니다.</div>
        </div>
      </div>
      <div class="pill" id="userPill">세션 확인 중</div>
    </div>

    <div class="grid">
      <div>
        <div class="card">
          <div class="sectionTitle">엑셀 업로드</div>

          <div class="field">
            <label>기본 연도</label>
            <select id="yearSelect"></select>
          </div>

          <div class="field">
            <label>파일</label>
            <input id="fileInput" type="file" accept=".xlsx,.xls,.csv" />
          </div>

          <div class="row">
            <button id="parseBtn" class="primary">파일 분석</button>
            <button id="uploadBtn" class="ok">백엔드 업로드</button>
            <button id="clearBtn" class="secondary">초기화</button>
          </div>

          <div class="status" id="statusText">대기 중</div>

          <div class="summary">
            <span class="pill">일자별 <strong id="countDaily">0</strong></span>
            <span class="pill">월누적 <strong id="countTotal">0</strong></span>
            <span class="pill">날짜 <strong id="countDates">0</strong></span>
            <span class="pill">캠프 <strong id="countCamps">0</strong></span>
            <span class="pill">라우트 <strong id="countRoutes">0</strong></span>
          </div>

          <div class="muted" style="margin-top:12px">
            저장 방식:<br>
            1) <b>Title 2026.05.02</b> 같은 단일 일자 블록은 일자별 데이터로 전송<br>
            2) <b>2026.03.26 ~ 2026.04.25</b>처럼 쿠팡 정산월 전체 기간인 블록은 월 누적 데이터로 전송<br>
            3) <b>마루웰 / 누적</b> 라벨이 있는 기간 블록은 중간 기간이어도 월 누적 데이터로 전송<br>
            4) Route는 저장 전 <b>126_A → 126A</b>처럼 정규화됩니다.
          </div>
        </div>

        <div class="card">
          <div class="sectionTitle">주의사항</div>
          <div class="muted">
            실제 DB 저장/중복 처리/최신 period_end 판단은 <b>maroowellfreshbag Worker 백엔드</b>에서 처리해야 합니다.<br>
            이 페이지는 파일 분석 후 백엔드에 일자별/월누적 row를 전달합니다.
          </div>
        </div>
      </div>

      <div>
        <div class="card">
          <div class="sectionTitle">추출 결과 미리보기</div>
          <div class="tableWrap">
            <table id="previewTable">
              <thead></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>

        <div class="card">
          <div class="sectionTitle">로그</div>
          <pre id="logOutput">아직 분석 결과가 없습니다.</pre>
        </div>
      </div>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">최고관리자 권한이 필요합니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="deniedHomeBtn" class="secondary" type="button">홈으로</button>
        <button id="deniedLogoutBtn" class="danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};

  const API_BASE = String(
    cfg.MAROOWELL_FRESHBAG_API_BASE ||
    cfg.MAROOWELL_FRESHBAG_API ||
    cfg.BACKENDS?.maroowellFreshbag ||
    "https://maroowellfreshbag.brain-0f6.workers.dev"
  ).replace(/\/+$/, "");

  let supabaseClient = null;
  let currentUser = null;
  let currentAccessToken = "";
  let fileName = "";
  let canUpload = false;

  let dailyRows = [];
  let totalRows = [];
  let parsedRows = [];

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg;
    $("statusText").className = type ? "status " + type : "status";
  }

  function log(value) {
    $("logOutput").textContent = typeof value === "string" ? value : JSON.stringify(value, null, 2);
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function normalizeCampForDb(value) {
    const s = clean(value).replace(/\s+/g, "");
    if (!s) return "";
    if (/^M(?!_)/i.test(s)) return "M_" + s.slice(1);
    return s;
  }

  function headerKey(v) {
    return clean(v)
      .replace(/\s+/g, "")
      .replace(/_/g, "")
      .replace(/[()（）\[\]{}]/g, "")
      .toLowerCase();
  }

  function waveLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "W2") return "주간";
    if (s === "W1") return "야간";
    return s;
  }

  function uniqueCount(arr) {
    return new Set(arr.filter(Boolean)).size;
  }

  function initYears() {
    const now = new Date().getFullYear();
    const years = [];

    for (let y = now + 1; y >= now - 8; y--) {
      years.push(y);
    }

    $("yearSelect").innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join("");
    $("yearSelect").value = String(now);
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  function showAccessDenied(detail = "") {
    $("accessDenied").classList.add("show");
    $("accessDeniedText").textContent = detail || "최고관리자 권한이 필요합니다.";
    $("accessDeniedEmail").textContent = currentUser?.email
      ? `현재 로그인: ${currentUser.email}`
      : "현재 로그인 이메일을 확인할 수 없습니다.";
    document.documentElement.style.visibility = "visible";
  }

  async function checkSuperAdmin() {
    if (!supabaseClient) initSupabase();

    const { data: sessionData, error: sessionError } = await supabaseClient.auth.getSession();
    if (sessionError) throw sessionError;

    const session = sessionData?.session;
    currentUser = session?.user;
    currentAccessToken = session?.access_token || "";

    if (!currentUser || !currentAccessToken) {
      const loginPath = cfg.PATHS?.login || "/login.html";
      location.href = loginPath + "?next=" + encodeURIComponent(location.pathname);
      return false;
    }

    $("userPill").textContent = currentUser.email || currentUser.id;

    const { data: access, error: accessError } = await supabaseClient
      .rpc("mw_my_access")
      .maybeSingle();

    if (accessError) {
      showAccessDenied(accessError.message);
      return false;
    }

    canUpload =
      access?.is_maroowell === true &&
      access?.is_admin === true &&
      Number(access?.max_role_level || 0) >= 90;

    if (!canUpload) {
      showAccessDenied("최고관리자 권한이 필요합니다.\n조건: 마루웰 권한 + 관리자 권한 + role_level 90 이상");
      return false;
    }

    document.documentElement.style.visibility = "visible";
    return true;
  }

  async function ratioApi(path, body = {}) {
    if (!currentAccessToken) await checkSuperAdmin();

    const res = await fetch(API_BASE + path, {
      method:"POST",
      headers:{
        "Content-Type":"application/json",
        "Authorization":"Bearer " + currentAccessToken
      },
      body:JSON.stringify(body),
      cache:"no-store"
    });

    const text = await res.text();
    let data = null;

    if (text) {
      try { data = JSON.parse(text); }
      catch { data = text; }
    }

    if (!res.ok || data?.ok === false) {
      const msg =
        (data && typeof data === "object" && (data.error || data.message || data.detail)) ||
        (typeof data === "string" ? data : "") ||
        `HTTP ${res.status}`;

      throw new Error(String(msg));
    }

    return data;
  }

  function pad2(n) {
    return String(Number(n)).padStart(2, "0");
  }

  function isoDate(y, m, d) {
    return `${y}-${pad2(m)}-${pad2(d)}`;
  }

  function parseIsoDate(iso) {
    const [y, m, d] = String(iso).split("-").map(Number);
    return new Date(y, m - 1, d);
  }

  function addMonths(date, count) {
    return new Date(date.getFullYear(), date.getMonth() + count, date.getDate());
  }

  function sameYearMonth(a, b) {
    return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth();
  }

  function excelSerialToDate(serial) {
    const n = Number(serial);
    if (!Number.isFinite(n)) return null;

    const utcDays = Math.floor(n - 25569);
    const utcValue = utcDays * 86400;
    const dateInfo = new Date(utcValue * 1000);

    if (Number.isNaN(dateInfo.getTime())) return null;

    return isoDate(dateInfo.getUTCFullYear(), dateInfo.getUTCMonth() + 1, dateInfo.getUTCDate());
  }

  function parseDateValue(v, defaultYear = null) {
    if (v instanceof Date && !Number.isNaN(v.getTime())) {
      return isoDate(v.getFullYear(), v.getMonth() + 1, v.getDate());
    }

    if (typeof v === "number") {
      return excelSerialToDate(v);
    }

    let s = clean(v);
    if (!s) return null;

    s = s
      .replace(/^date\s*[:：]?\s*/i, "")
      .replace(/^날짜\s*[:：]?\s*/i, "")
      .replace(/\([^)]*\)/g, "")
      .trim();

    let m = s.match(/(20\d{2})[.\-/년\s]+(\d{1,2})[.\-/월\s]+(\d{1,2})/);
    if (m) return isoDate(m[1], m[2], m[3]);

    m = s.match(/(\d{1,2})[.\-/월\s]+(\d{1,2})/);
    if (m && defaultYear) return isoDate(defaultYear, m[1], m[2]);

    if (/^\d{5}(\.\d+)?$/.test(s)) return excelSerialToDate(Number(s));

    return null;
  }

  function getCoupangMonthFromEndDate(endIso) {
    const end = parseIsoDate(endIso);

    return {
      data_year: end.getFullYear(),
      month_no: end.getMonth() + 1
    };
  }

  function makeRangeInfo(startIso, endIso, forceMonthTotal = false) {
    const start = parseIsoDate(startIso);
    const end = parseIsoDate(endIso);

    const isFullCoupangMonth =
      start.getDate() === 26 &&
      end.getDate() === 25 &&
      sameYearMonth(addMonths(start, 1), end);

    if (!isFullCoupangMonth && !forceMonthTotal) {
      return {
        kind: "ignore_range",
        period_start: startIso,
        period_end: endIso
      };
    }

    const monthInfo = getCoupangMonthFromEndDate(endIso);

    return {
      kind: "month_total",
      period_start: startIso,
      period_end: endIso,
      data_year: monthInfo.data_year,
      month_no: monthInfo.month_no
    };
  }

  function extractDateInfoFromText(value, defaultYear, forceMonthTotal = false) {
    const s = clean(value);
    if (!s) return null;

    const full = Array.from(
      s.matchAll(/(20\d{2})[.\-/년\s]+(\d{1,2})[.\-/월\s]+(\d{1,2})/g)
    ).map(m => isoDate(m[1], m[2], m[3]));

    if (full.length >= 2 && /[~∼～]/.test(s)) {
      const start = full[0];
      const end = full[full.length - 1];
      return makeRangeInfo(start, end, forceMonthTotal);
    }

    if (full.length === 1) {
      return {
        kind: "daily",
        date: full[0]
      };
    }

    const short = Array.from(
      s.matchAll(/(\d{1,2})[.\-/월\s]+(\d{1,2})/g)
    ).map(m => defaultYear ? isoDate(defaultYear, m[1], m[2]) : null).filter(Boolean);

    if (short.length >= 2 && /[~∼～]/.test(s)) {
      return makeRangeInfo(short[0], short[short.length - 1], forceMonthTotal);
    }

    if (short.length === 1) {
      return {
        kind: "daily",
        date: short[0]
      };
    }

    const single = parseDateValue(s, defaultYear);

    if (single) {
      return {
        kind: "daily",
        date: single
      };
    }

    return null;
  }

  function hasMaroowellTotalLabelNear(rows, headerRowIndex, startCol, endCol) {
    for (let r = Math.max(0, headerRowIndex - 5); r <= headerRowIndex; r++) {
      const row = rows[r] || [];

      for (let c = Math.max(0, startCol - 1); c <= endCol; c++) {
        const text = clean(row[c]);
        const key = headerKey(text);

        if (
          text.includes("마루웰") ||
          text.includes("누적") ||
          key.includes("maroowell") ||
          key.includes("total")
        ) {
          return true;
        }
      }
    }

    return false;
  }

  function parsePercentValue(v) {
    if (v === null || v === undefined || v === "") return null;

    if (typeof v === "number") {
      if (!Number.isFinite(v)) return null;
      const val = v > 0 && v <= 1 ? v * 100 : v;
      if (val < 0 || val > 1000) throw new Error(`퍼센트 범위를 벗어났습니다: ${v}`);
      return Math.round(val * 100) / 100;
    }

    const raw = clean(v);
    if (!raw) return null;

    if (raw === "해당" || raw === "미해당" || raw.includes("해당")) return null;

    const hasPercent = raw.includes("%");

    const normalized = raw
      .replace(/,/g, "")
      .replace(/%/g, "")
      .replace(/[^\d.\-]/g, "");

    if (!normalized || normalized === "." || normalized === "-") return null;

    const n = Number(normalized);
    if (!Number.isFinite(n)) return null;

    const val = !hasPercent && n > 0 && n <= 1 ? n * 100 : n;

    if (val < 0 || val > 1000) {
      throw new Error(`퍼센트 범위를 벗어났습니다: ${raw}`);
    }

    return Math.round(val * 100) / 100;
  }

  function isPercentLikeValue(v) {
    try {
      return parsePercentValue(v) !== null;
    } catch {
      return false;
    }
  }

  function scorePercentColumn(rows, colIndex, startRow, maxScan = 40) {
    let score = 0;

    for (let r = startRow; r < Math.min(rows.length, startRow + maxScan); r++) {
      const row = rows[r] || [];
      if (isPercentLikeValue(row[colIndex])) score++;
    }

    return score;
  }

  function parseWhich(v) {
    const key = headerKey(v);

    if (!key) return 0;

    if (
      key.includes("가중요인1") ||
      key.includes("가중1") ||
      key.includes("gajoong1") ||
      key.includes("factor1") ||
      key.includes("요인1") ||
      key === "1"
    ) {
      return 1;
    }

    if (
      key.includes("가중요인2") ||
      key.includes("가중2") ||
      key.includes("gajoong2") ||
      key.includes("factor2") ||
      key.includes("요인2") ||
      key === "2"
    ) {
      return 2;
    }

    return 0;
  }

  function findIndexByCandidates(keys, candidates) {
    return keys.findIndex(key => candidates.some(c => key === c || key.includes(c)));
  }

  function findLongHeader(rows) {
    for (let r = 0; r < Math.min(rows.length, 100); r++) {
      const row = rows[r] || [];
      const keys = row.map(headerKey);

      const dateIdx = findIndexByCandidates(keys, ["date", "날짜", "일자"]);
      const waveIdx = findIndexByCandidates(keys, ["wave", "웨이브", "주야간"]);
      const campIdx = findIndexByCandidates(keys, ["camp", "캠프"]);
      const routeIdx = findIndexByCandidates(keys, ["route", "라우트", "노선"]);
      const g1Idx = findIndexByCandidates(keys, ["gajoong1", "가중요인1", "가중1", "요인1"]);
      const g2Idx = findIndexByCandidates(keys, ["gajoong2", "가중요인2", "가중2", "요인2"]);

      if (dateIdx >= 0 && waveIdx >= 0 && campIdx >= 0 && routeIdx >= 0 && g1Idx >= 0 && g2Idx >= 0) {
        return {
          rowIndex: r,
          dateIdx,
          waveIdx,
          campIdx,
          routeIdx,
          g1Idx,
          g2Idx
        };
      }
    }

    return null;
  }

  function findBaseHeader(rows) {
    for (let r = 0; r < Math.min(rows.length, 100); r++) {
      const row = rows[r] || [];
      const keys = row.map(headerKey);

      const waveIdx = findIndexByCandidates(keys, ["wave", "웨이브", "주야간"]);
      const campIdx = findIndexByCandidates(keys, ["camp", "캠프"]);
      const routeIdx = findIndexByCandidates(keys, ["route", "라우트", "노선"]);

      if (waveIdx >= 0 && campIdx >= 0 && routeIdx >= 0) {
        return {
          rowIndex: r,
          row,
          keys,
          waveIdx,
          campIdx,
          routeIdx
        };
      }
    }

    return null;
  }

  function findBlockInfoNear(rows, headerRowIndex, startCol, endCol) {
    const defaultYear = Number($("yearSelect").value);
    const forceMonthTotal = hasMaroowellTotalLabelNear(rows, headerRowIndex, startCol, endCol);
    const candidates = [];

    for (let r = Math.max(0, headerRowIndex - 5); r <= headerRowIndex; r++) {
      const row = rows[r] || [];

      for (let c = startCol; c <= endCol; c++) {
        const info = extractDateInfoFromText(row[c], defaultYear, forceMonthTotal);

        if (info) {
          candidates.push(info);
        }
      }
    }

    const monthTotal = candidates.find(item => item.kind === "month_total");
    if (monthTotal) return monthTotal;

    const daily = candidates.find(item => item.kind === "daily");
    if (daily) return daily;

    const ignored = candidates.find(item => item.kind === "ignore_range");
    if (ignored) return ignored;

    return null;
  }

  function findRepeatedWideBlocks(rows, header) {
    const headerRow = rows[header.rowIndex] || [];
    const keys = headerRow.map(headerKey);
    const waveColumns = [];

    for (let c = 0; c < keys.length; c++) {
      const key = keys[c];

      if (
        key === "wave" ||
        key.includes("wave") ||
        key.includes("웨이브") ||
        key.includes("주야간")
      ) {
        waveColumns.push(c);
      }
    }

    const blocks = [];

    for (const waveIdx of waveColumns) {
      const searchEnd = Math.min(keys.length - 1, waveIdx + 12);

      let campIdx = -1;
      let routeIdx = -1;

      for (let c = waveIdx + 1; c <= searchEnd; c++) {
        if (
          campIdx < 0 &&
          (keys[c] === "camp" || keys[c].includes("camp") || keys[c].includes("캠프"))
        ) {
          campIdx = c;
        }

        if (
          routeIdx < 0 &&
          (
            keys[c] === "route" ||
            keys[c].includes("route") ||
            keys[c].includes("라우트") ||
            keys[c].includes("노선")
          )
        ) {
          routeIdx = c;
        }
      }

      if (campIdx < 0 || routeIdx < 0) continue;

      const nextWaveIdx = waveColumns.find(c => c > waveIdx) || keys.length;
      const blockEnd = nextWaveIdx - 1;
      const info = findBlockInfoNear(rows, header.rowIndex, waveIdx, blockEnd);

      if (!info || info.kind === "ignore_range") continue;

      const percentCandidates = [];

      for (let c = routeIdx + 1; c <= blockEnd; c++) {
        const which = parseWhich(headerRow[c]);
        const score = scorePercentColumn(rows, c, header.rowIndex + 1);

        if (which || score > 0) {
          percentCandidates.push({
            col:c,
            which,
            score
          });
        }
      }

      let g1Idx = -1;
      let g2Idx = -1;

      const explicitG1 = percentCandidates.find(item => item.which === 1);
      const explicitG2 = percentCandidates.find(item => item.which === 2);

      if (explicitG1) g1Idx = explicitG1.col;
      if (explicitG2) g2Idx = explicitG2.col;

      if (g1Idx < 0 || g2Idx < 0) {
        const sorted = percentCandidates
          .filter(item => item.score > 0)
          .sort((a, b) => b.score - a.score || a.col - b.col);

        if (g1Idx < 0 && sorted[0]) g1Idx = sorted[0].col;
        if (g2Idx < 0 && sorted[1]) g2Idx = sorted[1].col;
      }

      if (g1Idx < 0 || g2Idx < 0) continue;

      blocks.push({
        ...info,
        waveIdx,
        campIdx,
        routeIdx,
        g1Idx,
        g2Idx,
        startCol: waveIdx,
        endCol: blockEnd
      });
    }

    return blocks;
  }

  function normalizeWave(value) {
    const s = clean(value).toUpperCase();

    if (s === "주간") return "W2";
    if (s === "야간") return "W1";
    if (s === "W2") return "W2";
    if (s === "W1") return "W1";

    return s;
  }

  function makeDailyRow(info, row, block) {
    const wave = normalizeWave(row[block.waveIdx]);
    const camp = normalizeCampForDb(row[block.campIdx]);
    const route = clean(row[block.routeIdx]);
    const routeNorm = normalizeRoute(route);

    if (!wave || !camp || !routeNorm) return null;

    const g1 = parsePercentValue(row[block.g1Idx]);
    const g2 = parsePercentValue(row[block.g2Idx]);

    if (g1 === null && g2 === null) return null;

    return {
      date: info.date,
      wave,
      camp,
      route,
      route_norm: routeNorm,
      gajoong1: g1,
      gajoong2: g2,
      source_file_name: fileName
    };
  }

  function makeTotalRow(info, row, block) {
    const wave = normalizeWave(row[block.waveIdx]);
    const camp = normalizeCampForDb(row[block.campIdx]);
    const route = clean(row[block.routeIdx]);
    const routeNorm = normalizeRoute(route);

    if (!wave || !camp || !routeNorm) return null;

    const g1 = parsePercentValue(row[block.g1Idx]);
    const g2 = parsePercentValue(row[block.g2Idx]);

    if (g1 === null && g2 === null) return null;

    return {
      data_year: info.data_year,
      month_no: info.month_no,
      data_month: `${info.data_year}-${pad2(info.month_no)}`,
      period_start: info.period_start,
      period_end: info.period_end,
      wave,
      camp,
      route,
      route_norm: routeNorm,
      gajoong1: g1,
      gajoong2: g2,
      source_file_name: fileName
    };
  }

  function parseLongRows(rows, header) {
    const outDaily = [];
    const defaultYear = Number($("yearSelect").value);

    for (let r = header.rowIndex + 1; r < rows.length; r++) {
      const row = rows[r] || [];
      const date = parseDateValue(row[header.dateIdx], defaultYear);
      if (!date) continue;

      const wave = normalizeWave(row[header.waveIdx]);
      const camp = normalizeCampForDb(row[header.campIdx]);
      const route = clean(row[header.routeIdx]);
      const routeNorm = normalizeRoute(route);

      if (!wave || !camp || !routeNorm) continue;

      const g1 = parsePercentValue(row[header.g1Idx]);
      const g2 = parsePercentValue(row[header.g2Idx]);

      if (g1 === null && g2 === null) continue;

      outDaily.push({
        date,
        wave,
        camp,
        route,
        route_norm: routeNorm,
        gajoong1: g1,
        gajoong2: g2,
        source_file_name: fileName
      });
    }

    return {
      dailyRows: outDaily,
      totalRows: []
    };
  }

  function parseWideRows(rows, header) {
    const blocks = findRepeatedWideBlocks(rows, header);

    if (!blocks.length) {
      throw new Error("일자/기간 블록 또는 가중1/가중2 컬럼을 찾지 못했습니다.");
    }

    const outDaily = [];
    const outTotal = [];

    for (const block of blocks) {
      for (let r = header.rowIndex + 1; r < rows.length; r++) {
        const row = rows[r] || [];
        const wave = clean(row[block.waveIdx]);
        const camp = clean(row[block.campIdx]);
        const route = clean(row[block.routeIdx]);

        if (!wave || !camp || !route) continue;

        if (block.kind === "daily") {
          const item = makeDailyRow(block, row, block);
          if (item) outDaily.push(item);
        }

        if (block.kind === "month_total") {
          const item = makeTotalRow(block, row, block);
          if (item) outTotal.push(item);
        }
      }
    }

    return {
      dailyRows: outDaily,
      totalRows: outTotal,
      blocks: blocks.map(block => ({
        kind:block.kind,
        date:block.date,
        period_start:block.period_start,
        period_end:block.period_end,
        data_year:block.data_year,
        month_no:block.month_no,
        waveIdx:block.waveIdx,
        campIdx:block.campIdx,
        routeIdx:block.routeIdx,
        g1Idx:block.g1Idx,
        g2Idx:block.g2Idx
      }))
    };
  }

  async function readWorkbook(file) {
    const buf = await file.arrayBuffer();
    const wb = XLSX.read(buf, {
      type:"array",
      cellDates:true
    });
    const sheetName = wb.SheetNames[0];
    const ws = wb.Sheets[sheetName];

    return {
      sheetName,
      rows:XLSX.utils.sheet_to_json(ws, {
        header:1,
        raw:true,
        defval:""
      })
    };
  }

  function parseWorkbookRows(rows) {
    const longHeader = findLongHeader(rows);

    if (longHeader) {
      return {
        mode:"long",
        headerRow:longHeader.rowIndex + 1,
        ...parseLongRows(rows, longHeader)
      };
    }

    const baseHeader = findBaseHeader(rows);

    if (!baseHeader) {
      throw new Error("Wave / Camp / Route 헤더를 찾지 못했습니다.");
    }

    return {
      mode:"wide-block",
      headerRow:baseHeader.rowIndex + 1,
      ...parseWideRows(rows, baseHeader)
    };
  }

  function updateSummary() {
    $("countDaily").textContent = dailyRows.length.toLocaleString();
    $("countTotal").textContent = totalRows.length.toLocaleString();
    $("countDates").textContent = uniqueCount(dailyRows.map(row => row.date)).toLocaleString();
    $("countCamps").textContent = uniqueCount([...dailyRows, ...totalRows].map(row => row.camp)).toLocaleString();
    $("countRoutes").textContent = uniqueCount([...dailyRows, ...totalRows].map(row => `${row.wave}||${row.camp}||${row.route_norm}`)).toLocaleString();
  }

  function renderPreview() {
    const thead = $("previewTable").querySelector("thead");
    const tbody = $("previewTable").querySelector("tbody");

    thead.innerHTML = `
      <tr>
        <th>구분</th>
        <th>date/month</th>
        <th>period</th>
        <th>Wave</th>
        <th>Camp</th>
        <th>Route</th>
        <th>route_norm</th>
        <th>가중1</th>
        <th>가중2</th>
      </tr>
    `;

    const sample = parsedRows.slice(0, 400);

    if (!sample.length) {
      tbody.innerHTML = `<tr><td colspan="9">추출 데이터 없음</td></tr>`;
      return;
    }

    tbody.innerHTML = sample.map(item => {
      const row = item.row;

      const dateText = item.kind === "daily"
        ? row.date
        : row.data_month;

      const periodText = item.kind === "daily"
        ? ""
        : `${row.period_start || ""} ~ ${row.period_end || ""}`;

      return `
        <tr>
          <td class="${item.kind === "daily" ? "kindDaily" : "kindTotal"}">${item.kind === "daily" ? "일자별" : "월누적"}</td>
          <td>${esc(dateText)}</td>
          <td>${esc(periodText)}</td>
          <td>${esc(waveLabel(row.wave))}</td>
          <td>${esc(row.camp)}</td>
          <td>${esc(row.route)}</td>
          <td>${esc(row.route_norm)}</td>
          <td class="percent">${row.gajoong1 === null || row.gajoong1 === undefined ? "" : esc(row.gajoong1 + "%")}</td>
          <td class="percent">${row.gajoong2 === null || row.gajoong2 === undefined ? "" : esc(row.gajoong2 + "%")}</td>
        </tr>
      `;
    }).join("");
  }

  async function parseFile() {
    const file = $("fileInput").files?.[0];
    if (!file) throw new Error("파일을 선택하세요.");

    fileName = file.name;
    setStatus("파일 분석 중...", "warn");

    const { sheetName, rows } = await readWorkbook(file);
    const result = parseWorkbookRows(rows);

    dailyRows = result.dailyRows || [];
    totalRows = result.totalRows || [];

    parsedRows = [
      ...dailyRows.map(row => ({ kind:"daily", row })),
      ...totalRows.map(row => ({ kind:"total", row }))
    ];

    updateSummary();
    renderPreview();

    log({
      file:file.name,
      sheet:sheetName,
      mode:result.mode,
      headerRow:result.headerRow,
      dailyRows:dailyRows.length,
      totalRows:totalRows.length,
      api:API_BASE,
      blocks:result.blocks || undefined,
      sample:parsedRows.slice(0, 8)
    });

    setStatus(`분석 완료: 일자별 ${dailyRows.length.toLocaleString()}건 / 월누적 ${totalRows.length.toLocaleString()}건 추출`, "ok");
  }

  function uploadPercent(done, total) {
    if (!total) return 0;
    return Math.min(100, Math.max(0, Math.round((done / total) * 100)));
  }

  function chunkRows(arr, size) {
    const out = [];
    for (let i = 0; i < arr.length; i += size) {
      out.push(arr.slice(i, i + size));
    }
    return out;
  }

  async function uploadRows() {
    if (!canUpload) throw new Error("최고관리자 권한이 필요합니다.");
    if (!parsedRows.length) throw new Error("먼저 파일 분석을 실행하세요.");

    const dailyBatches = chunkRows(dailyRows, 1200);
    const totalBatches = chunkRows(totalRows, 1200);
    const totalCount = dailyRows.length + totalRows.length;

    let done = 0;
    const results = [];

    setStatus("마루웰 회수율 백엔드 업로드 중... 0%", "warn");

    for (let i = 0; i < dailyBatches.length; i++) {
      const rows = dailyBatches[i];

      const result = await ratioApi("/ratio/upload", {
        kind:"daily",
        fileName,
        rows
      });

      const uploaded = Number(result?.upserted || result?.count || rows.length);
      done += uploaded;
      results.push(result);

      setStatus(`마루웰 회수율 백엔드 업로드 중... ${uploadPercent(done, totalCount)}%`, "warn");
    }

    for (let i = 0; i < totalBatches.length; i++) {
      const rows = totalBatches[i];

      const result = await ratioApi("/ratio/upload", {
        kind:"month_total",
        fileName,
        rows
      });

      const uploaded = Number(result?.upserted || result?.count || rows.length);
      done += uploaded;
      results.push(result);

      setStatus(`마루웰 회수율 백엔드 업로드 중... ${uploadPercent(done, totalCount)}%`, "warn");
    }

    setStatus(`업로드 완료: 100% · 총 ${done.toLocaleString()}건`, "ok");

    log({
      upload:"done",
      api:API_BASE,
      file:fileName,
      total:totalCount,
      dailyRows:dailyRows.length,
      totalRows:totalRows.length,
      done,
      results:results.slice(-5)
    });
  }

  function clearAll() {
    fileName = "";
    dailyRows = [];
    totalRows = [];
    parsedRows = [];

    $("fileInput").value = "";
    $("previewTable").querySelector("thead").innerHTML = "";
    $("previewTable").querySelector("tbody").innerHTML = "";

    updateSummary();
    log("초기화 완료");
    setStatus("대기 중");
  }

  function handleError(e) {
    console.error(e);
    setStatus(e.message || String(e), "bad");
  }

  function run(fn) {
    fn().catch(handleError);
  }

  initYears();
  updateSummary();

  $("parseBtn").addEventListener("click", () => run(parseFile));
  $("uploadBtn").addEventListener("click", () => run(uploadRows));
  $("clearBtn").addEventListener("click", clearAll);

  $("deniedHomeBtn").addEventListener("click", () => {
    location.href = cfg.PATHS?.index || "/zipcode_search";
  });

  $("deniedLogoutBtn").addEventListener("click", () => {
    if (supabaseClient) {
      supabaseClient.auth.signOut().finally(() => {
        location.href = cfg.PATHS?.login || "/";
      });
    } else {
      location.href = cfg.PATHS?.login || "/";
    }
  });

  try {
    initSupabase();

    run(async () => {
      const ok = await checkSuperAdmin();
      if (!ok) return;
      setStatus("최고관리자 확인 완료. 파일을 선택해 분석하세요.", "ok");
    });
  } catch (e) {
    document.documentElement.style.visibility = "visible";
    handleError(e);
  }
})();
</script>
<script src="/board-menu.js"></script>
</body>
</html>
