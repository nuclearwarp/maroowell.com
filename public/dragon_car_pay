<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>용차 정산</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0f1a2d;
      --panel2:#0c1524;
      --line:rgba(255,255,255,.08);
      --line2:#d4dbe5;
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;
      --ok:#1a5a3a;
      --warn:#6a4b13;
      --danger:#6b1b1b;

      --sheetBg:#eef3f8;
      --headBg:#dde7f3;
      --cellBg:#ffffff;
      --cellAlt:#f8fbff;
      --cellTxt:#0f172a;

      --dirtyBg:#e0eeff;
      --dirtyBorder:#60a5fa;

      --warnBg:#fff1a8;
      --warnBorder:#e2c44d;

      --paidBg:#dbeafe;
      --paidAlt:#d3e8fb;

      --topbarH:56px;
      --toolbarH:58px;
      --statusH:44px;
    }

    *{ box-sizing:border-box; }
    html,body{
      margin:0;
      height:100%;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }
    body{ overflow:hidden; }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--topbarH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }

    .spacer{ flex:1; }

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }

    .btn:hover{ background:var(--btn2); }
    .btn.ok{ background:rgba(26,90,58,.35); border-color:rgba(0,255,140,.18); }
    .btn.warn{ background:rgba(106,75,19,.35); border-color:rgba(255,180,0,.18); }
    .btn.danger{ background:rgba(107,27,27,.35); border-color:rgba(255,60,60,.22); color:#ffccd3; }
    .btn:disabled{ opacity:.55; cursor:not-allowed; }

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:var(--panel2);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .toolGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolGroup label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .toolbar input{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbar input:focus{
      border-color:rgba(96,165,250,.55);
    }

    .main{
      min-height:0;
      display:grid;
      grid-template-columns:300px 1fr;
    }

    .sidebar{
      border-right:1px solid var(--line);
      background:linear-gradient(180deg,var(--panel),#0b1321);
      display:flex;
      flex-direction:column;
      min-height:0;
    }

    .sideSection{
      padding:12px;
      border-bottom:1px solid var(--line);
    }

    .sideTitle{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:10px;
    }

    .monthCard, .statCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:12px;
    }

    .monthValue{
      font-size:24px;
      font-weight:900;
      line-height:1.05;
    }

    .statGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .statLabel{
      color:var(--muted);
      font-size:11px;
      font-weight:900;
      margin-bottom:4px;
    }

    .statValue{
      font-size:18px;
      font-weight:900;
      color:#fff;
    }

    .statValue.blue{ color:#bfdbfe; }
    .statValue.green{ color:#bbf7d0; }
    .statValue.red{ color:#fecaca; }

    .orderList{
      min-height:0;
      overflow:auto;
      padding:10px;
    }

    .orderItem{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:16px;
      padding:12px;
      margin-bottom:10px;
      cursor:pointer;
      transition:.14s ease;
    }

    .orderItem:hover{
      border-color:rgba(255,255,255,.18);
      background:rgba(255,255,255,.07);
    }

    .orderItem.active{
      border-color:rgba(96,165,250,.55);
      background:rgba(59,130,246,.12);
      box-shadow:inset 0 0 0 1px rgba(96,165,250,.22);
    }

    .orderName{
      font-weight:900;
      color:#fff;
      line-height:1.25;
      margin-bottom:8px;
      word-break:break-word;
    }

    .orderMeta{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:6px 12px;
      font-size:12px;
      color:#c9d7f2;
    }

    .orderMeta b{
      color:#fff;
      font-weight:900;
    }

    .content{
      min-width:0;
      min-height:0;
      display:grid;
      grid-template-rows:auto auto 1fr;
      background:#0f1726;
    }

    .summaryWrap{
      padding:12px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,#10192b,#0e1625);
    }

    .hero{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:18px;
      padding:14px;
    }

    .heroTitle{
      font-size:22px;
      font-weight:900;
      line-height:1.15;
      margin-bottom:6px;
    }

    .heroSub{
      font-size:12px;
      color:#c8d6f1;
      line-height:1.5;
      white-space:pre-line;
    }

    .kpiRow{
      display:grid;
      grid-template-columns:repeat(6, minmax(120px,1fr));
      gap:10px;
      margin-top:12px;
    }

    .kpi{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(0,0,0,.16);
      border-radius:14px;
      padding:12px;
    }

    .kpiLabel{
      color:var(--muted);
      font-size:11px;
      font-weight:900;
      margin-bottom:6px;
    }

    .kpiValue{
      font-size:20px;
      font-weight:900;
      line-height:1.05;
    }

    .kpiValue.blue{ color:#bfdbfe; }
    .kpiValue.green{ color:#bbf7d0; }
    .kpiValue.red{ color:#fecaca; }

    .statementWrap{
      padding:12px;
      border-bottom:1px solid var(--line);
      background:#0d1523;
    }

    .sectionTitle{
      font-size:13px;
      font-weight:900;
      color:#dbe7ff;
      margin-bottom:10px;
    }

    .tableWrap{
      overflow:auto;
      background:var(--sheetBg);
      border-radius:16px;
      border:1px solid rgba(255,255,255,.08);
    }

    table.sheet{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
      min-width:1800px;
    }

    .sheet th, .sheet td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    .sheet th:first-child, .sheet td:first-child{
      border-left:1px solid var(--line2);
    }

    .sheet thead th{
      position:sticky;
      top:0;
      z-index:2;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .sheet tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    .sheet tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    .sheet tbody tr.paidRow td{
      background:rgba(219,234,254,.72);
    }

    .sheet tbody tr.paidRow:nth-child(even) td{
      background:rgba(210,228,250,.82);
    }

    .sheet td.dirty{
      background:var(--dirtyBg) !important;
      box-shadow:inset 0 0 0 2px var(--dirtyBorder);
    }

    .sheet td.warn{
      background:var(--warnBg) !important;
      box-shadow:inset 0 0 0 1px var(--warnBorder);
    }

    .cellView{
      min-height:42px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:0 10px;
      font-size:13px;
      line-height:1.35;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .cellView.left{ justify-content:flex-start; text-align:left; }
    .cellView.center{ justify-content:center; text-align:center; }
    .cellView.right{ justify-content:flex-end; text-align:right; font-variant-numeric:tabular-nums; }
    .code{
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:12px;
    }

    .cellInput, .cellSelect, .cellTextarea{
      width:100%;
      border:none;
      outline:none;
      background:transparent;
      color:var(--cellTxt);
      font:inherit;
      border-radius:0;
    }

    .cellInput, .cellSelect{
      height:42px;
      padding:0 10px;
      font-size:13px;
    }

    .cellTextarea{
      min-height:42px;
      padding:10px;
      resize:vertical;
      line-height:1.4;
      font-size:13px;
    }

    .cellInput.center, .cellSelect.center{ text-align:center; }
    .cellInput.right{ text-align:right; font-variant-numeric:tabular-nums; }
    .cellInput.code{ font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; font-size:12px; }

    .rowActions{
      display:flex;
      gap:6px;
      justify-content:center;
      align-items:center;
      padding:6px;
      min-height:42px;
    }

    .miniBtn{
      height:30px;
      min-width:30px;
      padding:0 8px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      cursor:pointer;
      font-size:12px;
      font-weight:800;
    }

    .miniBtn:hover{ background:#f5f7fb; }
    .miniBtn.del{
      background:#fff1f2;
      color:#b91c1c;
      border-color:#fecdd3;
    }

    .empty{
      padding:18px 14px;
      text-align:center;
      color:#64748b;
      font-weight:900;
      background:#f8fbff;
    }

    .editorWrap{
      min-height:0;
      overflow:auto;
      padding:12px;
      background:#0b1320;
    }

    .editorCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:18px;
      overflow:hidden;
    }

    .editorHead{
      padding:12px 14px;
      border-bottom:1px solid rgba(255,255,255,.08);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      background:rgba(255,255,255,.03);
    }

    .editorTableWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{ color:#bbf7d0; }
    .pill.warn{ color:#fde68a; }
    .pill.err{ color:#fecaca; }

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{ display:flex; }

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width:1280px){
      .kpiRow{
        grid-template-columns:repeat(3, minmax(120px,1fr));
      }
    }

    @media (max-width:900px){
      .main{ grid-template-columns:1fr; }
      .sidebar{ max-height:280px; }
      .btn{ padding:0 10px; font-size:12px; }
      .toolbar{ padding:8px; gap:8px; }
      .kpiRow{
        grid-template-columns:repeat(2, minmax(120px,1fr));
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>용차 정산</b>
        <small>dragon_car 기반 · 최고관리자 전용</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnSaveAll" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="toolGroup">
        <label for="monthInput">정산월</label>
        <input id="monthInput" type="text" placeholder="YYYY-MM" />
      </div>

      <div class="toolGroup">
        <label for="orderSearch">Order 검색</label>
        <input id="orderSearch" type="text" placeholder="Order / 기사 / 라우트 / 비고" />
      </div>

      <div class="toolGroup">
        <button id="btnClearSearch" class="btn" type="button">검색 초기화</button>
        <button id="btnAddRow" class="btn warn" type="button">행 추가</button>
      </div>
    </div>

    <div class="main">
      <aside class="sidebar">
        <div class="sideSection">
          <div class="sideTitle">현재 조회</div>
          <div class="monthCard">
            <div class="statLabel">정산월</div>
            <div id="monthValue" class="monthValue">-</div>
          </div>
        </div>

        <div class="sideSection">
          <div class="sideTitle">월 요약</div>
          <div class="statGrid">
            <div class="statCard">
              <div class="statLabel">Order 수</div>
              <div id="sideOrderCount" class="statValue">0</div>
            </div>
            <div class="statCard">
              <div class="statLabel">행 수</div>
              <div id="sideRowCount" class="statValue blue">0</div>
            </div>
            <div class="statCard">
              <div class="statLabel">월 총금액</div>
              <div id="sideMonthAmount" class="statValue">₩0</div>
            </div>
            <div class="statCard">
              <div class="statLabel">미입금</div>
              <div id="sideMonthUnpaid" class="statValue red">₩0</div>
            </div>
          </div>
        </div>

        <div class="sideSection">
          <div class="sideTitle">Order 목록</div>
        </div>

        <div id="orderList" class="orderList"></div>
      </aside>

      <main class="content">
        <div class="summaryWrap">
          <div class="hero">
            <div id="heroTitle" class="heroTitle">Order를 선택해줘</div>
            <div id="heroSub" class="heroSub">왼쪽에서 Order를 고르면 정산 요약과 편집 테이블이 같이 뜬다.</div>

            <div class="kpiRow">
              <div class="kpi">
                <div class="kpiLabel">총금액</div>
                <div id="kpiAmount" class="kpiValue">₩0</div>
              </div>
              <div class="kpi">
                <div class="kpiLabel">입금금액</div>
                <div id="kpiPaidAmount" class="kpiValue blue">₩0</div>
              </div>
              <div class="kpi">
                <div class="kpiLabel">미입금금액</div>
                <div id="kpiUnpaidAmount" class="kpiValue red">₩0</div>
              </div>
              <div class="kpi">
                <div class="kpiLabel">배송</div>
                <div id="kpiParcel" class="kpiValue">0</div>
              </div>
              <div class="kpi">
                <div class="kpiLabel">반품</div>
                <div id="kpiReturn" class="kpiValue">0</div>
              </div>
              <div class="kpi">
                <div class="kpiLabel">행 수</div>
                <div id="kpiRows" class="kpiValue green">0</div>
              </div>
            </div>
          </div>
        </div>

        <div class="statementWrap">
          <div class="sectionTitle">선택 Order 정산서</div>
          <div class="tableWrap">
            <table class="sheet">
              <colgroup>
                <col style="width:110px" />
                <col style="width:140px" />
                <col style="width:110px" />
                <col style="width:80px" />
                <col style="width:140px" />
                <col style="width:90px" />
                <col style="width:90px" />
                <col style="width:90px" />
                <col style="width:120px" />
                <col style="width:120px" />
                <col style="width:110px" />
                <col style="width:110px" />
                <col style="width:180px" />
              </colgroup>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>연결 벤더</th>
                  <th>캠프</th>
                  <th>주/야</th>
                  <th>라우트</th>
                  <th>단가</th>
                  <th>배송</th>
                  <th>반품</th>
                  <th>합계</th>
                  <th>금액</th>
                  <th>정산일자</th>
                  <th>입금여부</th>
                  <th>비고</th>
                </tr>
              </thead>
              <tbody id="statementBody"></tbody>
            </table>
          </div>
        </div>

        <div class="editorWrap">
          <div class="editorCard">
            <div class="editorHead">
              <div class="sectionTitle" style="margin:0">dragon_car 편집</div>
            </div>

            <div class="editorTableWrap">
              <table class="sheet">
                <colgroup>
                  <col style="width:80px" />
                  <col style="width:120px" />
                  <col style="width:140px" />
                  <col style="width:120px" />
                  <col style="width:90px" />
                  <col style="width:80px" />
                  <col style="width:160px" />
                  <col style="width:100px" />
                  <col style="width:90px" />
                  <col style="width:120px" />
                  <col style="width:90px" />
                  <col style="width:90px" />
                  <col style="width:90px" />
                  <col style="width:120px" />
                  <col style="width:100px" />
                  <col style="width:80px" />
                  <col style="width:100px" />
                  <col style="width:100px" />
                  <col style="width:180px" />
                  <col style="width:72px" />
                </colgroup>
                <thead>
                  <tr>
                    <th>순번</th>
                    <th>Date</th>
                    <th>연결 벤더</th>
                    <th>Order</th>
                    <th>캠프</th>
                    <th>주/야</th>
                    <th>라우트</th>
                    <th>단가</th>
                    <th>정산일자</th>
                    <th>투입 기사</th>
                    <th>배송</th>
                    <th>반품</th>
                    <th>합계</th>
                    <th>금액</th>
                    <th>정산월</th>
                    <th>ID</th>
                    <th>PW</th>
                    <th>세금계산서</th>
                    <th>입금여부</th>
                    <th>비고</th>
                    <th>삭제</th>
                  </tr>
                </thead>
                <tbody id="editorBody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillDirty" class="pill warn">변경 0</span>
      <span id="statusText" class="statusText">dragon_car 기반 정산 페이지</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 최고관리자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INDEX_PATH = PATHS?.index || "/index.html";

      const ACCESS_TABLE = "user_access";
      const DATA_TABLE = "dragon_car";

      const DATA_COLUMNS = [
        "order_date",
        "vendor_id",
        "order_name",
        "camp",
        "wave",
        "route",
        "price",
        "settlement_day",
        "delivery_driver",
        "parcel",
        "return_count",
        "total_count",
        "amount",
        "settlement_month",
        "dragon_car_id",
        "dragon_car_pw",
        "tax_invoice",
        "payment_confirm",
        "dragon_car_note"
      ];

      const COLUMN_CONFIG = [
        { key: "pk_id", type: "readonly", className: "right code center" },
        { key: "order_date", type: "date", className: "center code" },
        { key: "vendor_id" },
        { key: "order_name" },
        { key: "camp", className: "center" },
        { key: "wave", type: "select", options: ["", "주간", "야간", "주/야"], className: "center" },
        { key: "route", type: "textarea" },
        { key: "price", className: "right code" },
        { key: "settlement_day", className: "center" },
        { key: "delivery_driver", className: "center" },
        { key: "parcel", className: "right code" },
        { key: "return_count", className: "right code" },
        { key: "total_count", type: "readonly", className: "right code center" },
        { key: "amount", className: "right code" },
        { key: "settlement_month", className: "center code" },
        { key: "dragon_car_id", className: "center code" },
        { key: "dragon_car_pw", className: "center code" },
        { key: "tax_invoice", type: "bool", className: "center" },
        { key: "payment_confirm", type: "bool", className: "center" },
        { key: "dragon_car_note", type: "textarea" }
      ];

      const $ = (sel) => document.querySelector(sel);

      const dom = {
        monthInput: $("#monthInput"),
        orderSearch: $("#orderSearch"),
        btnClearSearch: $("#btnClearSearch"),
        btnReload: $("#btnReload"),
        btnSaveAll: $("#btnSaveAll"),
        btnExportCsv: $("#btnExportCsv"),
        btnLogout: $("#btnLogout"),
        btnAddRow: $("#btnAddRow"),

        monthValue: $("#monthValue"),
        sideOrderCount: $("#sideOrderCount"),
        sideRowCount: $("#sideRowCount"),
        sideMonthAmount: $("#sideMonthAmount"),
        sideMonthUnpaid: $("#sideMonthUnpaid"),
        orderList: $("#orderList"),

        heroTitle: $("#heroTitle"),
        heroSub: $("#heroSub"),
        kpiAmount: $("#kpiAmount"),
        kpiPaidAmount: $("#kpiPaidAmount"),
        kpiUnpaidAmount: $("#kpiUnpaidAmount"),
        kpiParcel: $("#kpiParcel"),
        kpiReturn: $("#kpiReturn"),
        kpiRows: $("#kpiRows"),

        statementBody: $("#statementBody"),
        editorBody: $("#editorBody"),

        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillDirty: $("#pillDirty"),
        statusText: $("#statusText"),

        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout")
      };

      const state = {
        rows: [],
        selectedOrder: "",
        month: defaultMonth(),
        loading: false,
        viewerEmail: "",
        viewerUserId: "",
        accessRow: null,
        session: null,
        deletedIds: new Set(),
        tempSeq: 0
      };

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function defaultMonth() {
        const now = new Date();
        return now.getFullYear() + "-" + String(now.getMonth() + 1).padStart(2, "0");
      }

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function toNumber(v) {
        if (v == null || v === "") return 0;
        const n = Number(String(v).replace(/[^\d.-]/g, ""));
        return Number.isFinite(n) ? n : 0;
      }

      function formatNumber(v) {
        return new Intl.NumberFormat("ko-KR").format(toNumber(v));
      }

      function formatCurrency(v) {
        return "₩" + formatNumber(v);
      }

      function formatDate(v) {
        const s = normalizeText(v);
        if (!s) return "";
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
        if (/^\d{4}\.\d{1,2}\.\d{1,2}$/.test(s)) {
          const [y, m, d] = s.split(".");
          return `${y.padStart(4, "0")}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
        }
        const d = new Date(s);
        if (!Number.isNaN(d.getTime())) {
          const yy = d.getFullYear();
          const mm = String(d.getMonth() + 1).padStart(2, "0");
          const dd = String(d.getDate()).padStart(2, "0");
          return `${yy}-${mm}-${dd}`;
        }
        return s;
      }

      function normalizeBool(v) {
        if (v === true || v === "true" || v === "TRUE" || v === "t" || v === "1" || v === 1) return true;
        if (v === false || v === "false" || v === "FALSE" || v === "f" || v === "0" || v === 0) return false;
        return null;
      }

      function boolText(v, yesLabel, noLabel) {
        const b = normalizeBool(v);
        if (b === true) return yesLabel;
        if (b === false) return noLabel;
        return "-";
      }

      function valueForSave(key, value, row) {
        if (key === "order_date") return normalizeText(value) || null;
        if (key === "settlement_month") return normalizeText(value) || null;

        if (key === "price" || key === "parcel" || key === "return_count" || key === "total_count" || key === "amount") {
          const raw = normalizeText(value);
          if (!raw) {
            if (key === "total_count") return calcTotal(row);
            if (key === "amount") return effectiveAmount(row);
            return null;
          }
          return toNumber(raw);
        }

        if (key === "tax_invoice" || key === "payment_confirm") {
          const b = normalizeBool(value);
          if (b === null) return null;
          return b;
        }

        return normalizeText(value) || null;
      }

      function rowId(row) {
        return row.pk_id ?? row.__temp_id;
      }

      function calcTotal(row) {
        return toNumber(row.parcel) + toNumber(row.return_count);
      }

      function calcAmount(row) {
        return calcTotal(row) * toNumber(row.price);
      }

      function effectiveAmount(row) {
        const raw = normalizeText(row.amount);
        if (raw) return toNumber(raw);
        return calcAmount(row);
      }

      function isAmountMismatch(row) {
        const raw = normalizeText(row.amount);
        if (!raw) return false;
        return effectiveAmount(row) !== calcAmount(row);
      }

      function isPaid(row) {
        return normalizeBool(row.payment_confirm) === true;
      }

      function normalizeLoadedRow(row) {
        const out = { ...(row || {}) };
        for (const key of DATA_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }
        out.order_date = formatDate(out.order_date);
        out.__dirty = false;
        out.__dirtyFields = {};
        out.__isNew = false;
        return out;
      }

      function blankRow() {
        const row = {
          __temp_id: "new_" + (++state.tempSeq),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {}
        };

        for (const key of DATA_COLUMNS) row[key] = "";
        row.order_name = state.selectedOrder || "";
        row.settlement_month = state.month;
        row.wave = "주간";
        row.tax_invoice = "";
        row.payment_confirm = "";
        return row;
      }

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";
        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnSaveAll.disabled = !!on;
        dom.btnExportCsv.disabled = !!on;
        dom.btnAddRow.disabled = !!on;
        if (on) setStatus(text || "처리 중...", "warn");
      }

      function updatePills() {
        const visibleRows = getVisibleRows();
        const dirtyCount = state.rows.filter(row => row.__dirty).length + state.deletedIds.size;
        dom.pillRows.textContent = "행 " + visibleRows.length;
        dom.pillDirty.textContent = "변경 " + dirtyCount;
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "이 페이지는 최고관리자만 접근할 수 있습니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";
        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function requireAdmin() {
        if (!supabase || !supabase.auth) {
          alert("Supabase 설정을 확인하세요.");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();

          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          state.session = session;
          state.viewerEmail = normalizeText(session.user?.email || "");
          state.viewerUserId = normalizeText(session.user?.id || "");

          if (!state.viewerUserId) {
            showAccessDenied(state.viewerEmail, "로그인 사용자 ID를 확인할 수 없습니다.");
            return false;
          }

          const { data: accessRow, error } = await supabase
            .from(ACCESS_TABLE)
            .select("user_id, email, is_maroowell, is_admin")
            .eq("user_id", state.viewerUserId)
            .maybeSingle();

          if (error) {
            console.error(error);
            showAccessDenied(state.viewerEmail, "권한 테이블 조회 실패: " + error.message);
            return false;
          }

          state.accessRow = accessRow || null;

          if (!accessRow?.is_admin) {
            showAccessDenied(state.viewerEmail, "이 페이지는 최고관리자만 접근할 수 있습니다.");
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          console.error(e);
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      function getVisibleRows() {
        return state.rows.filter(row => !(row.pk_id && state.deletedIds.has(row.pk_id)));
      }

      function getMonthRows() {
        const target = normalizeText(state.month);
        return getVisibleRows().filter(row => normalizeText(row.settlement_month) === target);
      }

      function getOrderStats() {
        const rows = getMonthRows();
        const q = normalizeLower(dom.orderSearch.value);

        const map = new Map();

        for (const row of rows) {
          const orderName = normalizeText(row.order_name);
          if (!orderName) continue;

          const bag = [
            row.order_name,
            row.delivery_driver,
            row.route,
            row.dragon_car_note,
            row.vendor_id,
            row.camp
          ].map(normalizeLower).join(" | ");

          if (q && !bag.includes(q)) continue;

          if (!map.has(orderName)) {
            map.set(orderName, {
              orderName,
              rows: 0,
              amount: 0,
              paidAmount: 0,
              unpaidAmount: 0,
              parcel: 0,
              returnCount: 0
            });
          }

          const s = map.get(orderName);
          const amt = effectiveAmount(row);
          s.rows += 1;
          s.amount += amt;
          s.parcel += toNumber(row.parcel);
          s.returnCount += toNumber(row.return_count);
          if (isPaid(row)) s.paidAmount += amt;
          else s.unpaidAmount += amt;
        }

        return Array.from(map.values()).sort((a, b) => {
          if (b.amount !== a.amount) return b.amount - a.amount;
          return a.orderName.localeCompare(b.orderName, "ko");
        });
      }

      function ensureSelectedOrder(orderStats) {
        if (state.selectedOrder && orderStats.some(x => x.orderName === state.selectedOrder)) return;
        state.selectedOrder = orderStats[0]?.orderName || "";
      }

      function getSelectedRows() {
        const order = normalizeText(state.selectedOrder);
        return getMonthRows()
          .filter(row => normalizeText(row.order_name) === order)
          .sort((a, b) => {
            const da = formatDate(a.order_date);
            const db = formatDate(b.order_date);
            return da.localeCompare(db) || String(a.pk_id ?? "").localeCompare(String(b.pk_id ?? ""));
          });
      }

      function renderSidebar(orderStats) {
        dom.monthValue.textContent = state.month || "-";

        const monthRows = getMonthRows();
        const monthAmount = monthRows.reduce((acc, row) => acc + effectiveAmount(row), 0);
        const monthUnpaid = monthRows.filter(row => !isPaid(row)).reduce((acc, row) => acc + effectiveAmount(row), 0);

        dom.sideOrderCount.textContent = String(orderStats.length);
        dom.sideRowCount.textContent = String(monthRows.length);
        dom.sideMonthAmount.textContent = formatCurrency(monthAmount);
        dom.sideMonthUnpaid.textContent = formatCurrency(monthUnpaid);

        if (!orderStats.length) {
          dom.orderList.innerHTML = `<div class="empty">해당 월 데이터가 없습니다.</div>`;
          return;
        }

        dom.orderList.innerHTML = orderStats.map(item => {
          const active = item.orderName === state.selectedOrder ? "active" : "";
          return `
            <div class="orderItem ${active}" data-order-pick="${escapeHtml(item.orderName)}">
              <div class="orderName">${escapeHtml(item.orderName)}</div>
              <div class="orderMeta">
                <div>총금액 <b>${escapeHtml(formatCurrency(item.amount))}</b></div>
                <div>미입금 <b>${escapeHtml(formatCurrency(item.unpaidAmount))}</b></div>
                <div>배송 <b>${escapeHtml(formatNumber(item.parcel))}</b></div>
                <div>반품 <b>${escapeHtml(formatNumber(item.returnCount))}</b></div>
              </div>
            </div>
          `;
        }).join("");
      }

      function renderSummary() {
        if (!state.selectedOrder) {
          dom.heroTitle.textContent = "Order를 선택해줘";
          dom.heroSub.textContent = "왼쪽에서 Order를 고르면 정산 요약과 편집 테이블이 같이 뜬다.";
          dom.kpiAmount.textContent = formatCurrency(0);
          dom.kpiPaidAmount.textContent = formatCurrency(0);
          dom.kpiUnpaidAmount.textContent = formatCurrency(0);
          dom.kpiParcel.textContent = "0";
          dom.kpiReturn.textContent = "0";
          dom.kpiRows.textContent = "0";
          return;
        }

        const rows = getSelectedRows();
        const totalAmount = rows.reduce((acc, row) => acc + effectiveAmount(row), 0);
        const paidAmount = rows.filter(isPaid).reduce((acc, row) => acc + effectiveAmount(row), 0);
        const unpaidAmount = rows.filter(row => !isPaid(row)).reduce((acc, row) => acc + effectiveAmount(row), 0);
        const parcel = rows.reduce((acc, row) => acc + toNumber(row.parcel), 0);
        const returnCount = rows.reduce((acc, row) => acc + toNumber(row.return_count), 0);

        dom.heroTitle.textContent = `${state.selectedOrder} · ${state.month}`;
        dom.heroSub.textContent = `행 ${rows.length}건 · 배송 ${formatNumber(parcel)} · 반품 ${formatNumber(returnCount)}`;
        dom.kpiAmount.textContent = formatCurrency(totalAmount);
        dom.kpiPaidAmount.textContent = formatCurrency(paidAmount);
        dom.kpiUnpaidAmount.textContent = formatCurrency(unpaidAmount);
        dom.kpiParcel.textContent = formatNumber(parcel);
        dom.kpiReturn.textContent = formatNumber(returnCount);
        dom.kpiRows.textContent = String(rows.length);
      }

      function renderStatement() {
        const rows = getSelectedRows();

        if (!rows.length) {
          dom.statementBody.innerHTML = `<tr><td colspan="13" class="empty">선택된 Order 데이터가 없습니다.</td></tr>`;
          return;
        }

        dom.statementBody.innerHTML = rows.map(row => {
          const paidCls = isPaid(row) ? "paidRow" : "";
          const warnAmountCls = isAmountMismatch(row) ? "warn" : "";
          return `
            <tr class="${paidCls}">
              <td><div class="cellView center code">${escapeHtml(formatDate(row.order_date))}</div></td>
              <td><div class="cellView left">${escapeHtml(normalizeText(row.vendor_id))}</div></td>
              <td><div class="cellView center">${escapeHtml(normalizeText(row.camp))}</div></td>
              <td><div class="cellView center">${escapeHtml(normalizeText(row.wave))}</div></td>
              <td><div class="cellView left">${escapeHtml(normalizeText(row.route))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatCurrency(row.price))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatNumber(row.parcel))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatNumber(row.return_count))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatNumber(calcTotal(row)))}</div></td>
              <td class="${warnAmountCls}"><div class="cellView right code">${escapeHtml(formatCurrency(effectiveAmount(row)))}</div></td>
              <td><div class="cellView center">${escapeHtml(normalizeText(row.settlement_day))}</div></td>
              <td><div class="cellView center">${escapeHtml(boolText(row.payment_confirm, "입금", "미입금"))}</div></td>
              <td><div class="cellView left">${escapeHtml(normalizeText(row.dragon_car_note))}</div></td>
            </tr>
          `;
        }).join("");
      }

      function buildBoolSelect(current, dataAttrs) {
        const value = normalizeBool(current);
        const currentVal = value === true ? "true" : value === false ? "false" : "";
        return `
          <select class="cellSelect center" ${dataAttrs}>
            <option value="" ${currentVal === "" ? "selected" : ""}>-</option>
            <option value="true" ${currentVal === "true" ? "selected" : ""}>예</option>
            <option value="false" ${currentVal === "false" ? "selected" : ""}>아니오</option>
          </select>
        `;
      }

      function buildCell(row, col) {
        const rid = rowId(row);
        const dirty = row.__dirtyFields?.[col.key] ? "dirty" : "";
        const warn = ((col.key === "amount" && isAmountMismatch(row)) || (col.key === "total_count" && isAmountMismatch(row))) ? "warn" : "";
        const cls = [dirty, warn].filter(Boolean).join(" ");

        if (col.type === "readonly") {
          const val = col.key === "pk_id" ? (row.pk_id ?? "NEW") : calcTotal(row);
          return `<td class="${cls}"><div class="cellView ${col.className || ""}">${escapeHtml(String(val))}</div></td>`;
        }

        if (col.type === "bool") {
          return `<td class="${cls}">${buildBoolSelect(row[col.key], `data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}"` )}</td>`;
        }

        if (col.type === "select") {
          const current = normalizeText(row[col.key]);
          const options = (col.options || []).map(opt => {
            const selected = String(opt) === String(current) ? "selected" : "";
            const label = opt || "-";
            return `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(label)}</option>`;
          }).join("");

          return `
            <td class="${cls}">
              <select class="cellSelect ${col.className || ""}" data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}">
                ${options}
              </select>
            </td>
          `;
        }

        if (col.type === "textarea") {
          return `
            <td class="${cls}">
              <textarea class="cellTextarea" data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}">${escapeHtml(normalizeText(row[col.key]))}</textarea>
            </td>
          `;
        }

        const inputType = col.type === "date" ? "date" : "text";
        return `
          <td class="${cls}">
            <input
              class="cellInput ${col.className || ""}"
              type="${inputType}"
              value="${escapeHtml(col.type === "date" ? formatDate(row[col.key]) : normalizeText(row[col.key]))}"
              data-row-id="${escapeHtml(rid)}"
              data-key="${escapeHtml(col.key)}"
              autocomplete="off"
            />
          </td>
        `;
      }

      function renderEditor() {
        const rows = getSelectedRows();

        if (!rows.length) {
          dom.editorBody.innerHTML = `<tr><td colspan="21" class="empty">선택된 Order 편집 대상이 없습니다.</td></tr>`;
          return;
        }

        dom.editorBody.innerHTML = rows.map(row => {
          const paidRow = isPaid(row) ? "paidRow" : "";
          const cells = COLUMN_CONFIG.map(col => buildCell(row, col)).join("");
          return `
            <tr class="${paidRow}" data-row="${escapeHtml(rowId(row))}">
              ${cells}
              <td class="${row.__dirty ? "dirty" : ""}">
                <div class="rowActions">
                  <button class="miniBtn del" type="button" data-delete-row="${escapeHtml(rowId(row))}">✕</button>
                </div>
              </td>
            </tr>
          `;
        }).join("");
      }

      function renderAll() {
        const orderStats = getOrderStats();
        ensureSelectedOrder(orderStats);
        renderSidebar(orderStats);
        renderSummary();
        renderStatement();
        renderEditor();
        updatePills();

        if (!state.rows.length) setStatus("데이터가 없습니다.", "warn");
        else setStatus(`dragon_car ${getMonthRows().length}건 로드 완료`, "ok");
      }

      function findRowById(id) {
        return state.rows.find(row => String(rowId(row)) === String(id)) || null;
      }

      function markRowDirty(row, key, value) {
        if (!row) return;
        row[key] = value;
        row.__dirty = true;
        row.__dirtyFields = row.__dirtyFields || {};
        row.__dirtyFields[key] = true;

        if (key === "parcel" || key === "return_count") {
          row.total_count = String(calcTotal(row));
          row.__dirtyFields.total_count = true;
        }

        if (key === "settlement_month" && normalizeText(row.settlement_month) !== normalizeText(state.month)) {
          // 월을 다른 값으로 바꾸면 현재 월 목록에서 사라질 수 있음
        }
      }

      async function fetchRows() {
        try {
          setLoading(true, "데이터 불러오는 중...");
          state.deletedIds.clear();

          const { data, error } = await supabase
            .from(DATA_TABLE)
            .select("*")
            .eq("settlement_month", normalizeText(state.month))
            .order("order_name", { ascending: true })
            .order("order_date", { ascending: true })
            .order("pk_id", { ascending: true });

          if (error) throw error;

          state.rows = Array.isArray(data) ? data.map(normalizeLoadedRow) : [];
          renderAll();
        } catch (e) {
          console.error(e);
          state.rows = [];
          renderAll();
          setStatus("불러오기 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      async function saveAll() {
        try {
          setLoading(true, "저장 중...");

          const deleteIds = Array.from(state.deletedIds).filter(Boolean);
          const dirtyRows = state.rows.filter(row => row.__dirty && !(row.pk_id && state.deletedIds.has(row.pk_id)));
          const updateRows = dirtyRows.filter(row => !row.__isNew && row.pk_id != null);
          const insertRows = dirtyRows.filter(row => row.__isNew);

          if (!deleteIds.length && !updateRows.length && !insertRows.length) {
            setStatus("저장할 변경사항이 없습니다.", "warn");
            return;
          }

          if (deleteIds.length) {
            const { error } = await supabase
              .from(DATA_TABLE)
              .delete()
              .in("pk_id", deleteIds);
            if (error) throw error;
          }

          if (updateRows.length) {
            const payload = updateRows.map(row => {
              const obj = { pk_id: row.pk_id };
              for (const key of DATA_COLUMNS) {
                obj[key] = valueForSave(key, row[key], row);
              }
              return obj;
            });

            const { error } = await supabase
              .from(DATA_TABLE)
              .upsert(payload, { onConflict: "pk_id" });
            if (error) throw error;
          }

          if (insertRows.length) {
            const payload = insertRows.map(row => {
              const obj = {};
              for (const key of DATA_COLUMNS) {
                obj[key] = valueForSave(key, row[key], row);
              }
              return obj;
            });

            const { error } = await supabase
              .from(DATA_TABLE)
              .insert(payload);
            if (error) throw error;
          }

          await fetchRows();
          setStatus("저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("저장 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      function deleteRow(rowIdValue) {
        const row = findRowById(rowIdValue);
        if (!row) return;

        const label = normalizeText(row.order_name) || String(rowIdValue);
        if (!confirm(`삭제 대상으로 표시할까?\n저장해야 실제 반영됨.\n\n대상: ${label}`)) return;

        if (row.__isNew) {
          state.rows = state.rows.filter(r => String(rowId(r)) !== String(rowIdValue));
        } else if (row.pk_id) {
          state.deletedIds.add(row.pk_id);
          row.__dirty = true;
        }

        renderAll();
        setStatus("삭제 대상으로 표시했습니다. 저장하면 반영됩니다.", "warn");
      }

      function addRow() {
        state.rows.push(blankRow());
        renderAll();
        setStatus("새 행이 추가되었습니다.", "ok");
      }

      function exportCsv() {
        const rows = getSelectedRows();
        if (!rows.length) {
          alert("내보낼 데이터가 없습니다.");
          return;
        }

        const headers = ["pk_id", ...DATA_COLUMNS, "calc_total", "calc_amount", "effective_amount"];
        const lines = [
          headers.join(","),
          ...rows.map(row => {
            const values = [
              row.pk_id ?? "",
              ...DATA_COLUMNS.map(key => {
                if (key === "tax_invoice" || key === "payment_confirm") {
                  const b = normalizeBool(row[key]);
                  return b === null ? "" : String(b);
                }
                if (key === "order_date") return formatDate(row[key]);
                return normalizeText(row[key]);
              }),
              calcTotal(row),
              calcAmount(row),
              effectiveAmount(row)
            ];
            return values.map(v => `"${String(v ?? "").replaceAll('"', '""')}"`).join(",");
          })
        ];

        const csv = "\uFEFF" + lines.join("\n");
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = `dragon_car_pay_${state.month}_${state.selectedOrder || "all"}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", () => {
          state.month = normalizeText(dom.monthInput.value) || defaultMonth();
          dom.monthInput.value = state.month;
          fetchRows();
        });

        dom.monthInput.addEventListener("keydown", (e) => {
          if (e.key !== "Enter") return;
          e.preventDefault();
          dom.btnReload.click();
        });

        dom.orderSearch.addEventListener("input", renderAll);

        dom.btnClearSearch.addEventListener("click", () => {
          dom.orderSearch.value = "";
          renderAll();
        });

        dom.btnAddRow.addEventListener("click", addRow);
        dom.btnSaveAll.addEventListener("click", saveAll);
        dom.btnExportCsv.addEventListener("click", exportCsv);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.btnDeniedHome.addEventListener("click", () => location.replace(INDEX_PATH));
        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        document.body.addEventListener("click", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const orderPick = target.closest("[data-order-pick]");
          if (orderPick) {
            state.selectedOrder = orderPick.getAttribute("data-order-pick") || "";
            renderAll();
            return;
          }

          const deleteBtn = target.closest("[data-delete-row]");
          if (deleteBtn) {
            deleteRow(deleteBtn.getAttribute("data-delete-row"));
          }
        });

        document.body.addEventListener("input", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!rowIdValue || !key) return;

          const row = findRowById(rowIdValue);
          if (!row) return;

          markRowDirty(row, key, target.value);
          renderAll();
        });

        document.body.addEventListener("change", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!rowIdValue || !key) return;

          const row = findRowById(rowIdValue);
          if (!row) return;

          markRowDirty(row, key, target.value);
          renderAll();
        });
      }

      bindEvents();

      dom.monthInput.value = state.month;

      if (!(await requireAdmin())) return;
      await fetchRows();
    })();
  </script>
</body>
</html>
