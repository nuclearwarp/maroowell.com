      async function parseWorkbook(file) {
        setBusy(true);
        setStatus("원본 정산서 파싱 중...", "warn");

        try {
          if (!state.masterRows.length) {
            await loadMasterRows(false);
          }

          const buffer = await file.arrayBuffer();
          const workbook = XLSX.read(buffer, { type: "array" });

          const rawSheet = workbook.Sheets["정산Raw"];
          const lossSheet = workbook.Sheets["분실파손List"];

          if (!rawSheet || !lossSheet) {
            throw new Error("정산Raw 또는 분실파손List 시트를 찾지 못했습니다.");
          }

          state.workbookName = file.name;
          state.rawRows = XLSX.utils.sheet_to_json(rawSheet, { defval: "" });
          state.lossRows = XLSX.utils.sheet_to_json(lossSheet, { defval: "" });

          state.rawCols = buildColumnMap(state.rawRows[0] || {}, getRawColDefs());
          state.lossCols = buildColumnMap(state.lossRows[0] || {}, getLossColDefs());

          if (
            !state.rawCols.id ||
            !state.rawCols.delivery ||
            !state.rawCols.return ||
            !state.rawCols.amount ||
            !state.lossCols.id ||
            !state.lossCols.amount
          ) {
            console.log("rawCols", state.rawCols);
            console.log("lossCols", state.lossCols);
            throw new Error("원본 시트의 필수 컬럼(ID/배송건수/반품/총금액/차감금액)을 찾지 못했습니다.");
          }

          state.idSummaries = buildIdSummaries();
          state.autoMatchedById = buildAutoMatches();
          state.aliasAssignments = {};

          recomputeDriverAggs();
          renderAll();

          setStatus(`원본 로드 완료: ${file.name}`, "ok");
        } catch (err) {
          console.error(err);
          setStatus(`파싱 실패: ${err.message || err}`, "err");
        } finally {
          setBusy(false);
          renderAll();
        }
      }

      async function refreshMaster(force = true) {
        setBusy(true);
        setStatus("기사정보 불러오는 중...", "warn");

        try {
          await loadMasterRows(force);

          if (state.idSummaries.length) {
            state.autoMatchedById = buildAutoMatches();

            const nextAlias = {};
            for (const [id, pk] of Object.entries(state.aliasAssignments)) {
              if (state.masterByPk.has(String(pk))) {
                nextAlias[id] = String(pk);
              }
            }
            state.aliasAssignments = nextAlias;
            recomputeDriverAggs();
          }

          renderAll();
          setStatus(`기사정보 ${state.masterRows.length}건 로드 완료`, "ok");
        } catch (err) {
          console.error(err);
          setStatus(`기사정보 로드 실패: ${err.message || err}`, "err");
        } finally {
          setBusy(false);
          renderAll();
        }
      }

      function setCurrentDriver(pk) {
        state.currentDriverPk = String(pk || "");
        renderDriverSelect();
        renderMainList();
        renderPreviewHeader();
        renderPreviewBody();
      }

      function handleUnmatchedAssign(id, pk) {
        const key = String(id || "");
        const value = String(pk || "");
        if (!key) return;

        if (!value) {
          delete state.aliasAssignments[key];
        } else {
          state.aliasAssignments[key] = value;
        }

        recomputeDriverAggs();
        renderAll();

        const assignedAgg = state.displayAggs.find((agg) => String(agg.pk_id) === value);
        if (assignedAgg) {
          setCurrentDriver(assignedAgg.pk_id);
        }

        setStatus(value ? `미매칭 ID ${key} 귀속 완료` : `미매칭 ID ${key} 귀속 해제`, "ok");
      }

      async function saveCurrentSheetAsPng() {
        const agg = getCurrentAgg();
        if (!agg) {
          alert("선택된 기사가 없습니다.");
          return;
        }

        try {
          setStatus("PNG 생성 중...", "warn");

          const canvas = await html2canvas(dom.captureTarget, {
            backgroundColor: "#ffffff",
            scale: 2,
            useCORS: true
          });

          const a = document.createElement("a");
          const title = dom.sheetTitle.textContent || "정산서";
          const month = dom.selectMonth.value || "month";
          const driver = agg.label || "driver";

          a.href = canvas.toDataURL("image/png");
          a.download = `${month}_${driver}_${title}.png`
            .replace(/\s+/g, "_")
            .replace(/[\\/:*?"<>|]+/g, "-");

          document.body.appendChild(a);
          a.click();
          a.remove();

          setStatus("PNG 저장 완료", "ok");
        } catch (err) {
          console.error(err);
          setStatus(`PNG 저장 실패: ${err.message || err}`, "err");
        }
      }

      function setActiveTab(tab) {
        state.currentTab = tab;
        dom.tabButtons.forEach((btn) => {
          btn.classList.toggle("active", btn.dataset.tab === tab);
        });
        renderPreviewHeader();
        renderPreviewBody();
      }

      function initDefaultMonth() {
        const now = new Date();
        const yyyy = now.getFullYear();
        const mm = String(now.getMonth() + 1).padStart(2, "0");
        dom.selectMonth.value = `${yyyy}-${mm}`;
      }

      function bindDragScroll(el) {
        let isDown = false;
        let startX = 0;
        let startY = 0;
        let scrollLeft = 0;
        let scrollTop = 0;
        let moved = false;

        el.addEventListener("mousedown", (e) => {
          const target = e.target;
          if (target.closest("select, input, button, option, textarea, a, label")) return;

          isDown = true;
          moved = false;
          startX = e.pageX;
          startY = e.pageY;
          scrollLeft = el.scrollLeft;
          scrollTop = el.scrollTop;
          el.classList.add("dragging");
        });

        window.addEventListener("mousemove", (e) => {
          if (!isDown) return;

          const dx = e.pageX - startX;
          const dy = e.pageY - startY;

          if (Math.abs(dx) > 3 || Math.abs(dy) > 3) moved = true;

          el.scrollLeft = scrollLeft - dx;
          el.scrollTop = scrollTop - dy;

          if (moved) e.preventDefault();
        }, { passive: false });

        window.addEventListener("mouseup", () => {
          isDown = false;
          el.classList.remove("dragging");
        });

        el.addEventListener("mouseleave", () => {
          isDown = false;
          el.classList.remove("dragging");
        });

        el.addEventListener("dragstart", (e) => e.preventDefault());
      }

      function bindEvents() {
        dom.fileWorkbook.addEventListener("change", async () => {
          const file = dom.fileWorkbook.files && dom.fileWorkbook.files[0];
          if (!file) return;
          await parseWorkbook(file);
        });

        dom.btnRefreshMaster.addEventListener("click", async () => {
          await refreshMaster(true);
        });

        dom.selectDriver.addEventListener("change", () => {
          setCurrentDriver(dom.selectDriver.value || "");
        });

        dom.selectMonth.addEventListener("change", renderPreviewHeader);

        dom.btnSavePng.addEventListener("click", saveCurrentSheetAsPng);

        dom.tabButtons.forEach((btn) => {
          btn.addEventListener("click", () => setActiveTab(btn.dataset.tab));
        });

        dom.unmatchedBody.addEventListener("change", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLSelectElement)) return;
          if (!target.classList.contains("unmatchedSelect")) return;

          const id = target.getAttribute("data-unmatched-id") || "";
          handleUnmatchedAssign(id, target.value || "");
        });

        dom.mainListBody.addEventListener("click", (e) => {
          const tr = e.target.closest("[data-driver-pk]");
          if (!tr) return;
          setCurrentDriver(tr.getAttribute("data-driver-pk") || "");
        });

        dom.scrollAreas.forEach(bindDragScroll);

        dom.btnDeniedHome?.addEventListener("click", () => {
          location.replace(INDEX_PATH);
        });

        dom.btnDeniedLogout?.addEventListener("click", signOutAndMove);
      }

      async function init() {
        if (!(await requireAdmin())) return;

        initDefaultMonth();
        bindEvents();

        try {
          await refreshMaster(false);
        } catch {}

        renderAll();
        document.documentElement.style.visibility = "visible";
      }

      init();
    })();
  </script>

  <script>
    window.MW_BOARD_MENU_MODE = "admin";
  </script>
  <script src="/board-menu.js"></script>
</body>
</html>
