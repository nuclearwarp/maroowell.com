      function drawGraph(kind){const data=graphData(kind);state.currentGraph=kind;els.graphTitle.textContent=data.title;const canvas=els.graphCanvas;const rows=data.rows;const width=Math.max(900,rows.length*68+160),height=560;canvas.width=width*2;canvas.height=height*2;canvas.style.width=width+"px";canvas.style.height=height+"px";const ctx=canvas.getContext("2d");ctx.scale(2,2);ctx.fillStyle="#fff";ctx.fillRect(0,0,width,height);ctx.fillStyle="#111827";ctx.font="800 22px system-ui,-apple-system,Segoe UI,sans-serif";ctx.fillText(data.title,24,36);if(!rows.length){ctx.font="800 16px system-ui";ctx.fillText("조회된 그래프 데이터가 없습니다.",24,90);return}const max=Math.max(...rows.map(r=>r.value),1);const chartX=70,chartY=70,chartW=width-100,chartH=360;ctx.strokeStyle="#cbd5e1";ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(chartX,chartY);ctx.lineTo(chartX,chartY+chartH);ctx.lineTo(chartX+chartW,chartY+chartH);ctx.stroke();ctx.fillStyle="#64748b";ctx.font="700 11px system-ui";for(let i=0;i<=4;i++){const y=chartY+chartH-(chartH*i/4);const v=max*i/4;ctx.fillText(Math.round(v).toLocaleString("ko-KR"),8,y+4);ctx.strokeStyle="#e2e8f0";ctx.beginPath();ctx.moveTo(chartX,y);ctx.lineTo(chartX+chartW,y);ctx.stroke()}const gap=8,barW=Math.max(20,(chartW-(rows.length+1)*gap)/rows.length);rows.forEach((r,i)=>{const x=chartX+gap+i*(barW+gap);const h=chartH*(r.value/max);const y=chartY+chartH-h;ctx.fillStyle="#2563eb";ctx.fillRect(x,y,barW,h);ctx.fillStyle="#111827";ctx.font="800 11px system-ui";ctx.textAlign="center";ctx.fillText(Math.round(r.value).toLocaleString("ko-KR"),x+barW/2,Math.max(y-6,chartY+12));ctx.save();ctx.translate(x+barW/2,chartY+chartH+14);ctx.rotate(-Math.PI/4);ctx.textAlign="right";ctx.font="700 10px system-ui";ctx.fillText(r.label,0,0);ctx.restore()});ctx.textAlign="left"}
      function openGraph(kind){drawGraph(kind);els.graphModal.classList.add("show")}function closeGraph(){els.graphModal.classList.remove("show")}async function copyGraph(){const canvas=els.graphCanvas;if(!canvas.width){alert("복사할 그래프가 없습니다.");return}canvas.toBlob(async blob=>{if(!blob){alert("그래프 이미지 생성 실패");return}if(navigator.clipboard&&window.ClipboardItem){await navigator.clipboard.write([new ClipboardItem({"image/png":blob})]);alert("그래프 이미지를 클립보드에 복사했습니다.");return}const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="account_graph.png";a.click();URL.revokeObjectURL(a.href)},"image/png")}
      function bind(){els.btnLogout.addEventListener("click",logout);els.deniedLogoutBtn.addEventListener("click",logout);els.deniedHomeBtn.addEventListener("click",()=>{location.href=HOME_PATH});els.btnLoad.addEventListener("click",loadRows);els.btnExcel.addEventListener("click",exportExcel);els.btnReset.addEventListener("click",resetTables);els.btnCloseGraph.addEventListener("click",closeGraph);els.graphModal.addEventListener("click",e=>{if(e.target===els.graphModal)closeGraph()});els.btnCopyGraph.addEventListener("click",copyGraph);document.querySelectorAll("[data-copy-table]").forEach(btn=>btn.addEventListener("click",()=>copyTable(btn.dataset.copyTable)));document.querySelectorAll("[data-graph]").forEach(btn=>btn.addEventListener("click",()=>openGraph(btn.dataset.graph)));const upperRouteInput=el=>{const s=el.selectionStart,e=el.selectionEnd;const v=el.value.toUpperCase();if(el.value!==v){el.value=v;try{el.setSelectionRange(s,e)}catch{}}};[els.currentRouteInput,els.pastRoutesInput].forEach(el=>el.addEventListener("input",()=>upperRouteInput(el)));[els.campSelect,els.waveSelect,els.currentCampInput,els.currentRouteInput,els.pastRoutesInput,els.searchInput].forEach(el=>{el.addEventListener("input",()=>{if(state.rawRows.length)buildStats()});el.addEventListener("change",()=>{if(state.rawRows.length)buildStats()})});[els.yearSelect,els.startMonthSelect,els.endMonthSelect].forEach(el=>el.addEventListener("change",resetTables));els.searchInput.addEventListener("keydown",e=>{if(e.key==="Enter"&&state.rawRows.length)buildStats()})}
      async function boot(){initPeriodSelects();bind();renderAll();try{await checkAccess()}catch(err){console.error(err);showAccessDenied(err.message||String(err))}}
      boot();
    })();
  </script>
