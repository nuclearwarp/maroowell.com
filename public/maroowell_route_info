  function routeCodeForPoint(row) {
    return normalizeRoute(row?.route_code || row?.route_norm || row?.route);
  }

  function polygonsForSelectedRoute() {
    if (!selectedRoute) return [];
    const code = routeCodeOf(selectedRoute);

    return polygonRows.filter(row => {
      return String(row.route_info_id || "") === String(selectedRoute.id || "") ||
        polygonCodeOf(row) === code;
    });
  }

  function pointsForSelectedRoute() {
    if (!selectedRoute) return [];
    const code = routeCodeOf(selectedRoute);

    return pointRows.filter(row => {
      return String(row.route_info_id || "") === String(selectedRoute.id || "") ||
        routeCodeForPoint(row) === code;
    });
  }

  function renderPointList() {
    const list = $("pointList");
    const rows = selectedRoute ? pointsForSelectedRoute() : pointRows;

    if (!rows.length) {
      list.innerHTML = `<div class="detailEmpty">배송 포인트 없음</div>`;
