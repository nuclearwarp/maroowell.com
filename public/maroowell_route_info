    if (!isSuperAdmin) {
      setStatus("최고관리자만 라우트 대강 등록을 사용할 수 있습니다.", "bad");
      return;
    }

    if (!bulkRows.length) addBulkRows(3);
    $("bulkModal").classList.add("open");
  }

  function hideBulkModal() {
    syncBulkFromDom();
    $("bulkModal").classList.remove("open");
  }

  function togglePane(side) {
    const app = $("app");

    if (side === "left") {
      app.classList.toggle("left-collapsed");
      $("toggleLeftBtn").textContent = app.classList.contains("left-collapsed") ? "좌측 열기" : "좌측 접기";
    }

    if (side === "right") {
      app.classList.toggle("right-collapsed");
      $("toggleRightBtn").textContent = app.classList.contains("right-collapsed") ? "우측 열기" : "우측 접기";
    }

    setTimeout(() => {
      try { map?.relayout(); } catch {}
    }, 260);
  }

  function handleError(e) {
    console.error(e);
    setStatus(e.message || String(e), "bad");
  }

  function run(fn) {
    fn().catch(handleError);
  }

  $("loadBtn").addEventListener("click", () => run(loadData));
  $("clearBtn").addEventListener("click", () => clearSearchResults());
  $("routeSearchInput").addEventListener("keydown", e => {
    if (e.key === "Enter") run(loadData);
  });
  $("campInput").addEventListener("keydown", e => {
    if (e.key === "Enter") run(loadData);
  });

  $("routeList").addEventListener("click", e => {
    const card = e.target.closest("[data-route-id]");
    if (!card) return;
    selectRouteById(card.dataset.routeId);
  });

  $("pointList").addEventListener("click", e => {
    const card = e.target.closest("[data-point-id]");
    if (!card) return;
    selectPointById(card.dataset.pointId);
  });

  $("toggleLeftBtn").addEventListener("click", () => togglePane("left"));
  $("toggleRightBtn").addEventListener("click", () => togglePane("right"));
  $("openLeftBtn").addEventListener("click", () => togglePane("left"));
  $("openRightBtn").addEventListener("click", () => togglePane("right"));
  $("toggleMapTypeBtn").addEventListener("click", setMapType);
  $("toggleRoadviewBtn").addEventListener("click", toggleRoadviewOverlay);
  $("fitAllBtn").addEventListener("click", fitAll);
  $("resetMapBtn").addEventListener("click", resetMapView);
  $("startDrawBtn").addEventListener("click", startDrawMode);
  $("finishDrawBtn").addEventListener("click", () => run(finishDrawMode));
  $("cancelDrawBtn").addEventListener("click", cancelDrawMode);
  $("pointPickModeBtn").addEventListener("click", toggleAddPointMode);
  $("addressSearchBtn").addEventListener("click", searchAddressOrPlace);

  $("saveRouteBtn").addEventListener("click", () => run(saveRoute));
  $("deleteRouteBtn").addEventListener("click", () => run(deleteRoute));
  $("savePolygonBtn").addEventListener("click", () => run(saveCurrentPolygon));
  $("deletePolygonBtn").addEventListener("click", () => run(deleteSelectedPolygon));
  $("savePointBtn").addEventListener("click", () => run(savePoint));
  $("deletePointBtn").addEventListener("click", () => run(deleteSelectedPoint));
  $("newPointBtn").addEventListener("click", resetPointForm);
  $("clearPointLocationBtn").addEventListener("click", clearPointLocation);

  $("uploadAttachmentBtn").addEventListener("click", () => run(uploadAttachments));
  $("clearAttachmentBtn").addEventListener("click", clearAttachmentsState);

  $("attachmentList").addEventListener("click", e => {
    const img = e.target.closest("[data-preview-url]");
    if (img) {
      openImagePreview(img.dataset.previewUrl, img.dataset.caption || "");
      return;
    }

    const previewBtn = e.target.closest("[data-attachment-preview]");
    if (previewBtn) {
      const id = previewBtn.dataset.attachmentPreview;
      const row = attachmentRows.find(item => String(item.id) === String(id));
      const url = attachmentSignedUrls.get(row?.id) || row?.signed_url || row?.public_url || "";
      if (url) openImagePreview(url, row?.caption || row?.file_name || "");
      return;
    }

    const deleteBtn = e.target.closest("[data-attachment-delete]");
    if (deleteBtn) {
      run(() => deleteAttachment(deleteBtn.dataset.attachmentDelete));
    }
  });

  $("imageModalCloseBtn").addEventListener("click", () => {
    $("imageModal").classList.remove("open");
    $("imagePreviewImg").src = "";
  });

  $("bulkOpenBtn").addEventListener("click", showBulkModal);
  $("bulkCloseBtn").addEventListener("click", hideBulkModal);
  $("bulkAddRowBtn").addEventListener("click", () => addBulkRows(1));
  $("bulkAddFiveBtn").addEventListener("click", () => addBulkRows(5));
  $("bulkSaveBtn").addEventListener("click", () => run(saveBulkRows));
  $("bulkClearBtn").addEventListener("click", clearBulkRows);
  $("bulkRows").addEventListener("click", e => {
    const btn = e.target.closest("[data-bulk-delete]");
    if (!btn) return;
    syncBulkFromDom();
    bulkRows.splice(Number(btn.dataset.bulkDelete), 1);
    renderBulkRows();
  });

  document.addEventListener("keydown", e => {
    if (e.key !== "Escape") return;

    if ($("imageModal")?.classList.contains("open")) {
      $("imageModal").classList.remove("open");
      $("imagePreviewImg").src = "";
      return;
    }

    if ($("bulkModal")?.classList.contains("open")) {
      hideBulkModal();
      return;
    }

    if (drawMode) {
      cancelDrawMode();
      return;
    }

    setPointPickMode(false, false);
    clearSelection(true);
    setStatus("선택을 해제했습니다.", "ok");
    setPointStatus("");
  });

  $("deniedHomeBtn").addEventListener("click", () => {
    location.href = cfg.PATHS?.index || "/zipcode_search";
  });

  $("deniedLogoutBtn").addEventListener("click", () => {
    if (supabaseClient) {
      supabaseClient.auth.signOut().finally(() => {
        location.href = cfg.PATHS?.login || "/";
      });
    } else {
      location.href = cfg.PATHS?.login || "/";
    }
  });

  try {
    initSupabase();

    run(async () => {
      const ok = await checkAccess();
      if (!ok) return;

      await initMap();
      setTimeout(() => {
        try { map?.relayout(); } catch {}
      }, 180);
      renderCounts();
      renderRouteList();
      renderPointList();

      setStatus("Camp와 Route를 입력해 조회하세요.", "warn");
    });
  } catch (e) {
    document.documentElement.style.visibility = "visible";
    handleError(e);
  }
})();
</script>

<script src="/board-menu.js"></script>
</body>
</html>
