<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>마루웰 라우트정보</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://dapi.kakao.com/v2/maps/sdk.js?appkey=add4ce93b38c0ff9d9b9053728e067b3&autoload=false&libraries=services"></script>

  <style>
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --card:#ffffff;
      --soft:#f8fafc;
      --line:#d8e0ee;
      --line2:#cbd5e1;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --blue2:#60a5fa;
      --green:#16a34a;
      --red:#dc2626;
      --yellow:#a16207;
      --purple:#7c3aed;
      --shadow:0 12px 30px rgba(15,23,42,.08);
      --font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,body{
      height:100%;
      margin:0;
      overflow:hidden;
      background:
        radial-gradient(circle at 18% 0%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 86% 0%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,#f6f8fc 100%);
      color:var(--txt);
      font-family:var(--font);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
      font-weight:400;
    }

    body,
    input,
    select,
    textarea,
    button,
    table,
    th,
    td,
    .titleText b,
    .titleText small,
    .cardTitle,
    .routeCode,
    .routeMeta,
    .routeDesc,
    .miniBadge,
    .status,
    .pill,
    .detailTitle,
    .sectionTitle{
      font-weight:400 !important;
      letter-spacing:-0.015em;
      text-shadow:none;
      -webkit-text-stroke:0 transparent;
    }

    b,strong{font-weight:520}

    .app{
      height:100%;
      display:grid;
      grid-template-columns:390px minmax(480px,1fr) 420px;
      background:transparent;
      transition:grid-template-columns .22s ease;
    }

    .app.left-collapsed{grid-template-columns:0 minmax(480px,1fr) 420px}
    .app.right-collapsed{grid-template-columns:390px minmax(480px,1fr) 0}
    .app.left-collapsed.right-collapsed{grid-template-columns:0 minmax(480px,1fr) 0}

    .left,.right{
      min-height:0;
      overflow:auto;
      padding:14px;
      background:rgba(255,255,255,.88);
      border-color:var(--line);
      backdrop-filter:blur(10px);
    }

    .left{border-right:1px solid var(--line)}
    .right{border-left:1px solid var(--line)}

    .app.left-collapsed .left,
    .app.right-collapsed .right{
      overflow:hidden;
      padding:0;
      border:0;
      visibility:hidden;
    }

    .mapPane{
      position:relative;
      min-width:0;
      min-height:0;
      background:#eef4fb;
    }

    #map{
      position:absolute;
      inset:0;
      z-index:1;
    }

    .title{
      display:flex;
      align-items:center;
      gap:10px;
      margin:0 0 12px;
      min-width:0;
    }

    .title a{
      display:flex;
      align-items:center;
      justify-content:center;
      width:34px;
      height:34px;
      min-width:34px;
      text-decoration:none;
      border:0;
      background:transparent;
      box-shadow:none;
    }

    .title img{
      width:32px;
      height:32px;
      object-fit:contain;
      filter:drop-shadow(0 4px 8px rgba(15,23,42,.10));
    }

    .titleText{
      flex:1;
      min-width:0;
    }

    .titleText b{
      display:block;
      font-size:22px;
      line-height:1.1;
      letter-spacing:-.04em;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      font-weight:360 !important;
    }

    .titleText small{
      display:block;
      margin-top:4px;
      color:var(--muted);
      font-size:12px;
      line-height:1.35;
      font-weight:320 !important;
    }

    .titleAction{
      flex:0 0 auto;
      margin-left:auto;
    }

    .paneToggleBtn{
      min-height:34px !important;
      height:34px !important;
      padding:0 12px !important;
      font-size:12px !important;
      background:#f8fafc !important;
      color:#334155 !important;
    }

    .rightTopBar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:12px;
      padding:10px 12px;
      border:1px solid var(--line);
      border-radius:18px;
      background:rgba(255,255,255,.96);
      box-shadow:var(--shadow);
    }

    .userPill{
      flex:0 1 auto;
      max-width:220px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      border:1px solid var(--line);
      border-radius:999px;
      background:#f8fafc;
      color:#64748b;
      padding:7px 10px;
      font-size:12px;
      font-weight:320 !important;
    }

    .card{
      background:rgba(255,255,255,.96);
      border:1px solid var(--line);
      border-radius:18px;
      padding:12px;
      margin-bottom:12px;
      box-shadow:var(--shadow);
    }

    .cardTitle{
      font-size:15px;
      margin:0 0 10px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      color:#0f172a;
    }

    .cardTitle small{
      color:var(--muted);
      font-size:11px;
      font-weight:400 !important;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
      margin-bottom:10px;
    }

    .field label{
      font-size:12px;
      color:#64748b;
      margin-left:2px;
    }

    input,select,textarea{
      width:100%;
      border-radius:12px;
      border:1px solid var(--line2);
      background:#f8fafc;
      color:#0f172a;
      outline:none;
      font-family:var(--font);
      font-size:13px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.75);
    }

    input,select{
      height:40px;
      padding:0 12px;
    }

    input[type=file]{
      height:auto;
      padding:10px;
    }

    textarea{
      min-height:76px;
      padding:10px 12px;
      resize:vertical;
      line-height:1.45;
    }

    input:focus,select:focus,textarea:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
      background:#fff;
    }

    select option{
      background:#fff;
      color:#0f172a;
    }

    .row{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
    }

    .row > *{
      flex:1;
      min-width:0;
    }

    button{
      min-height:38px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      padding:0 14px;
      font-family:var(--font);
      font-size:13px;
      cursor:pointer;
      white-space:nowrap;
      box-shadow:0 1px 0 rgba(255,255,255,.85),0 4px 12px rgba(15,23,42,.04);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      line-height:1.1;
    }

    button:hover{background:#f8fbff;border-color:#93c5fd}
    button.primary{background:linear-gradient(180deg,#3b82f6,#2563eb);border-color:#2563eb;color:#fff;box-shadow:0 8px 18px rgba(37,99,235,.18)}
    button.ok{background:linear-gradient(180deg,#22c55e,#16a34a);border-color:#16a34a;color:#fff;box-shadow:0 8px 18px rgba(22,163,74,.16)}
    button.secondary{background:#f8fafc;color:#334155}
    button.danger{background:#fff5f5;border-color:#fecaca;color:#dc2626}
    button.warn{background:#fffbeb;border-color:#fde68a;color:#a16207}
    button.purple{background:linear-gradient(180deg,#8b5cf6,#7c3aed);border-color:#7c3aed;color:#fff;box-shadow:0 8px 18px rgba(124,58,237,.18)}

    .iconBtn{
      min-height:36px;
      width:36px;
      padding:0;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }

    .status{
      margin-top:8px;
      color:#64748b;
      font-size:12px;
      line-height:1.55;
      white-space:pre-wrap;
      word-break:keep-all;
    }

    .status.ok{color:#15803d}
    .status.bad{color:#dc2626}
    .status.warn{color:#a16207}

    .summary{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      min-height:28px;
      padding:0 10px;
      border-radius:999px;
      border:1px solid var(--line);
      background:#f8fafc;
      color:#64748b;
      font-size:12px;
    }

    .pill strong{
      color:#0f172a;
      margin-left:5px;
      font-weight:340;
    }

    .routeList{
      display:grid;
      gap:8px;
      max-height:calc(100vh - 404px);
      overflow:auto;
      padding-right:2px;
    }

    .routeCard{
      border:1px solid #d8e0ee;
      background:#fff;
      border-radius:15px;
      padding:11px;
      cursor:pointer;
      box-shadow:0 8px 20px rgba(15,23,42,.04);
    }

    .routeCard:hover{
      background:#f8fbff;
      border-color:#93c5fd;
    }

    .routeCard.active{
      border-color:#60a5fa;
      background:#eff6ff;
      box-shadow:inset 0 0 0 1px rgba(37,99,235,.16),0 10px 22px rgba(37,99,235,.08);
    }

    .routeMain{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:center;
      margin-bottom:7px;
    }

    .routeCode{
      color:#1d4ed8;
      font-size:15px;
      font-weight:340 !important;
    }

    .routeMeta{
      color:#64748b;
      font-size:12px;
      font-weight:300 !important;
    }

    .routeDesc{
      color:#334155;
      font-size:12px;
      line-height:1.45;
      white-space:pre-wrap;
      word-break:break-word;
      font-weight:300 !important;
    }

    .routeBadges{
      margin-top:8px;
      display:flex;
      gap:5px;
      flex-wrap:wrap;
    }

    .miniBadge{
      display:inline-flex;
      align-items:center;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#eff6ff;
      border:1px solid #bfdbfe;
      color:#1d4ed8;
      font-size:11px;
    }

    .mapControls{
      position:absolute;
      top:12px;
      right:12px;
      z-index:20;
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      max-width:calc(100% - 24px);
    }

    .mapControls button{
      background:rgba(255,255,255,.94);
      border:1px solid #d8e0ee;
      color:#0f172a;
      backdrop-filter:blur(8px);
      min-height:36px;
      font-size:12px;
      font-weight:340 !important;
      box-shadow:0 8px 22px rgba(15,23,42,.12);
    }

    .mapControls button.active{
      background:#eff6ff;
      border-color:#60a5fa;
      color:#1d4ed8;
    }

    .floatingPaneToggle{
      position:absolute;
      top:12px;
      z-index:22;
      display:none;
      min-height:38px !important;
      padding:0 16px !important;
      background:rgba(255,255,255,.96) !important;
      border:1px solid #d8e0ee !important;
      color:#0f172a !important;
      box-shadow:0 8px 22px rgba(15,23,42,.14) !important;
      backdrop-filter:blur(8px);
    }

    .leftOpenBtn{left:12px}
    .rightOpenBtn{right:164px}

    .app.left-collapsed .leftOpenBtn,
    .app.right-collapsed .rightOpenBtn{
      display:inline-flex;
    }

    .polygonActionRow button{
      min-width:0;
      padding-left:10px !important;
      padding-right:10px !important;
    }

    .routeMapLabel{
      transform:translate(-50%,-50%);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:48px;
      height:28px;
      padding:0 10px;
      border-radius:999px;
      color:#ffffff;
      font-size:12px;
      font-weight:340 !important;
      border:1px solid rgba(255,255,255,.88);
      box-shadow:0 8px 20px rgba(15,23,42,.28);
      white-space:nowrap;
      pointer-events:none;
    }

    .drawStatus{
      position:absolute;
      left:12px;
      bottom:12px;
      z-index:20;
      max-width:760px;
      display:none;
      border:1px solid #60a5fa;
      background:rgba(239,246,255,.94);
      color:#0f172a;
      border-radius:14px;
      padding:10px 12px;
      font-size:12px;
      line-height:1.55;
      backdrop-filter:blur(8px);
      pointer-events:none;
      box-shadow:0 8px 24px rgba(15,23,42,.10);
    }

    .drawStatus.show{display:block}

    .markerTip{
      position:relative;
      transform:translate(-50%,-100%);
      cursor:pointer;
      user-select:none;
    }

    .markerBubble{
      min-width:34px;
      height:34px;
      border-radius:999px;
      display:flex;
      align-items:center;
      justify-content:center;
      color:#fff;
      font-weight:340;
      font-size:14px;
      border:2px solid rgba(255,255,255,.9);
      box-shadow:0 8px 22px rgba(15,23,42,.30);
    }

    .markerLabel{
      position:absolute;
      top:36px;
      left:50%;
      transform:translateX(-50%);
      white-space:nowrap;
      background:rgba(15,23,42,.78);
      border:1px solid rgba(255,255,255,.18);
      border-radius:999px;
      color:#fff;
      padding:3px 7px;
      font-size:11px;
      font-weight:320;
      pointer-events:none;
    }

    .marker-tip .markerBubble{background:#2563eb}
    .marker-entrance .markerBubble{background:#16a34a}
    .marker-password .markerBubble{background:#7c3aed}
    .marker-parking .markerBubble{background:#0f766e}
    .marker-caution .markerBubble{background:#dc2626}
    .marker-door .markerBubble{background:#ea580c}
    .marker-gate .markerBubble{background:#0891b2}
    .marker-etc .markerBubble{background:#64748b}

    .detailEmpty{
      border:1px dashed #cbd5e1;
      border-radius:14px;
      padding:12px;
      color:#64748b;
      font-size:12px;
      line-height:1.55;
      background:#f8fafc;
      white-space:pre-wrap;
    }

    .detailTitle{
      color:#0f172a;
      font-size:15px;
      line-height:1.35;
      margin-bottom:8px;
    }

    .detailMeta{
      display:grid;
      gap:6px;
      color:#334155;
      font-size:12px;
      line-height:1.45;
    }

    .pointList{
      display:grid;
      gap:8px;
      max-height:220px;
      overflow:auto;
      padding-right:2px;
    }

    .pointCard{
      border:1px solid #d8e0ee;
      background:#fff;
      border-radius:14px;
      padding:10px;
      cursor:pointer;
      color:#334155;
      font-size:12px;
      line-height:1.45;
      box-shadow:0 8px 18px rgba(15,23,42,.04);
    }

    .pointCard:hover{background:#f8fbff;border-color:#93c5fd}
    .pointCard.active{border-color:#60a5fa;background:#eff6ff}

    .locationBox{
      min-height:42px;
      border:1px solid #cbd5e1;
      border-radius:12px;
      background:#f8fafc;
      padding:10px 12px;
      color:#334155;
      font-size:12px;
      line-height:1.45;
      white-space:pre-wrap;
    }

    .locationBox.empty{color:#94a3b8}

    .attachmentGrid{
      margin-top:10px;
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:8px;
    }

    .attachmentCard{
      border:1px solid #d8e0ee;
      border-radius:14px;
      background:#fff;
      padding:8px;
      overflow:hidden;
      box-shadow:0 8px 18px rgba(15,23,42,.04);
    }

    .attachmentCard img{
      width:100%;
      aspect-ratio:1.25/1;
      object-fit:cover;
      border-radius:10px;
      background:#f1f5f9;
      display:block;
      cursor:pointer;
    }

    .attachmentCaption{
      margin-top:6px;
      color:#334155;
      font-size:11px;
      line-height:1.35;
      word-break:break-word;
    }

    .attachmentActions{
      display:flex;
      gap:6px;
      margin-top:7px;
    }

    .attachmentActions button{
      min-height:28px;
      font-size:11px;
      padding:0 8px;
    }

    .bulkTableWrap{
      overflow:auto;
      border:1px solid #d8e0ee;
      border-radius:14px;
      background:#fff;
      max-height:54vh;
    }

    .bulkTable{
      border-collapse:separate;
      border-spacing:0;
      width:max-content;
      min-width:100%;
      font-size:12px;
    }

    .bulkTable th,
    .bulkTable td{
      border-right:1px solid #d8e0ee;
      border-bottom:1px solid #d8e0ee;
      padding:6px;
      background:#fff;
      color:#0f172a;
      text-align:center;
    }

    .bulkTable th{
      position:sticky;
      top:0;
      z-index:2;
      background:#dbeafe;
    }

    .bulkTable input{
      min-width:0;
      height:34px;
      font-size:12px;
      border-radius:10px;
    }

    .bulkTable textarea{
      min-height:34px;
      height:34px;
      font-size:12px;
      border-radius:10px;
      resize:vertical;
    }

    .modal{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:18px;
      background:rgba(15,23,42,.42);
      backdrop-filter:blur(3px);
      z-index:99999;
    }

    .modal.open{display:flex}

    .modalCard{
      width:min(1180px,calc(100vw - 24px));
      max-height:calc(100vh - 24px);
      overflow:auto;
      border:1px solid #d8e0ee;
      border-radius:22px;
      background:#fff;
      box-shadow:0 24px 70px rgba(15,23,42,.24);
    }

    .modalTop{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:14px 16px;
      border-bottom:1px solid #d8e0ee;
      background:#f8fafc;
      position:sticky;
      top:0;
      z-index:3;
    }

    .modalTitle{
      font-size:18px;
      font-weight:340;
      color:#0f172a;
    }

    .modalBody{padding:16px}

    .bulkHelp{
      color:#64748b;
      font-size:13px;
      line-height:1.55;
      margin-bottom:12px;
      padding:12px;
      border-radius:14px;
      background:#f8fafc;
      border:1px solid #d8e0ee;
    }

    #imagePreviewImg{
      max-width:100%;
      max-height:72vh;
      display:block;
      margin:0 auto;
      border-radius:16px;
      background:#f1f5f9;
    }

    #imagePreviewCaption{
      margin-top:10px;
      color:#334155;
      text-align:center;
      font-size:13px;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg,rgba(246,248,252,.96),rgba(255,255,255,.98));
      z-index:999999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(540px,calc(100vw - 24px));
      border:1px solid #d8e0ee;
      border-radius:22px;
      background:#fff;
      box-shadow:0 24px 60px rgba(15,23,42,.16);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
      font-weight:560;
    }

    .accessCard p{
      margin:0;
      color:#64748b;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid #d8e0ee;
      background:#f8fafc;
      color:#0f172a;
      font-size:13px;
      word-break:break-word;
      line-height:1.6;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    .hiddenCoord{display:none}

    @media(max-width:980px){
      .app{
        grid-template-columns:minmax(0,1fr);
        grid-template-rows:45vh 55vh;
        overflow:auto;
      }

      .app.left-collapsed,
      .app.right-collapsed,
      .app.left-collapsed.right-collapsed{
        grid-template-columns:minmax(0,1fr);
      }

      .mapPane{
        grid-row:1;
        min-height:45vh;
      }

      .left{
        grid-row:2;
        border-right:0;
        border-top:1px solid var(--line);
      }

      .right{
