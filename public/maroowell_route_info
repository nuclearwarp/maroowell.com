  function renderCounts() {
    $("routeCount").textContent = String(routeRows.length);
    $("polygonCount").textContent = String(polygonRows.length);
    $("pointCount").textContent = String(pointRows.length);
    $("routeListHint").textContent = hasSearched ? `${routeRows.length}건` : "선택 없음";
    $("pointListCount").textContent = `${pointRows.length}개`;
    $("attachmentCount").textContent = `${attachmentRows.length}장`;
  }

  async function loadData() {
    const camp = normalizeCampForDb($("campInput").value);
    const routeQuery = clean($("routeSearchInput").value);
    const tokens = parseRouteSearchTokens(routeQuery);

    if (!camp) {
      setStatus("Camp를 입력하세요.", "bad");
      return;
    }

    setStatus("routeinfo 백엔드로 조회 중...", "warn");

    const data = await routeInfoApi("/route-info/query", {
      camp,
      route_query: routeQuery,
      tokens
    });

    routeRows = sortRouteRows(data.routes || []);
    polygonRows = data.polygons || [];
    pointRows = data.points || [];
    hasSearched = true;

    selectedRoute = null;
    selectedPoint = null;
    selectedPolygonId = null;

    clearAttachmentsState();
    clearRouteDetail();
    fillPointForm(null);
    renderRouteList();
    renderPointList();
    renderMapFeatures();
    renderCounts();
    fitAll();

    setStatus(
      `조회 완료: 라우트 ${routeRows.length}건 / 폴리곤 ${polygonRows.length}건 / 포인트 ${pointRows.length}건\n검색 규칙: 숫자만 입력하면 하위 전체, 서서브코드 입력하면 정확히 해당 코드만 조회`,
      "ok"
    );
  }

  function renderRouteList() {
    const list = $("routeList");

    if (!routeRows.length) {
      list.innerHTML = `<div class="detailEmpty">${hasSearched ? "조회된 라우트가 없습니다." : "불러오기를 누르면 라우트가 표시됩니다."}</div>`;
      return;
    }

    list.innerHTML = routeRows.map(row => {
      const code = routeCodeOf(row);
      const active = selectedRoute?.id === row.id ? "active" : "";

      return `
        <div class="routeCard ${active}" data-route-id="${esc(row.id)}">
          <div class="routeMain">
            <div class="routeCode">${esc(code)}</div>
            <div class="routeMeta">${esc(row.camp || "")}</div>
          </div>
          <div class="routeDesc">${esc(row.description || row.memo || row.info || "설명 없음")}</div>
          <div class="routeBadges">
            <span class="miniBadge">Route ${esc(row.route || "")}</span>
            ${clean(row.sub) ? `<span class="miniBadge">Sub ${esc(row.sub)}</span>` : ""}
            ${clean(row.sub_sub) ? `<span class="miniBadge">Sub-sub ${esc(row.sub_sub)}</span>` : ""}
            ${clean(row.sub_package) ? `<span class="miniBadge">${esc(row.sub_package)}</span>` : ""}
          </div>
        </div>
      `;
