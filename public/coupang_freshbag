<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>프레시백 현황 조회</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    :root{
      --bg:#0b1220;
      --card:#121a2d;
      --line:rgba(255,255,255,.12);
      --txt:#e6eefc;
      --muted:#9fb0d2;
      --blue:#60a5fa;
      --red:#ef4444;
      --green:#22c55e;
      --yellow:#f59e0b;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      min-height:100vh;
      background:linear-gradient(180deg,#0b1220,#070b13);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }
    .wrap{
      max-width:1720px;
      margin:0 auto;
      padding:22px 18px 44px;
    }
    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:18px;
    }
    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }
    .brand img{
      width:34px;
      height:34px;
    }
    .title{
      font-size:28px;
      font-weight:950;
      letter-spacing:-.6px;
      line-height:1.15;
    }
    .sub{
      color:var(--muted);
      font-size:14px;
      margin-top:5px;
      line-height:1.45;
    }
    .card{
      background:rgba(18,26,45,.9);
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 18px 60px rgba(0,0,0,.25);
    }
    .row{
      display:flex;
      gap:10px;
      align-items:flex-end;
      flex-wrap:wrap;
    }
    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
    }
    .field label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-left:2px;
    }
    input,select{
      height:42px;
      border-radius:12px;
      border:1px solid var(--line);
      background:rgba(0,0,0,.25);
      color:var(--txt);
      padding:0 12px;
      outline:none;
      min-width:150px;
    }
    select option{
      background:#111827;
      color:#fff;
    }
    input:focus,select:focus{
      border-color:rgba(96,165,250,.55);
      box-shadow:0 0 0 2px rgba(96,165,250,.12);
    }
    button{
      min-height:42px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(59,130,246,.24);
      color:#fff;
      padding:0 18px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
    }
    button:hover{
      background:rgba(59,130,246,.36);
    }
    button.secondary{
      background:rgba(255,255,255,.07);
    }
    button.secondary:hover{
      background:rgba(255,255,255,.12);
    }
    .pill{
      display:inline-flex;
      align-items:center;
      min-height:32px;
      padding:0 12px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.06);
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }
    .pill strong{
      color:#fff;
      margin-left:5px;
    }
    .status{
      font-size:13px;
      color:var(--muted);
      margin-top:10px;
      line-height:1.55;
    }
    .status.ok{color:#bbf7d0}
    .status.bad{color:#fecaca}
    .summary{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
      margin-top:10px;
    }
    .tableWrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:rgba(0,0,0,.18);
      max-height:calc(100vh - 255px);
    }
    table{
      border-collapse:separate;
      border-spacing:0;
      width:max-content;
      min-width:100%;
      font-size:13px;
    }
    th,td{
      border-right:1px solid rgba(255,255,255,.12);
      border-bottom:1px solid rgba(255,255,255,.12);
      padding:8px 10px;
      text-align:center;
      white-space:nowrap;
      min-width:74px;
    }
    th{
      position:sticky;
      top:0;
      z-index:5;
      background:#263247;
      color:#fff;
      font-weight:950;
    }
    th.monthHead{
      min-width:88px;
    }
    th.sticky,td.sticky{
      position:sticky;
      left:0;
      z-index:4;
      min-width:82px;
    }
    th.sticky{z-index:7}
    td.sticky{
      background:#111827;
      color:#e6eefc;
      font-weight:900;
    }
    th.sticky2,td.sticky2{
      position:sticky;
      left:82px;
      z-index:4;
      min-width:90px;
    }
    th.sticky2{z-index:7}
    td.sticky2{
      background:#111827;
      color:#e6eefc;
      font-weight:900;
    }
    th.sticky3,td.sticky3{
      position:sticky;
      left:172px;
      z-index:4;
      min-width:100px;
    }
    th.sticky3{z-index:7}
    td.sticky3{
      background:#111827;
      color:#bfdbfe;
      font-weight:950;
    }
    .yes{
      background:#7dd3fc;
      color:#082f49;
      font-weight:950;
    }
    .no{
      background:#fff;
      color:#ef4444;
      font-weight:950;
    }
    .empty{
      color:#6b7280;
      background:rgba(255,255,255,.03);
    }
    .hint{
      color:var(--muted);
      font-size:13px;
      line-height:1.55;
      margin-top:10px;
    }
    @media(max-width:900px){
      .top{
        flex-direction:column;
        align-items:flex-start;
      }
      .row{
        flex-direction:column;
        align-items:stretch;
      }
      input,select,button{
        width:100%;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <a href="#" id="mwBoardMenuToggle"><img src="/favicon.ico" alt="MarooWell"></a>
        <div>
          <div class="title">프레시백 현황 조회</div>
          <div class="sub">원하는 연도 / 캠프 / 웨이브 / 라우트를 월별 가중요인 표로 조회합니다. Route는 101_A → 101A 로 표시됩니다.</div>
        </div>
      </div>
      <div class="pill" id="userPill">세션 확인 중</div>
    </div>

    <div class="card">
      <div class="row">
        <div class="field">
          <label>연도</label>
          <select id="yearFilter"></select>
        </div>

        <div class="field">
          <label>Camp</label>
          <input id="campFilter" placeholder="예: 일산2" />
        </div>

        <div class="field">
          <label>Wave</label>
          <input id="waveFilter" placeholder="예: W1" />
        </div>

        <div class="field">
          <label>Route</label>
          <input id="routeFilter" placeholder="예: 130_A / 130A" />
        </div>

        <div class="field">
          <label>가중1</label>
          <select id="g1Filter">
            <option value="">전체</option>
            <option value="해당">해당</option>
            <option value="미해당">미해당</option>
          </select>
        </div>

        <div class="field">
          <label>가중2</label>
          <select id="g2Filter">
            <option value="">전체</option>
            <option value="해당">해당</option>
            <option value="미해당">미해당</option>
          </select>
        </div>

        <button id="loadBtn">조회</button>
        <button id="clearBtn" class="secondary">필터 초기화</button>
        <button id="copyBtn" class="secondary">표 복사</button>
      </div>

      <div class="hint">
        필터를 넣으면 해당 조건의 라우트만 월별로 피벗 조회합니다. Route 검색은 <b>130_A</b>로 입력해도 <b>130A</b> 기준으로 검색됩니다.
      </div>

      <div class="status" id="statusText">대기 중</div>

      <div class="summary">
        <span class="pill">원본 row <strong id="rawCount">0</strong></span>
        <span class="pill">표시 라우트 <strong id="routeCount">0</strong></span>
        <span class="pill">캠프 <strong id="campCount">0</strong></span>
        <span class="pill">월 데이터 <strong id="monthCount">0</strong></span>
      </div>
    </div>

    <div class="card">
      <div class="tableWrap">
        <table id="resultTable">
          <thead></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};

  let supabaseClient = null;
  let rawRows = [];
  let pivotRows = [];

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg;
    $("statusText").className = type ? "status " + type : "status";
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function valueClass(v) {
    const s = clean(v);
    if (s === "해당") return "yes";
    if (s === "미해당") return "no";
    if (!s) return "empty";
    return "";
  }

  function initYearOptions() {
    const now = new Date().getFullYear();
    const years = [];

    for (let y = now + 1; y >= now - 6; y--) {
      years.push(y);
    }

    $("yearFilter").innerHTML =
      years.map(y => `<option value="${y}">${y}</option>`).join("");

    $("yearFilter").value = String(now);
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage: storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  async function checkSession() {
    if (!supabaseClient) initSupabase();

    const { data, error } = await supabaseClient.auth.getSession();
    if (error) throw error;

    const user = data?.session?.user;
    if (!user) throw new Error("로그인이 필요합니다.");

    $("userPill").textContent = user.email || user.id;
  }

  function applyFilterToQuery(q) {
    const year = Number($("yearFilter").value);
    const camp = clean($("campFilter").value);
    const wave = clean($("waveFilter").value);
    const routeInput = clean($("routeFilter").value);
    const routeNorm = normalizeRoute(routeInput);
    const g1 = $("g1Filter").value;
    const g2 = $("g2Filter").value;

    q = q.eq("data_year", year);

    if (camp) q = q.ilike("camp", `%${camp}%`);
    if (wave) q = q.ilike("wave", `%${wave}%`);
    if (routeNorm) q = q.ilike("route_norm", `%${routeNorm}%`);
    if (g1) q = q.eq("gajoong1", g1);
    if (g2) q = q.eq("gajoong2", g2);

    return q;
  }

  async function fetchAllRows() {
    const pageSize = 1000;
    let from = 0;
    let all = [];

    while (true) {
      let q = supabaseClient
        .from("coupang_freshbag")
        .select(`
          id,
          data_year,
          month_no,
          data_month,
          period_label,
          wave,
          camp,
          route,
          route_norm,
          gajoong1,
          gajoong2,
          source_file_name,
          created_at,
          updated_at
        `)
        .order("camp", { ascending: true })
        .order("wave", { ascending: true })
        .order("route_norm", { ascending: true })
        .order("month_no", { ascending: true })
        .range(from, from + pageSize - 1);

      q = applyFilterToQuery(q);

      const { data, error } = await q;
      if (error) throw error;

      const rows = Array.isArray(data) ? data : [];
      all = all.concat(rows);

      if (rows.length < pageSize) break;

      from += pageSize;
      setStatus(`조회 중... ${all.length.toLocaleString()}건 불러옴`);
    }

    return all;
  }

  async function loadData() {
    setStatus("조회 중...");

    rawRows = await fetchAllRows();
    pivotRows = makePivotRows(rawRows);

    renderTable(pivotRows);
    renderSummary();

    setStatus(`조회 완료: 원본 ${rawRows.length.toLocaleString()}건 / 표시 ${pivotRows.length.toLocaleString()}개 라우트`, "ok");
  }

  function makePivotRows(rows) {
    const map = new Map();

    for (const row of rows) {
      const wave = clean(row.wave);
      const camp = clean(row.camp);
      const routeNorm = normalizeRoute(row.route_norm || row.route);
      const month = Number(row.month_no || 0);

      if (!wave || !camp || !routeNorm || month < 1 || month > 12) continue;

      const key = `${wave}||${camp}||${routeNorm}`;

      if (!map.has(key)) {
        map.set(key, {
          wave,
          camp,
          route: routeNorm,
          months: {}
        });
      }

      const item = map.get(key);

      item.months[month] = {
        gajoong1: row.gajoong1 || "",
        gajoong2: row.gajoong2 || "",
        period: row.period_label || row.data_month || "",
        source_file_name: row.source_file_name || ""
      };
    }

    return Array.from(map.values()).sort((a, b) => {
      return (
        a.camp.localeCompare(b.camp, "ko") ||
        a.wave.localeCompare(b.wave, "ko", { numeric: true }) ||
        a.route.localeCompare(b.route, "ko", { numeric: true })
      );
    });
  }

  function renderSummary() {
    const campSet = new Set();
    const monthSet = new Set();

    for (const row of rawRows) {
      if (row.camp) campSet.add(row.camp);
      if (row.month_no) monthSet.add(row.month_no);
    }

    $("rawCount").textContent = rawRows.length.toLocaleString();
    $("routeCount").textContent = pivotRows.length.toLocaleString();
    $("campCount").textContent = campSet.size.toLocaleString();
    $("monthCount").textContent = monthSet.size.toLocaleString();
  }

  function renderTable(rows) {
    const thead = $("resultTable").querySelector("thead");
    const tbody = $("resultTable").querySelector("tbody");

    const headers = [];
    for (let m = 1; m <= 12; m++) {
      headers.push(`<th class="monthHead">${m}월 가중1</th>`);
      headers.push(`<th class="monthHead">${m}월 가중2</th>`);
    }

    thead.innerHTML = `
      <tr>
        <th class="sticky">Wave</th>
        <th class="sticky2">Camp</th>
        <th class="sticky3">Route</th>
        ${headers.join("")}
      </tr>
    `;

    if (!rows.length) {
      tbody.innerHTML = `<tr><td colspan="27" class="empty">데이터 없음</td></tr>`;
      return;
    }

    tbody.innerHTML = rows.map(item => {
      const cells = [];

      for (let m = 1; m <= 12; m++) {
        const month = item.months[m] || {};
        const g1 = month.gajoong1 || "";
        const g2 = month.gajoong2 || "";

        cells.push(`<td class="${valueClass(g1)}">${esc(g1 || "데이터 없음")}</td>`);
        cells.push(`<td class="${valueClass(g2)}">${esc(g2 || "데이터 없음")}</td>`);
      }

      return `
        <tr>
          <td class="sticky">${esc(item.wave)}</td>
          <td class="sticky2">${esc(item.camp)}</td>
          <td class="sticky3">${esc(item.route)}</td>
          ${cells.join("")}
        </tr>
      `;
    }).join("");
  }

  async function copyTable() {
    if (!pivotRows.length) {
      setStatus("복사할 데이터가 없습니다.", "bad");
      return;
    }

    const header = ["Wave", "Camp", "Route"];

    for (let m = 1; m <= 12; m++) {
      header.push(`${m}월 가중1`, `${m}월 가중2`);
    }

    const lines = [header.join("\t")];

    for (const item of pivotRows) {
      const row = [item.wave, item.camp, item.route];

      for (let m = 1; m <= 12; m++) {
        const month = item.months[m] || {};
        row.push(month.gajoong1 || "데이터 없음", month.gajoong2 || "데이터 없음");
      }

      lines.push(row.join("\t"));
    }

    await navigator.clipboard.writeText(lines.join("\n"));
    setStatus("표 복사 완료", "ok");
  }

  function clearFilters() {
    const now = new Date().getFullYear();

    $("yearFilter").value = String(now);
    $("campFilter").value = "";
    $("waveFilter").value = "";
    $("routeFilter").value = "";
    $("g1Filter").value = "";
    $("g2Filter").value = "";

    renderTable([]);
    rawRows = [];
    pivotRows = [];
    renderSummary();
    setStatus("필터 초기화 완료. 조건 입력 후 조회하세요.", "ok");
  }

  function handleError(e) {
    console.error(e);
    setStatus(e.message || String(e), "bad");
  }

  function run(fn) {
    fn().catch(handleError);
  }

  initYearOptions();

  $("loadBtn").addEventListener("click", () => run(loadData));
  $("clearBtn").addEventListener("click", clearFilters);
  $("copyBtn").addEventListener("click", () => run(copyTable));

  ["yearFilter", "g1Filter", "g2Filter"].forEach(id => {
    $(id).addEventListener("change", () => run(loadData));
  });

  ["campFilter", "waveFilter", "routeFilter"].forEach(id => {
    $(id).addEventListener("keydown", e => {
      if (e.key === "Enter") run(loadData);
    });
  });

  try {
    initSupabase();
    run(async () => {
      await checkSession();
      renderTable([]);
      renderSummary();
      setStatus("조건 입력 후 조회하세요.", "ok");
    });
  } catch (e) {
    handleError(e);
  }
})();
</script>
<script src="/board-menu.js"></script>
</body>
</html>
