      });
      clone.querySelectorAll(".zipLink").forEach(el => {
        const text = (el.textContent || "").trim();
        el.replaceWith(document.createTextNode(text ? text + " " : ""));
      });
      clone.querySelectorAll("input,select,textarea").forEach(el => {
        let value = "";
        if (el.tagName === "SELECT") value = el.options?.[el.selectedIndex]?.textContent || el.value || "";
        else value = el.value || el.textContent || "";
        el.replaceWith(document.createTextNode(value));
      });
      clone.querySelectorAll("br").forEach(el => el.replaceWith(document.createTextNode("\n")));

      return (clone.innerText || clone.textContent || "")
        .replace(/\u00a0/g, " ")
        .replace(/[ \t]+\n/g, "\n")
        .replace(/\n[ \t]+/g, "\n")
        .replace(/[ \t]{2,}/g, " ")
        .trim();
    })();

    const subText = Array.from(cell.querySelectorAll(".subNum"))
      .map(el => (el.textContent || "").trim())
      .filter(Boolean)
      .join("\n");

    return { mainText, subText };
  }

  function splitLongToken(ctx, token, maxWidth) {
    const out = [];
    let cur = "";

    for (const ch of String(token || "")) {
      const test = cur + ch;

      if (cur && ctx.measureText(test).width > maxWidth) {
        out.push(cur);
        cur = ch;
      } else {
        cur = test;
      }
    }

    if (cur) out.push(cur);

    return out;
  }

  function wrapCanvasText(ctx, text, maxWidth) {
    const paragraphs = String(text || "")
      .split(/\n+/)
      .map(v => v.trim())
      .filter(Boolean);

    const lines = [];

    for (const paragraph of paragraphs.length ? paragraphs : [""]) {
      const words = paragraph.split(/\s+/).filter(Boolean);

      if (!words.length) {
        lines.push("");
        continue;
      }

      let line = "";

      for (const word of words) {
        const candidate = line ? line + " " + word : word;

        if (ctx.measureText(candidate).width <= maxWidth) {
          line = candidate;
          continue;
        }

        if (line) {
          lines.push(line);
          line = "";
        }

        if (ctx.measureText(word).width <= maxWidth) {
          line = word;
          continue;
        }

        const parts = splitLongToken(ctx, word, maxWidth);
        if (parts.length) {
          lines.push(...parts.slice(0, -1));
          line = parts[parts.length - 1] || "";
        }
      }

      if (line) lines.push(line);
    }

    return lines.length ? lines : [""];
  }

  function cellCanvasAlign(cell) {
    const cls = cell?.classList;

    if (cls?.contains("routeCell") || cls?.contains("zipCell") || cls?.contains("vendorCell")) {
      return "left";
    }

    if (cls?.contains("num") || cls?.contains("priceCell")) {
      return "right";
    }

    return "center";
  }

  function cellCanvasColor(cell, row) {
