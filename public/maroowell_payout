  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 마루웰 소속 최고관리자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn warn" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INDEX_PATH = PATHS?.index || "/index.html";
      const ACCESS_TABLE = "user_access";

      const PAYOUT_API_BASE = "https://payout.maroowell.com";

      const $ = (sel) => document.querySelector(sel);

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function showAccessDenied(email, detail) {
        const denied = $("#accessDenied");
        const deniedText = $("#accessDeniedText");
        const deniedEmail = $("#accessDeniedEmail");

        denied.classList.add("show");
        deniedText.textContent = detail || "이 페이지는 마루웰 소속 최고관리자만 접근할 수 있습니다.";
        deniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";

        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function requireAdmin() {
        if (!supabase || !supabase.auth) {
          alert("Supabase 설정을 확인하세요.");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();

          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          const viewerEmail = String(session.user?.email || "").trim();
          const viewerUserId = String(session.user?.id || "").trim();

          if (!viewerUserId) {
            showAccessDenied(viewerEmail, "로그인 사용자 ID를 확인할 수 없습니다.");
            return false;
          }

          const { data: accessRow, error } = await supabase
            .from(ACCESS_TABLE)
            .select("user_id, email, is_maroowell, is_admin")
            .eq("user_id", viewerUserId)
            .maybeSingle();

          if (error) {
            showAccessDenied(viewerEmail, "권한 테이블 조회 실패: " + error.message);
            return false;
          }

          if (!accessRow?.is_maroowell || !accessRow?.is_admin) {
            showAccessDenied(viewerEmail, "이 페이지는 마루웰 소속 최고관리자만 접근할 수 있습니다.");
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      const dom = {
        fileWorkbook: $("#fileWorkbook"),
        selectDriver: $("#selectDriver"),
        selectMonth: $("#selectMonth"),
        btnRefreshMaster: $("#btnRefreshMaster"),
        btnSavePng: $("#btnSavePng"),

        statRawRows: $("#statRawRows"),
        statLossRows: $("#statLossRows"),
        statIds: $("#statIds"),
        statMasterRows: $("#statMasterRows"),
        statAutoMatched: $("#statAutoMatched"),
        statUnmatched: $("#statUnmatched"),
        helperText: $("#helperText"),

        unmatchedBody: $("#unmatchedBody"),
        mainListBody: $("#mainListBody"),

        sheetTitle: $("#sheetTitle"),
        metaMonth: $("#metaMonth"),
        metaDriver: $("#metaDriver"),
        metaId: $("#metaId"),
        metaCampWave: $("#metaCampWave"),
        metaPayroll: $("#metaPayroll"),
        metaBusiness: $("#metaBusiness"),

        sumDelivery: $("#sumDelivery"),
        sumReturn: $("#sumReturn"),
        sumAmount: $("#sumAmount"),
        sumLoss: $("#sumLoss"),
        sumFinal: $("#sumFinal"),

        baseFixedComm: $("#baseFixedComm"),
        baseFixedUnit: $("#baseFixedUnit"),
        baseDragonComm: $("#baseDragonComm"),
        baseInsurance: $("#baseInsurance"),

        payoutBreakdownTitle: $("#payoutBreakdownTitle"),
        payoutRowsBody: $("#payoutRowsBody"),
        typeSummaryBody: $("#typeSummaryBody"),
        matchIdsBody: $("#matchIdsBody"),
        detailBody: $("#detailBody"),
        lossDetailBody: $("#lossDetailBody"),
        sheetNote: $("#sheetNote"),
        captureTarget: $("#captureTarget"),

        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        statusText: $("#statusText"),

        tabButtons: Array.from(document.querySelectorAll(".tabBtn")),
        scrollAreas: [$("#unmatchedWrap"), $("#mainListWrap"), $("#previewWrap")].filter(Boolean),

        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout")
      };

      const state = {
        busy: false,
        currentTab: "main",

        workbookName: "",
        rawRows: [],
        lossRows: [],
        rawCols: {},
        lossCols: {},

        masterRows: [],
        masterByPk: new Map(),
        masterByNormId: new Map(),
        duplicateMasterIds: [],

        idSummaries: [],
        autoMatchedById: {},
        aliasAssignments: {},

        realAggs: [],
        pseudoAggs: [],
        displayAggs: [],
        currentDriverPk: ""
      };

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeHeader(v) {
        return String(v ?? "").replace(/\s+/g, "").trim().toLowerCase();
      }

      function normalizeId(v) {
        let s = normalizeText(v).toLowerCase();
        if (!s) return "";
        s = s.replace(/\s+/g, "");
        s = s.replace(/@df$/i, "");
        return s;
      }

      function toNumber(v) {
        if (v == null || v === "") return 0;
        const s = String(v).replace(/,/g, "").replace(/원/g, "").trim();
        const n = Number(s);
        return Number.isFinite(n) ? n : 0;
      }

      function fmt(v) {
        return Number(toNumber(v)).toLocaleString("ko-KR");
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function setBusy(on) {
        state.busy = !!on;
        dom.fileWorkbook.disabled = !!on;
        dom.selectDriver.disabled = !!on || !state.displayAggs.length;
        dom.btnRefreshMaster.disabled = !!on;
        dom.btnSavePng.disabled = !!on || !state.displayAggs.length;
      }

      function setStatus(text, tone = "warn") {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill " + (tone === "ok" ? "ok" : tone === "err" ? "err" : "warn");
        dom.pillState.textContent = tone === "ok" ? "READY" : tone === "err" ? "ERROR" : "WAIT";
      }

      async function apiGet(url) {
        const res = await fetch(url, { method: "GET" });
        const text = await res.text();

        let data = null;
        try {
          data = text ? JSON.parse(text) : null;
        } catch {}

        if (!res.ok) {
          throw new Error(data?.error || text || `HTTP ${res.status}`);
        }

        return data;
      }

      function buildColumnMap(sampleRow, defs) {
        const keys = Object.keys(sampleRow || {});
        const normalizedKeys = keys.map((key) => ({
          raw: key,
          norm: normalizeHeader(key)
        }));

        const out = {};

        for (const [field, candidates] of Object.entries(defs)) {
          out[field] = "";

          for (const candidate of candidates) {
            const normCandidate = normalizeHeader(candidate);

            let found = normalizedKeys.find((item) => item.norm === normCandidate);
            if (!found) {
              found = normalizedKeys.find((item) =>
                item.norm.includes(normCandidate) || normCandidate.includes(item.norm)
              );
            }

            if (found) {
              out[field] = found.raw;
              break;
            }
          }
        }

        return out;
      }

      function getRawColDefs() {
        return {
          type: ["구분"],
          id: ["ID", "id"],
          name: ["이름", "기사명"],
          route: ["Route", "route"],
          date: ["배송일자"],
          camp: ["캠프명"],
          wave: ["배송유형(주간/심야)", "배송유형"],
          delivery: ["배송건수(파슬)", "배송건수", "배송건수파슬"],
          return: ["반품(운송장)", "반품", "반품운송장"],
          amount: ["총금액"],
          incentive: ["프레시백회수인센티브", "프레시백 회수 인센티브"]
        };
      }

      function getLossColDefs() {
        return {
          date: ["날짜"],
          camp: ["캠프"],
          id: ["ID", "id"],
          name: ["이름"],
          type: ["유형"],
          detail: ["상세"],
          qty: ["개수"],
          amount: ["차감금액"]
        };
      }

      function parseFixedAmount(v) {
        return toNumber(v);
      }

      function parsePercent(v) {
        const s = String(v ?? "").trim();
        if (!s) return 0;
        if (!s.includes("%")) return 0;
        return toNumber(s.replace("%", ""));
      }

      function calcDragonDeduction(value, gross) {
        const percent = parsePercent(value);
        if (percent > 0) {
          return Math.round(gross * (percent / 100));
        }
        return parseFixedAmount(value);
      }

      function calcInsuranceDeduction(flag, gross) {
        const s = normalizeText(flag).toUpperCase();
        if (!["O", "1", "Y", "YES", "TRUE"].includes(s)) return 0;

        const supply = gross / 1.1;
        const base = supply * 0.654;
        return Math.floor((base * 0.008) / 10) * 10;
      }

      function calcVatSplit(gross) {
        const supply = Math.round(gross / 1.1);
        const vat = gross - supply;
        return { supply, vat };
      }

      async function loadMasterRows(force = false) {
        if (!force && state.masterRows.length) return state.masterRows;

        const data = await apiGet(`${PAYOUT_API_BASE}/master`);
        const rows = Array.isArray(data?.rows) ? data.rows : [];

        state.masterRows = rows.slice();
        state.masterByPk = new Map();
        state.masterByNormId = new Map();
        state.duplicateMasterIds = [];

        for (const row of state.masterRows) {
          const pk = String(row.pk_id);
          state.masterByPk.set(pk, row);

          const normId = normalizeId(row.coupang_id_norm || row.coupang_id);
          if (!normId) continue;

          if (state.masterByNormId.has(normId)) {
            state.duplicateMasterIds.push(normId);
            continue;
          }
          state.masterByNormId.set(normId, pk);
        }

        return state.masterRows;
      }

      function buildIdSummaries() {
        const map = new Map();

        for (const row of state.rawRows) {
          const id = normalizeId(row[state.rawCols.id]);
          if (!id) continue;

          if (!map.has(id)) {
            map.set(id, {
              id,
              displayId: normalizeText(row[state.rawCols.id]) || id,
              rawCount: 0,
              lossCount: 0,
              deliveryCount: 0,
              returnCount: 0,
              amountSum: 0,
              lossSum: 0,
              camps: new Set(),
              waves: new Set(),
              names: new Set()
            });
          }

          const s = map.get(id);
          s.rawCount += 1;
          s.deliveryCount += toNumber(row[state.rawCols.delivery]);
          s.returnCount += toNumber(row[state.rawCols.return]);
          s.amountSum += toNumber(row[state.rawCols.amount]);

          const camp = normalizeText(row[state.rawCols.camp]);
          const wave = normalizeText(row[state.rawCols.wave]);
          const name = normalizeText(row[state.rawCols.name]);

          if (camp) s.camps.add(camp);
          if (wave) s.waves.add(wave);
          if (name) s.names.add(name);
        }

        for (const row of state.lossRows) {
          const id = normalizeId(row[state.lossCols.id]);
          if (!id) continue;

          if (!map.has(id)) {
            map.set(id, {
              id,
              displayId: normalizeText(row[state.lossCols.id]) || id,
              rawCount: 0,
              lossCount: 0,
              deliveryCount: 0,
              returnCount: 0,
              amountSum: 0,
              lossSum: 0,
              camps: new Set(),
              waves: new Set(),
              names: new Set()
            });
          }

          const s = map.get(id);
          s.lossCount += 1;
          s.lossSum += toNumber(row[state.lossCols.amount]);

          const camp = normalizeText(row[state.lossCols.camp]);
          const name = normalizeText(row[state.lossCols.name]);

          if (camp) s.camps.add(camp);
          if (name) s.names.add(name);
        }

        return Array.from(map.values())
          .filter((item) => item.deliveryCount > 0)
          .map((item) => ({
            ...item,
            campsText: Array.from(item.camps).join(", "),
            wavesText: Array.from(item.waves).join(", "),
            namesText: Array.from(item.names).join(", ")
          }))
          .sort((a, b) => a.id.localeCompare(b.id, "ko"));
      }

      function buildAutoMatches() {
        const out = {};
        for (const item of state.idSummaries) {
          const pk = state.masterByNormId.get(item.id);
          if (pk) out[item.id] = pk;
        }
        return out;
      }

      function resolveDriverPkForId(id) {
        return String(state.aliasAssignments[id] || state.autoMatchedById[id] || "");
      }

      function buildBaseAgg(master, pkId) {
        return {
          pk_id: String(pkId),
          master,
          isPseudo: false,
          label: master?.person_name || "-",
          repId: master?.coupang_id || "-",
          campCode: master?.camp_code || "-",
          wave: master?.wave || "-",
          matchIds: new Set(),
          rawRows: [],
          lossRows: [],
          deliveryCount: 0,
          returnCount: 0,
          amountSum: 0,
          lossSum: 0
        };
      }

      function buildPseudoAgg(item) {
        const rawRows = state.rawRows.filter((row) => normalizeId(row[state.rawCols.id]) === item.id);
        const lossRows = state.lossRows.filter((row) => normalizeId(row[state.lossCols.id]) === item.id);

        return {
          pk_id: `id:${item.id}`,
          master: null,
          isPseudo: true,
          label: item.displayId || item.id,
          repId: item.displayId || item.id,
          campCode: item.campsText || "-",
          wave: item.wavesText || "-",
          matchIds: new Set([item.id]),
          rawRows,
          lossRows,
          deliveryCount: item.deliveryCount,
          returnCount: item.returnCount,
          amountSum: item.amountSum,
          lossSum: item.lossSum
        };
      }

      function finalizeAgg(agg) {
        return {
          ...agg,
          finalAmount: agg.amountSum - agg.lossSum,
          matchIdsArr: Array.from(agg.matchIds).sort((a, b) => a.localeCompare(b, "ko"))
        };
      }

      function recomputeDriverAggs() {
        const aggMap = new Map();

        const ensureAgg = (pk) => {
          const key = String(pk);
          if (!aggMap.has(key)) {
            const master = state.masterByPk.get(key);
            if (!master) return null;
            aggMap.set(key, buildBaseAgg(master, key));
          }
          return aggMap.get(key);
        };

        for (const item of state.idSummaries) {
          const pk = resolveDriverPkForId(item.id);
          if (!pk) continue;

          const agg = ensureAgg(pk);
          if (!agg) continue;
          agg.matchIds.add(item.id);
        }

        for (const row of state.rawRows) {
          const id = normalizeId(row[state.rawCols.id]);
          const pk = resolveDriverPkForId(id);
          if (!pk) continue;

          const agg = ensureAgg(pk);
          if (!agg) continue;

          agg.rawRows.push(row);
          agg.deliveryCount += toNumber(row[state.rawCols.delivery]);
          agg.returnCount += toNumber(row[state.rawCols.return]);
          agg.amountSum += toNumber(row[state.rawCols.amount]);
        }

        for (const row of state.lossRows) {
          const id = normalizeId(row[state.lossCols.id]);
          const pk = resolveDriverPkForId(id);
          if (!pk) continue;

          const agg = ensureAgg(pk);
          if (!agg) continue;

          agg.lossRows.push(row);
          agg.lossSum += toNumber(row[state.lossCols.amount]);
        }

        state.realAggs = Array.from(aggMap.values())
          .filter((agg) => agg.deliveryCount > 0)
          .map(finalizeAgg)
          .sort((a, b) => {
            const ac = normalizeText(a.campCode);
            const bc = normalizeText(b.campCode);
            if (ac !== bc) return ac.localeCompare(bc, "ko");

            const aw = normalizeText(a.wave);
            const bw = normalizeText(b.wave);
            if (aw !== bw) return aw.localeCompare(bw, "ko");

            return normalizeText(a.label).localeCompare(normalizeText(b.label), "ko");
          });

        const pseudoList = state.idSummaries
          .filter((item) => !state.autoMatchedById[item.id] && !state.aliasAssignments[item.id])
          .map(buildPseudoAgg)
          .map(finalizeAgg)
          .sort((a, b) => normalizeText(a.label).localeCompare(normalizeText(b.label), "ko"));

        state.pseudoAggs = pseudoList;
        state.displayAggs = [...state.realAggs, ...state.pseudoAggs];

        const currentExists = state.displayAggs.some((agg) => String(agg.pk_id) === String(state.currentDriverPk));
        if (!currentExists) {
          state.currentDriverPk = state.displayAggs[0]?.pk_id || "";
        }
