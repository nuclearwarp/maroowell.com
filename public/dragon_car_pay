<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰 용차 정산서</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0f1a2d;
      --panel2:#0c1524;
      --line:rgba(255,255,255,.08);
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;
      --ok:#1a5a3a;
      --danger:#6b1b1b;

      --paper:#ffffff;
      --paperLine:#1f1f1f;
      --paperHead:#dce8c4;
      --paperTitle:#d9edf1;
      --paperTxt:#111827;
      --paperBg:#f7f7f7;

      --sumBlue:#8db8e8;
      --sumPeach:#ffd9b8;
      --sumPurple:#cbbbd9;
      --sumGreen:#dce8c4;
      --finalGreen:#00b857;
      --finalCyan:#bfe8ef;

      --headerH:56px;
      --toolbarH:58px;
      --statusH:44px;
    }

    * { box-sizing:border-box; }

    html, body{
      margin:0;
      height:100%;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }

    body{ overflow:hidden; }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--headerH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }

    .spacer{ flex:1; }

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }

    .btn:hover{ background:var(--btn2); }
    .btn.ok{ background:rgba(26,90,58,.35); border-color:rgba(0,255,140,.18); }
    .btn.danger{ background:rgba(107,27,27,.35); border-color:rgba(255,60,60,.22); color:#ffccd3; }
    .btn:disabled{ opacity:.55; cursor:not-allowed; }

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:var(--panel2);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .toolGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolGroup label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .toolbar input{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbar input:focus{
      border-color:rgba(96,165,250,.55);
    }

    .modeTabs{
      display:flex;
      gap:8px;
    }

    .modeBtn{
      height:38px;
      min-width:92px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.04);
      color:#dce8ff;
      font-weight:900;
      cursor:pointer;
    }

    .modeBtn.active{
      background:rgba(59,130,246,.18);
      border-color:rgba(96,165,250,.5);
      color:#fff;
    }

    .main{
      min-height:0;
      display:grid;
      grid-template-columns:360px 1fr;
    }

    .sidebar{
      min-height:0;
      border-right:1px solid var(--line);
      background:linear-gradient(180deg,var(--panel),#0b1321);
      display:flex;
      flex-direction:column;
    }

    .sideSection{
      padding:12px;
      border-bottom:1px solid var(--line);
    }

    .sideTitle{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:10px;
    }

    .summaryGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .summaryCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:12px;
      min-width:0;
    }

    .summaryLabel{
      font-size:11px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:4px;
    }

    .summaryValue{
      font-size:18px;
      line-height:1.1;
      font-weight:900;
      color:#fff;
      word-break:break-word;
      font-variant-numeric:tabular-nums;
    }

    .summaryValue.blue{ color:#bfdbfe; }
    .summaryValue.red{ color:#fecaca; }
    .summaryValue.green{ color:#bbf7d0; }
    .summaryValue.yellow{ color:#fde68a; }

    .groupList{
      min-height:0;
      overflow:auto;
      padding:10px;
    }

    .groupItem{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:16px;
      padding:12px;
      margin-bottom:10px;
      cursor:pointer;
      transition:.14s ease;
    }

    .groupItem:hover{
      border-color:rgba(255,255,255,.18);
      background:rgba(255,255,255,.07);
    }

    .groupItem.active{
      border-color:rgba(96,165,250,.55);
      background:rgba(59,130,246,.12);
      box-shadow:inset 0 0 0 1px rgba(96,165,250,.22);
    }

    .groupName{
      font-weight:900;
      color:#fff;
      line-height:1.3;
      margin-bottom:9px;
      word-break:break-word;
      white-space:pre-line;
    }

    .groupMeta{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:6px 10px;
      font-size:12px;
      color:#d3def5;
    }

    .groupMeta span{
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .groupMeta b{
      color:#fff;
      font-weight:900;
      font-variant-numeric:tabular-nums;
    }

    .groupMeta .wide{
      grid-column:1 / -1;
    }

    .content{
      min-width:0;
      min-height:0;
      overflow:auto;
      background:#0d1523;
      padding:16px;
    }

    .invoicePage{
      width:min(1180px, 100%);
      margin:0 auto;
      background:#ffffff;
      color:var(--paperTxt);
      border-radius:4px;
      box-shadow:0 16px 42px rgba(0,0,0,.24);
      overflow:hidden;
      padding:24px 26px 28px;
    }

    .statementTopStrip{
      display:flex;
      align-items:center;
      gap:8px;
      margin-bottom:12px;
      font-size:14px;
      font-weight:900;
    }

    .topChip{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:100px;
      height:30px;
      padding:0 12px;
      border:1px solid #cbd5e1;
      background:#dce8c4;
      color:#000;
    }

    .topChip.value{
      background:#ddd6eb;
      min-width:150px;
      font-weight:700;
    }

    .topChip.moneyA,
    .topChip.moneyB,
    .topChip.moneyC{
      color:#fff;
      background:#a000ff;
      min-width:130px;
    }

    .topChip.moneyB{ background:#498ce8; }

    .mwSheet{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
      font-size:14px;
      color:#111;
    }

    .mwSheet th,
    .mwSheet td{
      border:1px solid #1f1f1f;
      padding:6px 7px;
      text-align:center;
      vertical-align:middle;
      line-height:1.25;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .mwSheet .title{
      background:var(--paperTitle);
      font-size:24px;
      font-weight:900;
      padding:10px;
      letter-spacing:-.02em;
    }

    .mwSheet .head{
      background:var(--paperHead);
      font-size:21px;
      font-weight:900;
    }

    .mwSheet .subhead{
      background:var(--paperHead);
      font-weight:900;
    }

    .mwSheet .left{
      text-align:left;
    }

    .mwSheet .right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .mwSheet .money{
      text-align:right;
      font-variant-numeric:tabular-nums;
      padding-right:10px;
    }

    .mwSheet .red{
      color:#ff0000;
      font-weight:900;
    }

    .mwSheet .greenText{
      color:#0ba84f;
      font-weight:900;
    }

    .mwSheet .blueCell{
      background:var(--sumBlue);
      font-weight:900;
    }

    .mwSheet .peachCell{
      background:var(--sumPeach);
      font-weight:900;
      color:#ff0000;
    }

    .mwSheet .purpleCell{
      background:var(--sumPurple);
      font-weight:900;
      color:#11395f;
    }

    .mwSheet .greenCell{
      background:var(--sumGreen);
      font-weight:900;
    }

    .mwSheet .finalLabel{
      background:var(--finalCyan);
      font-size:21px;
      font-weight:900;
    }

    .mwSheet .finalAmount{
      background:var(--finalGreen);
      color:#8a2be2;
      font-size:18px;
      font-weight:900;
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .mwSheet .blankRow td{
      height:25px;
      color:transparent;
    }

    .mwSheet .lossLabel{
      color:#ff0000;
      font-weight:900;
      text-align:left;
      padding-left:12px;
    }

    .mwSheet .note{
      text-align:center;
      line-height:1.65;
      padding:18px 10px;
    }

    .mwSheet .sectionGap td{
      border-left:none;
      border-right:none;
      height:22px;
      padding:0;
      background:#fff;
    }

    .emptyState{
      width:min(940px, 100%);
      margin:0 auto;
      padding:24px;
      border:1px dashed rgba(255,255,255,.14);
      border-radius:16px;
      text-align:center;
      color:#c1d0ea;
      background:rgba(255,255,255,.03);
      font-weight:900;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{ color:#bbf7d0; }
    .pill.warn{ color:#fde68a; }
    .pill.err{ color:#fecaca; }

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{ display:flex; }

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    .invoicePage.capture-export{
      overflow:visible !important;
      width:1180px !important;
      max-width:none !important;
      height:auto !important;
      max-height:none !important;
      border-radius:0 !important;
      box-shadow:none !important;
    }

    .capture-host{
      position:fixed;
      left:-100000px;
      top:0;
      z-index:-1;
      background:#ffffff;
      padding:24px;
      width:auto;
      height:auto;
      overflow:visible;
    }

    @media (max-width:1100px){
      .main{ grid-template-columns:1fr; }
      .sidebar{ max-height:360px; }
      .btn{ padding:0 10px; font-size:12px; }
      .toolbar{ padding:8px; gap:8px; }
      .invoicePage{
        padding-left:12px;
        padding-right:12px;
      }
      .statementTopStrip{
        flex-wrap:wrap;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a id="mwBoardMenuToggle" href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>용차 정산서</b>
        <small>월별 업체 / 기사 정산서 생성기</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnDownloadPng" class="btn ok" type="button">PNG 저장</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="toolGroup">
        <label for="monthInput">정산월</label>
        <input id="monthInput" type="text" placeholder="예: 2026-04 / 26년 4월" />
      </div>

      <div class="toolGroup">
        <label>정산서 종류</label>
        <div class="modeTabs">
          <button id="btnModeVendor" class="modeBtn active" type="button">업체 정산서</button>
          <button id="btnModeDriver" class="modeBtn" type="button">기사 정산서</button>
        </div>
      </div>

      <div class="toolGroup">
        <label for="searchInput">검색</label>
        <input id="searchInput" type="text" placeholder="업체 / Order / 기사 / 캠프 / 라우트" />
      </div>

      <div class="toolGroup">
        <button id="btnClearSearch" class="btn" type="button">검색 초기화</button>
      </div>
    </div>

    <div class="main">
      <aside class="sidebar">
        <div class="sideSection">
          <div class="sideTitle">현재 조회</div>
          <div class="summaryGrid">
            <div class="summaryCard">
              <div class="summaryLabel">정산월</div>
              <div id="sideMonth" class="summaryValue">-</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">정산서 수</div>
              <div id="sideGroupCount" class="summaryValue blue">0</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">월 총금액</div>
              <div id="sideAmount" class="summaryValue">₩0</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">세금계산서 발행</div>
              <div id="sideIssued" class="summaryValue green">₩0</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">수수료 공제</div>
              <div id="sideCommission" class="summaryValue red">₩0</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">고용/산재</div>
              <div id="sideInsurance" class="summaryValue yellow">₩0</div>
            </div>
          </div>
        </div>

        <div class="sideSection">
          <div class="sideTitle">정산서 목록</div>
        </div>

        <div id="groupList" class="groupList"></div>
      </aside>

      <main class="content">
        <div id="statementCapture" class="invoicePage" style="display:none"></div>

        <div id="emptyState" class="emptyState">
          월을 선택하고, 좌측에서 업체 또는 기사를 선택하면 정산서가 생성됩니다.
        </div>
      </main>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillGroups" class="pill">정산서 0</span>
      <span id="statusText" class="statusText">세금계산서 발행/미발행, 용차 수수료, 고용/산재 공제를 자동 계산합니다.</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 최고관리자 또는 용차 관리자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INDEX_PATH = PATHS?.index || "/index.html";

      const ACCESS_TABLE = "user_access";
      const PROFILES_TABLE = "profiles";
      const DATA_TABLE = "dragon_car";
      const VENDORS_TABLE = "vendors";
      const DRIVER_INFO_TABLE = "maroowell_info";

      const ZERO_COMMISSION_DRIVER_NAMES = new Set(["김용준", "장세인", "이우람"]);
      const TEAM_LEADER_NAME = "한재봉";
      const DEFAULT_DRAGON_COMMISSION_RATE = 0.08;
      const VAT_RATE = 0.10;
      const EMPLOYMENT_ACCIDENT_RATE = 0.0168;
      const FILLER_ROW_TARGET = 28;

      const PAYMENT_INFO = {
        bankName: "국민은행",
        accountNumber: "293237 - 04 - 011538",
        depositor: "마루웰",
        requestNote: "금액 확인 요청 드립니다.\n\n금액 확인 하신 후에 이상 없으시면 세금계산서 발행 하겠습니다.\n\n이후 정산일자에 입금 부탁드립니다."
      };

      const COLUMN_CANDIDATES = {
        rowId: ["id", "pk_id", "seq", "no"],
        month: ["settlement_month", "pay_month", "month", "정산월"],
        date: ["delivery_date", "work_date", "service_date", "settlement_date", "date", "driving_date", "운행일", "배송일자", "일자"],
        vendorId: ["vendor_id", "vendorId", "vendor", "vendor_pk", "거래처id", "벤더id"],
        vendorName: ["vendor_name", "vendorName", "company_name", "companyName", "업체", "업체명", "거래처"],
        orderName: ["order_name", "orderName", "order", "order_no", "order_number", "오더", "오더명", "Order"],
        driver: ["delivery_driver", "driver_name", "driverName", "driver", "기사", "기사명", "용차기사"],
        camp: ["camp", "camp_code", "campCode", "camp_name", "캠프"],
        wave: ["wave", "work_wave", "day_night", "dayNight", "shift", "주야", "주간야간", "주_야"],
        route: ["route", "route_name", "routeName", "route_code", "routeCode", "라우트"],
        unitPrice: ["unit_price", "unitPrice", "price", "delivery_unit_price", "unit_cost", "단가"],
        quantity: ["delivery_quantity", "delivery_qty", "delivery_count", "parcel_count", "quantity", "qty", "count", "배송수량", "배송_수량", "수량"],
        returnQuantity: ["return_quantity", "return_qty", "return_count", "returnCount", "반품수량", "반품_수량"],
        amount: ["amount", "settlement_amount", "total_amount", "pay_amount", "payment_amount", "supply_amount", "정산금액", "금액", "총금액"],
