      function canvasRoundRect(ctx,x,y,w,h,r){
        const rr = Math.min(r,w/2,h/2);
        ctx.beginPath();
        ctx.moveTo(x+rr,y);
        ctx.arcTo(x+w,y,x+w,y+h,rr);
        ctx.arcTo(x+w,y+h,x,y+h,rr);
        ctx.arcTo(x,y+h,x,y,rr);
        ctx.arcTo(x,y,x+w,y,rr);
        ctx.closePath();
      }

      function captionColorForClass(className){
        const cls=String(className||"");

        if(cls.includes("statMax")) return "#dc2626";
        if(cls.includes("statMin")) return "#2563eb";
        if(cls.includes("statAvg")) return "#a16207";
        if(cls.includes("sundayText")) return "#dc2626";

        return "#334155";
      }

      function collectCaptionRuns(node,color="#334155",nowrap=false){
        const out=[];

        if(!node) return out;

        node.childNodes.forEach(child => {
          if(child.nodeType === Node.TEXT_NODE){
            const text=String(child.textContent || "");
            if(text) out.push({ text, color, nowrap });
            return;
          }

          if(child.nodeType === Node.ELEMENT_NODE){
            const className=String(child.className || "");
            const nextColor=captionColorForClass(className) || color;
            const nextNowrap=nowrap || className.includes("statAvg");
            out.push(...collectCaptionRuns(child,nextColor,nextNowrap));
          }
        });

        return out;
      }

      function tokenizeCaptionRun(run){
        if(run.nowrap){
          const text=String(run.text || "").replace(/\s+/g," ").trim();
          return text ? [{ text, color:run.color, nowrap:true }] : [];
        }

        const pieces=String(run.text || "").split(/(\s+)/).filter(piece => piece.length > 0);
        return pieces.map(text => ({ text, color:run.color }));
      }

      function layoutCaptionLines(ctx,runs,maxWidth){
        const tokens=runs.flatMap(tokenizeCaptionRun);
        const lines=[];
        let line=[];
        let lineWidth=0;

        function pushLine(){
          while(line.length && /^\s+$/.test(line[0].text)){
            lineWidth -= ctx.measureText(line[0].text).width;
            line.shift();
          }

          while(line.length && /^\s+$/.test(line[line.length-1].text)){
            lineWidth -= ctx.measureText(line[line.length-1].text).width;
            line.pop();
          }

          if(line.length){
            lines.push(line);
          }

          line=[];
          lineWidth=0;
        }

        tokens.forEach(token => {
          const tokenWidth=ctx.measureText(token.text).width;

          if(token.nowrap && line.length && lineWidth + tokenWidth > maxWidth){
            pushLine();
          }else if(line.length && lineWidth + tokenWidth > maxWidth){
            pushLine();
          }

          if(!token.nowrap && tokenWidth > maxWidth){
            let buffer="";
            for(const ch of token.text){
              const next=buffer+ch;
              if(buffer && ctx.measureText(next).width > maxWidth){
                line.push({ text:buffer, color:token.color });
                pushLine();
                buffer=ch;
              }else{
                buffer=next;
              }
            }
            if(buffer){
              line.push({ text:buffer, color:token.color });
              lineWidth += ctx.measureText(buffer).width;
            }
            return;
          }

          line.push(token);
          lineWidth += tokenWidth;
        });

        pushLine();

        return lines.length ? lines : [[{ text:"", color:"#334155" }]];
      }

      function drawCaptionLine(ctx,line,x,y){
        let cursor=x;

        line.forEach(part => {
          ctx.fillStyle=part.color || "#334155";
          ctx.fillText(part.text,cursor,y);
          cursor += ctx.measureText(part.text).width;
        });
      }

      function makeTableCanvas(table){
        const captionEl = table.querySelector("caption");
        const captionRuns = captionEl ? collectCaptionRuns(captionEl) : [];
        const headerRows = Array.from(table.querySelectorAll("thead tr"));
        const bodyRows = Array.from(table.querySelectorAll("tbody tr"))
          .filter(tr => !tr.querySelector(".emptyBox"));

        if(!headerRows.length || !bodyRows.length){
          throw new Error("복사할 표 데이터가 없습니다.");
        }

        const rows = [];

        headerRows.forEach(tr => {
          rows.push({
            type:"head",
            cells:Array.from(tr.children).map(cell => ({
              text:(cell.textContent || "").replace(/\s+/g," ").trim(),
              lines:[{ text:(cell.textContent || "").replace(/\s+/g," ").trim(), kind:"head" }],
              className:cell.className || "",
              isSunday:cell.classList.contains("sundayText") || isSundayText(cell.textContent)
            }))
          });
        });

        bodyRows.forEach(tr => {
          rows.push({
            type:"body",
            cells:Array.from(tr.children).map(cell => ({
              text:(cell.textContent || "").replace(/\s+/g," ").trim(),
              lines:parseCellLines(cell),
              className:cell.className || "",
              isMoney:cell.classList.contains("money") || !!cell.querySelector?.(".money"),
              isWarn:cell.classList.contains("warnText"),
              isSunday:cell.classList.contains("sundayText") || isSundayText(cell.textContent),
              isMax:cell.classList.contains("maxQty") || !!cell.querySelector?.(".maxQty"),
              isMin:cell.classList.contains("minQty") || !!cell.querySelector?.(".minQty")
            }))
          });
        });

        const colCount = Math.max(...rows.map(row => row.cells.length));
        const measureCanvas = document.createElement("canvas");
        const mctx = measureCanvas.getContext("2d");

        const fontMain = "500 13px '문경감홍사과체', 'Noto Sans KR', Arial, sans-serif";
        const fontHead = "600 13px '문경감홍사과체', 'Noto Sans KR', Arial, sans-serif";
        const fontAvg = "400 11px '문경감홍사과체', 'Noto Sans KR', Arial, sans-serif";
        const fontChange = "400 10px '문경감홍사과체', 'Noto Sans KR', Arial, sans-serif";
        const fontCaption = "500 13px '문경감홍사과체', 'Noto Sans KR', Arial, sans-serif";

        const colWidths = Array.from({ length:colCount }, () => 68);

        rows.forEach(row => {
          row.cells.forEach((cell, index) => {
            cell.lines.forEach(line => {
              mctx.font = line.kind === "avg" ? fontAvg : line.kind?.startsWith("change") ? fontChange : row.type === "head" ? fontHead : fontMain;
              colWidths[index] = Math.max(colWidths[index], Math.ceil(mctx.measureText(line.text || "-").width) + 24);
            });
          });
        });

        for(let i=0;i<colWidths.length;i++){
          colWidths[i] = Math.min(Math.max(colWidths[i], 62), 260);
        }

        const headerHeight = 34;
        const bodyBaseHeight = 38;
        const bodyQtyHeight = 52;
        const bodyChangeHeight = 66;
        const padding = 14;
        const tableWidth = colWidths.reduce((sum,w) => sum + w, 0);

        mctx.font = fontCaption;
        const captionLines = captionRuns.length ? layoutCaptionLines(mctx,captionRuns,tableWidth-20) : [];
        const captionHeight = captionLines.length ? captionLines.length * 22 + 14 : 0;

        const rowHeights = rows.map(row => {
          if(row.type === "head") return headerHeight;
          if(row.cells.some(cell => cell.lines.some(line => String(line.kind||"").startsWith("change")))) return bodyChangeHeight;
          return row.cells.some(cell => cell.lines.length > 1) ? bodyQtyHeight : bodyBaseHeight;
        });

        const tableHeight = rowHeights.reduce((sum,h) => sum + h, 0);
        const width = tableWidth + padding * 2;
        const height = tableHeight + captionHeight + padding * 2;

        const scale = 2;
        const canvas = document.createElement("canvas");
        canvas.width = Math.ceil(width * scale);
        canvas.height = Math.ceil(height * scale);

        const ctx = canvas.getContext("2d", { alpha:false });
        ctx.scale(scale,scale);
        ctx.fillStyle = "#ffffff";
        ctx.fillRect(0,0,width,height);

        canvasRoundRect(ctx,0.5,0.5,width-1,height-1,18);
        ctx.fillStyle = "#ffffff";
        ctx.fill();
        ctx.strokeStyle = "#d8e0ee";
        ctx.lineWidth = 1;
        ctx.stroke();

        let y = padding;

        if(captionLines.length){
          ctx.fillStyle = "#f8fafc";
          ctx.fillRect(padding,y,tableWidth,captionHeight);
          ctx.strokeStyle = "#d8e0ee";
          ctx.strokeRect(padding,y,tableWidth,captionHeight);

          ctx.font = fontCaption;
          ctx.textAlign = "left";
          ctx.textBaseline = "middle";

          captionLines.forEach((line,index) => {
            drawCaptionLine(ctx,line,padding+10,y+15+index*22);
          });

          y += captionHeight;
        }

        rows.forEach((row,rowIndex) => {
          let x = padding;
          const rowHeight = rowHeights[rowIndex];

          row.cells.forEach((cell,colIndex) => {
            const w = colWidths[colIndex];
            const isHead = row.type === "head";
            const isEvenBody = row.type === "body" && ((rowIndex - headerRows.length) % 2 === 1);

            ctx.fillStyle = isHead ? "#dbeafe" : isEvenBody ? "#f8fafc" : "#ffffff";
            ctx.fillRect(x,y,w,rowHeight);

            ctx.strokeStyle = "#d8e0ee";
            ctx.lineWidth = 1;
            ctx.strokeRect(x,y,w,rowHeight);

            ctx.textAlign = cell.className.includes("left") ? "left" : "center";
            ctx.textBaseline = "middle";

            if(cell.lines.length > 1){
              const main = cell.lines.find(line => line.kind === "main")?.text || "";
              const avg = cell.lines.find(line => line.kind === "avg")?.text || "";
              const changeLine = cell.lines.find(line => String(line.kind||"").startsWith("change"));
              const lineX = ctx.textAlign === "left" ? x + 10 : x + w/2;
              const hasAvg = !!avg;
              const hasChange = !!changeLine;
              const mainOffset = hasAvg && hasChange ? -15 : -8;
              const secondOffset = hasAvg && hasChange ? 2 : 10;
              const thirdOffset = 18;

              ctx.font = fontMain;
              if(cell.isSunday) ctx.fillStyle = "#dc2626";
              else if(cell.isMax) ctx.fillStyle = "#dc2626";
              else if(cell.isMin) ctx.fillStyle = "#2563eb";
              else ctx.fillStyle = cell.isMoney ? "#047857" : "#0f172a";
              ctx.fillText(main, lineX, y + rowHeight/2 + mainOffset);

              if(hasAvg){
                ctx.font = fontAvg;
                ctx.fillStyle = cell.isSunday ? "#dc2626" : "#a16207";
                ctx.fillText(avg, lineX, y + rowHeight/2 + secondOffset);
              }

              if(hasChange){
                ctx.font = fontChange;
                ctx.fillStyle = changeLine.kind === "changeUp" ? "#dc2626" : changeLine.kind === "changeDown" ? "#2563eb" : "#64748b";
                ctx.fillText(changeLine.text, lineX, y + rowHeight/2 + (hasAvg ? thirdOffset : secondOffset));
              }
            }else{
              ctx.font = isHead ? fontHead : fontMain;

              if(cell.isSunday) ctx.fillStyle = "#dc2626";
              else if(cell.isMax) ctx.fillStyle = "#dc2626";
              else if(cell.isMin) ctx.fillStyle = "#2563eb";
              else if(isHead) ctx.fillStyle = "#0f172a";
              else if(cell.isMoney) ctx.fillStyle = "#047857";
              else if(cell.isWarn) ctx.fillStyle = "#a16207";
              else ctx.fillStyle = "#0f172a";

              const text = cell.lines[0]?.text || "";
              ctx.fillText(text, ctx.textAlign === "left" ? x + 10 : x + w/2, y + rowHeight/2);
            }

            x += w;
          });

          y += rowHeight;
        });

        return canvas;
      }


