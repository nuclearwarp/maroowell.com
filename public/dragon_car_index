                <button class="btn" type="button" data-deduction-action="cancel">취소</button>
                <button class="btn primary" type="button" data-deduction-action="save">저장</button>
              </div>
            </div>
          </div>
        `;

        document.body.appendChild(root);
        state.deduction.root = root;

        root.addEventListener("click", async (e) => {
          const actionEl = e.target.closest("[data-deduction-action]");
          if (!actionEl) {
            if (e.target === root) closeDeductionModal();
            return;
          }

          const action = actionEl.dataset.deductionAction;

          if (action === "close" || action === "cancel") {
            closeDeductionModal();
            return;
          }

          if (action === "add") {
            state.deduction.items.push(cloneDeductionItem());
            renderDeductionModal();
            return;
          }

          if (action === "delete") {
            const idx = Number(actionEl.dataset.index);
            const item = state.deduction.items[idx];
            if (!item) return;

            if (item.id) item.__delete = !item.__delete;
            else state.deduction.items.splice(idx, 1);

            renderDeductionModal();
            return;
          }

          if (action === "save") {
            await saveDeductions();
          }
        });

