          id:driverId || null,
          route:null,
          delivery_date:deliveryDate,
          camp:camp || null,
          wave:null,
          company_name:companyName || null,
          driver_name:driverName || null,
          parcel:0,
          "return":0,
          price:0,
          freshbag_incentive:0,
          default_price:0,
          freshbag_incentive_price:0,
          freshbag_return:0,
          total_price:-Math.abs(deductionPrice),
          loss_damage_type:lossType || null,
          loss_damage_detail:lossDetail || null,
          loss_damage_count:lossCount,
          deduction_price:deductionPrice,
          tracking_number:trackingNumber || null,
          product_name:productName || null
        };

        return {
          skip:false,
          data,
          validation:{
            hasError:false,
            exempt:false,
            errors:[],
            notes:["분실및파손: 차감금액을 deduction_price에 저장하고 total_price에는 음수로 반영"],
            expectedDefault:null,
            expectedFreshbag:null,
            expectedTotal:null,
