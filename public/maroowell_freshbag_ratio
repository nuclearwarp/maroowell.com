<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>마루웰 회수율</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>

  <style>
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --card:#ffffff;
      --soft:#f8fafc;
      --line:#d8e0ee;
      --line2:#cbd5e1;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --blue2:#60a5fa;
      --green:#16a34a;
      --red:#dc2626;
      --orange:#c2410c;
      --cyan:#dff4ff;
      --cyanText:#075985;
      --shadow:0 12px 30px rgba(15,23,42,.08);
      --font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      min-height:100vh;
      background:
        radial-gradient(circle at 16% 0%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 86% 0%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,#f6f8fc 100%);
      color:var(--txt);
      font-family:var(--font);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
      font-weight:400;
    }

    body,
    input,
    select,
    button,
    table,
    th,
    td,
    .pill,
    .status,
    .hint,
    .sub,
    .title,
    .sectionTitle{
      font-weight:400 !important;
      letter-spacing:-0.015em;
      text-shadow:none;
      -webkit-text-stroke:0 transparent;
    }

    b,strong{font-weight:520}

    .wrap{
      max-width:1760px;
      margin:0 auto;
      padding:18px 16px 40px;
    }

    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:16px;
      padding:14px 16px;
      border:1px solid var(--line);
      border-radius:22px;
      background:rgba(255,255,255,.94);
      box-shadow:var(--shadow);
      backdrop-filter:blur(12px);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .brand a{
      display:flex;
      align-items:center;
      justify-content:center;
      width:34px;
      height:34px;
      min-width:34px;
      padding:0;
      border:0;
      background:transparent;
      box-shadow:none;
    }

    .brand img{
      width:34px;
      height:34px;
      object-fit:contain;
      filter:drop-shadow(0 4px 8px rgba(15,23,42,.10));
    }

    .title{
      color:#0f172a;
      font-size:24px;
      font-weight:520 !important;
      letter-spacing:-.04em;
      line-height:1.15;
      word-break:keep-all;
    }

    .sub{
      color:#64748b;
      font-size:13px;
      line-height:1.5;
      margin-top:5px;
      word-break:keep-all;
    }

    .topActions{
      display:inline-flex;
      align-items:center;
      justify-content:flex-end;
      gap:8px;
      flex:0 0 auto;
      margin-left:auto;
    }

    .card{
      background:#fff;
      border:1px solid var(--line);
      border-radius:20px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:var(--shadow);
    }

    .row{
      display:flex;
      gap:10px;
      align-items:flex-end;
      flex-wrap:wrap;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    .field label{
      color:#64748b;
      font-size:12px;
      font-weight:450 !important;
      margin-left:2px;
    }

    input,select{
      height:42px;
      border-radius:12px;
      border:1px solid var(--line2);
      background:#f8fafc;
      color:#0f172a;
      padding:0 12px;
      outline:none;
      min-width:140px;
      font-family:var(--font);
      font-size:13px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.75);
    }

    select:disabled{
      opacity:1;
      color:#1d4ed8;
      border-color:#bfdbfe;
      background:#eff6ff;
      cursor:not-allowed;
    }

    input:focus,select:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
      background:#fff;
    }

    select option{
      background:#fff;
      color:#0f172a;
    }

    .campInput{min-width:190px}
    .routeInput{min-width:320px}

    button{
      min-height:42px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      padding:0 18px;
      font-family:var(--font);
      font-size:13px;
      font-weight:480 !important;
      cursor:pointer;
      white-space:nowrap;
      box-shadow:0 1px 0 rgba(255,255,255,.85),0 4px 12px rgba(15,23,42,.04);
    }

    button:hover{background:#f8fbff;border-color:#93c5fd}
    button.primary{background:linear-gradient(180deg,#3b82f6,#2563eb);border-color:#2563eb;color:#fff;box-shadow:0 8px 18px rgba(37,99,235,.18)}
    button.primary:hover{background:linear-gradient(180deg,#2563eb,#1d4ed8)}
    button.secondary{background:#f8fafc;color:#334155}
    button.secondary:hover{background:#eff6ff;color:#0f172a}
    button.danger{background:#fff5f5;border-color:#fecaca;color:#dc2626}
    button.danger:hover{background:#fee2e2}

    #mwRatioUploadSwitchBtn{
      min-height:32px !important;
      height:32px !important;
      width:auto !important;
      min-width:auto !important;
      padding:0 13px !important;
      border-radius:999px !important;
      border:1px solid #bfdbfe !important;
      background:#eff6ff !important;
      color:#1d4ed8 !important;
      font-size:12px !important;
      line-height:30px !important;
      box-shadow:0 6px 14px rgba(15,23,42,.06) !important;
      flex:0 0 auto;
    }

    #mwRatioUploadSwitchBtn.is-upload{
      border-color:#bbf7d0 !important;
      background:#f0fdf4 !important;
      color:#15803d !important;
    }

    .hint{
      color:#64748b;
      font-size:13px;
      line-height:1.55;
      margin-top:10px;
      word-break:keep-all;
    }

    .status{
      color:#64748b;
      font-size:13px;
      line-height:1.55;
      margin-top:10px;
      word-break:keep-all;
    }

    .status.ok{color:#15803d}
    .status.bad{color:#dc2626}
    .status.warn{color:#a16207}

    .summary{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      min-height:32px;
      padding:0 12px;
      border:1px solid #d8e0ee;
      border-radius:999px;
      background:#f8fafc;
      color:#64748b;
      font-size:12px;
      white-space:nowrap;
      box-shadow:none;
    }

    .pill strong{
      color:#0f172a;
      margin-left:5px;
      font-weight:520;
    }

    .sectionTitle{
      font-size:18px;
      font-weight:520 !important;
      margin:0 0 12px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      letter-spacing:-.03em;
    }

    .sectionTitle small{
      color:#64748b;
      font-size:12px;
      font-weight:400 !important;
    }

    .weekActions{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
    }

    .tableWrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:#fff;
      max-height:620px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.7);
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:max-content;
      min-width:100%;
      table-layout:fixed;
      font-size:13px;
      color:#0f172a;
      background:#fff;
    }

    th,td{
      border-right:1px solid #d8e0ee;
      border-bottom:1px solid #d8e0ee;
      text-align:center;
      white-space:nowrap;
      min-width:88px;
      max-width:190px;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    th{
      position:sticky;
      top:0;
      z-index:5;
      background:#dbeafe;
      color:#0f172a;
      font-weight:520 !important;
      padding:8px 10px;
    }

    td{
      background:#fff;
      padding:0;
      height:58px;
    }

    .fixedCell{
      padding:8px 10px;
      background:#f8fafc;
      color:#0f172a;
      font-weight:450 !important;
    }

    .routeCell{color:#1d4ed8}

    .ratioBox{
      display:grid;
      grid-template-rows:1fr 1fr;
      height:100%;
      min-height:58px;
    }

    .ratioLine{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:4px;
      font-weight:520 !important;
      padding:5px 8px;
      border-bottom:1px solid #d8e0ee;
      line-height:1.15;
    }

    .ratioLine:last-child{border-bottom:0}
    .ratioLabel{font-size:11px;opacity:.8;font-weight:400 !important}

    .ratioGood{background:#dff4ff;color:#075985}
    .ratioBad{background:#fff;color:#dc2626}
    .ratioEmpty{color:#94a3b8;background:#f8fafc;font-weight:400 !important}

    .ratioSubSep td{
      border-top:1.5px solid #64748b !important;
    }

    .ratioRouteSep td{
      border-top:4px double #64748b !important;
    }

    .ratioCampSep td{
      border-top:4px double #334155 !important;
    }

    .ratioSubSep td,
    .ratioSubSep td .ratioLine{
      box-shadow:none !important;
    }

    .ratioRouteSep td,
    .ratioRouteSep td .ratioLine,
    .ratioCampSep td,
    .ratioCampSep td .ratioLine{
      box-shadow:none !important;
    }

    .weekBlock{margin-top:18px}

    .weekTitle{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-bottom:8px;
      color:#0f172a;
      font-weight:520 !important;
    }

    .weekTitle small{
      color:#64748b;
      font-weight:400 !important;
    }

    .dayHead,
    .dayCell{
      min-width:124px;
      max-width:124px;
    }

    .emptyDay{
      color:#94a3b8;
      background:#f8fafc;
      font-weight:400 !important;
    }

    #mwRatioViewPanel[hidden],
    #mwRatioUploadPanel[hidden]{
      display:none !important;
    }

    .mw-ratio-upload-frame{
      display:block;
      width:100%;
      height:calc(100vh - 112px);
      min-height:760px;
      border:0;
      border-radius:20px;
      background:#f6f8fc;
      box-shadow:var(--shadow);
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(246,248,252,.96), rgba(255,255,255,.98));
      z-index:9999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(540px, calc(100vw - 24px));
      border:1px solid #d8e0ee;
      border-radius:22px;
      background:#fff;
      box-shadow:0 24px 60px rgba(15,23,42,.16);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
      font-weight:560;
    }

    .accessCard p{
      margin:0;
      color:#64748b;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid #d8e0ee;
      background:#f8fafc;
      color:#0f172a;
      font-size:13px;
      font-weight:450;
      word-break:break-word;
      line-height:1.6;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    .captureTarget{
      background:#fff;
    }

    @media(max-width:900px){
      .wrap{padding:12px 10px 28px}
      .top{flex-direction:column;align-items:stretch;padding:13px 14px;border-radius:20px}
      .brand{align-items:flex-start}
      .brand img,.brand a{width:30px;height:30px;min-width:30px}
      .title{font-size:21px;line-height:1.12}
      .sub{font-size:12px}
      .topActions{justify-content:flex-end;width:100%}
      .card{padding:12px;border-radius:18px}
      .row{flex-direction:column;align-items:stretch}
      input,select,button,
      .campInput,.routeInput{width:100%;min-width:0}
      #mwRatioUploadSwitchBtn{width:auto !important;align-self:flex-end}
      .sectionTitle{align-items:flex-start;flex-direction:column}
      .weekTitle{align-items:flex-start;flex-direction:column}
      .mw-ratio-upload-frame{height:calc(100vh - 160px);min-height:720px;border-radius:18px}
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <a href="#" id="mwBoardMenuToggle"><img src="/favicon.ico" alt="MarooWell"></a>
        <div>
          <div class="title">마루웰 회수율</div>
          <div class="sub">쿠팡 정산월 기준으로 월 누적 회수율과 주차별 일자 회수율을 조회합니다.</div>
        </div>
      </div>
      <div class="pill" id="userPill">세션 확인 중</div>
    </div>

    <div class="card">
      <div class="row">
        <div class="field">
          <label>연도</label>
          <select id="yearFilter"></select>
        </div>

        <div class="field">
          <label>월</label>
          <select id="monthFilter"></select>
        </div>

        <div class="field">
          <label>Camp</label>
          <select id="campFilter" class="campInput">
            <option value="">캠프 선택</option>
            <option value="일산2">일산2 - 주간</option>
            <option value="용인3">용인3 - 주간</option>
            <option value="대구3">대구3 - 주간</option>
            <option value="M익산1">M익산1 - 야간</option>
          </select>
        </div>

        <div class="field">
          <label>주간/야간</label>
          <select id="waveFilter" disabled>
            <option value="">자동 선택</option>
            <option value="W2">주간</option>
            <option value="W1">야간</option>
          </select>
        </div>

        <div class="field">
          <label>Route</label>
          <input id="routeFilter" class="routeInput" placeholder="예: 126A/126B/126C 또는 126_A" />
        </div>

        <button id="loadBtn" class="primary">조회</button>
        <button id="clearBtn" class="secondary">초기화</button>
      </div>

      <div class="hint" id="periodHint">
        쿠팡 정산월 기준입니다. 예: 4월 데이터 = 3월 26일 ~ 4월 25일.
      </div>

      <div class="hint">
        Camp 선택 시 주간/야간은 자동 선택됩니다. M익산1은 백엔드 조회 시 자동으로 <b>M_익산1</b>로 변환됩니다.
      </div>

      <div class="status" id="statusText">대기 중</div>

      <div class="summary">
        <span class="pill">월누적 <strong id="totalCount">0</strong></span>
        <span class="pill">일자별 <strong id="dailyCount">0</strong></span>
        <span class="pill">표시 행 <strong id="routeCount">0</strong></span>
        <span class="pill">캠프 <strong id="campCount">0</strong></span>
        <span class="pill">일자 <strong id="dateCount">0</strong></span>
      </div>
    </div>

    <div class="card">
      <div class="sectionTitle">
        <span>월 누적 회수율</span>
        <div class="weekActions">
          <small id="totalPeriodText"></small>
          <button type="button" class="secondary" id="copyTotalImageBtn">이미지 복사</button>
        </div>
      </div>
      <div class="tableWrap captureTarget" id="totalCaptureTarget">
        <table id="totalTable">
          <thead></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="sectionTitle">
        <span>주차별 일자 회수율</span>
        <small>각 주차 우측의 이미지 복사 버튼 사용</small>
      </div>
      <div id="weekContainer"></div>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">마루웰 소속 권한이 필요합니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="deniedHomeBtn" class="secondary" type="button">홈으로</button>
        <button id="deniedLogoutBtn" class="danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};

  const API_BASE = String(
    cfg.MAROOWELL_FRESHBAG_API_BASE ||
    cfg.MAROOWELL_FRESHBAG_API ||
    cfg.BACKENDS?.maroowellFreshbag ||
    "https://maroowellfreshbag.brain-0f6.workers.dev"
  ).replace(/\/+$/, "");

  const CAMP_WAVE_MAP = {
    "일산2":"W2",
    "용인3":"W2",
    "대구3":"W2",
    "M익산1":"W1",
    "M_익산1":"W1"
  };

  let supabaseClient = null;
  let currentUser = null;
  let currentAccessToken = "";
  let currentAccess = null;

  let totalRows = [];
  let dailyRows = [];
  let routeRows = [];

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg;
    $("statusText").className = type ? "status " + type : "status";
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function compact(v) {
    return clean(v).replace(/\s+/g, "");
  }

  function campKey(v) {
    return compact(v).replace(/_/g, "").toUpperCase();
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function routeGroup(v) {
    const s = normalizeRoute(v);
    const m = s.match(/^(\d+)/);
    return m ? m[1] : s;
  }

  function rowSeparatorClass(list, index) {
    if (index <= 0) return "";

    const prev = list[index - 1];
    const row = list[index];

    const prevCamp = clean(prev?.camp);
    const thisCamp = clean(row?.camp);
    const prevWave = clean(prev?.wave).toUpperCase();
    const thisWave = clean(row?.wave).toUpperCase();

    if ((prevCamp && thisCamp && prevCamp !== thisCamp) || (prevWave && thisWave && prevWave !== thisWave)) {
      return "ratioCampSep";
    }

    const prevGroup = routeGroup(prev?.route_norm || prev?.route);
    const thisGroup = routeGroup(row?.route_norm || row?.route);

    if (prevGroup && thisGroup && prevGroup !== thisGroup) {
      return "ratioRouteSep";
    }

    return "ratioSubSep";
  }

  function sortRatioRows(rows) {
    const waveOrder = { W2:1, W1:2 };

    return rows.slice().sort((a, b) => {
      return (
        String(a.camp || "").localeCompare(String(b.camp || ""), "ko", { numeric:true }) ||
        ((waveOrder[String(a.wave || "").toUpperCase()] || 9) - (waveOrder[String(b.wave || "").toUpperCase()] || 9)) ||
        String(normalizeRoute(a.route_norm || a.route)).localeCompare(String(normalizeRoute(b.route_norm || b.route)), "ko", { numeric:true })
      );
    });
  }

  function campDbValue(value) {
    const raw = compact(value);
    const key = campKey(raw);

    if (key === campKey("M익산1") || key === campKey("M_익산1")) return "M_익산1";

    return clean(value);
  }

  function waveForCamp(value) {
    const dbCamp = campDbValue(value);
    return CAMP_WAVE_MAP[dbCamp] || CAMP_WAVE_MAP[clean(value)] || "";
  }

  function syncWaveFromCamp() {
    const camp = clean($("campFilter").value);
    const wave = waveForCamp(camp);

    $("waveFilter").value = wave || "";

    return wave;
  }

  function waveLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "W2") return "주간";
    if (s === "W1") return "야간";
    return s || "";
  }

  function pad2(n) {
    return String(Number(n)).padStart(2, "0");
  }

  function isoDate(date) {
    return `${date.getFullYear()}-${pad2(date.getMonth() + 1)}-${pad2(date.getDate())}`;
  }

  function parseIsoDate(iso) {
    const [y, m, d] = String(iso).split("-").map(Number);
    return new Date(y, m - 1, d);
  }

  function addDays(date, days) {
    return new Date(date.getFullYear(), date.getMonth(), date.getDate() + days);
  }

  function formatKoreanDate(iso) {
    const d = parseIsoDate(iso);
    const days = ["일", "월", "화", "수", "목", "금", "토"];
    return `${d.getMonth() + 1}/${d.getDate()} ${days[d.getDay()]}`;
  }

  function formatPercent(v) {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    if (!Number.isFinite(n)) return "";
    return n.toFixed(2) + "%";
  }

  function isGoodValue(field, wave, value) {
    if (value === null || value === undefined || value === "") return false;

    const n = Number(value);
    if (!Number.isFinite(n)) return false;

    if (field === "gajoong1") return n >= 95;
    if (field === "gajoong2") return clean(wave).toUpperCase() === "W1" ? n >= 75 : n >= 85;

    return false;
  }

  function valueClass(field, wave, value) {
    if (value === null || value === undefined || value === "") return "ratioEmpty";
    return isGoodValue(field, wave, value) ? "ratioGood" : "ratioBad";
  }

  function ratioBox(row) {
    return `
      <div class="ratioBox">
        <div class="ratioLine ${valueClass("gajoong1", row.wave, row.gajoong1)}">
          <span class="ratioLabel">가중1:</span>
          <span>${esc(formatPercent(row.gajoong1) || "-")}</span>
        </div>
        <div class="ratioLine ${valueClass("gajoong2", row.wave, row.gajoong2)}">
          <span class="ratioLabel">가중2:</span>
          <span>${esc(formatPercent(row.gajoong2) || "-")}</span>
        </div>
      </div>
    `;
  }

  function routeListFromInput() {
    const raw = clean($("routeFilter").value);
    if (!raw) return [];

    return raw
