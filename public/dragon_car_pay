  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 최고관리자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const INDEX_PATH = PATHS?.index || "/index.html";
      const LOGIN_PATH = PATHS?.login || "/login.html";

      const ACCESS_TABLE = "user_access";
      const PAY_TABLE = "dragon_car_pay";
      const DEDUCTION_TABLE = "dragon_car_pay_deduction";

      const PAY_COLUMNS = [
        "work_date",
        "order_name",
        "camp_code",
        "wave",
        "route_code",
        "unit_price",
        "driver_name",
        "delivery_count",
        "return_count",
        "settlement_year",
        "settlement_month",
        "settlement_date",
        "tax_invoice_status",
        "payment_status",
        "note"
      ];

      const DEDUCTION_COLUMNS = [
        "deduction_date",
        "order_name",
        "camp_code",
        "driver_name",
        "deduction_amount",
        "deduction_status",
        "note",
        "settlement_year",
        "settlement_month"
      ];

      const PAY_COLUMN_CONFIG = [
        { key: "pk_id", type: "readonly", className: "right code center" },
        { key: "work_date", type: "date", className: "center code" },
        { key: "order_name" },
        { key: "camp_code", className: "center" },
        { key: "wave", type: "select", options: ["", "주간", "야간", "주/야"], className: "center" },
        { key: "route_code" },
        { key: "unit_price", type: "number", className: "right code" },
        { key: "driver_name", className: "center" },
        { key: "delivery_count", type: "number", className: "right code" },
        { key: "return_count", type: "number", className: "right code" },
        { key: "settlement_month_label", type: "readonly", className: "center code" },
        { key: "settlement_date", type: "date", className: "center code" },
        { key: "tax_invoice_status", type: "select", options: ["", "발행", "미발행"], className: "center" },
        { key: "payment_status", type: "select", options: ["", "입금", "미입금", "대기"], className: "center" },
        { key: "note" }
      ];

      const DEDUCTION_COLUMN_CONFIG = [
        { key: "pk_id", type: "readonly", className: "right code center" },
        { key: "deduction_date", type: "date", className: "center code" },
        { key: "order_name" },
        { key: "camp_code", className: "center" },
        { key: "driver_name", className: "center" },
        { key: "deduction_amount", type: "number", className: "right code" },
        { key: "deduction_status", type: "select", options: ["", "입금O", "차감 확정", "차감취소", "대기"], className: "center" },
        { key: "note" }
      ];

      const $ = (sel) => document.querySelector(sel);

      const dom = {
        yearSelect: $("#yearSelect"),
        monthSelect: $("#monthSelect"),
        orderSearchInput: $("#orderSearchInput"),
        btnClearSearch: $("#btnClearSearch"),
        btnReload: $("#btnReload"),
        btnSaveAll: $("#btnSaveAll"),
        btnExportCsv: $("#btnExportCsv"),
        btnLogout: $("#btnLogout"),

        monthLabelValue: $("#monthLabelValue"),
        sideVendorCount: $("#sideVendorCount"),
        sideRowCount: $("#sideRowCount"),
        sideMonthGross: $("#sideMonthGross"),
        sideMonthDeduction: $("#sideMonthDeduction"),
        orderList: $("#orderList"),

        heroTitle: $("#heroTitle"),
        heroSub: $("#heroSub"),
        kpiGross: $("#kpiGross"),
        kpiDeduction: $("#kpiDeduction"),
        kpiNet: $("#kpiNet"),
        kpiUnpaidCount: $("#kpiUnpaidCount"),

        statementBody: $("#statementBody"),
        payEditorBody: $("#payEditorBody"),
        deductionEditorBody: $("#deductionEditorBody"),

        btnAddPayRow: $("#btnAddPayRow"),
        btnAddDeductionRow: $("#btnAddDeductionRow"),

        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillDeductions: $("#pillDeductions"),
        pillDirty: $("#pillDirty"),
        statusText: $("#statusText"),

        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout")
      };

      const state = {
        session: null,
        viewerEmail: "",
        viewerUserId: "",
        accessRow: null,

        year: new Date().getFullYear(),
        month: new Date().getMonth() + 1,

        payRows: [],
        deductionRows: [],
        filteredOrders: [],
        selectedOrder: "",

        deletedPayIds: new Set(),
        deletedDeductionIds: new Set(),

        tempSeq: 0,
        loading: false
      };

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function toNumber(v) {
        if (v == null || v === "") return 0;
        const n = Number(String(v).replace(/[^\d.-]/g, ""));
        return Number.isFinite(n) ? n : 0;
      }

      function formatNumber(v) {
        return new Intl.NumberFormat("ko-KR").format(toNumber(v));
      }

      function formatCurrency(v) {
        return "₩" + formatNumber(v);
      }

      function formatDate(v) {
        const s = normalizeText(v);
        if (!s) return "";
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
        if (/^\d{4}\.\d{1,2}\.\d{1,2}$/.test(s)) {
          const [y, m, d] = s.split(".");
          return `${y.padStart(4, "0")}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
        }
        const d = new Date(s);
        if (!Number.isNaN(d.getTime())) {
          const yy = d.getFullYear();
          const mm = String(d.getMonth() + 1).padStart(2, "0");
          const dd = String(d.getDate()).padStart(2, "0");
          return `${yy}-${mm}-${dd}`;
        }
        return s;
      }

      function makeMonthLabel(year, month) {
        return `${year}년 ${month}월`;
      }

      function rowId(row) {
        return row.pk_id ?? row.__temp_id;
      }

      function payAmount(row) {
        return (toNumber(row.delivery_count) + toNumber(row.return_count)) * toNumber(row.unit_price);
      }

      function isUnpaid(row) {
        const s = normalizeText(row.payment_status);
        return s && !/입금/i.test(s);
      }

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";
        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnSaveAll.disabled = !!on;
        dom.btnExportCsv.disabled = !!on;
        dom.btnAddPayRow.disabled = !!on;
        dom.btnAddDeductionRow.disabled = !!on;
        if (on) setStatus(text || "처리 중...", "warn");
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "이 페이지는 최고관리자만 접근할 수 있습니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";
        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function requireAdmin() {
        if (!supabase || !supabase.auth) {
          alert("Supabase 설정을 확인하세요.");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();

          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          state.session = session;
          state.viewerEmail = normalizeText(session.user?.email || "");
          state.viewerUserId = normalizeText(session.user?.id || "");

          if (!state.viewerUserId) {
            showAccessDenied(state.viewerEmail, "로그인 사용자 ID를 확인할 수 없습니다.");
            return false;
          }

          const { data: accessRow, error } = await supabase
            .from(ACCESS_TABLE)
            .select("user_id, email, is_maroowell, is_admin")
            .eq("user_id", state.viewerUserId)
            .maybeSingle();

          if (error) {
            console.error(error);
            showAccessDenied(state.viewerEmail, "권한 테이블 조회 실패: " + error.message);
            return false;
          }

          state.accessRow = accessRow || null;

          if (!accessRow?.is_admin) {
            showAccessDenied(state.viewerEmail, "이 페이지는 최고관리자만 접근할 수 있습니다.");
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          console.error(e);
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      function buildYearMonthOptions() {
        const now = new Date();
        const years = [];
        for (let y = now.getFullYear() - 2; y <= now.getFullYear() + 2; y++) years.push(y);

        dom.yearSelect.innerHTML = years.map(y => {
          const selected = y === state.year ? "selected" : "";
          return `<option value="${y}" ${selected}>${y}년</option>`;
        }).join("");

        dom.monthSelect.innerHTML = Array.from({ length: 12 }, (_, i) => i + 1).map(m => {
          const selected = m === state.month ? "selected" : "";
          return `<option value="${m}" ${selected}>${m}월</option>`;
        }).join("");
      }

      function normalizePayRow(row) {
        const out = { ...(row || {}) };
        for (const key of PAY_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }
        out.work_date = formatDate(out.work_date);
        out.settlement_date = formatDate(out.settlement_date);
        out.settlement_year = out.settlement_year ? String(out.settlement_year) : String(state.year);
        out.settlement_month = out.settlement_month ? String(out.settlement_month) : String(state.month);
        out.__dirty = false;
        out.__dirtyFields = {};
        out.__isNew = false;
        return out;
      }

      function normalizeDeductionRow(row) {
        const out = { ...(row || {}) };
        for (const key of DEDUCTION_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }
        out.deduction_date = formatDate(out.deduction_date);
        out.settlement_year = out.settlement_year ? String(out.settlement_year) : String(state.year);
        out.settlement_month = out.settlement_month ? String(out.settlement_month) : String(state.month);
        out.__dirty = false;
        out.__dirtyFields = {};
        out.__isNew = false;
        return out;
      }

      function makeBlankPayRow() {
        return {
          __temp_id: "pay_new_" + (++state.tempSeq),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {},
          work_date: "",
          order_name: state.selectedOrder || "",
          camp_code: "",
          wave: "주간",
          route_code: "",
          unit_price: "",
          driver_name: "",
          delivery_count: "",
          return_count: "",
          settlement_year: String(state.year),
          settlement_month: String(state.month),
          settlement_date: "",
          tax_invoice_status: "",
          payment_status: "",
          note: ""
        };
      }

      function makeBlankDeductionRow() {
        return {
          __temp_id: "ded_new_" + (++state.tempSeq),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {},
          deduction_date: "",
          order_name: state.selectedOrder || "",
          camp_code: "",
          driver_name: "",
          deduction_amount: "",
          deduction_status: "",
          note: "",
          settlement_year: String(state.year),
          settlement_month: String(state.month)
        };
      }

      function markRowDirty(row, key, value) {
        row[key] = value;
        row.__dirty = true;
        row.__dirtyFields = row.__dirtyFields || {};
        row.__dirtyFields[key] = true;
      }

      async function fetchData() {
        try {
          setLoading(true, "데이터 불러오는 중...");

          state.deletedPayIds.clear();
          state.deletedDeductionIds.clear();

          const year = String(state.year);
          const month = String(state.month);

          const { data: payData, error: payError } = await supabase
            .from(PAY_TABLE)
            .select("*")
            .eq("settlement_year", year)
            .eq("settlement_month", month)
            .order("work_date", { ascending: true })
            .order("pk_id", { ascending: true });

          if (payError) throw payError;

          const { data: deductionData, error: deductionError } = await supabase
            .from(DEDUCTION_TABLE)
            .select("*")
            .eq("settlement_year", year)
            .eq("settlement_month", month)
            .order("deduction_date", { ascending: true })
            .order("pk_id", { ascending: true });

          if (deductionError) throw deductionError;

          state.payRows = Array.isArray(payData) ? payData.map(normalizePayRow) : [];
          state.deductionRows = Array.isArray(deductionData) ? deductionData.map(normalizeDeductionRow) : [];

          renderAll();
        } catch (e) {
          console.error(e);
          state.payRows = [];
          state.deductionRows = [];
          renderAll();
          setStatus("불러오기 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      function getVisiblePayRows() {
        return state.payRows.filter(row => !(row.pk_id && state.deletedPayIds.has(row.pk_id)));
      }

      function getVisibleDeductionRows() {
        return state.deductionRows.filter(row => !(row.pk_id && state.deletedDeductionIds.has(row.pk_id)));
      }

      function getOrderStats() {
        const payRows = getVisiblePayRows();
        const deductionRows = getVisibleDeductionRows();
        const q = normalizeLower(dom.orderSearchInput.value);

        const map = new Map();

        for (const row of payRows) {
          const orderName = normalizeText(row.order_name);
          if (!orderName) continue;

          const bag = [
            row.order_name,
            row.driver_name,
            row.camp_code,
            row.route_code
          ].map(normalizeLower).join(" | ");

          if (q && !bag.includes(q)) continue;

          if (!map.has(orderName)) {
            map.set(orderName, {
              orderName,
              gross: 0,
              deduction: 0,
              rowCount: 0,
              unpaidCount: 0,
              camps: new Set(),
              drivers: new Set()
            });
          }

          const s = map.get(orderName);
          s.gross += payAmount(row);
          s.rowCount += 1;
          if (isUnpaid(row)) s.unpaidCount += 1;
          if (normalizeText(row.camp_code)) s.camps.add(normalizeText(row.camp_code));
          if (normalizeText(row.driver_name)) s.drivers.add(normalizeText(row.driver_name));
        }

        for (const row of deductionRows) {
          const orderName = normalizeText(row.order_name);
          if (!orderName) continue;

          const bag = [
            row.order_name,
            row.driver_name,
            row.camp_code,
            row.note
          ].map(normalizeLower).join(" | ");

          if (q && !bag.includes(q)) continue;

          if (!map.has(orderName)) {
            map.set(orderName, {
              orderName,
              gross: 0,
              deduction: 0,
              rowCount: 0,
              unpaidCount: 0,
              camps: new Set(),
              drivers: new Set()
            });
          }

          const s = map.get(orderName);
          s.deduction += toNumber(row.deduction_amount);
          if (normalizeText(row.camp_code)) s.camps.add(normalizeText(row.camp_code));
          if (normalizeText(row.driver_name)) s.drivers.add(normalizeText(row.driver_name));
        }

        const list = Array.from(map.values()).map(item => ({
          ...item,
          net: item.gross - item.deduction,
          campCount: item.camps.size,
          driverCount: item.drivers.size
        }));

        list.sort((a, b) => {
          if (b.net !== a.net) return b.net - a.net;
          return a.orderName.localeCompare(b.orderName, "ko");
        });

        return list;
      }

      function ensureSelectedOrder(orderStats) {
        if (state.selectedOrder && orderStats.some(x => x.orderName === state.selectedOrder)) return;
        state.selectedOrder = orderStats[0]?.orderName || "";
      }

      function getSelectedPayRows() {
        const order = state.selectedOrder;
        return getVisiblePayRows()
          .filter(row => normalizeText(row.order_name) === order)
          .sort((a, b) => {
            const da = formatDate(a.work_date);
            const db = formatDate(b.work_date);
            return da.localeCompare(db) || String(a.pk_id ?? "").localeCompare(String(b.pk_id ?? ""));
          });
      }

      function getSelectedDeductionRows() {
        const order = state.selectedOrder;
        return getVisibleDeductionRows()
          .filter(row => normalizeText(row.order_name) === order)
          .sort((a, b) => {
            const da = formatDate(a.deduction_date);
            const db = formatDate(b.deduction_date);
            return da.localeCompare(db) || String(a.pk_id ?? "").localeCompare(String(b.pk_id ?? ""));
          });
      }

      function renderSidebar(orderStats) {
        dom.monthLabelValue.textContent = makeMonthLabel(state.year, state.month);

        const monthGross = orderStats.reduce((acc, x) => acc + x.gross, 0);
        const monthDeduction = orderStats.reduce((acc, x) => acc + x.deduction, 0);

        dom.sideVendorCount.textContent = String(orderStats.length);
        dom.sideRowCount.textContent = String(getVisiblePayRows().length);
        dom.sideMonthGross.textContent = formatCurrency(monthGross);
        dom.sideMonthDeduction.textContent = formatCurrency(monthDeduction);

        if (!orderStats.length) {
          dom.orderList.innerHTML = `<div class="empty">해당 월 데이터가 없습니다.</div>`;
          return;
        }

        dom.orderList.innerHTML = orderStats.map(item => {
          const active = item.orderName === state.selectedOrder ? "active" : "";
          return `
            <div class="orderItem ${active}" data-order-pick="${escapeHtml(item.orderName)}">
              <div class="orderTop">
                <div class="orderName">${escapeHtml(item.orderName)}</div>
                <div class="orderTag">${item.rowCount}건</div>
              </div>
              <div class="orderSub">
                <div>정산 <b>${escapeHtml(formatCurrency(item.gross))}</b></div>
                <div>차감 <b>${escapeHtml(formatCurrency(item.deduction))}</b></div>
                <div>실정산 <b>${escapeHtml(formatCurrency(item.net))}</b></div>
                <div>미입금 <b>${item.unpaidCount}</b></div>
              </div>
            </div>
          `;
        }).join("");
      }

      function renderSummary() {
        if (!state.selectedOrder) {
          dom.heroTitle.textContent = "벤더를 선택해줘";
          dom.heroSub.textContent = "좌측에서 Order를 선택하면 월 정산서와 편집 테이블이 같이 보인다.";
          dom.kpiGross.textContent = formatCurrency(0);
          dom.kpiDeduction.textContent = formatCurrency(0);
          dom.kpiNet.textContent = formatCurrency(0);
          dom.kpiUnpaidCount.textContent = "0";
          return;
        }

        const payRows = getSelectedPayRows();
        const deductionRows = getSelectedDeductionRows();

        const gross = payRows.reduce((acc, row) => acc + payAmount(row), 0);
        const deduction = deductionRows.reduce((acc, row) => acc + toNumber(row.deduction_amount), 0);
        const unpaidCount = payRows.filter(isUnpaid).length;
        const net = gross - deduction;

        const campSet = new Set(payRows.map(r => normalizeText(r.camp_code)).filter(Boolean));
        const driverSet = new Set(payRows.map(r => normalizeText(r.driver_name)).filter(Boolean));

        dom.heroTitle.textContent = `${state.selectedOrder} · ${makeMonthLabel(state.year, state.month)}`;
        dom.heroSub.textContent =
          `캠프 ${campSet.size}개 · 기사 ${driverSet.size}명 · 원장 ${payRows.length}건 · 차감 ${deductionRows.length}건`;

        dom.kpiGross.textContent = formatCurrency(gross);
        dom.kpiDeduction.textContent = formatCurrency(deduction);
        dom.kpiNet.textContent = formatCurrency(net);
        dom.kpiUnpaidCount.textContent = String(unpaidCount);
      }

      function renderStatement() {
        const rows = getSelectedPayRows();

        if (!rows.length) {
          dom.statementBody.innerHTML = `<tr><td colspan="12" class="empty">선택된 벤더 원장 데이터가 없습니다.</td></tr>`;
          return;
        }

        dom.statementBody.innerHTML = rows.map(row => {
          const amount = payAmount(row);
          const bad = isUnpaid(row) ? "bad" : "";
          return `
            <tr>
              <td><div class="cellView center code">${escapeHtml(formatDate(row.work_date))}</div></td>
              <td><div class="cellView center">${escapeHtml(normalizeText(row.camp_code))}</div></td>
              <td><div class="cellView center">${escapeHtml(normalizeText(row.wave))}</div></td>
              <td><div class="cellView left">${escapeHtml(normalizeText(row.route_code))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatCurrency(row.unit_price))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatNumber(row.delivery_count))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatNumber(row.return_count))}</div></td>
              <td><div class="cellView right code">${escapeHtml(formatCurrency(amount))}</div></td>
              <td class="${bad}"><div class="cellView center">${escapeHtml(normalizeText(row.payment_status) || "-")}</div></td>
              <td><div class="cellView center">${escapeHtml(normalizeText(row.tax_invoice_status) || "-")}</div></td>
              <td><div class="cellView center">${escapeHtml(normalizeText(row.driver_name))}</div></td>
              <td><div class="cellView left">${escapeHtml(normalizeText(row.note))}</div></td>
            </tr>
          `;
        }).join("");
      }

      function buildPayCell(row, col) {
        const rid = rowId(row);
        const dirty = row.__dirtyFields?.[col.key] ? "dirty" : "";
        const warn = col.key === "payment_status" && isUnpaid(row) ? "bad" : "";
        const cls = [dirty, warn].filter(Boolean).join(" ");

        if (col.type === "readonly") {
          const val = col.key === "pk_id"
            ? (row.pk_id ?? "NEW")
            : makeMonthLabel(Number(row.settlement_year || state.year), Number(row.settlement_month || state.month));
          return `<td class="${cls}"><div class="cellView ${col.className || ""}">${escapeHtml(val)}</div></td>`;
        }

        if (col.type === "select") {
          const current = normalizeText(row[col.key]);
          const options = (col.options || []).map(opt => {
            const selected = String(opt) === String(current) ? "selected" : "";
            const label = opt || "-";
            return `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(label)}</option>`;
          }).join("");

          return `
            <td class="${cls}">
              <select class="cellSelect ${col.className || ""}" data-table="pay" data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}">${options}</select>
            </td>
          `;
        }

        const inputType = col.type === "date" ? "date" : "text";
        const val = col.key === "settlement_month_label"
          ? makeMonthLabel(Number(row.settlement_year || state.year), Number(row.settlement_month || state.month))
          : normalizeText(row[col.key]);

        return `
          <td class="${cls}">
            <input
              class="cellInput ${col.className || ""}"
              type="${inputType}"
              value="${escapeHtml(val)}"
              data-table="pay"
              data-row-id="${escapeHtml(rid)}"
              data-key="${escapeHtml(col.key)}"
              autocomplete="off"
            />
          </td>
        `;
      }

      function buildDeductionCell(row, col) {
        const rid = rowId(row);
        const dirty = row.__dirtyFields?.[col.key] ? "dirty" : "";
        const cls = dirty;

        if (col.type === "readonly") {
          const val = row.pk_id ?? "NEW";
          return `<td class="${cls}"><div class="cellView ${col.className || ""}">${escapeHtml(val)}</div></td>`;
        }

        if (col.type === "select") {
          const current = normalizeText(row[col.key]);
          const options = (col.options || []).map(opt => {
            const selected = String(opt) === String(current) ? "selected" : "";
            const label = opt || "-";
            return `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(label)}</option>`;
          }).join("");

          return `
            <td class="${cls}">
              <select class="cellSelect ${col.className || ""}" data-table="deduction" data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}">${options}</select>
            </td>
          `;
        }

        const inputType = col.type === "date" ? "date" : "text";
        const val = normalizeText(row[col.key]);

        return `
          <td class="${cls}">
            <input
              class="cellInput ${col.className || ""}"
              type="${inputType}"
              value="${escapeHtml(val)}"
              data-table="deduction"
              data-row-id="${escapeHtml(rid)}"
              data-key="${escapeHtml(col.key)}"
              autocomplete="off"
            />
          </td>
        `;
      }

      function renderEditors() {
        const payRows = getVisiblePayRows();
        const deductionRows = getVisibleDeductionRows();

        if (!payRows.length) {
          dom.payEditorBody.innerHTML = `<tr><td colspan="16" class="empty">원장 데이터가 없습니다.</td></tr>`;
        } else {
          dom.payEditorBody.innerHTML = payRows.map(row => {
            const cells = PAY_COLUMN_CONFIG.map(col => buildPayCell(row, col)).join("");
            const deleteCls = row.__dirty ? "dirty" : "";
            return `
              <tr data-pay-row="${escapeHtml(rowId(row))}">
                ${cells}
                <td class="${deleteCls}">
                  <div class="cellView center">
                    <button class="tinyBtn delete" type="button" data-delete-table="pay" data-delete-row="${escapeHtml(rowId(row))}">✕</button>
                  </div>
                </td>
              </tr>
            `;
          }).join("");
        }

        if (!deductionRows.length) {
          dom.deductionEditorBody.innerHTML = `<tr><td colspan="9" class="empty">차감 데이터가 없습니다.</td></tr>`;
        } else {
          dom.deductionEditorBody.innerHTML = deductionRows.map(row => {
            const cells = DEDUCTION_COLUMN_CONFIG.map(col => buildDeductionCell(row, col)).join("");
            const deleteCls = row.__dirty ? "dirty" : "";
            return `
              <tr data-deduction-row="${escapeHtml(rowId(row))}">
                ${cells}
                <td class="${deleteCls}">
                  <div class="cellView center">
                    <button class="tinyBtn delete" type="button" data-delete-table="deduction" data-delete-row="${escapeHtml(rowId(row))}">✕</button>
                  </div>
                </td>
              </tr>
            `;
          }).join("");
        }
      }

      function renderPills() {
        const dirtyCount =
          state.payRows.filter(r => r.__dirty).length +
          state.deductionRows.filter(r => r.__dirty).length +
          state.deletedPayIds.size +
          state.deletedDeductionIds.size;

        dom.pillRows.textContent = "원장 " + getVisiblePayRows().length;
        dom.pillDeductions.textContent = "차감 " + getVisibleDeductionRows().length;
        dom.pillDirty.textContent = "변경 " + dirtyCount;
      }

      function renderAll() {
        const orderStats = getOrderStats();
        ensureSelectedOrder(orderStats);
        renderSidebar(orderStats);
        renderSummary();
        renderStatement();
        renderEditors();
        renderPills();

        if (!state.payRows.length && !state.deductionRows.length) {
          setStatus("해당 월 데이터가 없습니다.", "warn");
        } else {
          setStatus(`원장 ${state.payRows.length}건 · 차감 ${state.deductionRows.length}건 로드 완료`, "ok");
        }
      }

      function findPayRow(id) {
        return state.payRows.find(r => String(rowId(r)) === String(id)) || null;
      }

      function findDeductionRow(id) {
        return state.deductionRows.find(r => String(rowId(r)) === String(id)) || null;
      }

      function addPayRow() {
        state.payRows.push(makeBlankPayRow());
        renderAll();
        setStatus("원장 새 행이 추가되었습니다.", "ok");
      }

      function addDeductionRow() {
        state.deductionRows.push(makeBlankDeductionRow());
        renderAll();
        setStatus("차감 새 행이 추가되었습니다.", "ok");
      }

      function deleteRow(tableName, rowIdValue) {
        const isPay = tableName === "pay";
        const row = isPay ? findPayRow(rowIdValue) : findDeductionRow(rowIdValue);
        if (!row) return;

        const label = normalizeText(row.order_name) || String(rowIdValue);
        if (!confirm(`삭제 대상으로 표시할까?\n저장해야 실제 반영됨.\n\n대상: ${label}`)) return;

        if (row.__isNew) {
          if (isPay) {
            state.payRows = state.payRows.filter(r => String(rowId(r)) !== String(rowIdValue));
          } else {
            state.deductionRows = state.deductionRows.filter(r => String(rowId(r)) !== String(rowIdValue));
          }
        } else if (row.pk_id) {
          if (isPay) state.deletedPayIds.add(row.pk_id);
          else state.deletedDeductionIds.add(row.pk_id);
          row.__dirty = true;
        }

        renderAll();
        setStatus("삭제 대상으로 표시했습니다. 전체 저장 시 반영됩니다.", "warn");
      }

      function hasAnyValue(row, columns) {
        return columns.some(key => normalizeText(row[key]));
      }

      function cleanPayPayload(row, includePk) {
        const obj = {};
        if (includePk && row.pk_id != null) obj.pk_id = row.pk_id;

        obj.work_date = normalizeText(row.work_date) || null;
        obj.order_name = normalizeText(row.order_name) || null;
        obj.camp_code = normalizeText(row.camp_code) || null;
        obj.wave = normalizeText(row.wave) || null;
        obj.route_code = normalizeText(row.route_code) || null;
        obj.unit_price = normalizeText(row.unit_price) ? toNumber(row.unit_price) : null;
        obj.driver_name = normalizeText(row.driver_name) || null;
        obj.delivery_count = normalizeText(row.delivery_count) ? toNumber(row.delivery_count) : null;
        obj.return_count = normalizeText(row.return_count) ? toNumber(row.return_count) : null;
        obj.settlement_year = String(state.year);
        obj.settlement_month = String(state.month);
        obj.settlement_date = normalizeText(row.settlement_date) || null;
        obj.tax_invoice_status = normalizeText(row.tax_invoice_status) || null;
        obj.payment_status = normalizeText(row.payment_status) || null;
        obj.note = normalizeText(row.note) || null;

        return obj;
      }

      function cleanDeductionPayload(row, includePk) {
        const obj = {};
        if (includePk && row.pk_id != null) obj.pk_id = row.pk_id;

        obj.deduction_date = normalizeText(row.deduction_date) || null;
        obj.order_name = normalizeText(row.order_name) || null;
        obj.camp_code = normalizeText(row.camp_code) || null;
        obj.driver_name = normalizeText(row.driver_name) || null;
        obj.deduction_amount = normalizeText(row.deduction_amount) ? toNumber(row.deduction_amount) : null;
        obj.deduction_status = normalizeText(row.deduction_status) || null;
        obj.note = normalizeText(row.note) || null;
        obj.settlement_year = String(state.year);
        obj.settlement_month = String(state.month);

        return obj;
      }

      async function saveAll() {
        try {
          setLoading(true, "저장 중...");

          const payDeleteIds = Array.from(state.deletedPayIds).filter(Boolean);
          const deductionDeleteIds = Array.from(state.deletedDeductionIds).filter(Boolean);

          const dirtyPayRows = state.payRows.filter(row => row.__dirty && !(row.pk_id && state.deletedPayIds.has(row.pk_id)));
          const dirtyDeductionRows = state.deductionRows.filter(row => row.__dirty && !(row.pk_id && state.deletedDeductionIds.has(row.pk_id)));

          const payUpdateRows = dirtyPayRows.filter(row => !row.__isNew && row.pk_id != null);
          const payInsertRows = dirtyPayRows.filter(row => row.__isNew && hasAnyValue(row, PAY_COLUMNS));

          const deductionUpdateRows = dirtyDeductionRows.filter(row => !row.__isNew && row.pk_id != null);
          const deductionInsertRows = dirtyDeductionRows.filter(row => row.__isNew && hasAnyValue(row, DEDUCTION_COLUMNS));

          if (!payDeleteIds.length && !deductionDeleteIds.length && !payUpdateRows.length && !payInsertRows.length && !deductionUpdateRows.length && !deductionInsertRows.length) {
            setStatus("저장할 변경사항이 없습니다.", "warn");
            return;
          }

          if (payDeleteIds.length) {
            const { error } = await supabase.from(PAY_TABLE).delete().in("pk_id", payDeleteIds);
            if (error) throw error;
          }

          if (deductionDeleteIds.length) {
            const { error } = await supabase.from(DEDUCTION_TABLE).delete().in("pk_id", deductionDeleteIds);
            if (error) throw error;
          }

          if (payUpdateRows.length) {
            const payload = payUpdateRows.map(row => cleanPayPayload(row, true));
            const { error } = await supabase.from(PAY_TABLE).upsert(payload, { onConflict: "pk_id" });
            if (error) throw error;
          }

          if (payInsertRows.length) {
            const payload = payInsertRows.map(row => cleanPayPayload(row, false));
            const { error } = await supabase.from(PAY_TABLE).insert(payload);
            if (error) throw error;
          }

          if (deductionUpdateRows.length) {
            const payload = deductionUpdateRows.map(row => cleanDeductionPayload(row, true));
            const { error } = await supabase.from(DEDUCTION_TABLE).upsert(payload, { onConflict: "pk_id" });
            if (error) throw error;
          }

          if (deductionInsertRows.length) {
            const payload = deductionInsertRows.map(row => cleanDeductionPayload(row, false));
            const { error } = await supabase.from(DEDUCTION_TABLE).insert(payload);
            if (error) throw error;
          }

          await fetchData();
          setStatus("저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("저장 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      function exportCsv() {
        const payRows = state.selectedOrder ? getSelectedPayRows() : getVisiblePayRows();
        const deductionRows = state.selectedOrder ? getSelectedDeductionRows() : getVisibleDeductionRows();

        if (!payRows.length && !deductionRows.length) {
          alert("내보낼 데이터가 없습니다.");
          return;
        }

        const lines = [];
        lines.push(`"${state.selectedOrder || "전체"} · ${makeMonthLabel(state.year, state.month)}"`);

        lines.push("");
        lines.push('"[용차 원장]"');
        lines.push([
          "work_date","order_name","camp_code","wave","route_code","unit_price","driver_name","delivery_count","return_count","amount","settlement_date","tax_invoice_status","payment_status","note"
        ].map(v => `"${v}"`).join(","));

        for (const row of payRows) {
          const amount = payAmount(row);
          const values = [
            formatDate(row.work_date),
            normalizeText(row.order_name),
            normalizeText(row.camp_code),
            normalizeText(row.wave),
            normalizeText(row.route_code),
            toNumber(row.unit_price),
            normalizeText(row.driver_name),
            toNumber(row.delivery_count),
            toNumber(row.return_count),
            amount,
            formatDate(row.settlement_date),
            normalizeText(row.tax_invoice_status),
            normalizeText(row.payment_status),
            normalizeText(row.note)
          ];
          lines.push(values.map(v => `"${String(v ?? "").replaceAll('"', '""')}"`).join(","));
        }

        lines.push("");
        lines.push('"[차감 내역]"');
        lines.push([
          "deduction_date","order_name","camp_code","driver_name","deduction_amount","deduction_status","note"
        ].map(v => `"${v}"`).join(","));

        for (const row of deductionRows) {
          const values = [
            formatDate(row.deduction_date),
            normalizeText(row.order_name),
            normalizeText(row.camp_code),
            normalizeText(row.driver_name),
            toNumber(row.deduction_amount),
            normalizeText(row.deduction_status),
            normalizeText(row.note)
          ];
          lines.push(values.map(v => `"${String(v ?? "").replaceAll('"', '""')}"`).join(","));
        }

        const csv = "\uFEFF" + lines.join("\n");
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = `dragon_car_pay_${state.year}_${String(state.month).padStart(2,"0")}${state.selectedOrder ? "_" + state.selectedOrder : ""}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      function bindTableEvents() {
        document.body.addEventListener("input", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const table = target.getAttribute("data-table");
          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!table || !rowIdValue || !key) return;

          if (table === "pay") {
            const row = findPayRow(rowIdValue);
            if (!row) return;
            markRowDirty(row, key, target.value);
          } else if (table === "deduction") {
            const row = findDeductionRow(rowIdValue);
            if (!row) return;
            markRowDirty(row, key, target.value);
          }

          renderAll();
        });

        document.body.addEventListener("change", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const table = target.getAttribute("data-table");
          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!table || !rowIdValue || !key) return;

          if (table === "pay") {
            const row = findPayRow(rowIdValue);
            if (!row) return;
            markRowDirty(row, key, target.value);
          } else if (table === "deduction") {
            const row = findDeductionRow(rowIdValue);
            if (!row) return;
            markRowDirty(row, key, target.value);
          }

          renderAll();
        });

        document.body.addEventListener("click", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const orderPick = target.closest("[data-order-pick]");
          if (orderPick) {
            state.selectedOrder = orderPick.getAttribute("data-order-pick") || "";
            renderAll();
            return;
          }

          const deleteBtn = target.closest("[data-delete-table]");
          if (deleteBtn) {
            deleteRow(
              deleteBtn.getAttribute("data-delete-table"),
              deleteBtn.getAttribute("data-delete-row")
            );
          }
        });
      }

      function bindEvents() {
        dom.yearSelect.addEventListener("change", async () => {
          state.year = Number(dom.yearSelect.value);
          await fetchData();
        });

        dom.monthSelect.addEventListener("change", async () => {
          state.month = Number(dom.monthSelect.value);
          await fetchData();
        });

        dom.orderSearchInput.addEventListener("input", renderAll);
        dom.btnClearSearch.addEventListener("click", () => {
          dom.orderSearchInput.value = "";
          renderAll();
        });

        dom.btnReload.addEventListener("click", fetchData);
        dom.btnSaveAll.addEventListener("click", saveAll);
        dom.btnExportCsv.addEventListener("click", exportCsv);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.btnAddPayRow.addEventListener("click", addPayRow);
        dom.btnAddDeductionRow.addEventListener("click", addDeductionRow);

        dom.btnDeniedHome.addEventListener("click", () => location.replace(INDEX_PATH));
        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        bindTableEvents();
      }

      buildYearMonthOptions();
      bindEvents();

      if (!(await requireAdmin())) return;
      await fetchData();
    })();
  </script>
</body>
</html>
