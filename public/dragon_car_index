            <td>
              <select class="deductionSelect" data-deduction-index="${idx}" data-deduction-field="payment_confirm">
                <option value="false" ${!item.payment_confirm ? "selected" : ""}>대기</option>
                <option value="true" ${item.payment_confirm ? "selected" : ""}>확인</option>
              </select>
            </td>
            <td style="text-align:center">
              <button class="deductionMiniBtn danger" type="button" data-deduction-action="delete" data-index="${idx}">${item.id && item.__delete ? "취소" : "삭제"}</button>
            </td>
          </tr>
        `).join("");

        renderDeductionSummaryOnly();
      }

      function deductionPayload(row, item) {
        return {
          dragon_car_id: Number(row.id),
          name: nullIfBlank(item.name),
          subtraction_price: Number(toNum(item.subtraction_price) || 0),
          subtraction_item: nullIfBlank(item.subtraction_item),
          subtraction_account: nullIfBlank(item.subtraction_account),
          subtraction_bank: nullIfBlank(item.subtraction_bank),
          subtraction_bank_name: nullIfBlank(item.subtraction_bank_name),
          subtraction_confirm: !!item.subtraction_confirm,
          payment_confirm: !!item.payment_confirm
        };
      }

      async function saveDeductions() {
        const rowIndex = state.deduction.rowIndex;
        const row = state.rows[rowIndex];

        if (!row?.id || state.deduction.saving) return;

        const saveBtn = state.deduction.root?.querySelector('[data-deduction-action="save"]');

        try {
          state.deduction.saving = true;
          if (saveBtn) saveBtn.disabled = true;
          setStatus("용차 차감 저장 중...", "warn");

          for (const item of state.deduction.items) {
            if (item.__delete) {
              if (item.id) {
                const { error } = await supabase.from(SUBTRACTION_TABLE).delete().eq("id", item.id);
                if (error) throw error;
              }
              continue;
            }

            const payload = deductionPayload(row, item);
            const hasAny = payload.name ||
              payload.subtraction_item ||
              payload.subtraction_account ||
              payload.subtraction_bank ||
              payload.subtraction_bank_name ||
              payload.subtraction_price > 0;

            if (!hasAny) continue;

            if (payload.subtraction_price < 0) {
              throw new Error("차감금액은 0 이상이어야 합니다.");
            }

            if (item.id) {
              const { error } = await supabase.from(SUBTRACTION_TABLE).update(payload).eq("id", item.id);
              if (error) throw error;
            } else {
              const { error } = await supabase.from(SUBTRACTION_TABLE).insert(payload);
              if (error) throw error;
            }
          }

          await loadSubtractionsForRows([row]);
          await loadAllSubtractions();
          closeDeductionModal();
          render();
          renderSubtractionSheet();
          setStatus("용차 차감 저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("용차 차감 저장 실패: " + formatDbError(e), "err");
        } finally {
          state.deduction.saving = false;
          if (saveBtn) saveBtn.disabled = false;
        }
      }


      function targetRowsForSubtraction() {
        const map = new Map();

        for (const row of state.rows || []) {
          const id = Number(row?.id);
          if (Number.isFinite(id) && id > 0) {
            map.set(id, row);
          }
        }

        for (const [id, row] of state.subtractionParents || new Map()) {
          if (Number.isFinite(Number(id)) && !map.has(Number(id))) {
            map.set(Number(id), row);
          }
        }

        return Array.from(map.values())
          .filter(row => row?.id)
          .sort(compareRowsForDisplay);
      }

      function targetRowSearchText(row) {
        return normalize([
          row?.id,
          staticDateText(row),
          rowVendorName(row),
          row?.order_name,
          row?.camp,
          row?.wave,
          row?.route,
          row?.delivery_driver,
          row?.dragon_car_note
        ].join(" "));
      }

      function targetRowTitle(row) {
        return [
          staticDateText(row),
          row?.camp,
          row?.wave,
          row?.route,
          row?.delivery_driver
        ].filter(v => v !== null && v !== undefined && String(v).trim() !== "").join(" / ") || `용차 ID ${row?.id}`;
      }

      function targetRowMeta(row) {
        return [
          `ID ${row?.id}`,
          rowVendorName(row),
          row?.order_name,
          row?.settlement_month ? `정산월 ${row.settlement_month}` : ""
        ].filter(v => v !== null && v !== undefined && String(v).trim() !== "").join(" · ");
