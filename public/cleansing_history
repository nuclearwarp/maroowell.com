<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>마루웰</title>
  <link rel="icon" href="/favicon.ico?v=2">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --panel:#ffffff;
      --panel2:#ffffff;
      --head:#ffffff;
      --th:#dbeafe;
      --line:#d8e0ee;
      --line2:#cbd5e1;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --green:#16a34a;
      --purple:#7c3aed;
      --red:#dc2626;
      --yellow:#d97706;
      --shadow:0 14px 34px rgba(15,23,42,.08);
      --font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,
    body{
      margin:0;
      min-height:100%;
      background:
        radial-gradient(circle at 12% 0%,rgba(37,99,235,.08),transparent 32%),
        radial-gradient(circle at 86% 0%,rgba(14,165,233,.08),transparent 30%),
        linear-gradient(180deg,#ffffff 0%,#f6f8fc 100%);
      color:var(--txt);
      font-family:var(--font);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
      text-shadow:none;
      -webkit-text-stroke:0 transparent;
    }

    body{
      overflow:hidden;
      display:grid;
      grid-template-rows:auto auto 1fr;
      height:100vh;
    }

    button,
    input,
    select{
      font-family:var(--font);
      font-weight:300;
    }

    .top{
      display:flex;
      gap:10px;
      align-items:center;
      margin:8px 12px 0;
      padding:11px 14px;
      background:rgba(255,255,255,.96);
      border:1px solid var(--line);
      border-radius:20px;
      min-width:0;
      overflow:auto hidden;
      box-shadow:var(--shadow);
      backdrop-filter:blur(12px);
    }

    .logo{
      width:32px;
      height:32px;
      min-width:32px;
      display:flex;
      align-items:center;
      justify-content:center;
      background:transparent;
      border:0;
      border-radius:0;
      box-shadow:none;
      text-decoration:none;
      flex:0 0 auto;
      padding:0;
    }

    .logo img{
      width:30px;
      height:30px;
      display:block;
      object-fit:contain;
      filter:drop-shadow(0 2px 4px rgba(15,23,42,.10));
    }

    .title{
      min-width:0;
      flex:0 0 auto;
    }

    .title h1{
      margin:0;
      font-size:20px;
      line-height:1.1;
      letter-spacing:-.04em;
      font-weight:420;
      white-space:nowrap;
    }

    .title p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:10px;
      font-weight:300;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .spacer{flex:1 0 18px}

    .pill{
      border:1px solid #bbf7d0;
      border-radius:999px;
      padding:7px 12px;
      background:#f0fdf4;
      font-size:10px;
      font-weight:300;
      color:#15803d;
      white-space:nowrap;
      flex:0 0 auto;
    }

    .bar{
      display:grid;
      grid-template-columns:120px 140px 105px 140px 165px 150px 105px 100px minmax(160px,1fr) 78px 84px 112px;
      gap:8px;
      margin:8px 12px 0;
      padding:12px;
      background:rgba(255,255,255,.96);
      border:1px solid var(--line);
      border-radius:18px;
      align-items:end;
      overflow:auto hidden;
      box-shadow:0 8px 22px rgba(15,23,42,.05);
    }

    label{
      display:block;
      color:#64748b;
      font-size:10px;
      font-weight:300;
      margin:0 0 5px 2px;
    }

    input,
    select{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid var(--line2);
      background:#f8fafc;
      color:var(--txt);
      padding:0 9px;
      font-size:10px;
      font-weight:300;
      outline:none;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.8);
    }

    input::placeholder{color:#94a3b8}

    input:focus,
    select:focus{
      border-color:#60a5fa;
      background:#fff;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
    }

    select option{
      background:#fff;
      color:#0f172a;
      font-weight:300;
    }

    .btn{
      height:34px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:#ffffff;
      color:var(--txt);
      font-weight:350;
      font-size:10px;
      padding:0 12px;
      cursor:pointer;
      align-self:end;
      white-space:nowrap;
      box-shadow:0 1px 0 rgba(255,255,255,.85),0 4px 12px rgba(15,23,42,.05);
    }

    .btn:hover{
      background:#f8fbff;
      border-color:#93c5fd;
    }

    .btn.primary{
      background:linear-gradient(180deg,#3b82f6,#2563eb);
      border-color:#2563eb;
      color:#fff;
      box-shadow:0 8px 18px rgba(37,99,235,.18);
    }

    .btn.ok{
      background:linear-gradient(180deg,#22c55e,#16a34a);
      border-color:#16a34a;
      color:#fff;
      box-shadow:0 8px 18px rgba(22,163,74,.16);
    }

    .btn.purple{
      background:linear-gradient(180deg,#8b5cf6,#7c3aed);
      border-color:#7c3aed;
      color:#fff;
      box-shadow:0 8px 18px rgba(124,58,237,.16);
    }

    .main{
      padding:10px 12px 14px;
      overflow:auto;
    }

    .board{
      min-width:1180px;
      border:1px solid var(--line);
      border-radius:18px;
      overflow:hidden;
      background:var(--panel2);
      box-shadow:var(--shadow);
    }

    .head{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:flex-end;
      padding:14px 16px;
      background:var(--head);
      border-bottom:1px solid var(--line);
    }

    .head h2{
      margin:0;
      font-size:20px;
      letter-spacing:-.04em;
      font-weight:420;
    }

    .head p{
      margin:5px 0 0;
      color:#64748b;
      font-size:10px;
      font-weight:300;
    }

    .actions{
      display:flex;
      gap:8px;
      align-items:center;
      flex:0 0 auto;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      background:#fff;
    }

    th,
    td{
      border-right:1px solid var(--line);
      border-bottom:1px solid var(--line);
      padding:7px 6px;
      text-align:center;
      font-size:10px;
      line-height:1.35;
      vertical-align:middle;
      color:#0f172a;
      font-weight:300;
    }

    th:last-child,
    td:last-child{
      border-right:none;
    }

    th{
      background:var(--th);
      font-weight:380;
      white-space:nowrap;
      padding-top:8px;
      padding-bottom:8px;
    }

    td{
      word-break:normal;
      overflow-wrap:anywhere;
      background:#fff;
    }

    tbody tr:nth-child(even) td{
      background:#f8fafc;
    }

    tbody tr:hover td{
      background:#eff6ff;
    }

    .left{text-align:left}
    .center{text-align:center}
    .num{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .green{color:#047857}
    .yellow{color:#a16207}
    .red{color:#b91c1c}

    .routeCell{
      text-align:left;
      white-space:normal;
      word-break:keep-all;
      overflow-wrap:anywhere;
    }

    .priceCell{
      text-align:center;
      font-variant-numeric:tabular-nums;
    }

    .zipCell,
    .vendorCell{
      text-align:left;
      white-space:normal;
      word-break:keep-all;
      overflow-wrap:anywhere;
    }

    .gradeBadge,
    .zipLink{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      font-weight:350;
      line-height:1;
      white-space:nowrap;
    }

    .gradeBadge{
      min-width:38px;
      min-height:21px;
      padding:4px 7px;
      border:1px solid currentColor;
      background:#fff;
    }

    .grade1{color:#15803d;background:#f0fdf4}
    .grade2{color:#4d7c0f;background:#f7fee7}
    .grade3{color:#b45309;background:#fffbeb}
    .grade4{color:#be123c;background:#fff1f2}
    .gradeNone{color:#64748b;background:#f8fafc}

    .zipLink{
      color:inherit;
      text-decoration:none;
      text-underline-offset:0;
      margin:0 2px 2px;
    }

    .zipLink:hover{color:inherit}

    .subNum{
      display:block;
      margin-top:4px;
      color:#64748b;
      font-size:9px;
      line-height:1.2;
      font-weight:300;
    }

    tbody tr.rowClean td,
    tbody tr.rowClean .green,
    tbody tr.rowClean .yellow,
    tbody tr.rowClean .red,
    tbody tr.rowClean .zipLink,
    tbody tr.rowClean .gradeBadge{
      color:#b91c1c;
      font-weight:360;
    }

    tbody tr.rowWarn td,
    tbody tr.rowWarn .green,
    tbody tr.rowWarn .yellow,
    tbody tr.rowWarn .red,
    tbody tr.rowWarn .zipLink,
    tbody tr.rowWarn .gradeBadge{
      color:#92400e;
      font-weight:360;
    }

    tbody tr.rowClean td{
      background:#fff5f5!important;
    }

    tbody tr.rowWarn td{
      background:#fffbeb!important;
    }

    tbody tr.waveDivider td{
      border-top:4px double #64748b;
    }

    .cellInput{
      height:28px;
      min-width:0;
      border-radius:8px;
      padding:0 7px;
      font-size:10px;
      font-weight:300;
    }

    .empty,
    .denied{
      margin:38px auto;
      max-width:720px;
      padding:24px;
      border:1px dashed var(--line2);
      border-radius:18px;
      text-align:center;
      color:#64748b;
      font-weight:300;
      background:#f8fafc;
    }

    .denied{
      border-color:#fecaca;
      background:#fff5f5;
      text-align:left;
      color:#991b1b;
    }

    .denied h2{
      margin:0 0 12px;
      color:#991b1b;
      font-weight:420;
      font-size:20px;
    }

    .denied p{
      margin:0;
      line-height:1.65;
      font-weight:300;
    }


    #add{
      min-width:104px;
      padding-left:14px;
      padding-right:14px;
    }

    .vendorModal{
      position:fixed;
      inset:0;
      z-index:1200;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:18px;
      background:rgba(15,23,42,.42);
      backdrop-filter:blur(10px);
    }

    .vendorModal.hide{
      display:none!important;
    }

    .vendorPanel{
      width:min(460px,100%);
      border:1px solid var(--line);
      border-radius:22px;
      background:#ffffff;
      box-shadow:0 24px 80px rgba(15,23,42,.24);
      overflow:hidden;
    }

    .vendorPanelHead{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      padding:18px 20px 14px;
      border-bottom:1px solid #edf2f7;
      background:linear-gradient(180deg,#ffffff,#f8fafc);
    }

    .vendorPanelHead h3{
      margin:0;
      color:#0f172a;
      font-size:18px;
      line-height:1.15;
      font-weight:520;
      letter-spacing:-.04em;
    }

    .vendorPanelHead p{
      margin:6px 0 0;
      color:#64748b;
      font-size:11px;
      line-height:1.45;
      font-weight:300;
    }

    .vendorCloseBtn{
      width:34px;
      height:34px;
      border:1px solid var(--line2);
      border-radius:999px;
      background:#fff;
      color:#0f172a;
      cursor:pointer;
      font-size:18px;
      line-height:1;
      font-weight:400;
    }

    .vendorCloseBtn:hover{
      background:#f8fafc;
      border-color:#93c5fd;
    }

    .vendorPanelBody{
      padding:18px 20px 20px;
      display:grid;
      gap:14px;
    }

    .vendorField{
      display:grid;
      gap:7px;
    }

    .vendorField label{
      margin:0;
      color:#64748b;
      font-size:11px;
      font-weight:350;
    }

    .vendorField input{
      width:100%;
      height:42px;
      border:1px solid var(--line2);
      border-radius:13px;
      background:#f8fafc;
      color:#0f172a;
      padding:0 12px;
      font-size:12px;
      font-weight:320;
      outline:none;
      font-family:var(--font);
    }

    .vendorField input:focus{
      background:#fff;
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
    }

    .vendorPanelMsg{
      min-height:20px;
      color:#64748b;
      font-size:11px;
      line-height:1.5;
      font-weight:300;
      white-space:pre-wrap;
    }

    .vendorPanelMsg.ok{color:#15803d}
    .vendorPanelMsg.err{color:#b91c1c}

    .vendorPanelActions{
      display:flex;
      justify-content:flex-end;
      gap:8px;
      padding-top:2px;
    }

    .hide{display:none!important}

    .captureCloneWrap{
      position:absolute;
      left:-100000px;
      top:0;
      z-index:-1;
      pointer-events:none;
      background:#fff;
      padding:0;
      width:max-content;
      min-width:max-content;
      height:auto;
      min-height:max-content;
      overflow:visible;
    }

    .captureTable{
      width:auto!important;
      min-width:0!important;
      table-layout:fixed!important;
      border-collapse:separate!important;
      border-spacing:0!important;
      background:#fff!important;
      color:#111827!important;
      font-family:var(--font)!important;
    }

    .captureTable .manageCol{display:none!important}

    .captureTable th,
    .captureTable td{
      vertical-align:middle!important;
      background:#fff!important;
      color:#111827!important;
      border-right:1px solid #cfd8e3!important;
      border-bottom:1px solid #cfd8e3!important;
      padding:7px 6px!important;
      text-align:center!important;
      font-size:10px!important;
      line-height:1.35!important;
      font-weight:300!important;
      word-break:keep-all!important;
      overflow-wrap:anywhere!important;
      font-family:var(--font)!important;
    }

    .captureTable th{
      background:#dbeafe!important;
      color:#0f172a!important;
      font-weight:380!important;
      white-space:nowrap!important;
    }

    .captureTable tbody tr:nth-child(even) td{
      background:#f8fafc!important;
    }

    .captureTable .left,
    .captureTable .zipCell,
    .captureTable .vendorCell,
    .captureTable .routeCell{
      text-align:left!important;
    }

    .captureTable .priceCell{
      text-align:center!important;
      font-variant-numeric:tabular-nums!important;
    }

    .captureTable .num{
      text-align:right!important;
      font-variant-numeric:tabular-nums!important;
    }

    .captureTable .green{color:#047857!important;font-weight:350!important}
    .captureTable .yellow{color:#a16207!important;font-weight:350!important}
    .captureTable .red{color:#b91c1c!important;font-weight:350!important}

    .captureTable .subNum{
      color:#64748b!important;
      font-size:9px!important;
      font-weight:300!important;
    }

    .captureTable .zipLink{
      color:#111827!important;
      text-decoration:none!important;
      text-underline-offset:0!important;
      margin:0 2px 2px!important;
    }

    .captureTable .gradeBadge{
      background:#fff!important;
      border:1px solid currentColor!important;
      font-weight:350!important;
    }

    .captureTable .grade1{color:#15803d!important}
    .captureTable .grade2{color:#4d7c0f!important}
    .captureTable .grade3{color:#b45309!important}
    .captureTable .grade4{color:#be123c!important}
    .captureTable .gradeNone{color:#64748b!important}

    .captureTable tbody tr.rowClean td,
    .captureTable tbody tr.rowClean .green,
    .captureTable tbody tr.rowClean .yellow,
    .captureTable tbody tr.rowClean .red,
    .captureTable tbody tr.rowClean .zipLink,
    .captureTable tbody tr.rowClean .gradeBadge{
      color:#b91c1c!important;
      font-weight:360!important;
    }

    .captureTable tbody tr.rowWarn td,
    .captureTable tbody tr.rowWarn .green,
    .captureTable tbody tr.rowWarn .yellow,
    .captureTable tbody tr.rowWarn .red,
    .captureTable tbody tr.rowWarn .zipLink,
    .captureTable tbody tr.rowWarn .gradeBadge{
      color:#92400e!important;
      font-weight:360!important;
    }

    .captureTable tbody tr.waveDivider td{
      border-top:3px solid #64748b!important;
    }

    @media(max-width:1100px){
      body{
        grid-template-rows:auto auto 1fr;
      }

      .top{
        margin:0;
        border-radius:0;
        border-left:0;
        border-right:0;
        border-top:0;
      }

      .bar{
        grid-template-columns:repeat(2,minmax(140px,1fr));
        margin:0;
        border-left:0;
        border-right:0;
        border-radius:0 0 18px 18px;
      }

      .main{
        padding:8px;
      }

      .title h1{
        font-size:17px;
      }

      .title p{
        display:none;
      }

      .btn{
        width:100%;
      }
    }
  </style>
</head>

<body>
  <div class="top">
    <a href="#" id="mwBoardMenuToggle" class="logo">
      <img src="/favicon.ico" alt="MarooWell">
    </a>

    <div class="title">
      <h1>클렌징 히스토리</h1>
      <p>마지막 주차 기본 조회, 누적 데이터 제공</p>
    </div>

    <div class="spacer"></div>
    <span id="user" class="pill">세션 확인</span>
  </div>

  <div id="bar" class="bar">
    <div>
      <label>Week</label>
      <input id="week" placeholder="자동: 마지막 주차">
    </div>

    <div>
      <label>Camp</label>
      <input id="camp">
    </div>

    <div>
      <label>Wave</label>
      <select id="wave">
        <option value="">전체</option>
        <option value="2W">주간</option>
        <option value="1W">야간</option>
      </select>
    </div>

    <div>
      <label>Route</label>
      <input id="route">
    </div>

    <div>
      <label>Vendor</label>
      <input id="vendor">
    </div>

    <div>
      <label>사업자번호</label>
      <input id="biz">
    </div>

    <div>
      <label>Reason</label>
      <select id="reason">
        <option value="">전체</option>
        <option>수행률</option>
        <option>반품</option>
      </select>
    </div>

    <div>
      <label>Limit</label>
      <select id="limit">
        <option>100</option>
        <option selected>300</option>
        <option>500</option>
        <option>1000</option>
      </select>
    </div>

    <div>
      <label>통합 검색</label>
      <input id="q">
    </div>

    <button class="btn primary" id="search">조회</button>
    <button class="btn" id="reset">초기화</button>
    <button class="btn ok" id="add">신규 벤더</button>
  </div>

  <main class="main" id="main">
    <div class="board" id="board">
      <div class="head">
        <div>
          <h2>클렌징 히스토리</h2>
          <p id="summary">조회 전</p>
        </div>

        <div class="actions">
          <button class="btn" id="refresh">새로고침</button>
          <button class="btn purple" id="copyImage">이미지 복사</button>
        </div>
      </div>

      <div id="table"></div>
    </div>
  </main>

  <div class="vendorModal hide" id="vendorModal" role="dialog" aria-modal="true" aria-labelledby="vendorModalTitle">
    <div class="vendorPanel">
      <div class="vendorPanelHead">
        <div>
          <h3 id="vendorModalTitle">신규 벤더 등록</h3>
          <p>벤더명과 사업자번호를 입력하면 Route 벤더 DB에 바로 등록됩니다.</p>
        </div>
        <button class="vendorCloseBtn" id="vendorModalClose" type="button" aria-label="닫기">×</button>
      </div>

      <div class="vendorPanelBody">
        <div class="vendorField">
          <label for="vendorNewName">벤더명</label>
          <input id="vendorNewName" placeholder="예: 주식회사 모벤티스" autocomplete="off">
        </div>

        <div class="vendorField">
          <label for="vendorNewBiz">사업자번호</label>
          <input id="vendorNewBiz" placeholder="예: 123-45-67890" autocomplete="off">
        </div>

        <div class="vendorPanelMsg" id="vendorPanelMsg"></div>

        <div class="vendorPanelActions">
          <button class="btn" id="vendorModalCancel" type="button">취소</button>
          <button class="btn ok" id="vendorRegisterSave" type="button">등록</button>
        </div>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const $ = id => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};
  const API = (cfg.CLEANSING_HISTORY_API_BASE || "https://cleansinghistory.maroowell.com").replace(/\/$/, "");
  const ROUTE_VENDOR_ENDPOINT = "https://route.maroowell.com/vendors";
  const TABLE_HISTORY = "cleansing_history";
  const TABLE_CLHI_ACCESS = "cleansing_history_access";

  let supabaseClient = null;
  let me = {};
  let rows = [];
  let editingId = "";
  let sessionBridge = null;

  const esc = v => String(v ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");

  const val = id => $(id).value.trim();

  const fmtNum = v => {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    return Number.isFinite(n) ? n.toLocaleString("ko-KR") : String(v);
  };

  const fmtPct = v => {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    return Number.isFinite(n) ? n.toFixed(2).replace(/\.00$/, "") + "%" : String(v);
  };

  const fmtWon = v => {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    return Number.isFinite(n) ? "₩" + n.toLocaleString("ko-KR") : String(v);
  };

  const dailyAverage = value => {
    const n = Number(value);
    return Number.isFinite(n) ? n / 7 : null;
  };

  const fmtDailyAvg = value => {
    const n = dailyAverage(value);
    if (n === null) return "";
    return n.toLocaleString("ko-KR", { maximumFractionDigits: 1 });
  };

  const demandCell = value => {
    const avg = fmtDailyAvg(value);
    return `${fmtNum(value)}${avg ? `<span class="subNum">일평균 ${esc(avg)}</span>` : ""}`;
  };

  const isSuper = () => {
    return me?.is_super_admin === true || Number(me?.max_role_level || 0) >= 90;
  };

  const isBackendSessionError = err => {
    const msg = String(err?.message || err || "");
    return /invalid_session|JWT|refresh token|Auth session missing/i.test(msg);
  };

  const isBackendSaveError = err => {
    const msg = String(err?.message || err || "");
    return isBackendSessionError(err) || /supabase_(patch|insert|upsert)_failed:cleansing_history/i.test(msg);
  };

  function stringifyDetail(detail) {
    if (!detail) return "";
    if (typeof detail === "string") return detail;

    try {
      return JSON.stringify(detail);
    } catch {
      return String(detail);
    }
  }

  function parseWeek(week) {
    const raw = String(week || "").trim().toUpperCase();
    const yearMatch = raw.match(/^\s*(20\d{2})/);
    const weekMatch = raw.match(/(\d{1,2})\s*W\b/);
    const year = yearMatch ? Number(yearMatch[1]) : 0;
    const weekNo = weekMatch ? Number(weekMatch[1]) : 0;

    return { year, weekNo };
  }

  function compareWeekDesc(a, b) {
    const aw = parseWeek(a?.week ?? a);
    const bw = parseWeek(b?.week ?? b);
    const diff = (bw.year - aw.year) || (bw.weekNo - aw.weekNo);

    if (diff) return diff;

    return String(b?.week ?? b ?? "").localeCompare(String(a?.week ?? a ?? ""), "ko", {
      numeric: true,
      sensitivity: "base"
    });
  }

  function compareWeekAsc(a, b) {
    const aw = parseWeek(a?.week ?? a);
    const bw = parseWeek(b?.week ?? b);
    const diff = (aw.year - bw.year) || (aw.weekNo - bw.weekNo);

    if (diff) return diff;

    return String(a?.week ?? a ?? "").localeCompare(String(b?.week ?? b ?? ""), "ko", {
      numeric: true,
      sensitivity: "base"
    });
  }

  function waveSortValue(wave) {
    const raw = String(wave || "").trim().toUpperCase();

    if (raw === "2W" || raw === "W2" || raw === "WAVE2" || raw === "주간") return 0;
    if (raw === "1W" || raw === "W1" || raw === "WAVE1" || raw === "야간") return 1;

    return 2;
  }

  function compareRows(a, b) {
    return compareWeekAsc(a, b) ||
      (waveSortValue(a.wave) - waveSortValue(b.wave)) ||
      String(a.camp || "").localeCompare(String(b.camp || ""), "ko", { numeric:true, sensitivity:"base" }) ||
      String(a.route || "").localeCompare(String(b.route || ""), "ko", { numeric:true, sensitivity:"base" });
  }

  function noSpace(v) {
    return String(v ?? "").replace(/\s+/g, "");
  }

  function weekKey(v) {
    const parts = parseWeek(v);
    return parts.year && parts.weekNo ? `${parts.year}-${parts.weekNo}W` : noSpace(v);
  }

  function previousWeekKey(year, weekNo, back) {
    if (!year || !weekNo) return "";

    if (weekNo > back) {
      return `${year}-${weekNo - back}W`;
    }

    return `${year - 1}-${52 - (back - weekNo)}W`;
  }

  function routeKey(value) {
    const raw = noSpace(value);

    if (!raw) return "";

    return Array.from(new Set(raw.split(",").map(v => v.trim()).filter(Boolean)))
      .sort((a, b) => a.localeCompare(b, "ko", { numeric:true, sensitivity:"base" }))
      .join(",");
  }

  function statusKeys(row, weekOverride = "") {
    const week = weekOverride || weekKey(row.week);
    const camp = noSpace(row.camp);
    const wave = noSpace(row.wave);
    const route = routeKey(row.route);
    const reason = noSpace(row.reason);

    return {
      full: `${week}||${camp}||${wave}||${route}||${reason}`,
      route: `${week}||${camp}||${wave}||${route}`
    };
  }

  function buildStatusIndex(sourceRows) {
    const full = new Map();
    const route = new Map();

    for (const row of sourceRows || []) {
      const baseOk = weekKey(row.week) && noSpace(row.camp) && noSpace(row.wave) && routeKey(row.route);

      if (!baseOk) continue;

      const keys = statusKeys(row);

      if (noSpace(row.reason)) {
        full.set(keys.full, (full.get(keys.full) || 0) + 1);
      }

      route.set(keys.route, (route.get(keys.route) || 0) + 1);
    }

    return { full, route };
  }

  function cleansingStatus(row, index) {
    const parts = parseWeek(row.week);
    const prevOne = previousWeekKey(parts.year, parts.weekNo, 1);
    const prevTwo = previousWeekKey(parts.year, parts.weekNo, 2);

    if (!prevOne || !prevTwo) return "pass";

    const prevOneKeys = statusKeys(row, prevOne);
    const prevTwoKeys = statusKeys(row, prevTwo);
    const cleanCnt = index.full.get(prevTwoKeys.full) || 0;

    if (cleanCnt > 0) return "클렌징";

    const warnCnt =
      (index.full.get(prevOneKeys.full) || 0) +
      (index.full.get(prevTwoKeys.full) || 0) +
      (index.route.get(prevOneKeys.route) || 0) +
      (index.route.get(prevTwoKeys.route) || 0);

    return warnCnt > 0 ? "경고" : "pass";
  }

  function decorateRows(targetRows, sourceRows) {
    const index = buildStatusIndex(sourceRows);

    return (targetRows || []).map(row => ({
      ...row,
      cleansing_status: cleansingStatus(row, index)
    }));
  }

  function reasonClass(value) {
    return noSpace(value) === "반품" ? "red" : "";
  }

  function gradeKind(value) {
    const text = noSpace(value);

    if (text.includes("1등급")) return "grade1";
    if (text.includes("2등급")) return "grade2";
    if (text.includes("3등급")) return "grade3";
    if (text.includes("4등급")) return "grade4";
    if (text.includes("미수행")) return "gradeNone";

    return "";
  }

  function gradeBadge(value) {
    const text = String(value || "").trim();

    if (!text) return "";

    return `<span class="gradeBadge ${gradeKind(text)}">${esc(text)}</span>`;
  }

  function zipTokens(value) {
    return String(value || "")
      .split(/[,\s]+/)
      .map(v => v.trim())
      .filter(Boolean);
  }

  function zipUrl(value) {
    const zips = Array.isArray(value) ? value : zipTokens(value);
    return `/zipcode_search?zips=${encodeURIComponent(zips.join(","))}`;
  }

  function zipLinks(value) {
    const zips = zipTokens(value);

    if (!zips.length) return "";

    const href = esc(zipUrl(zips));

    return zips
      .map(zip => `<a class="zipLink" href="${href}" target="_blank" rel="opener">${esc(zip)}</a>`)
      .join("");
  }

  function sameWeek(a, b) {
    const aw = parseWeek(a?.week);
    const bw = parseWeek(b?.week);

    return aw.year === bw.year && aw.weekNo === bw.weekNo && aw.year && aw.weekNo;
  }

  function hasWaveDivider(row, index) {
    if (!index) return false;

    const prev = rows[index - 1];

    return sameWeek(row, prev) && waveSortValue(prev?.wave) !== waveSortValue(row?.wave);
  }

  function rowClass(row, index) {
    const classes = [];

    if (row?.cleansing_status === "클렌징") classes.push("rowClean");
    else if (row?.cleansing_status === "경고") classes.push("rowWarn");

    if (hasWaveDivider(row, index)) classes.push("waveDivider");

    return classes.join(" ");
  }

  function rowId(row) {
    return String(row?.id ?? "");
  }

  function isEditing(row) {
    return editingId && rowId(row) === editingId;
  }

  function inputCell(row, field, className = "") {
    return `<input class="cellInput ${className}" data-field="${esc(field)}" value="${esc(row?.[field] ?? "")}">`;
  }

  function waveCell(row) {
    const value = String(row?.wave || "");

    return `
      <select class="cellInput" data-field="wave">
        <option value="2W" ${value === "2W" ? "selected" : ""}>주간</option>
        <option value="1W" ${value === "1W" ? "selected" : ""}>야간</option>
      </select>
    `;
  }

  function displayWave(row) {
    return row.wave === "2W" ? "주간" : row.wave === "1W" ? "야간" : esc(row.wave || "");
  }

  function actionButton(row) {
    const id = rowId(row);
    const attr = isEditing(row) ? "data-save" : "data-edit";
    const text = isEditing(row) ? "저장" : "수정";

    return `<td class="manageCol"><button class="btn" style="height:26px;padding:0 9px" ${attr}="${esc(id)}">${text}</button></td>`;
  }

  function numericPatchValue(value) {
    const text = String(value || "").replace(/[,%₩,\s]/g, "");

    if (!text) return null;

    const n = Number(text);
    return Number.isFinite(n) ? n : null;
  }

  function readPatchFromRow(tr) {
    const patch = {};

    tr.querySelectorAll("[data-field]").forEach(input => {
      const field = input.dataset.field;
      const value = input.value.trim();

      if (["demand", "complete", "execution_rate", "price"].includes(field)) {
        patch[field] = numericPatchValue(value);
      } else {
        patch[field] = value || null;
      }
    });

    return patch;
  }

  function showErrorBox(title, message) {
    document.documentElement.style.visibility = "visible";
    $("bar").classList.add("hide");
    $("board").classList.add("hide");
    $("main").innerHTML = `
      <div class="denied">
        <h2>${esc(title)}</h2>
        <p>${esc(message)}</p>
      </div>
    `;
  }

  function showDenied() {
    showErrorBox(
      "클렌징 히스토리 권한 없음",
      "클히 권한이 있는 사용자만 조회할 수 있습니다."
    );
  }

  function initSupabase() {
    const { SUPABASE_URL, SUPABASE_ANON_KEY } = cfg;

    if (!SUPABASE_URL || !SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try {
        return window.sessionStorage;
      } catch {
        return undefined;
      }
    })();

    supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });

    try {
      supabaseClient.auth.onAuthStateChange((event, session) => {
        if (event === "SIGNED_OUT") {
          sessionBridge?.broadcastAuthState("SIGNED_OUT");
          return;
        }

        if (session?.access_token) {
          sessionBridge?.broadcastAuthState("SESSION_UPDATED");
        }
      });
    } catch {}
  }


  function getSupabaseProjectRef(url) {
    try {
      const host = new URL(url).hostname || "";
      return host.split(".")[0] || "";
    } catch {
      return "";
    }
  }

  function createSupabaseSessionBridge(url) {
    const projectRef = getSupabaseProjectRef(url);
    const prefixes = projectRef ? [
      "sb-" + projectRef + "-auth-token",
      "sb-" + projectRef + "-auth-token-code-verifier"
    ] : [];

    const origin = window.location.origin;
    const channelName = projectRef ? ("mw-auth-bridge:" + projectRef) : "";
    const tabId = Date.now().toString(36) + Math.random().toString(36).slice(2);

    let channel = null;
    let started = false;

    function matchesKey(key) {
      return !!key && prefixes.some(prefix => key === prefix || key.startsWith(prefix));
    }

    function readEntries(storage) {
      const target = storage || window.sessionStorage;
      const out = [];

      try {
        for (let i = 0; i < target.length; i++) {
          const key = target.key(i);

          if (!matchesKey(key)) continue;

          out.push({
            key,
            value: target.getItem(key)
          });
        }
      } catch {}

      return out;
    }

    function hasSession(storage) {
      return readEntries(storage).some(row =>
        row.key.includes("-auth-token") &&
        !row.key.includes("code-verifier") &&
        !!row.value
      );
    }

    function clearSession(storage) {
      const target = storage || window.sessionStorage;

      try {
        const keys = [];

        for (let i = 0; i < target.length; i++) {
          const key = target.key(i);

          if (matchesKey(key)) {
            keys.push(key);
          }
        }

        keys.forEach(key => target.removeItem(key));
      } catch {}
    }

    function responsePayload(requestId) {
      return {
        type: "MW_SESSION_RESPONSE",
        projectRef,
        requestId,
        entries: readEntries(window.sessionStorage),
        fromTabId: tabId
      };
    }

    function replyToWindowRequest(msg, eventSource) {
      if (!eventSource || !hasSession(window.sessionStorage)) return;

      try {
        eventSource.postMessage(responsePayload(msg.requestId), origin);
      } catch {}
    }

    function replyToChannelRequest(msg) {
      if (!channel || !hasSession(window.sessionStorage)) return;

      try {
        channel.postMessage(responsePayload(msg.requestId));
      } catch {}
    }

    function handleSyncState(state) {
      if (state === "SIGNED_OUT") {
        clearSession(window.sessionStorage);
      }
    }

    function onWindowMessage(event) {
      if (event.origin !== origin) return;

      const msg = event.data || {};

      if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

      if (msg.type === "MW_SESSION_REQUEST") {
        replyToWindowRequest(msg, event.source);
        return;
      }

      if (msg.type === "MW_AUTH_SYNC") {
        handleSyncState(msg.state);
      }
    }

    function onChannelMessage(event) {
      const msg = event.data || {};

      if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

      if (msg.type === "MW_SESSION_REQUEST") {
        replyToChannelRequest(msg);
        return;
      }

      if (msg.type === "MW_AUTH_SYNC") {
        handleSyncState(msg.state);
      }
    }

    function start() {
      if (started || !projectRef) return;

      started = true;
      window.addEventListener("message", onWindowMessage);

      try {
        if ("BroadcastChannel" in window) {
          channel = new BroadcastChannel(channelName);
          channel.addEventListener("message", onChannelMessage);
        }
      } catch {}
    }

    function broadcastAuthState(state) {
      if (!projectRef) return;

      start();

      const payload = {
        type: "MW_AUTH_SYNC",
        projectRef,
        state,
        fromTabId: tabId
      };

      try {
        channel?.postMessage(payload);
      } catch {}
    }

    return {
      start,
      broadcastAuthState
    };
  }

  function startSessionBridge() {
    if (sessionBridge) return sessionBridge;

    sessionBridge = createSupabaseSessionBridge(cfg.SUPABASE_URL);
    sessionBridge.start();

    return sessionBridge;
  }

  async function getSession() {
    if (!supabaseClient) initSupabase();

    const { data, error } = await supabaseClient.auth.getSession();

    if (error) throw error;

    const session = data?.session || null;

    if (!session) {
      throw new Error("로그인이 필요합니다. 먼저 로그인하세요.");
    }

    return session;
  }

  async function getToken(forceRefresh = false) {
    if (!supabaseClient) initSupabase();

    if (forceRefresh) {
      const { data, error } = await supabaseClient.auth.refreshSession();

      if (error) throw error;

      const refreshedToken = data?.session?.access_token;

      if (refreshedToken) return refreshedToken;
    }

    const { data, error } = await supabaseClient.auth.getSession();

    if (error) throw error;

    const token = data?.session?.access_token;

    if (!token) {
      throw new Error("로그인이 필요합니다. 먼저 로그인하세요.");
    }

    return token;
  }

  async function directMe() {
    const session = await getSession();
    const user = session.user || {};
    const uid = String(user.id || "").trim();
    const email = String(user.email || "").trim();

    if (!uid) {
      throw new Error("유효하지 않은 로그인 세션입니다.");
    }

    const out = {
      user: { id: uid, email },
      email,
      is_maroowell: false,
      is_admin: false,
      is_super_admin: false,
      is_dragon_car_admin: false,
      max_role_level: 0,
      can_select: false
    };

    try {
      const { data, error } = await supabaseClient.rpc("mw_my_access").maybeSingle();

      if (!error && data) {
        out.is_maroowell = data.is_maroowell === true;
        out.is_admin = data.is_admin === true;
        out.is_dragon_car_admin = data.is_dragon_car_admin === true;
        out.max_role_level = Number(data.max_role_level || data.role_level || 0);
        out.is_super_admin = out.max_role_level >= 90 || data.is_super_admin === true;
      }
    } catch {}

    if (out.is_super_admin) {
      out.can_select = true;
      return out;
    }

    const checks = [
      () => supabaseClient.from(TABLE_CLHI_ACCESS).select("can_select").eq("user_id", uid).eq("can_select", true).maybeSingle(),
      () => supabaseClient.from(TABLE_CLHI_ACCESS).select("can_select").eq("email", email).eq("can_select", true).maybeSingle()
    ];

    for (const run of checks) {
      try {
        const { data, error } = await run();

        if (!error && data?.can_select === true) {
          out.can_select = true;
          break;
        }
      } catch {}
    }

    return out;
  }

  async function directMeta() {
    if (!supabaseClient) initSupabase();

    const data = [];
    const pageSize = 1000;

    for (let from = 0; from < 10000; from += pageSize) {
      const { data: page, error } = await supabaseClient
        .from(TABLE_HISTORY)
        .select("week")
        .not("week", "is", null)
        .range(from, from + pageSize - 1);

      if (error) throw error;

      const pageRows = Array.isArray(page) ? page : [];
      data.push(...pageRows);

      if (pageRows.length < pageSize) break;
    }

    const latest = data
      .filter(row => String(row?.week || "").trim())
      .sort(compareWeekDesc)[0];

    return {
      ok: true,
      latest_week: latest?.week || ""
    };
  }

  function applyEq(query, field, value) {
    const v = String(value || "").trim();
    return v ? query.eq(field, v) : query;
  }

  function applyIlike(query, field, value) {
    const v = String(value || "").trim();
    return v ? query.ilike(field, `%${v.replaceAll("%", "\\%").replaceAll("_", "\\_")}%`) : query;
  }

  function safeOrSearch(value) {
    return String(value || "")
      .trim()
      .replace(/[,%]/g, " ")
      .replace(/\s+/g, " ");
  }

  function directRowsQuery({ count = false } = {}) {
    let query = supabaseClient
      .from(TABLE_HISTORY)
      .select("*", count ? { count:"exact" } : {});

    query = applyEq(query, "week", val("week"));
    query = applyEq(query, "camp", val("camp"));
    query = applyEq(query, "wave", val("wave"));
    query = applyIlike(query, "route", val("route"));
    query = applyIlike(query, "vendor_name", val("vendor"));
    query = applyIlike(query, "business_number", val("biz"));
    query = applyEq(query, "reason", val("reason"));

    const q = safeOrSearch(val("q"));

    if (q) {
      const like = `%${q}%`;
      query = query.or([
        `week.ilike.${like}`,
        `camp.ilike.${like}`,
        `wave.ilike.${like}`,
        `route.ilike.${like}`,
        `zip.ilike.${like}`,
        `execution_rate_grade.ilike.${like}`,
        `reason.ilike.${like}`,
        `vendor_name.ilike.${like}`,
        `business_number.ilike.${like}`
      ].join(","));
    }

    return query.order("id", { ascending:true });
  }

  async function directStatusContextRows() {
    const pageSize = 1000;
    const out = [];

    for (let from = 0; from < 10000; from += pageSize) {
      const { data, error } = await supabaseClient
        .from(TABLE_HISTORY)
        .select("week,camp,wave,route,reason")
        .range(from, from + pageSize - 1);

      if (error) throw error;

      const pageRows = Array.isArray(data) ? data : [];
      out.push(...pageRows);

      if (pageRows.length < pageSize) break;
    }

    return out;
  }

  async function directRows() {
    if (!supabaseClient) initSupabase();

    const limit = Math.max(1, Math.min(1000, Number(val("limit")) || 300));
    const pageSize = 1000;
    const fetched = [];
    let totalCount = null;

    for (let from = 0; from < 10000; from += pageSize) {
      const { data, error, count } = await directRowsQuery({ count: from === 0 })
        .range(from, from + pageSize - 1);

      if (error) throw error;

      if (from === 0 && typeof count === "number") {
        totalCount = count;
      }

      const pageRows = Array.isArray(data) ? data : [];
      fetched.push(...pageRows);

      if (pageRows.length < pageSize) break;
    }

    const contextRows = await directStatusContextRows();
    const sorted = decorateRows(fetched, contextRows).sort(compareRows);
    const out = sorted.slice(0, limit);

    return {
      ok: true,
      rows: out,
      count: totalCount ?? sorted.length,
      effective_week: val("week") || out[0]?.week || ""
    };
  }

  async function directSave(path, options) {
    if (!supabaseClient) initSupabase();

    const body = JSON.parse(options?.body || "{}");
    const id = path.match(/\/api\/cleansing-history\/([^/]+)$/)?.[1];
    const query = supabaseClient.from(TABLE_HISTORY);

    if (id) {
      const { data, error } = await query.update(body).eq("id", id).select("*").maybeSingle();

      if (error) throw error;

      return {
        ok: true,
        row: data
      };
    }

    const { data, error } = await query.insert(body).select("*").maybeSingle();

    if (error) throw error;

    return {
      ok: true,
      row: data
    };
  }

  async function api(path, options = {}, retrying = false) {
    const token = await getToken(retrying);

    const headers = new Headers(options.headers || {});
    headers.set("Authorization", "Bearer " + token);

    if (options.body && !headers.has("Content-Type")) {
      headers.set("Content-Type", "application/json");
    }

    const res = await fetch(API + path, {
      ...options,
      headers
    });

    const text = await res.text();

    let data = null;
    try {
      data = text ? JSON.parse(text) : null;
    } catch {
      data = {
        ok: false,
        error: text
      };
    }

    if (!res.ok || data?.ok === false) {
      if (!retrying && res.status === 401 && data?.error === "invalid_session") {
        return api(path, options, true);
      }

      const detail = stringifyDetail(data?.detail);
      throw new Error([
        data?.error || data?.message || text || "요청 실패",
        detail
      ].filter(Boolean).join("\n"));
    }

    return data;
  }

