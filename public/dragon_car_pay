<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>용차 정산</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0f1a2d;
      --panel2:#0c1524;
      --line:rgba(255,255,255,.08);
      --line2:#d4dbe5;
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;
      --ok:#1a5a3a;
      --warn:#6a4b13;
      --danger:#6b1b1b;

      --card:#121d33;
      --card2:#16233b;

      --sheetBg:#eef3f8;
      --headBg:#dde7f3;
      --filterBg:#edf3fb;
      --cellBg:#ffffff;
      --cellAlt:#f8fbff;
      --cellTxt:#0f172a;

      --dirtyBg:#e0eeff;
      --dirtyBorder:#60a5fa;

      --warnBg:#fff1a8;
      --warnBorder:#e2c44d;

      --dangerBg:#ffd9d6;
      --dangerBorder:#f1b7b0;

      --topbarH:56px;
      --toolbarH:58px;
      --statusH:44px;
    }

    *{ box-sizing:border-box; }
    html,body{
      height:100%;
      margin:0;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }
    body{ overflow:hidden; }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--topbarH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
    }
    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }
    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }
    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }
    .titleBox b{
      font-size:18px;
      line-height:1.1;
      letter-spacing:.1px;
    }
    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }
    .spacer{ flex:1; }

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }
    .btn:hover{ background:var(--btn2); }
    .btn.ok{ background:rgba(26,90,58,.35); border-color:rgba(0,255,140,.18); }
    .btn.warn{ background:rgba(106,75,19,.35); border-color:rgba(255,180,0,.18); }
    .btn.danger{ background:rgba(107,27,27,.35); border-color:rgba(255,60,60,.22); color:#ffccd3; }
    .btn:disabled{ opacity:.55; cursor:not-allowed; }

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:var(--panel2);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }
    .group{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }
    .group:last-child{
      border-right:none;
      padding-right:0;
    }
    .group label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }
    .toolbar input,
    .toolbar select{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(0,0,0,.22);
      color:#fff;
      outline:none;
      padding:0 12px;
      font-size:13px;
    }
    .toolbar input:focus,
    .toolbar select:focus{
      border-color:rgba(96,165,250,.65);
    }

    .main{
      min-height:0;
      display:grid;
      grid-template-columns:320px 1fr;
    }

    .sidebar{
      min-width:0;
      border-right:1px solid var(--line);
      background:linear-gradient(180deg,var(--panel),#0b1321);
      display:flex;
      flex-direction:column;
      min-height:0;
    }

    .sidebarSection{
      padding:12px;
      border-bottom:1px solid var(--line);
    }

    .sideTitle{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:10px;
      letter-spacing:.2px;
    }

    .monthCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:12px;
    }

    .monthLabel{
      font-size:12px;
      color:#cfe0ff;
      font-weight:900;
      margin-bottom:6px;
    }

    .monthValue{
      font-size:24px;
      font-weight:900;
      line-height:1.05;
    }

    .statGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .statCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:10px 12px;
    }

    .statLabel{
      color:var(--muted);
      font-size:11px;
      font-weight:900;
      margin-bottom:4px;
    }
    .statValue{
      font-size:18px;
      font-weight:900;
      line-height:1.1;
      color:#fff;
    }
    .statValue.green{ color:#bbf7d0; }
    .statValue.red{ color:#fecaca; }
    .statValue.blue{ color:#bfdbfe; }

    .orderList{
      min-height:0;
      overflow:auto;
      padding:10px;
    }

    .orderItem{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:16px;
      padding:12px;
      margin-bottom:10px;
      cursor:pointer;
      transition:.14s ease;
    }
    .orderItem:hover{
      border-color:rgba(255,255,255,.18);
      background:rgba(255,255,255,.07);
    }
    .orderItem.active{
      border-color:rgba(96,165,250,.55);
      background:rgba(59,130,246,.12);
      box-shadow:inset 0 0 0 1px rgba(96,165,250,.22);
    }
    .orderTop{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
      margin-bottom:8px;
    }
    .orderName{
      font-weight:900;
      color:#fff;
      line-height:1.25;
      word-break:keep-all;
    }
    .orderTag{
      flex:0 0 auto;
      border-radius:999px;
      padding:4px 8px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.06);
      font-size:11px;
      font-weight:900;
      color:#dbe7ff;
      white-space:nowrap;
    }
    .orderSub{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:6px 12px;
      font-size:12px;
      color:#c9d7f2;
    }
    .orderSub b{
      color:#fff;
      font-weight:900;
    }

    .content{
      min-width:0;
      min-height:0;
      display:grid;
      grid-template-rows:auto auto 1fr;
      background:#0f1726;
    }

    .summaryWrap{
      padding:12px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,#10192b,#0e1625);
    }

    .hero{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:18px;
      padding:14px;
      display:flex;
      justify-content:space-between;
      gap:16px;
      align-items:flex-start;
      flex-wrap:wrap;
    }

    .heroTitle{
      font-size:22px;
      font-weight:900;
      line-height:1.15;
      margin-bottom:6px;
      color:#fff;
    }
    .heroSub{
      font-size:12px;
      color:#c8d6f1;
      line-height:1.5;
      white-space:pre-line;
    }

    .kpiRow{
      display:grid;
      grid-template-columns:repeat(4,minmax(120px,1fr));
      gap:10px;
      margin-top:12px;
    }

    .kpi{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(0,0,0,.16);
      border-radius:14px;
      padding:12px;
    }
    .kpiLabel{
      color:var(--muted);
      font-size:11px;
      font-weight:900;
      margin-bottom:6px;
    }
    .kpiValue{
      font-size:20px;
      line-height:1.05;
      font-weight:900;
      color:#fff;
    }
    .kpiValue.green{ color:#bbf7d0; }
    .kpiValue.red{ color:#fecaca; }
    .kpiValue.blue{ color:#bfdbfe; }

    .statementWrap{
      padding:12px;
      border-bottom:1px solid var(--line);
      background:#0d1523;
    }

    .sectionTitle{
      font-size:13px;
      font-weight:900;
      color:#dbe7ff;
      margin-bottom:10px;
      letter-spacing:.2px;
    }

    .tableWrap{
      overflow:auto;
      background:var(--sheetBg);
      border-radius:16px;
      border:1px solid rgba(255,255,255,.08);
    }

    table.sheet{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
      min-width:1200px;
    }

    .sheet th, .sheet td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }
    .sheet th:first-child, .sheet td:first-child{
      border-left:1px solid var(--line2);
    }

    .sheet thead th{
      position:sticky;
      top:0;
      z-index:2;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .sheet tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }
    .sheet tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    .sheet td.dirty{
      background:var(--dirtyBg) !important;
      box-shadow:inset 0 0 0 2px var(--dirtyBorder);
    }

    .sheet td.warn{
      background:var(--warnBg) !important;
      box-shadow:inset 0 0 0 1px var(--warnBorder);
    }

    .sheet td.bad{
      background:var(--dangerBg) !important;
      box-shadow:inset 0 0 0 1px var(--dangerBorder);
    }

    .cellView{
      min-height:42px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:0 10px;
      font-size:13px;
      line-height:1.35;
      word-break:break-word;
      overflow-wrap:anywhere;
    }
    .cellView.left{ justify-content:flex-start; text-align:left; }
    .cellView.center{ justify-content:center; text-align:center; }
    .cellView.right{ justify-content:flex-end; text-align:right; font-variant-numeric:tabular-nums; }
    .code{
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:12px;
    }

    .editorWrap{
      min-height:0;
      overflow:auto;
      padding:12px;
      background:#0b1320;
    }

    .editorGrid{
      display:grid;
      grid-template-columns:1fr;
      gap:14px;
    }

    .editorCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:18px;
      overflow:hidden;
      min-height:0;
    }

    .editorHead{
      padding:12px 14px;
      border-bottom:1px solid rgba(255,255,255,.08);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      background:rgba(255,255,255,.03);
    }

    .editorActions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
    }

    .editorTableWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .cellInput,
    .cellSelect{
      width:100%;
      min-height:42px;
      border:none;
      outline:none;
      background:transparent;
      color:var(--cellTxt);
      padding:10px;
      font:inherit;
      border-radius:0;
    }
    .cellInput{ font-size:13px; }
    .cellInput.center, .cellSelect.center{ text-align:center; }
    .cellInput.right{ text-align:right; font-variant-numeric:tabular-nums; }
    .cellInput.code{ font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; font-size:12px; }
    .cellSelect{ cursor:pointer; }

    .tinyBtn{
      width:34px;
      height:34px;
      border-radius:10px;
      border:1px solid #d4dbe5;
      background:#fff;
      color:#64748b;
      cursor:pointer;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size:15px;
      font-weight:900;
    }
    .tinyBtn:hover{ background:#f8fafc; }
    .tinyBtn.delete{
      color:#b91c1c;
      border-color:#fecaca;
      background:#fff5f5;
    }

    .empty{
      padding:18px 14px;
      text-align:center;
      color:#64748b;
      font-weight:900;
      background:#f8fbff;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }
    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }
    .pill.ok{ color:#bbf7d0; }
    .pill.warn{ color:#fde68a; }
    .pill.err{ color:#fecaca; }
    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }
    .accessDenied.show{ display:flex; }
    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }
    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }
    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }
    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }
    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width: 1220px){
      .main{ grid-template-columns:280px 1fr; }
      .kpiRow{ grid-template-columns:repeat(2,minmax(120px,1fr)); }
    }

    @media (max-width: 880px){
      .main{ grid-template-columns:1fr; }
      .sidebar{
        max-height:260px;
      }
      .topbar{
        gap:8px;
        padding:0 10px;
      }
      .btn{
        padding:0 10px;
        font-size:12px;
      }
      .toolbar{
        padding:8px;
        gap:8px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>용차 정산</b>
        <small>최고관리자 전용 · 용차 정산 / 차감 관리</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnSaveAll" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="group">
        <label for="yearSelect">정산 연도</label>
        <select id="yearSelect"></select>
      </div>

      <div class="group">
        <label for="monthSelect">정산 월</label>
        <select id="monthSelect"></select>
      </div>

      <div class="group">
        <label for="orderSearchInput">벤더 검색</label>
        <input id="orderSearchInput" type="text" placeholder="Order / 기사명 / 캠프" />
      </div>

      <div class="group">
        <button id="btnClearSearch" class="btn" type="button">검색 초기화</button>
      </div>
    </div>

    <div class="main">
      <aside class="sidebar">
        <div class="sidebarSection">
          <div class="sideTitle">선택 월</div>
          <div class="monthCard">
            <div class="monthLabel">현재 조회</div>
            <div id="monthLabelValue" class="monthValue">-</div>
          </div>
        </div>

        <div class="sidebarSection">
          <div class="sideTitle">월 요약</div>
          <div class="statGrid">
            <div class="statCard">
              <div class="statLabel">벤더 수</div>
              <div id="sideVendorCount" class="statValue">0</div>
            </div>
            <div class="statCard">
              <div class="statLabel">정산 건수</div>
              <div id="sideRowCount" class="statValue blue">0</div>
            </div>
            <div class="statCard">
              <div class="statLabel">월 정산합</div>
              <div id="sideMonthGross" class="statValue">₩0</div>
            </div>
            <div class="statCard">
              <div class="statLabel">월 차감합</div>
              <div id="sideMonthDeduction" class="statValue red">₩0</div>
            </div>
          </div>
        </div>

        <div class="sidebarSection">
          <div class="sideTitle">벤더 목록</div>
        </div>
        <div id="orderList" class="orderList"></div>
      </aside>

      <main class="content">
        <div class="summaryWrap">
          <div class="hero">
            <div>
              <div id="heroTitle" class="heroTitle">벤더를 선택해줘</div>
              <div id="heroSub" class="heroSub">좌측에서 Order를 선택하면 월 정산서와 원장 편집이 같이 보인다.</div>
            </div>
          </div>

          <div class="kpiRow">
            <div class="kpi">
              <div class="kpiLabel">총 정산금액</div>
              <div id="kpiGross" class="kpiValue">₩0</div>
            </div>
            <div class="kpi">
              <div class="kpiLabel">총 차감금액</div>
              <div id="kpiDeduction" class="kpiValue red">₩0</div>
            </div>
            <div class="kpi">
              <div class="kpiLabel">실정산금액</div>
              <div id="kpiNet" class="kpiValue green">₩0</div>
            </div>
            <div class="kpi">
              <div class="kpiLabel">미입금 행</div>
              <div id="kpiUnpaidCount" class="kpiValue blue">0</div>
            </div>
          </div>
        </div>

        <div class="statementWrap">
          <div class="sectionTitle">선택 벤더 정산서</div>
          <div class="tableWrap">
            <table class="sheet">
              <colgroup>
                <col style="width:110px" />
                <col style="width:110px" />
                <col style="width:90px" />
                <col style="width:180px" />
                <col style="width:100px" />
                <col style="width:100px" />
                <col style="width:100px" />
                <col style="width:130px" />
                <col style="width:110px" />
                <col style="width:110px" />
                <col style="width:120px" />
                <col style="width:220px" />
              </colgroup>
              <thead>
                <tr>
                  <th>배송 일자</th>
                  <th>캠프</th>
                  <th>주/야</th>
                  <th>라우트</th>
                  <th>단가</th>
                  <th>배송 수량</th>
                  <th>반품 수량</th>
                  <th>정산 금액</th>
                  <th>입금 여부</th>
                  <th>세금계산서</th>
                  <th>투입 기사</th>
                  <th>비고</th>
                </tr>
              </thead>
              <tbody id="statementBody"></tbody>
            </table>
          </div>
        </div>

        <div class="editorWrap">
          <div class="editorGrid">
            <div class="editorCard">
              <div class="editorHead">
                <div class="sectionTitle" style="margin:0">용차 원장 편집</div>
                <div class="editorActions">
                  <button id="btnAddPayRow" class="btn warn" type="button">원장 행 추가</button>
                </div>
              </div>
              <div class="editorTableWrap">
                <table class="sheet">
                  <colgroup>
                    <col style="width:80px" />
                    <col style="width:120px" />
                    <col style="width:180px" />
                    <col style="width:110px" />
                    <col style="width:90px" />
