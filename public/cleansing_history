  async function copyImage() {
    if (!rows.length) {
      alert("복사할 조회 결과가 없습니다.");
      return;
    }

    if (!window.htmlToImage?.toBlob) {
      alert("이미지 생성 라이브러리를 불러오지 못했습니다. 새로고침 후 다시 시도하세요.");
      return;
    }

    const sourceTable = $("table").querySelector("table");

    if (!sourceTable) {
      alert("복사할 표를 찾지 못했습니다.");
      return;
    }

    const wrap = document.createElement("div");
    const tableClone = sourceTable.cloneNode(true);

    wrap.className = "captureCloneWrap";
    tableClone.classList.add("captureTable");
    tableClone.querySelectorAll(".manageCol").forEach(el => el.remove());

    wrap.appendChild(tableClone);
    document.body.appendChild(wrap);

    const tableRect = tableClone.getBoundingClientRect();
    const captureWidth = Math.ceil(Math.max(tableClone.scrollWidth, tableRect.width));
    const captureHeight = Math.ceil(Math.max(tableClone.scrollHeight, tableRect.height));

    tableClone.style.width = captureWidth + "px";
    wrap.style.width = captureWidth + "px";
    wrap.style.height = captureHeight + "px";

    try {
      const blob = await htmlToImage.toBlob(tableClone, {
        backgroundColor:"#ffffff",
        pixelRatio:2,
        width:captureWidth,
        height:captureHeight,
        style:{
          width:captureWidth + "px",
          height:captureHeight + "px",
          background:"#ffffff"
        },
        cacheBust:true
      });

      if (!blob) {
        throw new Error("이미지 생성 실패");
      }

      if (navigator.clipboard && window.ClipboardItem) {
        await navigator.clipboard.write([
          new ClipboardItem({ "image/png": blob })
        ]);
        alert("표 이미지를 클립보드에 복사했습니다.");
        return;
      }

      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = captureFileName();
      a.click();
      URL.revokeObjectURL(a.href);
    } finally {
      wrap.remove();
    }
  }

  function bind() {
    $("search").onclick = () => load().catch(e => alert(e.message));
    $("refresh").onclick = $("search").onclick;

    $("reset").onclick = async () => {
      ["week", "camp", "route", "vendor", "biz", "q"].forEach(id => {
        $(id).value = "";
      });

      $("wave").value = "";
      $("reason").value = "";

      try {
        await initWeek();
        await load();
      } catch (e) {
        alert(e.message);
      }
    };

    $("copyImage").onclick = () => copyImage().catch(e => alert(e.message));

    $("add").onclick = () => {
      save(null).catch(e => alert(e.message));
    };

    $("table").onclick = e => {
      const saveBtn = e.target.closest("[data-save]");

      if (saveBtn) {
        const id = saveBtn.dataset.save;
        const row = rows.find(r => rowId(r) === id);
        const tr = saveBtn.closest("tr");

        if (row && tr) {
          saveInline(row, tr).catch(err => alert(err.message));
        }

        return;
      }

      const btn = e.target.closest("[data-edit]");

      if (!btn) return;

      const row = rows.find(r => rowId(r) === btn.dataset.edit);

      if (row) {
        editingId = rowId(row);
        render();
      }
    };

    ["week", "camp", "route", "vendor", "biz", "q"].forEach(id => {
      $(id).addEventListener("keydown", e => {
        if (e.key === "Enter") {
          load().catch(err => alert(err.message));
        }
      });
    });

    $("wave").onchange = $("reason").onchange = () => {
      load().catch(e => alert(e.message));
    };
  }

  async function init() {
    try {
      initSupabase();
      bind();

      if (await initMe()) {
        await initWeek();
        await load();
      }
    } catch (e) {
      document.documentElement.style.visibility = "visible";
      showErrorBox("세션/조회 오류", e.message);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once:true });
  } else {
    init();
  }
})();
</script>
</body>
</html>
