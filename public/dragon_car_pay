<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰 용차 정산서</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>

  <style>
    html { visibility:hidden; }

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0f1a2d;
      --panel2:#0c1524;
      --line:rgba(255,255,255,.08);
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;
      --danger:#6b1b1b;

      --paperLine:#2e2e2e;
      --paperHead:#c9d7ee;
      --paperTxt:#111827;
      --paperBg:#f7f7f7;

      --sumMint:#cbe5d3;
      --sumPink:#f3c9c9;
      --sumBeige:#efe5be;
      --sumBlue:#dfeaf7;

      --driverHead:#dce8c4;
      --driverBlue:#8eb9e8;
      --driverPeach:#ffd8b8;
      --driverPurple:#c8bbd9;
      --driverFinal:#04b85f;
      --driverFinalLabel:#bfe8ef;

      --headerH:56px;
      --toolbarH:58px;
      --statusH:44px;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      height:100%;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }

    body{overflow:hidden}

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--headerH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }

    .spacer{flex:1}

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }

    .btn:hover{background:var(--btn2)}
    .btn.ok{background:rgba(26,90,58,.35);border-color:rgba(0,255,140,.18)}
    .btn.danger{background:rgba(107,27,27,.35);border-color:rgba(255,60,60,.22);color:#ffccd3}
    .btn:disabled{opacity:.55;cursor:not-allowed}

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:var(--panel2);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .toolGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolGroup label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .toolbar input{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbar input:focus{
      border-color:rgba(96,165,250,.55);
    }

    .modeTabs{
      display:flex;
      gap:8px;
    }

    .modeBtn{
      height:38px;
      min-width:92px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.04);
      color:#dce8ff;
      font-weight:900;
      cursor:pointer;
    }

    .modeBtn.active{
      background:rgba(59,130,246,.18);
      border-color:rgba(96,165,250,.5);
      color:#fff;
    }

    .main{
      min-height:0;
      display:grid;
      grid-template-columns:280px 1fr;
    }

    .sidebar{
      min-height:0;
      border-right:1px solid var(--line);
      background:linear-gradient(180deg,var(--panel),#0b1321);
      display:flex;
      flex-direction:column;
    }

    .sideSection{
      padding:10px;
      border-bottom:1px solid var(--line);
    }

    .sideTitle{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:10px;
    }

    .summaryGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:8px;
    }

    .summaryCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:12px;
      padding:10px;
      min-width:0;
    }

    .summaryLabel{
      font-size:11px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:4px;
    }

    .summaryValue{
      font-size:17px;
      line-height:1.1;
      font-weight:900;
      color:#fff;
      word-break:break-word;
      font-variant-numeric:tabular-nums;
    }

    .summaryValue.blue{color:#bfdbfe}
    .summaryValue.red{color:#fecaca}
    .summaryValue.green{color:#bbf7d0}
    .summaryValue.yellow{color:#fde68a}

    .groupList{
      min-height:0;
      overflow:auto;
      padding:8px;
    }

    .groupItem{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:10px;
      margin-bottom:8px;
      cursor:pointer;
      transition:.14s ease;
    }

    .groupItem:hover{
      border-color:rgba(255,255,255,.18);
      background:rgba(255,255,255,.07);
    }

    .groupItem.active{
      border-color:rgba(96,165,250,.55);
      background:rgba(59,130,246,.12);
      box-shadow:inset 0 0 0 1px rgba(96,165,250,.22);
    }

    .groupName{
      font-weight:900;
      color:#fff;
      line-height:1.3;
      margin-bottom:8px;
      word-break:break-word;
      white-space:pre-line;
    }

    .groupMeta{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:5px 8px;
      font-size:11px;
      color:#d3def5;
    }

    .groupMeta b{
      color:#fff;
      font-weight:900;
    }

    .groupMeta span{
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .groupMeta .wide{
      grid-column:1 / -1;
    }

    .content{
      min-width:0;
      min-height:0;
      overflow:auto;
      background:#0d1523;
      padding:10px;
    }

    .invoicePage{
      width:min(1120px,100%);
      margin:0;
      background:var(--paperBg);
      color:var(--paperTxt);
      border-radius:6px;
      box-shadow:0 16px 42px rgba(0,0,0,.24);
      overflow:hidden;
      padding:28px 34px 26px;
    }

    .invoiceTitleBox{
      border:3px solid #1d1d1d;
      background:#fff;
      text-align:center;
      font-size:24px;
      font-weight:900;
      letter-spacing:-.02em;
      padding:10px 16px;
      margin-bottom:26px;
    }

    .invoiceMeta{
      display:grid;
      grid-template-columns:120px 1fr;
      gap:6px 10px;
      margin-bottom:18px;
      font-size:14px;
    }

    .invoiceMeta .label{
      color:#435266;
      font-weight:800;
    }

    .invoiceMeta .value{
      font-weight:800;
      white-space:pre-line;
      word-break:break-word;
    }

    .sheetWrap{
      border:2px solid #1f1f1f;
      background:#fff;
    }

    table.invoiceTable{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
      font-size:12px;
    }

    .invoiceTable th,
    .invoiceTable td{
      border-right:1px solid var(--paperLine);
      border-bottom:1px solid var(--paperLine);
      padding:7px 6px;
      text-align:center;
      vertical-align:middle;
      line-height:1.35;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .invoiceTable th:last-child,
    .invoiceTable td:last-child{
      border-right:none;
    }

    .invoiceTable thead th{
      background:var(--paperHead);
      color:#111827;
      font-size:13px;
      font-weight:900;
      white-space:nowrap;
    }

    .invoiceTable tbody td{
      background:#fff;
      font-size:11px;
    }

    .invoiceTable tbody td.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
      padding-right:10px;
    }

    .invoiceTable tbody td.red{
      color:#ff3b30;
      font-weight:900;
    }

    .invoiceTable tbody td.green{
      color:#0ba84f;
      font-weight:900;
    }

    .invoiceTable tbody td.blank{
      height:28px;
      color:transparent;
    }

    .summarySheet{
      margin-top:0;
      border-left:2px solid #1f1f1f;
      border-right:2px solid #1f1f1f;
      border-bottom:2px solid #1f1f1f;
      background:#fff;
    }

    table.summaryTable{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
      font-size:12px;
    }

    .summaryTable td{
      border-right:1px solid var(--paperLine);
      padding:9px 8px;
      text-align:center;
      font-weight:900;
      line-height:1.2;
    }

    .summaryTable td:last-child{border-right:none}
    .summaryGreen{background:var(--sumMint)}
    .summaryPink{background:var(--sumPink);color:#d61f12}
    .summaryBeige{background:var(--sumBeige)}
    .summaryBlue{background:var(--sumBlue);color:#2f80ed}

    .bottomArea{
      display:grid;
      grid-template-columns:420px 1fr;
      gap:22px;
      margin-top:22px;
      align-items:start;
    }

    .bankBox,
    .noteBox{
      border:2px solid #1f1f1f;
      background:#fff;
    }

    table.bankTable{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
      font-size:14px;
    }

    .bankTable td{
      border-right:1px solid var(--paperLine);
      border-bottom:1px solid var(--paperLine);
      padding:8px 10px;
      line-height:1.25;
    }

    .bankTable tr:last-child td{border-bottom:none}
    .bankTable td:last-child{border-right:none}

    .bankLabel{
      width:42%;
      background:var(--paperHead);
      text-align:center;
      font-weight:900;
    }

    .bankValue{
      text-align:center;
      font-weight:800;
      background:#fff;
    }

    .bankValue.amount{
      color:#ff0000;
      font-size:18px;
      font-weight:900;
    }

    .noteBox{
      min-height:158px;
      padding:14px 16px;
      font-size:15px;
      line-height:1.8;
      white-space:pre-line;
    }

    .driverSheet{
      width:min(1180px,100%);
      margin:0;
      background:#fff;
      color:#111;
      border-radius:6px;
      box-shadow:0 16px 42px rgba(0,0,0,.24);
      overflow:hidden;
      padding:24px 28px 26px;
    }

    .driverTable{
      border-collapse:collapse;
      table-layout:fixed;
      width:100%;
      font-size:16px;
      color:#111;
      background:#fff;
    }

    .driverTable th,
    .driverTable td{
      border:1px solid #222;
      padding:6px 7px;
      text-align:center;
      vertical-align:middle;
      line-height:1.25;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .driverTable .title{
      background:#dceff3;
      font-size:29px;
      font-weight:900;
      padding:9px 10px;
      border:2px solid #222;
    }

    .driverTable .head{
      background:var(--driverHead);
      font-size:24px;
      font-weight:900;
    }

    .driverTable .money{
      text-align:right;
      font-variant-numeric:tabular-nums;
      padding-right:12px;
      white-space:nowrap;
    }

    .driverTable .red{
      color:#f00;
      font-weight:900;
    }

    .driverTable .green{
      color:#0aa64b;
      font-weight:900;
    }

    .driverTable .blue{
      background:var(--driverBlue);
      font-weight:900;
    }

    .driverTable .peach{
      background:var(--driverPeach);
      color:#f00;
      font-weight:900;
    }

    .driverTable .purple{
      background:var(--driverPurple);
      color:#13395a;
      font-weight:900;
    }

    .driverTable .memoHead{
      background:var(--driverHead);
      font-weight:900;
    }

    .driverTable .finalLabel{
      background:var(--driverFinalLabel);
      font-size:22px;
      font-weight:900;
    }

    .driverTable .finalMoney{
      background:var(--driverFinal);
      color:#8432c8;
      font-size:19px;
      font-weight:900;
      text-align:right;
      white-space:nowrap;
    }

    .driverTable .blank td{
      height:25px;
      color:transparent;
    }

    .driverTable .loss{
      color:#f00;
      font-weight:900;
      text-align:left;
      padding-left:12px;
    }

    .driverTable .note{
      text-align:center;
      line-height:1.65;
      padding:18px 10px;
      font-size:15px;
    }

    .driverTable.mt{margin-top:20px}

    .emptyState{
      width:min(940px,100%);
      margin:0 auto;
      padding:24px;
      border:1px dashed rgba(255,255,255,.14);
      border-radius:16px;
      text-align:center;
      color:#c1d0ea;
      background:rgba(255,255,255,.03);
      font-weight:900;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{color:#bbf7d0}
    .pill.warn{color:#fde68a}
    .pill.err{color:#fecaca}

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg,rgba(11,18,32,.96),rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(520px,calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    .invoicePage.capture-export,
    .driverSheet.capture-export{
      overflow:visible!important;
      width:1180px!important;
      max-width:none!important;
      height:auto!important;
      max-height:none!important;
      border-radius:0!important;
      box-shadow:none!important;
    }

    .capture-host{
      position:fixed;
      left:-100000px;
      top:0;
      z-index:-1;
      background:#fff;
      padding:24px;
      width:auto;
      height:auto;
      overflow:visible;
    }

    @media(max-width:1100px){
      .main{grid-template-columns:1fr}
      .sidebar{max-height:360px}
      .btn{padding:0 10px;font-size:12px}
      .toolbar{padding:8px;gap:8px}
      .bottomArea{grid-template-columns:1fr}
      .invoicePage{padding-left:16px;padding-right:16px}
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a id="mwBoardMenuToggle" href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>

      <div class="titleBox">
        <b>용차 정산서</b>
        <small>월별 업체 / 기사 정산서 생성기</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnDownloadPng" class="btn ok" type="button">PNG 저장</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="toolGroup">
        <label for="monthInput">정산월</label>
        <input id="monthInput" type="text" placeholder="예: 2026-04 / 26년 4월" />
      </div>

      <div class="toolGroup">
        <label>정산서 종류</label>
        <div class="modeTabs">
          <button id="btnModeVendor" class="modeBtn active" type="button">업체 정산서</button>
          <button id="btnModeDriver" class="modeBtn" type="button">기사 정산서</button>
        </div>
      </div>

      <div class="toolGroup">
        <label for="searchInput">검색</label>
        <input id="searchInput" type="text" placeholder="업체 / Order / 기사 / 캠프 / 라우트" />
      </div>

      <div class="toolGroup">
        <button id="btnClearSearch" class="btn" type="button">검색 초기화</button>
      </div>
    </div>

    <div class="main">
      <aside class="sidebar">
        <div class="sideSection">
          <div class="sideTitle">현재 조회</div>
          <div id="summaryGrid" class="summaryGrid"></div>
        </div>

        <div class="sideSection">
          <div class="sideTitle">정산서 목록</div>
        </div>

        <div id="groupList" class="groupList"></div>
      </aside>

      <main class="content">
        <div id="statementCapture" class="invoicePage" style="display:none"></div>

        <div id="emptyState" class="emptyState">
          월을 선택하고, 좌측에서 업체 또는 기사를 선택하면 정산서가 생성됩니다.
        </div>
      </main>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillGroups" class="pill">정산서 0</span>
      <span id="statusText" class="statusText">업체는 vendor_id + order_name 기준, 기사는 delivery_driver 기준입니다.</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 최고관리자 또는 용차 관리자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INDEX_PATH = PATHS?.index || "/index.html";

      const ACCESS_TABLE = "user_access";
      const PROFILES_TABLE = "profiles";
      const DATA_TABLE = "dragon_car";
      const VENDORS_TABLE = "vendors";
      const INFO_TABLE = "maroowell_info";

      const ZERO_COMMISSION_DRIVERS = new Set(["김용준", "장세인", "이우람"]);
      const TEAM_LEADER_NAME = "한재봉";
      const DEFAULT_COMMISSION_RATE = 0.08;
      const INSURANCE_RATE = 0.0168;
      const VENDOR_FILL_ROWS = 10;
      const DRIVER_FILL_ROWS = 10;

      const PAYMENT_INFO = {
        bankName:"국민은행",
        accountNumber:"293237 - 04 - 011538",
        depositor:"마루웰",
        requestNote:"금액 확인 요청 드립니다.\n\n금액 확인 하신 후에 이상 없으시면 세금계산서 발행 하겠습니다.\n\n이후 정산일자에 입금 부탁드립니다."
      };

