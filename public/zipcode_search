      async function copyShareUrl(url) {
        try {
          await navigator.clipboard.writeText(url);
          return true;
        } catch {
          try {
            const ta = document.createElement("textarea");
            ta.value = url;
            ta.style.position = "fixed";
            ta.style.left = "-9999px";
            ta.style.top = "0";
            document.body.appendChild(ta);
            ta.focus();
            ta.select();
            const ok = document.execCommand("copy");
            ta.remove();
            return ok;
          } catch {
            return false;
          }
        }
      }

      function buildShareUrlFromResponse(data) {
        const direct =
          data?.url ||
          data?.shareUrl ||
          data?.share_url ||
          data?.link ||
          data?.share_link;

        if (direct) return String(direct);

        const token = data?.token || data?.s || data?.share_token || data?.shareToken;
        const sig = data?.sig || data?.signature;

        if (token && sig) {
          return `${location.origin}${ZIP_SHARE_PAGE_PATH}?s=${encodeURIComponent(token)}&sig=${encodeURIComponent(sig)}`;
        }

        return "";
      }

      function collectShareZipcodes() {
        const zips = new Set();

        for (const zip of state.selectedZips) {
          if (/^\d{5}$/.test(String(zip))) zips.add(String(zip));
        }

        for (const zip of parseZips($("#zipInput")?.value || "")) {
          zips.add(zip);
        }

        return [...zips].sort();
      }

      async function createMapShareLink() {
        const btn = $("#shareMapBtn");
        const zips = collectShareZipcodes();

        if (!zips.length) {
          alert("공유할 우편번호를 먼저 추가하거나 지도표시 해주세요.");
          return;
        }

        const session = await getCurrentSession();

        if (!session?.access_token) {
          alert("로그인 세션을 확인하지 못했습니다. 새로고침 후 다시 시도해주세요.");
          return;
        }

        try {
          if (btn) {
            btn.disabled = true;
            btn.textContent = "공유 생성 중...";
          }

          const res = await fetch(`${ZIP_SHARE_API_BASE}/share/create`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Authorization": `Bearer ${session.access_token}`
            },
            body: JSON.stringify({
              zips,
              ttl_hours: 72,
              merge: state.mergeMode === true,
              source: "zipcode_search",
              title: `우편번호 지도 ${zips.slice(0, 4).join(", ")}${zips.length > 4 ? " 외" : ""}`
            }),
            cache: "no-store"
          });

          const text = await res.text();
          let data = null;

          try {
            data = text ? JSON.parse(text) : null;
          } catch {}

          if (!res.ok || data?.ok === false) {
            throw new Error(data?.error || data?.message || text || `HTTP ${res.status}`);
          }

          const shareUrl = buildShareUrlFromResponse(data);

          if (!shareUrl) {
            throw new Error("공유 링크 응답이 비어 있습니다.");
          }

          const copied = await copyShareUrl(shareUrl);

          if (copied) {
            showShareToast("지도 공유 링크 복사 완료!");
            alert(`지도 공유 링크를 복사했습니다.\n만료: 72시간\n\n${shareUrl}`);
          } else {
            prompt("지도 공유 링크입니다. 복사해서 전달하세요.", shareUrl);
          }
        } catch (e) {
          console.error("[zipcode_share] create failed", e);
          alert("지도 공유 링크 생성 실패: " + (e?.message || e));
        } finally {
          if (btn) {
            btn.disabled = false;
            btn.textContent = "지도 공유";
          }
        }
      }


