<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>라우트정보</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://dapi.kakao.com/v2/maps/sdk.js?appkey=add4ce93b38c0ff9d9b9053728e067b3&autoload=false&libraries=services"></script>

  <style>
    :root{
      --bg:#0b1220;
      --panel:#101827;
      --panel2:#121a2d;
      --line:rgba(255,255,255,.12);
      --txt:#e6eefc;
      --muted:#9fb0d2;
      --blue:#60a5fa;
      --green:#22c55e;
      --red:#ef4444;
      --yellow:#f59e0b;
      --cyan:#7dd3fc;
    }

    *{box-sizing:border-box}

    html,body{
      height:100%;
      margin:0;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#070b13;
      color:var(--txt);
      overflow:hidden;
    }

    .app{
      height:100%;
      display:grid;
      grid-template-columns:390px minmax(480px, 1fr) 420px;
      background:#070b13;
    }

    .left,
    .right{
      min-height:0;
      overflow:auto;
      background:linear-gradient(180deg,var(--bg),#070b13);
      border-color:var(--line);
      padding:14px;
    }

    .left{border-right:1px solid var(--line)}
    .right{border-left:1px solid var(--line)}

    .mapPane{
      position:relative;
      min-width:0;
      min-height:0;
      background:#0a0f1a;
    }

    #map{
      position:absolute;
      inset:0;
    }

    .title{
      display:flex;
      align-items:center;
      gap:10px;
      margin:0 0 12px;
      min-width:0;
    }

    .title a{
      display:flex;
      align-items:center;
      text-decoration:none;
      flex:0 0 auto;
    }

    .title img{
      width:28px;
      height:28px;
    }

    .titleText{
      flex:1;
      min-width:0;
    }

    .titleText b{
      display:block;
      font-size:21px;
      line-height:1.1;
      letter-spacing:-.4px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .titleText small{
      display:block;
      margin-top:4px;
      color:var(--muted);
      font-size:12px;
      line-height:1.35;
    }

    .userPill{
      flex:0 0 auto;
      max-width:160px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.06);
      color:#cfe0ff;
      padding:7px 10px;
      font-size:12px;
      font-weight:900;
    }

    .card{
      background:rgba(18,26,45,.86);
      border:1px solid var(--line);
      border-radius:16px;
      padding:12px;
      margin-bottom:12px;
      box-shadow:0 12px 34px rgba(0,0,0,.18);
    }

    .cardTitle{
      font-size:15px;
      font-weight:950;
      margin:0 0 10px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }

    .cardTitle small{
      color:var(--muted);
      font-size:11px;
      font-weight:800;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
      margin-bottom:10px;
    }

    .field label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-left:2px;
    }

    input,select,textarea{
      width:100%;
      border-radius:12px;
      border:1px solid var(--line);
      background:rgba(0,0,0,.24);
      color:var(--txt);
      outline:none;
      font:inherit;
    }

    input,select{
      height:40px;
      padding:0 12px;
    }

    input[type=file]{
      height:auto;
      padding:10px;
    }

    textarea{
      min-height:78px;
      padding:10px 12px;
      resize:vertical;
      line-height:1.45;
    }

    input:focus,
    select:focus,
    textarea:focus{
      border-color:rgba(96,165,250,.58);
      box-shadow:0 0 0 2px rgba(96,165,250,.12);
    }

    select option{
      background:#111827;
      color:#fff;
    }

    .row{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
    }

    .row > *{
      flex:1;
      min-width:0;
    }

    button{
      min-height:38px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(59,130,246,.24);
      color:#fff;
      padding:0 14px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
    }

    button:hover{background:rgba(59,130,246,.36)}

    button.secondary{background:rgba(255,255,255,.07)}
    button.secondary:hover{background:rgba(255,255,255,.12)}

    button.ok{
      background:rgba(34,197,94,.18);
      border-color:rgba(34,197,94,.30);
    }
    button.ok:hover{background:rgba(34,197,94,.28)}

    button.danger{
      background:rgba(239,68,68,.18);
      border-color:rgba(239,68,68,.34);
      color:#ffd1d1;
    }
    button.danger:hover{background:rgba(239,68,68,.28)}

    button.warn{
      background:rgba(245,158,11,.18);
      border-color:rgba(245,158,11,.34);
    }
    button.warn:hover{background:rgba(245,158,11,.28)}

    .status{
      margin-top:8px;
      color:var(--muted);
      font-size:12px;
      line-height:1.55;
      white-space:pre-wrap;
    }

    .status.ok{color:#bbf7d0}
    .status.bad{color:#fecaca}
    .status.warn{color:#fde68a}

    .summary{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      min-height:28px;
      padding:0 10px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.06);
      color:var(--muted);
      font-size:12px;
      font-weight:900;
    }

    .pill strong{
      color:#fff;
      margin-left:5px;
    }

    .routeList{
      display:grid;
      gap:8px;
      max-height:calc(100vh - 360px);
      overflow:auto;
      padding-right:2px;
    }

    .routeCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:11px;
      cursor:pointer;
    }

    .routeCard:hover{
      background:rgba(255,255,255,.08);
      border-color:rgba(255,255,255,.18);
    }

    .routeCard.active{
      border-color:rgba(96,165,250,.70);
      background:rgba(59,130,246,.16);
      box-shadow:inset 0 0 0 1px rgba(96,165,250,.22);
    }

    .routeMain{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:center;
      margin-bottom:7px;
    }

    .routeCode{
      color:#bfdbfe;
      font-size:15px;
      font-weight:950;
    }

    .routeMeta{
      color:var(--muted);
      font-size:12px;
      font-weight:800;
    }

    .routeDesc{
      color:#dbeafe;
      font-size:12px;
      line-height:1.45;
      white-space:pre-wrap;
      word-break:break-word;
    }

    .routeBadges{
      margin-top:8px;
      display:flex;
      gap:5px;
      flex-wrap:wrap;
    }

    .miniBadge{
      display:inline-flex;
      align-items:center;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.10);
      color:#dbeafe;
      font-size:11px;
      font-weight:900;
    }

    .mapControls{
      position:absolute;
      top:12px;
      right:12px;
      z-index:20;
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .mapControls button{
      background:rgba(0,0,0,.58);
      border:1px solid rgba(255,255,255,.14);
      backdrop-filter:blur(6px);
      min-height:36px;
      font-size:12px;
    }

    .mapHint{
      display:none !important;
    }

    .drawStatus{
      position:absolute;
      left:12px;
      bottom:12px;
      z-index:20;
      max-width:760px;
      display:none;
      border:1px solid rgba(14,165,233,.50);
      background:rgba(8,47,73,.84);
      color:#e0f2fe;
      border-radius:12px;
      padding:10px 12px;
      font-size:12px;
      line-height:1.55;
      backdrop-filter:blur(6px);
      pointer-events:none;
    }

    .drawStatus.show{display:block}

    .markerTip{
      position:relative;
      transform:translate(-50%,-100%);
      cursor:pointer;
      user-select:none;
    }

    .markerBubble{
      min-width:34px;
      height:34px;
      border-radius:999px;
      display:flex;
      align-items:center;
      justify-content:center;
      color:#fff;
      font-weight:950;
      font-size:14px;
      border:2px solid rgba(255,255,255,.86);
      box-shadow:0 6px 18px rgba(0,0,0,.32);
    }

    .markerLabel{
      position:absolute;
      top:36px;
      left:50%;
      transform:translateX(-50%);
      white-space:nowrap;
      background:rgba(0,0,0,.70);
      border:1px solid rgba(255,255,255,.12);
      border-radius:999px;
      color:#fff;
      padding:3px 7px;
      font-size:11px;
      font-weight:900;
      display:none;
    }

    .markerTip:hover .markerLabel,
    .markerTip.active .markerLabel{display:block}

    .marker-tip .markerBubble{background:#2563eb}
    .marker-entrance .markerBubble{background:#16a34a}
    .marker-password .markerBubble{background:#7c3aed}
    .marker-parking .markerBubble{background:#d97706}
    .marker-caution .markerBubble{background:#dc2626}
    .marker-door .markerBubble{background:#0891b2}
    .marker-gate .markerBubble{background:#0f766e}
    .marker-etc .markerBubble{background:#64748b}

    .detailEmpty{
      color:var(--muted);
      line-height:1.6;
      font-size:13px;
      padding:16px;
      border:1px dashed rgba(255,255,255,.15);
      border-radius:14px;
      background:rgba(255,255,255,.03);
    }

    .pointList{
      display:grid;
      gap:8px;
      max-height:220px;
      overflow:auto;
      padding-right:2px;
    }

    .pointCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:10px;
      cursor:pointer;
    }

    .pointCard:hover{background:rgba(255,255,255,.08)}

    .pointCard.active{
      border-color:rgba(96,165,250,.65);
      background:rgba(59,130,246,.16);
    }

    .pointTitle{
      font-weight:950;
      color:#fff;
      margin-bottom:5px;
      font-size:13px;
    }

    .pointSub{
      color:var(--muted);
      font-size:12px;
      line-height:1.45;
      white-space:pre-wrap;
    }

    .attachmentGrid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:8px;
      margin-top:10px;
    }

    .attachmentCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      overflow:hidden;
    }

    .attachmentThumb{
      display:block;
      width:100%;
      height:120px;
      object-fit:cover;
      background:#020617;
      cursor:pointer;
    }

    .attachmentMeta{padding:8px}

    .attachmentName{
      font-size:12px;
      font-weight:900;
      color:#e6eefc;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .attachmentCaption{
      margin-top:4px;
      font-size:11px;
      color:var(--muted);
      line-height:1.35;
      white-space:pre-wrap;
    }

    .attachmentActions{
      display:flex;
      gap:6px;
      padding:0 8px 8px;
    }

    .attachmentActions button{
      min-height:30px;
      padding:0 10px;
      font-size:11px;
    }

    .modal{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:rgba(0,0,0,.48);
      z-index:9999;
      backdrop-filter:blur(3px);
    }

    .modal.show{display:flex}

    .modalCard{
      width:min(900px, calc(100vw - 32px));
      max-height:min(780px, calc(100vh - 32px));
      overflow:hidden;
      border-radius:20px;
      border:1px solid rgba(255,255,255,.14);
      background:linear-gradient(180deg,#111c31,#08111f);
      box-shadow:0 24px 80px rgba(0,0,0,.55);
      display:flex;
      flex-direction:column;
    }

    .modalTop{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      padding:14px 16px;
      border-bottom:1px solid rgba(255,255,255,.10);
    }

    .modalTitle{
      font-size:17px;
      font-weight:950;
    }

    .modalBody{
      padding:14px 16px;
      overflow:auto;
    }

    .pasteBox{
      min-height:320px;
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:12px;
      white-space:pre;
    }

    #imagePreviewImg{
      display:block;
      max-width:100%;
      max-height:72vh;
      margin:0 auto;
      border-radius:14px;
      background:#020617;
    }

    #imagePreviewCaption{
      margin-top:10px;
      color:#dbeafe;
      font-size:13px;
      line-height:1.55;
      white-space:pre-wrap;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:10000;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(540px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
      line-height:1.6;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media(max-width:1180px){
      .app{grid-template-columns:360px 1fr}

      .right{
        position:absolute;
        right:12px;
        top:70px;
        bottom:12px;
        width:min(410px, calc(100vw - 24px));
        z-index:40;
        border:1px solid var(--line);
        border-radius:18px;
        box-shadow:0 20px 60px rgba(0,0,0,.40);
      }
    }

    @media(max-width:820px){
      .app{grid-template-columns:1fr}

      .left{
        position:absolute;
        left:10px;
        top:10px;
        width:min(370px, calc(100vw - 20px));
        max-height:46vh;
        z-index:50;
        border:1px solid var(--line);
        border-radius:18px;
        box-shadow:0 20px 60px rgba(0,0,0,.45);
      }

      .right{
        top:auto;
        left:10px;
        right:10px;
        bottom:10px;
        width:auto;
        max-height:45vh;
      }
    }
  </style>
</head>

<body>
<div class="app">
  <aside class="left">
    <div class="title">
      <a id="mwBoardMenuToggle" href="#"><img src="/favicon.ico" alt="MarooWell"></a>
      <div class="titleText">
        <b>라우트정보</b>
      </div>
      <div class="userPill" id="userPill">확인 중</div>
    </div>

    <div class="card">
      <div class="cardTitle">검색</div>

      <div class="field">
        <label>Camp</label>
        <input id="campInput" placeholder="예: 일산2, 대구3" />
      </div>

      <div class="field">
        <label>Route / Route Code</label>
        <input id="routeInput" placeholder="예: 126, 126A01, 213A" />
      </div>

      <div class="row">
        <button id="loadBtn">불러오기</button>
        <button id="resetMapBtn" class="secondary">지도 초기화</button>
      </div>

      <div class="row" style="margin-top:8px">
        <button id="pasteOpenBtn" class="secondary">엑셀 붙여넣기</button>
        <button id="addPointModeBtn" class="warn">점 추가 OFF</button>
      </div>

      <div id="statusText" class="status">대기 중</div>

      <div class="summary">
        <span class="pill">라우트 <strong id="routeCount">0</strong></span>
        <span class="pill">폴리곤 <strong id="polygonCount">0</strong></span>
        <span class="pill">포인트 <strong id="pointCount">0</strong></span>
      </div>
    </div>

    <div class="card">
      <div class="cardTitle">
        <span>라우트 목록</span>
        <small>클릭 시 지도 이동</small>
      </div>
      <div id="routeList" class="routeList"></div>
    </div>
  </aside>

  <main class="mapPane">
    <div id="map"></div>
    <div class="mapHint" id="mapHint"></div>
    <div class="drawStatus" id="drawStatus">폴리곤 편집 모드</div>

    <div class="mapControls">
      <button id="toggleMapTypeBtn">위성</button>
      <button id="fitAllBtn">전체보기</button>
    </div>
  </main>

  <aside class="right">
    <div class="card">
      <div class="cardTitle">
        <span>선택 라우트</span>
        <small id="selectedRouteCode">선택 없음</small>
      </div>

      <div id="routeDetailEmpty" class="detailEmpty">
        좌측에서 라우트를 선택하세요.
      </div>

      <div id="routeDetailForm" style="display:none">
        <div class="row">
          <div class="field">
            <label>Camp</label>
            <input id="routeCampInput" placeholder="예: 일산2" />
          </div>
          <div class="field">
            <label>Route</label>
            <input id="routeRouteInput" placeholder="예: 126" />
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label>Sub</label>
            <input id="routeSubInput" placeholder="예: A" />
          </div>
          <div class="field">
            <label>Sub-sub</label>
            <input id="routeSubSubInput" placeholder="예: 01" />
          </div>
        </div>

        <div class="row">
          <button id="saveRouteBaseBtn" class="ok">라우트 수정 저장</button>
          <button id="deleteRouteBtn" class="danger">라우트 삭제</button>
        </div>

        <div class="status" id="routeBaseInfoText">
          Camp / Route / Sub / Sub-sub 수정 시 연결된 폴리곤·포인트의 route_code도 같이 맞춰집니다.
        </div>

        <div class="field" style="margin-top:12px">
          <label>설명</label>
          <textarea id="routeDescriptionInput"></textarea>
        </div>

        <div class="field">
          <label>정보 / 메모</label>
          <textarea id="routeMemoInput"></textarea>
        </div>

        <div class="field">
          <label>서브패키지</label>
          <input id="routeSubPackageInput"/>
        </div>

        <div class="field">
          <label>좌표 / 원본 참고값</label>
          <input id="routeCoordinateInput" />
        </div>

        <div class="row">
          <button id="saveRouteInfoBtn" class="ok">라우트 정보 저장</button>
          <button id="focusRouteBtn" class="secondary">지도 이동</button>
        </div>

        <div class="row" style="margin-top:8px">
          <button id="drawReplaceBtn" class="warn">새로 그리기</button>
          <button id="drawEditBtn" class="warn">수정</button>
          <button id="drawAppendBtn" class="warn">구역 추가</button>
        </div>

        <div class="row" style="margin-top:8px">
          <button id="drawUndoBtn" class="secondary">마지막 점 취소</button>
          <button id="drawSaveBtn" class="ok">그리기 저장</button>
          <button id="drawCancelBtn" class="danger">취소</button>
        </div>

        <div class="status" id="drawInfoText">
          새로 그리기: 해당 라우트의 기존 활성 폴리곤을 모두 비활성화하고 새 폴리곤을 저장합니다.
          수정: 기존 폴리곤 좌표를 불러와 점 이동/추가/삭제 후 저장합니다.
          구역 추가: 기존 폴리곤은 유지하고 새 폴리곤을 추가 저장합니다.
