            classify,
            id:driverId,
            route
          };
        }

        if(!classify && !driverId && !route && !deliveryDate && !camp && !parcel && !returnCount && !totalPrice){
          return {
            skip:true,
            reason:"빈 정산 행",
            rowNo
          };
        }

        const qty = parcel + returnCount;
        const defaultPrice = explicitDefault !== null ? explicitDefault : roundMoney(qty * price);
        const freshbagPrice = sourceFreshbagTotal !== null ? sourceFreshbagTotal : roundMoney(qty * freshbagIncentive);

        const data = {
          date_year:Number(els.yearSelect.value),
          date_month:Number(els.monthSelect.value),
          source_sheet:REQUIRED_SHEET_NAME,
          classify:classify || null,
          id:driverId || null,
          route:route || null,
          delivery_date:deliveryDate,
          camp:camp || null,
          wave:wave || null,
          company_name:companyName || null,
          driver_name:driverName || null,
          parcel,
          "return":returnCount,
          price,
          freshbag_incentive:freshbagIncentive,
          default_price:defaultPrice,
          freshbag_incentive_price:freshbagPrice,
          freshbag_return:freshbagReturn,
          total_price:totalPrice,
          loss_damage_type:null,
          loss_damage_detail:null,
          loss_damage_count:0,
          deduction_price:0,
          tracking_number:null,
          product_name:null
        };

        const meta = {
          rowNo,
          vendor:companyName,
          sheet:REQUIRED_SHEET_NAME,
          sourceDefault:defaultPrice,
          sourceTotal:totalPrice,
          sourceFreshbagIncentive:freshbagIncentive,
          sourceFreshbagPrice:freshbagPrice,
          sourceFreshbagTotal:freshbagPrice,
          sourceFreshbagReturn:freshbagReturn,
          hasExplicitDefaultPrice:explicitDefault !== null,
          hasExplicitFreshbagTotal:sourceFreshbagTotal !== null
        };

        return {
          skip:false,
          data,
          validation:validateAmounts(data, meta),
          meta
        };
      }

      function findLossHeaderRow(rows){
        for(let r = 0; r < Math.min(rows.length, 50); r++){
          const keys = (rows[r] || []).map(compact);
          const hasDate = keys.some(k => k === "날짜" || k.includes("날짜"));
          const hasId = keys.some(k => k === "id" || k.includes("아이디"));
          const hasAmount = keys.some(k => k.includes("차감금액") || k.includes("차감"));
          const hasType = keys.some(k => k.includes("유형") || k.includes("타입"));
          if(hasDate && hasId && hasAmount && hasType) return r;
        }

        return 0;
      }

      function buildLossColumnMap(headers){
        return {
          deliveryDate: findColumnContains(headers, ["날짜", "일자", "배송일자"], 0),
          camp: findColumnContains(headers, ["캠프", "캠프명", "Camp"], 1),
          id: findColumnContains(headers, ["ID", "아이디"], 2),
          driverName: findColumnContains(headers, ["이름", "기사명", "성명"], 3),
          lossType: findColumnContains(headers, ["유형", "타입", "분류"], 4),
          lossDetail: findColumnContains(headers, ["상세", "상세유형", "내용"], 5),
          lossCount: findColumnContains(headers, ["개수", "수량", "건수"], 6),
          deductionPrice: findColumnContains(headers, ["차감금액", "차감액", "금액"], 7),
          companyName: findColumnContains(headers, ["업체명", "업체", "Vendor"], 8),
          trackingNumber: findColumnContains(headers, ["운송장번호", "운송장", "송장번호", "송장"], 9),
          productName: findColumnContains(headers, ["상품명상세", "상품명", "상품", "상세상품"], 10)
        };
      }

      function convertLossRow(row, col, rowNo){
        const deliveryDate = parseDateValue(col.deliveryDate >= 0 ? row[col.deliveryDate] : null);
        const camp = clean(col.camp >= 0 ? row[col.camp] : "");
        const driverId = clean(col.id >= 0 ? row[col.id] : "");
        const driverName = clean(col.driverName >= 0 ? row[col.driverName] : "");
        const lossType = clean(col.lossType >= 0 ? row[col.lossType] : "");
        const lossDetail = clean(col.lossDetail >= 0 ? row[col.lossDetail] : "");
        const lossCount = parseIntCount(col.lossCount >= 0 ? row[col.lossCount] : 0);
        const deductionPrice = parseNumber(col.deductionPrice >= 0 ? row[col.deductionPrice] : 0);
        const companyName = clean(col.companyName >= 0 ? row[col.companyName] : "");
        const trackingNumber = clean(col.trackingNumber >= 0 ? row[col.trackingNumber] : "");
        const productName = clean(col.productName >= 0 ? row[col.productName] : "");

        if(els.maroowellOnlyCheck.checked && companyName && companyName !== "마루웰"){
          return {
            skip:true,
            reason:"업체명 필터",
            rowNo,
            vendor:companyName,
            classify:"분실파손",
            id:driverId,
            route:""
          };
        }

        if(!deliveryDate && !camp && !driverId && !driverName && !deductionPrice && !trackingNumber && !productName){
          return {
            skip:true,
            reason:"빈 분실파손 행",
            rowNo
          };
        }

        const data = {
          date_year:Number(els.yearSelect.value),
          date_month:Number(els.monthSelect.value),
