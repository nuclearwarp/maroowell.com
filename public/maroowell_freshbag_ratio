  function getWeeks() {
    const p = getSelectedPeriod();
    const start = parseIsoDate(p.period_start);
    const end = parseIsoDate(p.period_end);

    const firstSunday = addDays(start, -start.getDay());
    const weeks = [];

    let wStart = firstSunday;
    let seq = 1;

    while (wStart <= end) {
      const days = [];

      for (let i = 0; i < 7; i++) {
        const d = addDays(wStart, i);
        const iso = isoDate(d);

        days.push({
          iso,
          inPeriod: d >= start && d <= end
        });
      }

      const activeDays = days.filter(day => day.inPeriod);

      if (activeDays.length) {
        weeks.push({
          seq,
          start: activeDays[0].iso,
          end: activeDays[activeDays.length - 1].iso,
          days
        });

        seq++;
      }

      wStart = addDays(wStart, 7);
    }

    return weeks;
  }

  function dailyMap() {
    const map = new Map();

    for (const row of dailyRows) {
      map.set(`${rowKey(row)}||${row.date}`, row);
    }

    return map;
  }

  function renderWeeklyTables() {
    const container = $("weekContainer");
    const weeks = getWeeks();
    const dmap = dailyMap();

    if (!routeRows.length) {
      container.innerHTML = `<div class="ratioEmpty" style="padding:20px;text-align:center;border:1px solid var(--line);border-radius:16px">일자별 데이터 없음</div>`;
      return;
    }

    container.innerHTML = weeks.map(week => {
      const headers = week.days.map(day => {
        return `<th class="dayHead" data-in-period="${day.inPeriod ? "1" : "0"}">${day.inPeriod ? esc(formatKoreanDate(day.iso)) : ""}</th>`;
      }).join("");

      const bodyRows = routeRows.map((routeRow, index) => {
        const cells = week.days.map(day => {
          if (!day.inPeriod) return `<td class="emptyDay" data-empty-week-day="1"></td>`;

          const item = dmap.get(`${routeRow.key}||${day.iso}`);

          if (!item) {
            return `<td class="emptyDay">-</td>`;
          }

          return `<td class="dayCell">${ratioBox(item)}</td>`;
        }).join("");

        return `
          <tr class="${rowSeparatorClass(routeRows, index)}">
            <td class="fixedCell">${esc(waveLabel(routeRow.wave))}</td>
            <td class="fixedCell">${esc(routeRow.camp)}</td>
            <td class="fixedCell routeCell">${esc(routeRow.route)}</td>
            ${cells}
          </tr>
        `;
      }).join("");

      return `
        <div class="weekBlock" data-week="${week.seq}">
          <div class="weekTitle">
            <div>${week.seq}주차</div>
            <div class="weekActions">
              <small>${esc(week.start)} ~ ${esc(week.end)}</small>
              <button type="button" class="secondary copyWeekImageBtn" data-week="${week.seq}">이미지 복사</button>
            </div>
          </div>
          <div class="tableWrap captureTarget" id="weekCaptureTarget${week.seq}">
            <table class="weekTable" data-week-table="${week.seq}">
              <thead>
                <tr>
                  <th>주간/야간</th>
                  <th>Camp</th>
                  <th>Route</th>
                  ${headers}
                </tr>
              </thead>
              <tbody>${bodyRows}</tbody>
            </table>
          </div>
        </div>
      `;
    }).join("");
  }

  function trimEmptyWeekColumnsForCopy(root) {
    const table = root?.querySelector("table.weekTable");
    if (!table) return;

    const headerCells = Array.from(table.querySelectorAll("thead tr:first-child th"));
    const removeIndexes = [];

    headerCells.forEach((th, index) => {
      if (index < 3) return;

      const isOutOfPeriod =
        th.dataset.inPeriod === "0" ||
        !clean(th.textContent);

      const bodyCells = Array.from(table.querySelectorAll("tbody tr")).map(tr => tr.children[index]).filter(Boolean);

      const hasRatioData = bodyCells.some(cell => {
        if (cell.matches("[data-empty-week-day='1']")) return false;
        if (cell.classList.contains("emptyDay")) return false;

        const text = clean(cell.textContent).replace(/\s+/g, "");
        if (!text || text === "-") return false;

        return /\d/.test(text);
      });

      if (isOutOfPeriod || !hasRatioData) {
        removeIndexes.push(index);
      }
    });

    removeIndexes
      .sort((a, b) => b - a)
      .forEach(index => {
        table.querySelectorAll("tr").forEach(tr => {
          const cell = tr.children[index];
          if (cell) cell.remove();
        });
      });
  }

    async function copyElementImage(element, label, options = {}) {
    if (!element) {
      setStatus("이미지로 복사할 영역을 찾지 못했습니다.", "bad");
      return;
    }

    if (!window.html2canvas) {
      setStatus("이미지 복사 라이브러리를 불러오지 못했습니다.", "bad");
      return;
    }

    setStatus(`${label} 이미지 생성 중...`, "warn");

    let captureElement = element;
    let tempWrap = null;

    if (options.trimEmptyWeekColumns) {
      tempWrap = document.createElement("div");
      tempWrap.style.position = "fixed";
      tempWrap.style.left = "-100000px";
      tempWrap.style.top = "0";
      tempWrap.style.background = "#ffffff";
      tempWrap.style.padding = "0";
      tempWrap.style.zIndex = "-1";

      const clone = element.cloneNode(true);
      clone.id = "";
      clone.style.maxHeight = "none";
      clone.style.overflow = "visible";
      clone.style.width = "max-content";
      clone.style.borderRadius = "16px";

      const cloneTable = clone.querySelector("table");
      if (cloneTable) {
        cloneTable.style.width = "max-content";
        cloneTable.style.minWidth = "0";
      }

      tempWrap.appendChild(clone);
      document.body.appendChild(tempWrap);

      trimEmptyWeekColumnsForCopy(clone);

      const trimmedTable = clone.querySelector("table");
      if (trimmedTable) {
        trimmedTable.style.width = "max-content";
        trimmedTable.style.minWidth = "0";
      }

      captureElement = clone;
    }

    try {
      const canvas = await html2canvas(captureElement, {
        backgroundColor:"#ffffff",
        scale:Math.max(2, Math.min(4, window.devicePixelRatio || 2)),
        useCORS:true
      });

      const blob = await new Promise(resolve => canvas.toBlob(resolve, "image/png", 1));

      if (!blob) {
        setStatus("이미지 생성에 실패했습니다.", "bad");
        return;
      }

      if (navigator.clipboard?.write && window.ClipboardItem && !/Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent || "")) {
        try {
          await navigator.clipboard.write([
            new ClipboardItem({ "image/png": blob })
          ]);
          setStatus(`${label} 이미지 클립보드 복사 완료`, "ok");
          return;
        } catch (e) {
          console.warn("clipboard image copy failed", e);
        }
      }

      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `maroowell_freshbag_ratio_${Date.now()}.png`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      setStatus(`${label} 이미지 PNG 저장 완료`, "ok");
    } finally {
      if (tempWrap) tempWrap.remove();
    }
  }

  function initRatioUploadSwitchIfAllowed() {
    if (!isSuperAdminAccess()) return;

    const wrap = document.querySelector(".wrap");
    const top = wrap?.querySelector(":scope > .top");
    const userPill = $("userPill");

    if (!wrap || !top || !userPill) return;
    if ($("mwRatioUploadSwitchBtn")) return;

    const viewPanel = document.createElement("div");
    viewPanel.id = "mwRatioViewPanel";

    let node = top.nextSibling;
    while (node) {
      const next = node.nextSibling;
      viewPanel.appendChild(node);
      node = next;
    }
    wrap.appendChild(viewPanel);

    const uploadPanel = document.createElement("div");
    uploadPanel.id = "mwRatioUploadPanel";
    uploadPanel.hidden = true;

    const uploadFrameSrcBase = "/maroowell_freshbag_ratio_upload?embed=1";
    uploadPanel.innerHTML = `
      <iframe
        id="mwRatioUploadFrame"
        class="mw-ratio-upload-frame"
        title="마루웰 회수율 업로드"
        data-src="${uploadFrameSrcBase}"
        src="${uploadFrameSrcBase}&preload=1"
      ></iframe>
    `;
    wrap.appendChild(uploadPanel);

    const uploadFrame = $("mwRatioUploadFrame");
    let uploadLoadTimer = 0;

    function buildUploadFrameSrc(reason = "load") {
      return `${uploadFrameSrcBase}&t=${Date.now()}&r=${encodeURIComponent(reason)}`;
    }

    function reloadUploadFrame(reason = "reload") {
      if (!uploadFrame) return;
      uploadFrame.dataset.loaded = "";
      uploadFrame.setAttribute("src", buildUploadFrameSrc(reason));
    }

    if (uploadFrame) {
      uploadFrame.addEventListener("load", () => {
        uploadFrame.dataset.loaded = "1";
        if (uploadLoadTimer) {
          clearTimeout(uploadLoadTimer);
          uploadLoadTimer = 0;
        }
      });
    }

    const actions = document.createElement("div");
    actions.className = "topActions";

    const btn = document.createElement("button");
    btn.id = "mwRatioUploadSwitchBtn";
    btn.type = "button";
    btn.textContent = "Upload";

    userPill.parentNode.insertBefore(actions, userPill);
    actions.appendChild(btn);
    actions.appendChild(userPill);

    const titleEl = top.querySelector(".title");
    const subEl = top.querySelector(".sub");
    const viewTitle = titleEl?.textContent || "마루웰 회수율";
    const viewSub = subEl?.textContent || "";

    function setMode(mode, updateHash = true) {
      const uploadMode = mode === "upload";
      const frame = $("mwRatioUploadFrame");

      viewPanel.hidden = uploadMode;
      uploadPanel.hidden = !uploadMode;

      btn.textContent = uploadMode ? "View" : "Upload";
      btn.classList.toggle("is-upload", uploadMode);
      btn.setAttribute("aria-pressed", uploadMode ? "true" : "false");

      if (titleEl) {
        titleEl.textContent = uploadMode ? "마루웰 회수율 업로드" : viewTitle;
      }

      if (subEl) {
        subEl.textContent = uploadMode
          ? "엑셀 업로드 화면입니다. View 버튼을 누르면 조회 화면으로 돌아갑니다."
          : viewSub;
      }

      if (uploadMode && frame) {
        if (!frame.getAttribute("src")) {
          reloadUploadFrame("empty-src");
        }

        if (frame.dataset.loaded !== "1") {
          if (uploadLoadTimer) clearTimeout(uploadLoadTimer);

          uploadLoadTimer = setTimeout(() => {
            if (frame.dataset.loaded !== "1") {
              reloadUploadFrame("retry-visible");
            }
          }, 900);
        }
      }

      if (updateHash && window.history?.replaceState) {
        const nextUrl = uploadMode
          ? `${location.pathname}${location.search}#upload`
          : `${location.pathname}${location.search}`;
        history.replaceState(null, "", nextUrl);
      }
    }

    btn.addEventListener("click", () => {
      setMode(uploadPanel.hidden ? "upload" : "view");
    });

    if (location.hash === "#upload") {
      setMode("upload", false);
    }
  }

