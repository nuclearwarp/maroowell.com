      async function ensureAuthenticated() {
        if (!supabase) {
          document.documentElement.style.visibility = "visible";
          showAccessDenied("Supabase 설정이 없어 페이지를 사용할 수 없습니다.", "");
          return false;
        }

        sessionBridge.start();
        await sessionBridge.requestSessionCopy(1200);
        const { data: sessionData } = await supabase.auth.getSession();
        state.session = sessionData?.session || null;
        if (!state.session) {
          window.location.href = LOGIN_PATH;
          return false;
        }

        state.viewerEmail = state.session.user?.email || "";
        state.viewerUserId = state.session.user?.id || "";
        return true;
      }

      async function checkAccess() {
        const email = state.viewerEmail;
        const userId = state.viewerUserId;
        let accessRow = null;
        let profileRow = null;

        try {
          const { data } = await supabase
            .from(ACCESS_TABLE)
            .select("*")
            .or("email.eq." + email + ",user_id.eq." + userId)
            .limit(1)
            .maybeSingle();
          accessRow = data || null;
        } catch (err) {
          console.warn("access check skipped", err);
        }

        try {
          const { data } = await supabase
            .from(PROFILES_TABLE)
            .select("*")
            .eq("id", userId)
            .limit(1)
            .maybeSingle();
          profileRow = data || null;
        } catch (err) {
          console.warn("profile check skipped", err);
        }

        const roleLevel = Number(accessRow?.role_level || accessRow?.roleLevel || 0);
        const isMaroowell = !!(accessRow?.is_maroowell || accessRow?.isMaroowell);
        const isSuperAdmin = !!(accessRow?.is_super_admin || accessRow?.is_admin || roleLevel >= 60);
        const isDragonCarAdmin = !!(profileRow?.is_dragon_car_admin || accessRow?.is_dragon_car_admin);
        const allowed = isSuperAdmin || isDragonCarAdmin || (isMaroowell && roleLevel >= 30);

        if (!allowed) {
          showAccessDenied("이 페이지는 최고관리자 또는 용차 관리자만 접근할 수 있습니다.\n조건: role_level 30 이상 또는 profiles.is_dragon_car_admin = true", email);
          return false;
        }
        return true;
      }

      function showAccessDenied(message, email) {
        dom.accessDeniedText.textContent = message || "접근 권한이 없습니다.";
        dom.accessDeniedEmail.textContent = email ? ("로그인 계정: " + email) : "";
        dom.accessDenied.classList.add("show");
      }

      async function logout() {
