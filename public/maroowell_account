<body>
  <div class="app">
    <header class="topbar"><div class="brand"><a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기"><img src="/favicon.ico" alt="Maroowell" /></a><div class="brandText"><h1>정산 통계 조회</h1><p>월별·일별·요일별·노선별 배송/반품 수량 통계</p></div></div><div class="topSpacer"></div><div id="userBadge" class="userBadge">-</div><button id="btnLogout" class="btn danger" type="button">로그아웃</button></header>
    <main class="wrap">
      <section class="card"><div class="cardHead"><h2>조회 조건</h2><span id="stateText" class="muted">대기 중</span></div><div class="cardBody"><div class="toolbar">
        <div class="field"><label for="yearSelect">정산 연도</label><select id="yearSelect" class="select"></select></div>
        <div class="field"><label for="startMonthSelect">시작 월</label><select id="startMonthSelect" class="select"></select></div>
        <div class="field"><label for="endMonthSelect">종료 월</label><select id="endMonthSelect" class="select"></select></div>
        
        <div class="field"><label for="waveSelect">주/야</label><select id="waveSelect" class="select"><option value="">전체</option><option value="주간">주간</option><option value="야간">야간</option><option value="WAVE2">WAVE2</option><option value="WAVE1">WAVE1</option></select></div>
        <div class="field"><label for="currentCampInput">현재 캠프</label><input id="currentCampInput" class="input" placeholder="예: 일산2" autocomplete="off" /></div>
        <div class="field"><label for="currentRouteInput">현재 노선</label><input id="currentRouteInput" class="input" placeholder="예: 126A,126B" autocomplete="off" /></div>
        <div class="field"><label for="pastRoutesInput">과거 캠프/노선</label><input id="pastRoutesInput" class="input" placeholder="예: 대구3/329, 대구2/211" autocomplete="off" /></div>
        <div class="field"><label for="searchInput">통합 검색</label><input id="searchInput" class="input" type="text" placeholder="ID / 캠프 / 노선 / 배송유형" autocomplete="off" /></div>
        <button id="btnLoad" class="btn primary" type="button">조회</button><button id="btnReset" class="btn" type="button">초기화</button>
      </div><div class="hint">현재 캠프/현재 노선이 조회 기준입니다. 현재 노선이 비어 있으면 현재 캠프의 전 노선을 조회합니다. 과거 노선을 같이 보고 싶으면 과거 캠프/노선에 <b>대구3/329, 대구2/211</b>처럼 입력하세요. 서브라우트는 <b>126A,126B</b>처럼 쉼표로 여러 개 입력 가능합니다.</div><div id="statusText" class="status">정산 연도와 월 범위를 선택하고 조회를 누르세요.</div><div id="summaryGrid" class="pillGrid"></div></div></section>
      <section class="card"><div class="cardHead"><h2>노선별 수량 통계</h2><div class="cardActions"><span id="routeNote" class="muted">-</span><button class="btn copy" data-copy-table="routeTable">표 복사</button><button class="btn graph" data-graph="route">그래프</button></div></div><div class="tableWrap"><table id="routeTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section>
      <div class="grid2"><section class="subCard"><div class="subCardHead"><h3>일별 수량 통계</h3><div class="cardActions"><span id="dailyNote" class="muted">-</span><button class="btn copy" data-copy-table="dailyTable">표 복사</button><button class="btn graph" data-graph="daily">그래프</button></div></div><div class="tableWrap"><table id="dailyTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section><section class="subCard"><div class="subCardHead"><h3>요일별 수량 통계</h3><div class="cardActions"><span id="weekdayNote" class="muted">-</span><button class="btn copy" data-copy-table="weekdayTable">표 복사</button><button class="btn graph" data-graph="weekday">그래프</button></div></div><div class="tableWrap"><table id="weekdayTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section></div>
      <section class="card"><div class="cardHead"><h2>월별 수량 통계</h2><div class="cardActions"><span id="monthlyNote" class="muted">-</span><button class="btn copy" data-copy-table="monthlyTable">표 복사</button><button class="btn graph" data-graph="monthly">총수량 그래프</button><button class="btn graph" data-graph="monthlyAvg">일평균 그래프</button></div></div><div class="tableWrap"><table id="monthlyTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section>
    </main>
  </div>
  <div id="graphModal" class="modalBackdrop"><div class="modal"><div class="modalHead"><h2 id="graphTitle">그래프</h2><div class="modalActions"><button id="btnCopyGraph" class="btn copy">그래프 복사</button><button id="btnCloseGraph" class="btn">닫기</button></div></div><div class="modalBody"><div class="chartBox"><canvas id="graphCanvas" class="chartCanvas" width="1000" height="560"></canvas></div></div></div></div>
  <div id="accessDenied" class="accessDenied"><div class="accessCard"><h2>접근 권한 없음</h2><p id="accessDeniedText">팀장 권한이 필요합니다.</p><div id="accessDeniedEmail" class="accessMeta"></div><div class="accessActions"><button id="deniedHomeBtn" class="btn" type="button">홈으로</button><button id="deniedLogoutBtn" class="btn danger" type="button">로그아웃</button></div></div></div>

  <script>
    (async function(){
      "use strict";
      const CONFIG=window.MARUWELL_CONFIG||{};const SUPABASE_URL=CONFIG.SUPABASE_URL;const SUPABASE_ANON_KEY=CONFIG.SUPABASE_ANON_KEY;const LOGIN_PATH=CONFIG.PATHS?.login||"/login.html";const HOME_PATH=CONFIG.PATHS?.index||"/zipcode_search";const TABLE_NAME="maroowell_account";const WEEKDAYS=["일","월","화","수","목","금","토"];
      const els={userBadge:document.getElementById("userBadge"),btnLogout:document.getElementById("btnLogout"),yearSelect:document.getElementById("yearSelect"),startMonthSelect:document.getElementById("startMonthSelect"),endMonthSelect:document.getElementById("endMonthSelect"),waveSelect:document.getElementById("waveSelect"),currentCampInput:document.getElementById("currentCampInput"),currentRouteInput:document.getElementById("currentRouteInput"),pastRoutesInput:document.getElementById("pastRoutesInput"),searchInput:document.getElementById("searchInput"),btnLoad:document.getElementById("btnLoad"),btnExcel:document.getElementById("btnExcel"),btnReset:document.getElementById("btnReset"),stateText:document.getElementById("stateText"),statusText:document.getElementById("statusText"),summaryGrid:document.getElementById("summaryGrid"),routeTable:document.getElementById("routeTable"),dailyTable:document.getElementById("dailyTable"),weekdayTable:document.getElementById("weekdayTable"),monthlyTable:document.getElementById("monthlyTable"),routeNote:document.getElementById("routeNote"),dailyNote:document.getElementById("dailyNote"),weekdayNote:document.getElementById("weekdayNote"),monthlyNote:document.getElementById("monthlyNote"),graphModal:document.getElementById("graphModal"),graphTitle:document.getElementById("graphTitle"),graphCanvas:document.getElementById("graphCanvas"),btnCopyGraph:document.getElementById("btnCopyGraph"),btnCloseGraph:document.getElementById("btnCloseGraph"),accessDenied:document.getElementById("accessDenied"),accessDeniedText:document.getElementById("accessDeniedText"),accessDeniedEmail:document.getElementById("accessDeniedEmail"),deniedHomeBtn:document.getElementById("deniedHomeBtn"),deniedLogoutBtn:document.getElementById("deniedLogoutBtn")};
      const state={session:null,user:null,access:null,rows:[],rawRows:[],filteredRows:[],stats:null,currentGraph:null};
      const supabaseClient=SUPABASE_URL&&SUPABASE_ANON_KEY&&window.supabase?window.supabase.createClient(SUPABASE_URL,SUPABASE_ANON_KEY,{auth:{storage:window.sessionStorage,persistSession:true,autoRefreshToken:true,detectSessionInUrl:true}}):null;
      function clean(v){return String(v??"").trim()}function loose(v){return clean(v).replace(/[\s_\-]/g,"").toLowerCase()}function esc(v){return String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#39;")}function num(v){const n=Number(v||0);return Number.isFinite(n)?n:0}function int(v){return Math.round(num(v))}function money(v){return num(v).toLocaleString("ko-KR")}function count(v){return int(v).toLocaleString("ko-KR")}function setStatus(t,type){els.statusText.textContent=t||"";els.statusText.className=type?`status ${type}`:"status"}function setBusy(b){els.btnLoad.disabled=b;if(els.btnExcel)els.btnExcel.disabled=b;els.stateText.textContent=b?"처리 중":"READY"}function weekdayOf(date){const d=new Date(`${date}T00:00:00`);return Number.isFinite(d.getTime())?d.getDay():-1}function weekdayLabel(date){const wd=weekdayOf(date);return wd>=0?WEEKDAYS[wd]:""}function isoMonth(date){return clean(date).slice(0,7)}
      function isLossRow(row){const s=clean(row.source_sheet).replace(/\s+/g,"").toLowerCase();const c=clean(row.classify).replace(/\s+/g,"").toLowerCase();return s==="분실파손list"||c==="분실파손"||c.includes("분실")||c.includes("파손")}function isRawRow(row){return !isLossRow(row)}function isExcludedStatsRow(row){const c=clean(row.classify).replace(/\s+/g,"");const r=clean(row.route);if(c.includes("미계약"))return true;if(!r||r==="-"||r==="–"||r==="—")return true;return false}function normalizeWave(v){const raw=clean(v).toUpperCase();if(raw==="WAVE2"||raw==="2W"||raw==="주간")return"주간";if(raw==="WAVE1"||raw==="1W"||raw==="야간")return"야간";return clean(v)||"-"}
