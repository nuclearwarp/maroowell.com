  async function runPatch() {
    if (patchRunning) return;

    const driverMode = $("#btnModeDriver")?.classList.contains("active");
    const target = $("#statementCapture");

    if (!driverMode) {
      target?.classList.remove("mwDriverExcelSheet");
      return;
    }

    if (!target || target.style.display === "none") return;

    patchRunning = true;

    try {
      await loadData();

      const month = currentMonth();
      const name = selectedDriverName();

      if (!name) return;

      const monthRows = rawRows
        .map(row => normalizeDragonRow(row, month))
        .filter(row => row.month === month);

      const monthly = monthlyTeamStats(monthRows);

      patchGroupList(monthRows, monthly);

      const { rows, stats } = statsForDriver(monthRows, name, monthly);

      const patchKey = [
        month,
        name,
        rows.length,
        rows.reduce((sum, row) => sum + row.amount, 0),
        stats.total,
        stats.finalPay,
        stats.teamBonus
      ].join("::");

      if (target.dataset.mwDriverSettlementPatchKey === patchKey && target.querySelector(".mwTop")) {
        return;
      }

      target.dataset.mwDriverSettlementPatchKey = patchKey;
      renderDriverSheet(name, rows, stats, monthly, month);
    } catch (err) {
      console.error("mw dragon driver settlement patch error", err);
    } finally {
      patchRunning = false;
    }
  }

  function schedulePatch() {
    clearTimeout(patchTimer);
    patchTimer = setTimeout(runPatch, 220);
  }

  function startPatch() {
    document.addEventListener("click", schedulePatch, true);
    document.addEventListener("keyup", schedulePatch, true);
    document.addEventListener("change", schedulePatch, true);

    const capture = $("#statementCapture");
    if (capture) {
      new MutationObserver(schedulePatch).observe(capture, {
        childList: true,
        subtree: false,
        attributes: true,
        attributeFilter: ["style", "class"]
      });
    }

    const list = $("#groupList");
    if (list) {
      new MutationObserver(schedulePatch).observe(list, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ["class"]
      });
    }

    schedulePatch();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", startPatch);
  } else {
    startPatch();
  }
})();
