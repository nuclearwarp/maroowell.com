<!doctype html><html lang="ko"><head><style>html{visibility:hidden}</style><script src="/config.js"></script><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>클렌징 히스토리</title><link rel="icon" href="/favicon.ico?v=2"><script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script><script src="/board-menu.js" defer></script><style>:root{--bg:#081120;--p:#101b2f;--p2:#0d1728;--l:rgba(255,255,255,.14);--t:#eaf2ff;--m:#9fb0d0;--b:#60a5fa;--g:#22c55e;--r:#ef4444;--y:#f59e0b}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--t);font-family:system-ui,-apple-system,'Noto Sans KR',sans-serif}.top{display:flex;gap:10px;align-items:center;padding:12px 14px;background:#07101d;border-bottom:1px solid var(--l)}.logo{width:34px;height:34px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.05)}.logo img{width:28px}.title h1{margin:0;font-size:22px}.title p{margin:4px 0 0;color:var(--m);font-size:12px;font-weight:800}.spacer{flex:1}.pill{border:1px solid var(--l);border-radius:999px;padding:7px 11px;background:rgba(255,255,255,.05);font-size:12px;font-weight:900;color:#bfdbfe}.bar{display:grid;grid-template-columns:repeat(8,minmax(90px,1fr)) 1.4fr auto auto auto;gap:8px;padding:12px;background:var(--p2);border-bottom:1px solid var(--l)}label{display:block;color:#bfdbfe;font-size:12px;font-weight:900;margin:0 0 5px 2px}input,select{width:100%;height:38px;border-radius:11px;border:1px solid var(--l);background:#0b1220;color:var(--t);padding:0 10px;font-weight:800}.btn{height:38px;border-radius:999px;border:1px solid var(--l);background:rgba(255,255,255,.07);color:var(--t);font-weight:900;padding:0 13px;cursor:pointer}.btn.primary{background:rgba(37,99,235,.75)}.btn.ok{background:rgba(22,163,74,.55)}.btn.purple{background:rgba(126,34,206,.5)}.main{padding:14px;overflow:auto}.board{min-width:1280px;border:1px solid var(--l);border-radius:18px;overflow:hidden;background:#0e1728}.head{display:flex;justify-content:space-between;gap:10px;align-items:flex-end;padding:14px 16px;background:#111c30;border-bottom:1px solid var(--l)}.head h2{margin:0;font-size:22px}.head p{margin:5px 0 0;color:#bfdbfe;font-size:13px;font-weight:900}.actions{display:flex;gap:8px}table{width:100%;border-collapse:separate;border-spacing:0;table-layout:fixed}th,td{border-right:1px solid rgba(255,255,255,.1);border-bottom:1px solid rgba(255,255,255,.1);padding:8px 7px;text-align:center;font-size:12px}th{background:#27364d;font-weight:1000;white-space:nowrap}td{font-weight:800}.left{text-align:left}.num{text-align:right}.green{color:#bbf7d0}.yellow{color:#fde68a}.empty,.denied{margin:40px auto;max-width:720px;padding:26px;border:1px dashed var(--l);border-radius:18px;text-align:center;color:#cbd5e1;font-weight:900}.denied{border-color:rgba(239,68,68,.35);background:rgba(127,29,29,.18);text-align:left;color:#fecaca}.hide{display:none!important}@media(max-width:1100px){.bar{grid-template-columns:1fr 1fr}.main{padding:8px}.title p{display:none}}</style></head><body><div class="top"><a href="#" id="mwBoardMenuToggle" class="logo"><img src="/favicon.ico"></a><div class="title"><h1>클렌징 히스토리</h1><p>퀵플렉스 메타어드민 누적 입찰 / 수행률 데이터</p></div><div class="spacer"></div><span id="user" class="pill">로그인 확인</span></div><div id="bar" class="bar"><div><label>Week</label><input id="week"></div><div><label>Camp</label><input id="camp"></div><div><label>Wave</label><input id="wave"></div><div><label>Route</label><input id="route"></div><div><label>Vendor</label><input id="vendor"></div><div><label>사업자번호</label><input id="biz"></div><div><label>Reason</label><select id="reason"><option value="">전체</option><option>수행률</option><option>반품</option></select></div><div><label>Limit</label><select id="limit"><option>100</option><option selected>300</option><option>500</option><option>1000</option></select></div><div><label>통합 검색</label><input id="q"></div><button class="btn primary" id="search">조회</button><button class="btn" id="reset">초기화</button><button class="btn ok" id="add">신규</button></div><main class="main" id="main"><div class="board" id="board"><div class="head"><div><h2>누적 데이터</h2><p id="summary">조회 전</p></div><div class="actions"><button class="btn" id="refresh">새로고침</button><button class="btn purple" id="csv">CSV</button></div></div><div id="table"></div></div></main><script>(()=>{const $=id=>document.getElementById(id),cfg=window.MARUWELL_CONFIG||{};let sb,acc,rows=[];const cols='id,week,camp,wave,route,zip,demand,complete,execution_rate,execution_rate_grade,reason,price,vendor_name,business_number,vendor_code,created_at';const esc=v=>String(v??'').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#39;');const val=id=>$(id).value.trim();const n=v=>v==null||v===''?'':Number.isFinite(Number(v))?Number(v).toLocaleString('ko-KR'):String(v);const pct=v=>v==null||v===''?'':Number.isFinite(Number(v))?Number(v).toFixed(2).replace(/\.00$/,'')+'%':String(v);const won=v=>v==null||v===''?'':Number.isFinite(Number(v))?'₩'+Number(v).toLocaleString('ko-KR'):String(v);function superAdmin(){return acc?.is_maroowell&&acc?.is_admin&&Number(acc?.max_role_level||0)>=90}function initSb(){const {SUPABASE_URL,SUPABASE_ANON_KEY}=cfg;if(!SUPABASE_URL||!SUPABASE_ANON_KEY)throw Error('config.js 확인 필요');const st=(()=>{try{return sessionStorage}catch{return undefined}})();sb=supabase.createClient(SUPABASE_URL,SUPABASE_ANON_KEY,{auth:{persistSession:!!st,storage:st,autoRefreshToken:true,detectSessionInUrl:true}})}async function initAccess(){const {data:s}=await sb.auth.getSession();const u=s?.session?.user;if(!u)throw Error('로그인이 필요합니다');const {data:a}=await sb.rpc('mw_my_access').maybeSingle();acc={email:u.email,user_id:u.id,is_maroowell:a?.is_maroowell===true,is_admin:a?.is_admin===true,max_role_level:Number(a?.max_role_level||0),can_clhi:false};if(superAdmin())acc.can_clhi=true;else{const {data:c}=await sb.from('cleansing_history_access').select('can_select').eq('user_id',u.id).maybeSingle();acc.can_clhi=c?.can_select===true}$('user').textContent=acc.email;$('add').classList.toggle('hide',!superAdmin());document.documentElement.style.visibility='visible';if(!acc.can_clhi){$('bar').classList.add('hide');$('board').classList.add('hide');$('main').innerHTML='<div class="denied"><h2>클렌징 히스토리 권한 없음</h2><p>클히 권한이 있는 사용자만 조회할 수 있습니다.</p></div>'}}async function load(){if(!acc?.can_clhi)return;let q=sb.from('cleansing_history').select(cols,{count:'exact'}).order('created_at',{ascending:false}).limit(Number(val('limit')||300));[['week','week'],['camp','camp'],['wave','wave'],['route','route'],['vendor_name','vendor'],['business_number','biz']].forEach(([c,id])=>{const v=val(id);if(v)q=q.ilike(c,'%'+v+'%')});if(val('reason'))q=q.eq('reason',val('reason'));if(val('q')){const k=val('q');q=q.or(`camp.ilike.%${k}%,route.ilike.%${k}%,zip.ilike.%${k}%,vendor_name.ilike.%${k}%,business_number.ilike.%${k}%,vendor_code.ilike.%${k}%`)}const {data,error,count}=await q;if(error)throw error;rows=data||[];render();$('summary').textContent=`표시 ${rows.length.toLocaleString('ko-KR')}건 / 조건 ${Number(count||0).toLocaleString('ko-KR')}건`}function render(){if(!rows.length){$('table').innerHTML='<div class="empty">조회 결과가 없습니다.</div>';return}const edit=superAdmin();$('table').innerHTML=`<table><thead><tr>${edit?'<th style="width:70px">관리</th>':''}<th style="width:100px">Week</th><th style="width:90px">Camp</th><th style="width:70px">Wave</th><th style="width:130px">Route</th><th style="width:230px">Zip</th><th style="width:90px">Demand</th><th style="width:90px">Complete</th><th style="width:90px">수행률</th><th style="width:80px">등급</th><th style="width:80px">Reason</th><th style="width:90px">Price</th><th style="width:210px">Vendor</th><th style="width:120px">사업자번호</th><th style="width:110px">Vendor Code</th></tr></thead><tbody>${rows.map(r=>`<tr>${edit?`<td><button class="btn" style="height:28px;padding:0 9px" data-edit="${r.id}">수정</button></td>`:''}<td>${esc(r.week)}</td><td>${esc(r.camp)}</td><td>${esc(r.wave||'')}</td><td>${esc(r.route)}</td><td class="left">${esc(r.zip||'')}</td><td class="num">${n(r.demand)}</td><td class="num">${n(r.complete)}</td><td class="num green">${pct(r.execution_rate)}</td><td>${esc(r.execution_rate_grade||'')}</td><td>${esc(r.reason||'')}</td><td class="num yellow">${won(r.price)}</td><td class="left">${esc(r.vendor_name||'')}</td><td>${esc(r.business_number||'')}</td><td>${esc(r.vendor_code||'')}</td></tr>`).join('')}</tbody></table>`}async function save(row){if(!superAdmin())return;const patch={week:prompt('week',row?.week||'')||null,camp:prompt('camp',row?.camp||'')||null,route:prompt('route',row?.route||'')||null,wave:prompt('wave',row?.wave||'')||null,zip:prompt('zip',row?.zip||'')||null,demand:Number(prompt('demand',row?.demand||'')||0)||null,complete:Number(prompt('complete',row?.complete||'')||0)||null,execution_rate:Number(prompt('execution_rate',row?.execution_rate||'')||0)||null,execution_rate_grade:prompt('grade',row?.execution_rate_grade||'')||null,reason:prompt('reason',row?.reason||'')||null,price:Number(prompt('price',row?.price||'')||0)||null,vendor_name:prompt('vendor_name',row?.vendor_name||'')||null,business_number:prompt('business_number',row?.business_number||'')||null,vendor_code:prompt('vendor_code',row?.vendor_code||'')||null};if(!patch.week||!patch.camp||!patch.route)return alert('week/camp/route 필수');const res=row?await sb.from('cleansing_history').update(patch).eq('id',row.id):await sb.from('cleansing_history').insert(patch);if(res.error)alert(res.error.message);else load()}function csv(){const h=['week','camp','wave','route','zip','demand','complete','execution_rate','execution_rate_grade','reason','price','vendor_name','business_number','vendor_code','created_at'];const lines=[h.join(',')].concat(rows.map(r=>h.map(k=>'"'+String(r[k]??'').replaceAll('"','""')+'"').join(',')));const b=new Blob(['\ufeff'+lines.join('\n')],{type:'text/csv'}),a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='cleansing_history.csv';a.click();URL.revokeObjectURL(a.href)}function bind(){$('search').onclick=()=>load().catch(e=>alert(e.message));$('refresh').onclick=$('search').onclick;$('reset').onclick=()=>{['week','camp','wave','route','vendor','biz','q'].forEach(id=>$(id).value='');$('reason').value='';load()};$('csv').onclick=csv;$('add').onclick=()=>save(null);$('table').onclick=e=>{const b=e.target.closest('[data-edit]');if(b)save(rows.find(r=>r.id===b.dataset.edit))};['week','camp','wave','route','vendor','biz','q'].forEach(id=>$(id).addEventListener('keydown',e=>{if(e.key==='Enter')load()}))}async function init(){try{initSb();bind();await initAccess();if(acc.can_clhi)await load()}catch(e){document.documentElement.style.visibility='visible';alert(e.message)}}document.readyState==='loading'?document.addEventListener('DOMContentLoaded',init,{once:true}):init()})();</script></body></html>