  function renderDetailRows(rows, teamBonus, month) {
    const sorted = [...rows].sort((a, b) => {
      const da = parseDate(a.date, month)?.getTime() || 0;
      const db = parseDate(b.date, month)?.getTime() || 0;

      return da - db
        || clean(a.camp).localeCompare(clean(b.camp), "ko")
        || clean(a.route).localeCompare(clean(b.route), "ko");
    });

    const rowCount = Math.max(FILLER_ROW_TARGET, sorted.length + (teamBonus ? 1 : 0), 1);
    let html = "";

    sorted.forEach((row, index) => {
      html += `
        <tr>
          ${index === 0 ? `<td rowspan="${rowCount}"><b>전체</b></td>` : ""}
          <td class="${isSunday(row.date, month) ? "red" : ""}">${esc(formatDate(row.date, month))}</td>
          <td>${esc(row.camp)}</td>
          <td>${esc(row.wave)}</td>
          <td>${esc(row.route)}</td>
          <td class="money">${money(row.price)}</td>
          <td>${qty(row.parcel)}</td>
          <td class="${row.taxIssued ? "green" : "red"}">${row.taxIssued ? "발행" : "미발행"}</td>
          <td class="money">${money(row.amount)}</td>
        </tr>
      `;
    });

    if (!sorted.length) {
      html += `<tr><td rowspan="${rowCount}"><b>전체</b></td><td colspan="8">표시할 정산 행이 없습니다.</td></tr>`;
    }

    if (teamBonus) {
      html += `
        <tr>
          <td colspan="6">한팀장 용차 수수료</td>
          <td class="green">발행</td>
          <td class="money">${money(teamBonus)}</td>
        </tr>
      `;
    }

    const used = Math.max(1, sorted.length) + (teamBonus ? 1 : 0);
    for (let i = used; i < rowCount; i++) {
      html += `
        <tr class="blank">
          <td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td>
          <td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td>
        </tr>
      `;
    }

    return html;
  }

  function statsForDriver(monthRows, name, monthly) {
    const rows = monthRows.filter(row => compact(row.driver) === compact(name));
    const stats = baseStats(rows, name);

    if (compact(name) === compact(TEAM_LEADER_NAME)) {
      stats.teamBonus = monthly.bonus;
      stats.issued += monthly.bonus;
      stats.total += monthly.bonus;

      const tax = taxBreakdown(stats.issued);
      stats.supply = tax.supply;
      stats.vat = tax.vat;
      stats.finalPay += monthly.bonus;
      stats.afterInsurance += monthly.bonus;
      stats.afterCommission += monthly.bonus;
    }

    return { rows, stats };
  }

  function patchGroupList(monthRows, monthly) {
    $all("#groupList .groupItem").forEach(item => {
      const name = clean(item.querySelector(".groupName")?.textContent || "").split("\n")[0];
      if (!name) return;

      const meta = item.querySelector(".groupMeta");
      if (!meta) return;

      const { stats } = statsForDriver(monthRows, name, monthly);
      const rateText = Math.round(stats.rate * 1000) / 10;

      meta.innerHTML = `
        <span>벌어온 금액 <b>${money(stats.total)}</b></span>
        <span>수수료 ${rateText}% <b>${money(stats.commission)}</b></span>
        <span>공제 후 <b>${money(stats.afterCommission)}</b></span>
        <span>고용/산재 <b>${money(stats.insurance)}</b></span>
