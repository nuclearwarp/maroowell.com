    if (cell?.querySelector?.(".grade3")) return "#b45309";
    if (cell?.querySelector?.(".grade4")) return "#be123c";
    if (cell?.querySelector?.(".gradeNone")) return "#64748b";
    if (cell?.classList?.contains("green")) return "#047857";
    if (cell?.classList?.contains("yellow")) return "#a16207";
    if (cell?.classList?.contains("red")) return "#b91c1c";
    if (cell?.classList?.contains("priceCell")) return "#a16207";

    return "#0f172a";
  }

  function buildTableCanvas(table) {
    const fontFamily = "'문경감홍사과체','Noto Sans KR',Arial,sans-serif";
    const measure = document.createElement("canvas").getContext("2d");
    const dpr = Math.min(2, Math.max(1, window.devicePixelRatio || 1));

    const title = document.querySelector(".head h2")?.textContent?.trim() || "클렌징 히스토리";
    const subTitle = document.querySelector(".head p")?.textContent?.trim() || "";
    const summary = $("summary")?.textContent?.trim() || "";

    const rowsDom = Array.from(table.rows || []);
    const headerRow = rowsDom[0];
    const skip = new Set();

    const bodyRows = rowsDom.filter(tr => tr.closest("tbody"));
    const firstHeaderText = headerRow?.cells?.[0]?.textContent?.replace(/\s+/g, "").trim() || "";
    const firstBodyText = bodyRows[0]?.cells?.[0]?.textContent?.replace(/\s+/g, "").trim() || "";

    if (
      isSuper() ||
      firstHeaderText === "관리" ||
      firstHeaderText.includes("관리") ||
      firstBodyText === "수정" ||
      firstBodyText === "저장" ||
      bodyRows.some(tr => {
        const c = tr.cells?.[0];
        const t = c?.textContent?.replace(/\s+/g, "").trim() || "";
        return c?.classList?.contains("manageCol") || t === "수정" || t === "저장";
      })
    ) {
      skip.add(0);
    }

    if (headerRow) {
      Array.from(headerRow.cells).forEach((cell, idx) => {
        const text = (cell.textContent || "").replace(/\s+/g, "").trim();
        if (cell.classList.contains("manageCol") || text === "관리") {
          skip.add(idx);
        }
      });
    }

    const includeCell = (cell, idx) => {
      const text = (cell?.textContent || "").replace(/\s+/g, "").trim();
      return !skip.has(idx) &&
        !cell.classList.contains("manageCol") &&
        text !== "관리" &&
        text !== "수정" &&
        text !== "저장";
    };

    const colCount = headerRow
      ? Array.from(headerRow.cells).filter((cell, idx) => includeCell(cell, idx)).length
      : 0;

    if (!colCount) {
      throw new Error("복사할 표 컬럼을 찾지 못했습니다.");
    }

    const rawWidths = headerRow
      ? Array.from(headerRow.cells)
          .filter((cell, idx) => includeCell(cell, idx))
          .map(cell => {
            const inlineWidth = parseFloat(cell.style.width || "");
            const rectWidth = cell.getBoundingClientRect?.().width || 0;
            return Math.max(54, Math.ceil(inlineWidth || rectWidth || 80));
          })
      : [];

    const minByIdx = [84, 82, 62, 105, 180, 86, 86, 78, 68, 68, 78, 185, 118];
    const colWidths = rawWidths.map((w, idx) => {
      const min = minByIdx[idx] || 70;
      const max = idx === 4 || idx === 11 ? 220 : idx === 3 ? 140 : 150;
      return Math.max(min, Math.min(max, w));
    });

    const tableWidth = colWidths.reduce((a, b) => a + b, 0);
    const outerPad = 18;
    const headerTitleHeight = 78;
    const width = tableWidth + outerPad * 2;

    const prepared = [];
    let bodyRowIndex = 0;

    for (const tr of rowsDom) {
      const isHead = tr.closest("thead") != null;
      const isBody = tr.closest("tbody") != null;
      const sourceCells = Array.from(tr.cells).filter((cell, idx) => includeCell(cell, idx));

      measure.font = isHead
        ? `500 11px ${fontFamily}`
        : `400 10px ${fontFamily}`;

      const cells = sourceCells.map((cell, idx) => {
        const parts = tableCellCanvasParts(cell);

        measure.font = isHead
          ? `500 11px ${fontFamily}`
          : `500 10px ${fontFamily}`;
        const mainLines = wrapCanvasText(measure, parts.mainText, Math.max(30, colWidths[idx] - 12));

        measure.font = `400 8px ${fontFamily}`;
        const subLines = parts.subText
          ? wrapCanvasText(measure, parts.subText, Math.max(30, colWidths[idx] - 12))
          : [];

        const align = isHead ? "center" : cellCanvasAlign(cell);
        const color = isHead ? "#0f172a" : cellCanvasColor(cell, tr);

        return { cell, text:parts.mainText, lines:mainLines, subLines, align, color };
      });

      const lineHeight = isHead ? 15 : 13;
      const subLineHeight = 10;
      const minHeight = isHead ? 38 : 40;
      const rowHeight = Math.max(
        minHeight,
        ...cells.map(c => c.lines.length * lineHeight + c.subLines.length * subLineHeight + (c.subLines.length ? 4 : 0) + 14)
      ) + (tr.classList.contains("waveDivider") ? 6 : 0);

      const bg = isHead
        ? "#dbeafe"
        : tr.classList.contains("rowClean")
          ? "#fff5f5"
          : tr.classList.contains("rowWarn")
            ? "#fffbeb"
            : bodyRowIndex % 2
              ? "#f8fafc"
              : "#ffffff";

      prepared.push({
        tr,
        isHead,
        isBody,
        cells,
        rowHeight,
        lineHeight,
        bg,
        divider: tr.classList.contains("waveDivider") || (
          isBody &&
          prepared.some(row => row.isBody) &&
          tableCellCopyText(sourceCells[2] || null).trim() !==
            tableCellCopyText(prepared.filter(row => row.isBody).at(-1)?.sourceCells?.[2] || null).trim()
        ),
        sourceCells
      });

      if (isBody) bodyRowIndex += 1;
    }

    const tableHeight = prepared.reduce((sum, row) => sum + row.rowHeight, 0);
    const height = outerPad + headerTitleHeight + tableHeight + outerPad;

    const canvas = document.createElement("canvas");
    canvas.width = Math.ceil(width * dpr);
    canvas.height = Math.ceil(height * dpr);
    canvas.style.width = width + "px";
    canvas.style.height = height + "px";

    const ctx = canvas.getContext("2d");
    ctx.scale(dpr, dpr);
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0, 0, width, height);

    ctx.fillStyle = "#0f172a";
    ctx.font = `520 22px ${fontFamily}`;
    ctx.textAlign = "left";
    ctx.textBaseline = "top";
    ctx.fillText(title, outerPad, outerPad);

    ctx.font = `400 11px ${fontFamily}`;
    ctx.fillStyle = "#64748b";
    const subtitleLine = [subTitle, summary].filter(Boolean).join(" / ");
    ctx.fillText(subtitleLine, outerPad, outerPad + 34);

    let y = outerPad + headerTitleHeight;

    for (const row of prepared) {
      let x = outerPad;

      row.cells.forEach((info, idx) => {
        const w = colWidths[idx];
        const h = row.rowHeight;

        ctx.fillStyle = row.bg;
        ctx.fillRect(x, y, w, h);

        ctx.strokeStyle = "#d8e0ee";
        ctx.lineWidth = 1;
        ctx.strokeRect(x + 0.5, y + 0.5, w, h);

        ctx.textBaseline = "middle";

        const subLineHeight = row.isHead ? 0 : 10;
        const subGap = !row.isHead && info.subLines.length ? 4 : 0;
        const textH = info.lines.length * row.lineHeight + info.subLines.length * subLineHeight + subGap;
        let ty = y + h / 2 - textH / 2 + row.lineHeight / 2;

        const setAlign = () => {
          let tx = x + w / 2;
          ctx.textAlign = "center";

          if (info.align === "left" || info.align === "start") {
            ctx.textAlign = "left";
            tx = x + 7;
          } else if (info.align === "right" || info.align === "end") {
            ctx.textAlign = "right";
            tx = x + w - 7;
          }

          return tx;
        };

        ctx.font = row.isHead
          ? `500 11px ${fontFamily}`
          : `500 10px ${fontFamily}`;
        ctx.fillStyle = info.color;

        for (const line of info.lines) {
          ctx.fillText(line, setAlign(), ty);
          ty += row.lineHeight;
        }

        if (!row.isHead && info.subLines.length) {
          ty += subGap;
          ctx.font = `400 8px ${fontFamily}`;
          ctx.fillStyle = row.tr?.classList?.contains("rowClean")
            ? "#b91c1c"
            : row.tr?.classList?.contains("rowWarn")
              ? "#92400e"
              : "#64748b";

          for (const line of info.subLines) {
            ctx.fillText(line, setAlign(), ty);
            ty += subLineHeight;
          }
        }

        x += w;
      });

      if (row.divider) {
        ctx.fillStyle = "#64748b";
        ctx.fillRect(outerPad, y + 0.5, tableWidth, 2);
        ctx.fillRect(outerPad, y + 5.5, tableWidth, 2);
      }

      y += row.rowHeight;
    }

    return canvas;
  }

  async function copyImage() {
    if (!rows.length) {
      alert("복사할 조회 결과가 없습니다.");
      return;
    }

    const sourceTable = $("table").querySelector("table");

    if (!sourceTable) {
      alert("복사할 표를 찾지 못했습니다.");
      return;
    }

    try {
      try {
        if (document.fonts?.ready) await document.fonts.ready;
      } catch {}

      const canvas = buildTableCanvas(sourceTable);
      const blob = await canvasBlob(canvas);

      if (navigator.clipboard && window.ClipboardItem) {
        await navigator.clipboard.write([
          new ClipboardItem({ "image/png": blob })
        ]);
        alert("표 이미지를 클립보드에 복사했습니다.");
        return;
      }

      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = captureFileName();
      a.click();
      URL.revokeObjectURL(a.href);
    } catch (err) {
      console.error(err);

      if (window.htmlToImage?.toBlob) {
        let fallbackWrap = null;

        try {
          fallbackWrap = document.createElement("div");
          fallbackWrap.className = "captureCloneWrap";

          const clone = sourceTable.cloneNode(true);
          clone.classList.add("captureTable");

          clone.querySelectorAll(".manageCol").forEach(el => el.remove());
          clone.querySelectorAll("tr").forEach(tr => {
            const first = tr.children?.[0];
            const text = first?.textContent?.replace(/\s+/g, "").trim() || "";

            if (text === "관리" || text === "수정" || text === "저장") {
              first.remove();
            }
          });

          fallbackWrap.appendChild(clone);
          document.body.appendChild(fallbackWrap);

          const blob = await htmlToImage.toBlob(fallbackWrap, {
            backgroundColor:"#ffffff",
            pixelRatio:1,
            cacheBust:true,
            style:{
              background:"#ffffff",
              overflow:"visible"
            }
          });

          if (blob && navigator.clipboard && window.ClipboardItem) {
            await navigator.clipboard.write([
              new ClipboardItem({ "image/png": blob })
            ]);
            alert("표 이미지를 클립보드에 복사했습니다.");
            return;
          }

          if (blob) {
            const a = document.createElement("a");
            a.href = URL.createObjectURL(blob);
            a.download = captureFileName();
            a.click();
            URL.revokeObjectURL(a.href);
            return;
          }
        } catch (fallbackErr) {
          console.error(fallbackErr);
        } finally {
          fallbackWrap?.remove();
        }
      }

      throw err;
    }
  }

  function bind() {
    $("search").onclick = () => load().catch(e => alert(e.message));
    $("refresh").onclick = $("search").onclick;

    $("reset").onclick = async () => {
      ["week", "camp", "route", "vendor", "biz", "q"].forEach(id => {
        $(id).value = "";
      });

      $("wave").value = "";
      $("reason").value = "";

      try {
        await initWeek();
        await load();
      } catch (e) {
        alert(e.message);
      }
    };

    $("copyImage").onclick = () => copyImage().catch(e => alert(e.message));

    $("add").onclick = openVendorPanel;
    $("vendorModalClose").onclick = closeVendorPanel;
    $("vendorModalCancel").onclick = closeVendorPanel;
    $("vendorRegisterSave").onclick = () => registerVendor().catch(e => setVendorPanelMsg(e.message, "err"));
    $("vendorModal").onclick = e => {
      if (e.target === $("vendorModal")) closeVendorPanel();
    };

    ["vendorNewName", "vendorNewBiz"].forEach(id => {
      $(id).addEventListener("keydown", e => {
        if (e.key === "Enter") {
          e.preventDefault();
          registerVendor().catch(err => setVendorPanelMsg(err.message, "err"));
        }

        if (e.key === "Escape") {
          closeVendorPanel();
        }
      });
    });

    $("table").onclick = e => {
      const saveBtn = e.target.closest("[data-save]");

      if (saveBtn) {
        const id = saveBtn.dataset.save;
        const row = rows.find(r => rowId(r) === id);
        const tr = saveBtn.closest("tr");

        if (row && tr) {
          saveInline(row, tr).catch(err => alert(err.message));
        }

        return;
      }

      const btn = e.target.closest("[data-edit]");

      if (!btn) return;

      const row = rows.find(r => rowId(r) === btn.dataset.edit);

      if (row) {
        editingId = rowId(row);
        render();
      }
    };

    ["week", "camp", "route", "vendor", "biz", "q"].forEach(id => {
      $(id).addEventListener("keydown", e => {
        if (e.key === "Enter") {
          load().catch(err => alert(err.message));
        }
      });
    });

    $("wave").onchange = $("reason").onchange = () => {
      load().catch(e => alert(e.message));
    };
  }

  async function init() {
    try {
      initSupabase();
      startSessionBridge();
      bind();

      if (await initMe()) {
        await initWeek();
        await load();
      }
    } catch (e) {
      document.documentElement.style.visibility = "visible";
      showErrorBox("세션/조회 오류", e.message);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once:true });
  } else {
    init();
  }
})();
</script>
