<script>
(() => {
  "use strict";

  const cfg = window.MARUWELL_CONFIG || {};
  const $ = id => document.getElementById(id);

  const API_BASE = String(
    cfg.ROUTEINFO_API_BASE ||
    cfg.ROUTE_INFO_API_BASE ||
    cfg.BACKENDS?.routeinfo ||
    "https://routeinfo.brain-0f6.workers.dev"
  ).replace(/\/+$/, "");

  let supabaseClient = null;
  let currentUser = null;
  let currentAccessToken = "";
  let access = null;
  let isSuperAdmin = false;

  let map = null;
  let isSatellite = false;
  let isRoadviewOn = false;
  let roadviewOverlay = null;
  let kakaoGeocoder = null;
  let kakaoPlaces = null;

  let hasSearched = false;
  let lastFeatureClickAt = 0;

  let routeRows = [];
  let polygonRows = [];
  let pointRows = [];
  let attachmentRows = [];
  let attachmentSignedUrls = new Map();

  let selectedRoute = null;
  let selectedPoint = null;
  let selectedPolygonId = null;

  let addPointMode = false;

  let drawMode = false;
  let drawEditingPolygonId = null;
  let drawVertices = [];

  let polygonObjects = [];
  let polygonLabels = [];
  let pointOverlays = [];

  let drawVertexMarkers = [];
  let drawLine = null;
  let drawPreviewPolygon = null;

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg || "";
    $("statusText").className = type ? "status " + type : "status";
  }

  function setPointStatus(msg, type = "") {
    $("pointStatusText").textContent = msg || "";
    $("pointStatusText").className = type ? "status " + type : "status";
  }

  function setAttachmentStatus(msg, type = "") {
    $("attachmentStatusText").textContent = msg || "";
    $("attachmentStatusText").className = type ? "status " + type : "status";
  }

  function setDrawStatus(msg, show = false) {
    $("drawStatus").textContent = msg || "";
    $("drawStatus").className = show ? "drawStatus show" : "drawStatus";
    $("drawInfoText").textContent = msg || "";
  }

  function setRouteBaseStatus(msg, type = "") {
    $("routeBaseInfoText").textContent = msg || "";
    $("routeBaseInfoText").className = type ? "status " + type : "status";
  }

  function setBulkStatus(msg, type = "") {
    $("bulkStatusText").textContent = msg || "";
    $("bulkStatusText").className = type ? "status " + type : "status";
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function normalizeCampForDb(value) {
    const s = clean(value).replace(/\s+/g, "");
    if (!s) return "";
    if (/^M(?!_)/i.test(s)) return "M_" + s.slice(1);
    return s;
  }

  function parseRouteSearchTokens(value) {
    return String(value || "")
      .toUpperCase()
      .split(/[\s,;/|]+/g)
      .map(token => normalizeRoute(token))
      .filter(Boolean);
  }

  function routeCodeOf(row) {
    return normalizeRoute(row?.route_code || `${row?.route || ""}${row?.sub || ""}${row?.sub_sub || ""}`);
  }

  function routeLabel(row) {
    return [row.route, clean(row.sub), clean(row.sub_sub)].filter(Boolean).join("-");
  }

  function polygonCodeOf(row) {
    return normalizeRoute(row?.route_code || row?.route_norm || row?.route);
  }

  function naturalCompare(a, b) {
    return String(a ?? "").localeCompare(String(b ?? ""), "ko-KR", {
      numeric: true,
      sensitivity: "base"
    });
  }

  function sortRouteRows(rows) {
    return [...(rows || [])].sort((a, b) => {
      return (
        naturalCompare(a.camp, b.camp) ||
        naturalCompare(a.route, b.route) ||
        naturalCompare(a.sub, b.sub) ||
        naturalCompare(a.sub_sub, b.sub_sub) ||
        naturalCompare(routeCodeOf(a), routeCodeOf(b))
      );
    });
  }

  function subRouteKeyOfCode(code) {
    const norm = normalizeRoute(code);
    const match = norm.match(/^(\d+[A-Z가-힣]?)/);
    return match ? match[1] : norm.slice(0, 3) || "기타";
  }

  function colorOfSubRoute(code) {
    const key = subRouteKeyOfCode(code);

    const palette = [
      { stroke:"#2563eb", fill:"#93c5fd", label:"#1d4ed8" },
      { stroke:"#16a34a", fill:"#86efac", label:"#15803d" },
      { stroke:"#7c3aed", fill:"#c4b5fd", label:"#6d28d9" },
      { stroke:"#ea580c", fill:"#fdba74", label:"#c2410c" },
      { stroke:"#0891b2", fill:"#67e8f9", label:"#0e7490" },
      { stroke:"#db2777", fill:"#f9a8d4", label:"#be185d" },
      { stroke:"#ca8a04", fill:"#fde047", label:"#a16207" },
      { stroke:"#0f766e", fill:"#5eead4", label:"#0f766e" },
      { stroke:"#475569", fill:"#cbd5e1", label:"#334155" }
    ];

    let hash = 0;
    for (const ch of String(key)) hash = (hash * 31 + ch.charCodeAt(0)) >>> 0;

    return palette[hash % palette.length];
  }

  function pointTypeLabel(type) {
    return {
      tip: "배송팁",
      entrance: "입구",
      password: "비번",
      parking: "주차",
      caution: "주의",
      door: "문/동선",
      gate: "게이트",
      etc: "기타"
    }[type] || "기타";
  }

  function pointTypeIcon(type) {
    return {
      tip: "팁",
      entrance: "입",
      password: "🔒",
      parking: "P",
      caution: "!",
      door: "문",
      gate: "G",
      etc: "·"
    }[type] || "·";
  }

  function pointTypeClass(type) {
    return "marker-" + (type || "etc");
  }

  function markFeatureClick() {
    lastFeatureClickAt = Date.now();
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  async function checkAccess() {
    const { data: sessionData, error: sessionError } = await supabaseClient.auth.getSession();
    if (sessionError) throw sessionError;

    const session = sessionData?.session;
    currentUser = session?.user;
    currentAccessToken = session?.access_token || "";

    if (!currentUser || !currentAccessToken) {
      location.href = (cfg.PATHS?.login || "/login.html") + "?next=" + encodeURIComponent(location.pathname);
      return false;
    }

    $("userPill").textContent = currentUser.email || currentUser.id;

    const { data, error } = await supabaseClient.rpc("mw_my_access").maybeSingle();

    if (error) {
      showDenied(error.message);
      return false;
    }

    access = data || {};
    isSuperAdmin =
      access?.is_maroowell === true &&
      access?.is_admin === true &&
      Number(access?.max_role_level || 0) >= 90;

    if (access?.is_maroowell !== true) {
      showDenied("마루웰 소속 권한이 필요합니다.\n조건: user_access.is_maroowell = true");
      return false;
    }

    if (!isSuperAdmin) {
      $("deleteRouteBtn").style.display = "none";
      $("bulkOpenBtn").style.display = "none";
    }

    document.documentElement.style.visibility = "visible";
    return true;
  }

  function showDenied(message) {
    $("accessDenied").classList.add("show");
    $("accessDeniedText").textContent = message || "접근 권한이 없습니다.";
    $("accessDeniedEmail").textContent = currentUser?.email
      ? `현재 로그인: ${currentUser.email}`
      : "현재 로그인 정보를 확인할 수 없습니다.";
    document.documentElement.style.visibility = "visible";
  }

  async function routeInfoApi(path, body = {}) {
    if (!currentAccessToken) await checkAccess();

    const res = await fetch(API_BASE + path, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + currentAccessToken
      },
      body: JSON.stringify(body),
      cache: "no-store"
    });

    const text = await res.text();
    let data = null;

    if (text) {
      try { data = JSON.parse(text); }
      catch { data = text; }
    }

    if (!res.ok || data?.ok === false) {
      const msg =
        (data && typeof data === "object" && (data.error || data.message || data.detail)) ||
        (typeof data === "string" ? data : "") ||
        `HTTP ${res.status}`;
      throw new Error(String(msg));
    }

    return data;
  }

  function initMap() {
    return new Promise(resolve => {
      kakao.maps.load(() => {
        map = new kakao.maps.Map($("map"), {
          center: new kakao.maps.LatLng(37.5665, 126.9780),
          level: 8
        });

        kakaoGeocoder = new kakao.maps.services.Geocoder();
        kakaoPlaces = new kakao.maps.services.Places();

        try {
          roadviewOverlay = new kakao.maps.RoadviewOverlay();
        } catch {
          roadviewOverlay = null;
        }

        kakao.maps.event.addListener(map, "click", e => {
          if (Date.now() - lastFeatureClickAt < 180) return;

          if (drawMode) {
            addDrawVertex(e.latLng);
            return;
          }

          if (addPointMode) {
            if (!selectedRoute) {
              setStatus("먼저 좌측에서 라우트를 선택하세요.", "bad");
              return;
            }

            createNewPointFromMapClick(e.latLng);
            return;
          }

          clearSelection(true);
        });

        kakao.maps.event.addListener(map, "rightclick", e => {
          if (drawMode) deleteNearestDrawVertex(e.latLng);
        });

        resolve();
      });
    });
  }

  function clearMapObjects() {
    polygonObjects.forEach(obj => obj.setMap(null));
    polygonLabels.forEach(obj => obj.setMap(null));
    pointOverlays.forEach(obj => obj.setMap(null));
    polygonObjects = [];
    polygonLabels = [];
    pointOverlays = [];
  }

  function clearDrawObjects() {
    drawVertexMarkers.forEach(marker => marker.setMap(null));
    drawVertexMarkers = [];

    if (drawLine) {
      drawLine.setMap(null);
      drawLine = null;
    }

    if (drawPreviewPolygon) {
      drawPreviewPolygon.setMap(null);
      drawPreviewPolygon = null;
    }
  }

  function clearSearchResults(showIdleStatus = true) {
    hasSearched = false;
    routeRows = [];
    polygonRows = [];
    pointRows = [];
    selectedRoute = null;
    selectedPoint = null;
    selectedPolygonId = null;
    cancelDrawModeSilently();
    setPointPickMode(false, false);
    clearAttachmentsState();
    clearRouteDetail();
    fillPointForm(null);
    renderRouteList();
    renderPointList();
    clearMapObjects();
    renderCounts();

    if (showIdleStatus) {
