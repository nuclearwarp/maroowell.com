        accessDeniedEmail:$("#accessDeniedEmail"),
        btnDeniedHome:$("#btnDeniedHome"),
        btnDeniedLogout:$("#btnDeniedLogout")
      };

      const state = {
        session:null,
        viewerEmail:"",
        viewerUserId:"",
        month:defaultMonth(),
        mode:"vendor",
        allRows:[],
        monthRows:[],
        groups:[],
        selectedGroupKey:"",
        vendorRows:[],
