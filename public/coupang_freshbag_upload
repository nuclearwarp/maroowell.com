<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>프레시백 현황 업로드</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
  <style>
    @font-face{font-family:"문경감홍사과체";src:url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),url("/assets/fonts/MungyeongGamhong.woff") format("woff"),url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");font-weight:400 1000;font-style:normal;font-display:swap}
    :root{--bg:#f6f8fc;--card:#fff;--line:#d8e0ee;--line2:#cbd5e1;--txt:#0f172a;--muted:#64748b;--blue:#2563eb;--red:#dc2626;--green:#16a34a;--shadow:0 14px 34px rgba(15,23,42,.08);--font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif}
    *{box-sizing:border-box}
    html,body{margin:0;min-height:100vh;background:radial-gradient(circle at 12% 0%,rgba(37,99,235,.08),transparent 32%),radial-gradient(circle at 86% 0%,rgba(14,165,233,.08),transparent 30%),linear-gradient(180deg,#fff 0%,#f6f8fc 100%);color:var(--txt);font-family:var(--font);-webkit-font-smoothing:antialiased;text-rendering:geometricPrecision}
    .wrap{max-width:1480px;margin:0 auto;padding:18px 16px 44px}
    .top{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:16px;padding:14px 16px;border:1px solid var(--line);border-radius:22px;background:rgba(255,255,255,.94);box-shadow:var(--shadow);backdrop-filter:blur(12px)}
    .brand{display:flex;align-items:center;gap:12px;min-width:0}
    .brand a{display:flex;align-items:center;justify-content:center;width:36px;height:36px;min-width:36px;border-radius:12px;border:1px solid #e2e8f0;background:#fff;box-shadow:0 6px 14px rgba(15,23,42,.06)}
    .brand img{width:28px;height:28px;object-fit:contain;filter:drop-shadow(0 3px 6px rgba(15,23,42,.08))}
    .title{font-size:25px;font-weight:760;letter-spacing:-.04em;line-height:1.15;word-break:keep-all}
    .sub{color:var(--muted);font-size:13px;font-weight:500;margin-top:5px;line-height:1.45;word-break:keep-all}
    .grid{display:grid;grid-template-columns:minmax(360px,430px) 1fr;gap:16px;align-items:start}
    .card{background:rgba(255,255,255,.96);border:1px solid var(--line);border-radius:20px;padding:16px;margin-bottom:16px;box-shadow:var(--shadow)}
    .sectionTitle{font-size:17px;font-weight:750;letter-spacing:-.03em;margin:0 0 12px;display:flex;align-items:center;gap:8px}
    .sectionTitle::before{content:"";width:8px;height:20px;border-radius:999px;background:linear-gradient(180deg,#60a5fa,#2563eb);display:inline-block}
    .field{margin-bottom:12px}.field label{display:block;font-size:12px;color:var(--muted);font-weight:650;margin:0 0 6px 2px}
    input,select{width:100%;height:42px;border-radius:12px;border:1px solid var(--line2);background:#f8fafc;color:var(--txt);padding:0 12px;outline:none;font-family:var(--font);font-size:13px;font-weight:500;box-shadow:inset 0 1px 0 rgba(255,255,255,.75)}
    input[type=file]{height:auto;min-height:42px;padding:10px 12px;cursor:pointer}input::placeholder{color:#94a3b8}select option{background:#fff;color:var(--txt)}
    input:focus,select:focus{border-color:#60a5fa;background:#fff;box-shadow:0 0 0 3px rgba(37,99,235,.12)}
    .row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
    button{min-height:42px;border-radius:999px;border:1px solid var(--line2);background:#fff;color:#0f172a;padding:0 18px;font-family:var(--font);font-size:13px;font-weight:720;cursor:pointer;white-space:nowrap;box-shadow:0 1px 0 rgba(255,255,255,.85),0 4px 12px rgba(15,23,42,.05)}
    button:hover{background:#f8fbff;border-color:#93c5fd}
    button.primary{background:linear-gradient(180deg,#3b82f6,#2563eb);border-color:#2563eb;color:#fff;box-shadow:0 8px 18px rgba(37,99,235,.18)}
    button.primary:hover{background:linear-gradient(180deg,#2563eb,#1d4ed8)}
    button.ok{background:linear-gradient(180deg,#22c55e,#16a34a);border-color:#16a34a;color:#fff;box-shadow:0 8px 18px rgba(22,163,74,.18)}
    button.ok:hover{background:linear-gradient(180deg,#22c55e,#15803d)}
    button.secondary{background:#f8fafc;color:#334155}button.secondary:hover{background:#eff6ff;color:#0f172a}
    #saveAliasBtn{background:linear-gradient(180deg,#8b5cf6,#7c3aed);border-color:#7c3aed;color:#fff;box-shadow:0 8px 18px rgba(124,58,237,.20)}
    #saveAliasBtn:hover{background:linear-gradient(180deg,#7c3aed,#6d28d9)}
    .status{font-size:13px;color:var(--muted);margin-top:10px;line-height:1.55;font-weight:500;word-break:keep-all}.status.ok{color:#15803d}.status.bad{color:#dc2626}.status.warn{color:#a16207}
    .muted{color:var(--muted);line-height:1.55;font-size:13px;font-weight:500;word-break:keep-all}
    .guideBox{margin-top:12px;padding:12px 13px;border:1px solid #e2e8f0;border-radius:14px;background:#f8fafc;color:#475569;font-size:13px;line-height:1.55;font-weight:500}
    pre{white-space:pre-wrap;word-break:break-word;background:#f8fafc;border:1px solid var(--line);border-radius:14px;padding:14px;max-height:380px;overflow:auto;font:12px/1.5 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;color:#334155;margin:0}
    .tableWrap{overflow:auto;border:1px solid var(--line);border-radius:16px;background:#fff;max-height:560px;box-shadow:inset 0 1px 0 rgba(255,255,255,.7)}
    table{border-collapse:separate;border-spacing:0;width:100%;min-width:860px;font-size:13px;color:var(--txt);background:#fff}
    th,td{border-right:1px solid var(--line);border-bottom:1px solid var(--line);padding:7px 9px;text-align:center;white-space:nowrap}
    th{position:sticky;top:0;z-index:2;background:#dbeafe;color:#0f172a;font-weight:700}
    td{background:#fff;font-weight:500}tbody tr:nth-child(even) td{background:#f8fafc}
    .yes{background:#dff4ff!important;color:#075985;font-weight:700}.no{background:#fff7ed!important;color:#c2410c;font-weight:700}
    .pill{display:inline-flex;align-items:center;justify-content:center;min-height:34px;padding:0 13px;border:1px solid #bfdbfe;border-radius:999px;background:#eff6ff;font-size:12px;color:#1d4ed8;font-weight:700;white-space:nowrap}
    .pill.ok{border-color:#bbf7d0;background:#f0fdf4;color:#15803d}.pill.bad{border-color:#fecaca;background:#fff5f5;color:#dc2626}
    .uploadSummary{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-bottom:12px}
    .summaryItem{padding:11px 12px;border:1px solid var(--line);border-radius:14px;background:#f8fafc}.summaryLabel{font-size:11px;font-weight:650;color:#64748b;margin-bottom:5px}.summaryValue{font-size:18px;font-weight:760;color:#0f172a;letter-spacing:-.03em}
    @media(max-width:980px){.wrap{padding:12px 10px 30px}.grid{grid-template-columns:1fr}.top{align-items:stretch;flex-direction:column;padding:13px 14px;border-radius:20px}.title{font-size:22px}.sub{font-size:12px}.card{border-radius:18px;padding:13px}.row{flex-direction:column;align-items:stretch}.row button{width:100%}.uploadSummary{grid-template-columns:1fr}.tableWrap{max-height:520px}table{font-size:12px;min-width:760px}th,td{padding:6px 7px}}
  </style>

  <style id="mw-freshbag-upload-ultra-light-logo-fix">
    /*
      업로드 페이지 최종 보정
      - 문경감홍사과체가 기본적으로 두꺼워 보여서 전체 굵기를 대폭 낮춤
      - 로고 주변의 별도 흰 박스/테두리/그림자 제거
    */

    body,
    input,
    select,
    table,
    th,
    td,
    pre,
    button,
    .title,
    .sub,
    .sectionTitle,
    .field label,
    .summaryLabel,
    .summaryValue,
    .pill,
    .muted,
    .guideBox,
    .status,
    .yes,
    .no{
      font-weight:400 !important;
      letter-spacing:-0.015em !important;
      text-shadow:none !important;
      -webkit-text-stroke:0 transparent !important;
    }

    .title{
      font-weight:500 !important;
      letter-spacing:-0.035em !important;
    }

    .sectionTitle,
    th,
    button{
      font-weight:450 !important;
    }

    .summaryValue{
      font-weight:500 !important;
    }

    .brand a{
      width:36px !important;
      height:36px !important;
      min-width:36px !important;
      border:0 !important;
      border-radius:0 !important;
      background:transparent !important;
      box-shadow:none !important;
      padding:0 !important;
    }

    .brand img{
      width:32px !important;
      height:32px !important;
      object-fit:contain !important;
      filter:drop-shadow(0 2px 4px rgba(15,23,42,.10)) !important;
    }

    .top{
      background:rgba(255,255,255,.96) !important;
    }
  </style>

</head>
<body>
  <div class="wrap">
    <div class="top"><div class="brand"><a href="#" id="mwBoardMenuToggle"><img src="/favicon.ico" alt="MarooWell"></a><div><div class="title">프레시백 현황 업로드</div><div class="sub">엑셀에서 Wave / Camp / Route / 가중요인 데이터를 추출해 freshbag 백엔드로 저장합니다.</div></div></div><div class="pill" id="userPill">세션 확인 중</div></div>
    <div class="grid">
      <div>
        <div class="card"><div class="sectionTitle">엑셀 업로드</div>
          <div class="field"><label>기준 연도</label><select id="yearSelect"></select></div>
          <div class="field"><label>단일 월 파일일 때 기준 월</label><select id="monthSelect"><option value="">월별 컬럼 파일이면 선택 안 해도 됨</option><option value="1">1월</option><option value="2">2월</option><option value="3">3월</option><option value="4">4월</option><option value="5">5월</option><option value="6">6월</option><option value="7">7월</option><option value="8">8월</option><option value="9">9월</option><option value="10">10월</option><option value="11">11월</option><option value="12">12월</option></select></div>
          <div class="field"><label>파일</label><input id="fileInput" type="file" accept=".xlsx,.xls,.csv" /></div>
          <div class="row"><button id="parseBtn" class="primary">파일 분석</button><button id="uploadBtn" class="ok">백엔드 업로드</button><button id="clearBtn" class="secondary">초기화</button></div>
          <div class="status" id="statusText">대기 중</div>
          <div class="guideBox">헤더가 A열부터 시작해도 되고 B열부터 시작해도 됩니다.<br>Route는 저장 시 자동으로 <b>101_A → 101A</b> 형태로 정규화됩니다.<br>DB 저장은 프론트 직접 저장이 아니라 <b>freshbag Worker 백엔드</b>를 통해 처리합니다.</div>
        </div>
        <div class="card"><div class="sectionTitle">이전 라우트 번호 매핑</div><div class="muted">라우트 번호가 바뀐 경우, 이전 번호를 현재 번호에 연결하면 조회 페이지에서 같은 행으로 합쳐집니다.</div>
          <div class="field" style="margin-top:12px"><label>Camp</label><input id="aliasCamp" placeholder="예: 일산2" /></div><div class="field"><label>현재 라우트</label><input id="aliasCurrent" placeholder="예: 130A" /></div><div class="field"><label>이전 라우트</label><input id="aliasOld" placeholder="예: 130AB" /></div><div class="field"><label>메모</label><input id="aliasMemo" placeholder="예: 2025년 5월부터 변경" /></div>
          <button id="saveAliasBtn">매핑 저장</button><div class="status" id="aliasStatus">대기 중</div>
        </div>
      </div>
      <div>
        <div class="card"><div class="sectionTitle">추출 결과 미리보기</div><div class="uploadSummary"><div class="summaryItem"><div class="summaryLabel">추출 row</div><div class="summaryValue" id="summaryRows">0</div></div><div class="summaryItem"><div class="summaryLabel">월 개수</div><div class="summaryValue" id="summaryMonths">0</div></div><div class="summaryItem"><div class="summaryLabel">라우트 수</div><div class="summaryValue" id="summaryRoutes">0</div></div></div><div class="tableWrap"><table id="previewTable"><thead></thead><tbody></tbody></table></div></div>
        <div class="card"><div class="sectionTitle">로그</div><pre id="logOutput">아직 분석 결과가 없습니다.</pre></div>
      </div>
    </div>
  </div>
<script>
(() => {
  "use strict";
  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};
  const FRESHBAG_API_BASE = String(cfg.BACKENDS?.freshbag || cfg.FRESHBAG_API || "https://freshbag.brain-0f6.workers.dev").replace(/\/+$/, "");
  let supabaseClient = null, currentAccessToken = "", parsedRows = [], fileName = "";
  function setStatus(msg,type=""){$("statusText").textContent=msg;$("statusText").className=type?"status "+type:"status"}
  function setAliasStatus(msg,type=""){$("aliasStatus").textContent=msg;$("aliasStatus").className=type?"status "+type:"status"}
  function setUserPill(msg,type=""){$("userPill").textContent=msg;$("userPill").className=type?"pill "+type:"pill"}
  function log(obj){$("logOutput").textContent=typeof obj==="string"?obj:JSON.stringify(obj,null,2)}
  function normalizeRoute(v){return String(v||"").toUpperCase().replace(/[^0-9A-Z가-힣]/g,"")}
  function clean(v){return String(v??"").trim()}
  function normalizeCampForDb(value){const s=clean(value).replace(/\s+/g,"");if(!s)return "";if(/^M(?!_)/i.test(s))return "M_"+s.slice(1);return s}
  function headerKey(v){return clean(v).replace(/\s+/g,"").replace(/_/g,"").toLowerCase()}
  function esc(v){return String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#39;")}
  function initYears(){const now=new Date().getFullYear();const years=[];for(let y=now+1;y>=now-5;y--)years.push(y);$("yearSelect").innerHTML=years.map(y=>`<option value="${y}">${y}</option>`).join("");$("yearSelect").value=String(now)}
  function initSupabase(){if(!cfg.SUPABASE_URL||!cfg.SUPABASE_ANON_KEY||!window.supabase?.createClient)throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");const storage=(()=>{try{return window.sessionStorage}catch{return undefined}})();supabaseClient=window.supabase.createClient(cfg.SUPABASE_URL,cfg.SUPABASE_ANON_KEY,{auth:{persistSession:!!storage,storage,autoRefreshToken:true,detectSessionInUrl:true}})}
  async function checkSession(){if(!supabaseClient)initSupabase();const {data,error}=await supabaseClient.auth.getSession();if(error)throw error;const session=data?.session;const user=session?.user;currentAccessToken=session?.access_token||"";if(!user||!currentAccessToken)throw new Error("로그인이 필요합니다.");setUserPill(user.email||user.id,"ok")}
  async function freshbagApi(path,body={}){if(!currentAccessToken)await checkSession();const res=await fetch(FRESHBAG_API_BASE+path,{method:"POST",headers:{"Content-Type":"application/json","Authorization":"Bearer "+currentAccessToken},body:JSON.stringify(body),cache:"no-store"});const text=await res.text();let data=null;if(text){try{data=JSON.parse(text)}catch{data=text}}if(!res.ok||data?.ok===false){const msg=(data&&typeof data==="object"&&(data.error||data.message||data.detail))||(typeof data==="string"?data:"")||`HTTP ${res.status}`;throw new Error(String(msg))}return data}
  function findHeader(rows){for(let r=0;r<Math.min(rows.length,80);r++){const row=rows[r]||[];const keys=row.map(headerKey);const waveIdx=keys.findIndex(v=>v==="wave"||v==="웨이브");const campIdx=keys.findIndex(v=>v==="camp"||v==="캠프");const routeIdx=keys.findIndex(v=>v==="route"||v==="라우트");if(waveIdx>=0&&campIdx>=0&&routeIdx>=0)return{rowIndex:r,row,keys,waveIdx,campIdx,routeIdx}}throw new Error("Wave / Camp / Route 헤더를 찾지 못했습니다.")}
  function findSingleGajoongColumns(header){const g1Idx=header.keys.findIndex(v=>v==="가중요인1"||v==="가중1"||v.includes("가중요인1")||v.includes("가중1"));const g2Idx=header.keys.findIndex(v=>v==="가중요인2"||v==="가중2"||v.includes("가중요인2")||v.includes("가중2"));return g1Idx>=0&&g2Idx>=0?{g1Idx,g2Idx}:null}
  function findMonthlyColumns(header){const found=[];for(let i=0;i<header.row.length;i++){const key=headerKey(header.row[i]);const m=key.match(/^(\d{1,2})월가중(?:요인)?([12])$/);if(!m)continue;const month=Number(m[1]),which=Number(m[2]);if(month<1||month>12)continue;let item=found.find(x=>x.month===month);if(!item){item={month,g1Idx:-1,g2Idx:-1};found.push(item)}if(which===1)item.g1Idx=i;if(which===2)item.g2Idx=i}return found.filter(x=>x.g1Idx>=0&&x.g2Idx>=0)}
  function parseTitlePeriod(rows){for(let r=0;r<Math.min(rows.length,20);r++){for(let c=0;c<Math.min((rows[r]||[]).length,20);c++){const s=clean(rows[r][c]);if(!s)continue;if(/title/i.test(s)||/\d{4}\.\s*\d{1,2}\.\s*\d{1,2}/.test(s))return s.replace(/^title\s*:\s*/i,"").trim()}}return ""}
  async function readWorkbook(file){const buf=await file.arrayBuffer();const wb=XLSX.read(buf,{type:"array"});const sheetName=wb.SheetNames[0];const ws=wb.Sheets[sheetName];return{sheetName,rows:XLSX.utils.sheet_to_json(ws,{header:1,raw:false,defval:""})}}
  function parseRows(rows){const year=Number($("yearSelect").value);const selectedMonth=Number($("monthSelect").value||0);const periodLabel=parseTitlePeriod(rows);const header=findHeader(rows);const monthlyColumns=findMonthlyColumns(header);const singleColumns=findSingleGajoongColumns(header);const out=[];const mode=monthlyColumns.length?"monthly-wide":"single-month";if(mode==="single-month"&&!selectedMonth)throw new Error("이 파일은 단일 월 형식입니다. 기준 월을 선택하세요.");for(let r=header.rowIndex+1;r<rows.length;r++){const row=rows[r]||[];const wave=clean(row[header.waveIdx]);const camp=normalizeCampForDb(row[header.campIdx]);const route=clean(row[header.routeIdx]);const routeNorm=normalizeRoute(route);if(!wave||!camp||!routeNorm)continue;if(mode==="monthly-wide"){for(const col of monthlyColumns){const g1=clean(row[col.g1Idx]);const g2=clean(row[col.g2Idx]);if(!g1&&!g2)continue;out.push({data_year:year,month_no:col.month,data_month:`${year}-${String(col.month).padStart(2,"0")}`,period_label:periodLabel||`${year}-${String(col.month).padStart(2,"0")}`,wave,camp,route,route_norm:routeNorm,gajoong1:g1||null,gajoong2:g2||null,source_file_name:fileName})}}else{if(!singleColumns)throw new Error("가중요인1 / 가중요인2 컬럼을 찾지 못했습니다.");const g1=clean(row[singleColumns.g1Idx]);const g2=clean(row[singleColumns.g2Idx]);if(!g1&&!g2)continue;out.push({data_year:year,month_no:selectedMonth,data_month:`${year}-${String(selectedMonth).padStart(2,"0")}`,period_label:periodLabel||`${year}-${String(selectedMonth).padStart(2,"0")}`,wave,camp,route,route_norm:routeNorm,gajoong1:g1||null,gajoong2:g2||null,source_file_name:fileName})}}return{mode,periodLabel,headerRow:header.rowIndex+1,count:out.length,rows:out}}
  function updateSummary(rows){const months=new Set(),routes=new Set();for(const row of rows){if(row.month_no)months.add(String(row.month_no));if(row.wave&&row.camp&&row.route_norm)routes.add(`${row.wave}||${row.camp}||${row.route_norm}`)}$("summaryRows").textContent=rows.length.toLocaleString();$("summaryMonths").textContent=months.size.toLocaleString();$("summaryRoutes").textContent=routes.size.toLocaleString()}
  function renderPreview(rows){const thead=$("previewTable").querySelector("thead");const tbody=$("previewTable").querySelector("tbody");thead.innerHTML=`<tr><th>data_month</th><th>Wave</th><th>Camp</th><th>Route</th><th>route_norm</th><th>가중1</th><th>가중2</th></tr>`;const sample=rows.slice(0,300);if(!sample.length){tbody.innerHTML=`<tr><td colspan="7">추출 데이터 없음</td></tr>`;updateSummary([]);return}tbody.innerHTML=sample.map(row=>`<tr><td>${esc(row.data_month)}</td><td>${esc(row.wave)}</td><td>${esc(row.camp)}</td><td>${esc(row.route)}</td><td>${esc(row.route_norm)}</td><td class="${row.gajoong1==="해당"?"yes":row.gajoong1==="미해당"?"no":""}">${esc(row.gajoong1)}</td><td class="${row.gajoong2==="해당"?"yes":row.gajoong2==="미해당"?"no":""}">${esc(row.gajoong2)}</td></tr>`).join("");updateSummary(rows)}
  async function parseFile(){const file=$("fileInput").files?.[0];if(!file)throw new Error("파일을 선택하세요.");fileName=file.name;setStatus("파일 분석 중...");const {sheetName,rows}=await readWorkbook(file);const result=parseRows(rows);parsedRows=result.rows;renderPreview(parsedRows);log({file:file.name,sheet:sheetName,mode:result.mode,headerRow:result.headerRow,periodLabel:result.periodLabel,extractedRows:result.count,api:FRESHBAG_API_BASE,sample:parsedRows.slice(0,5)});setStatus(`분석 완료: ${parsedRows.length.toLocaleString()}건 추출`,"ok")}
  function chunkUploadRows(arr,size){const out=[];for(let i=0;i<arr.length;i+=size)out.push(arr.slice(i,i+size));return out}
  async function uploadRows(){if(!parsedRows.length)throw new Error("먼저 파일 분석을 실행하세요.");const batchSize=1500;const batches=chunkUploadRows(parsedRows,batchSize);let done=0;setStatus(`freshbag 백엔드 업로드 중... 0/${parsedRows.length.toLocaleString()}건`);const results=[];for(let i=0;i<batches.length;i++){const batch=batches[i];const result=await freshbagApi("/freshbag/upsert",{rows:batch,batch_size:2000});const uploaded=Number(result?.upserted||batch.length);done+=uploaded;results.push(result);setStatus(`freshbag 백엔드 업로드 중... ${done.toLocaleString()}/${parsedRows.length.toLocaleString()}건 (${i+1}/${batches.length})`)}setStatus(`업로드 완료: ${done.toLocaleString()}건`,"ok");log({upload:"done",api:FRESHBAG_API_BASE,total:parsedRows.length,done,batchSize,batches:batches.length,results:results.slice(-3)})}
  async function saveAlias(){const camp=normalizeCampForDb($("aliasCamp").value);const current=clean($("aliasCurrent").value);const old=clean($("aliasOld").value);const memo=clean($("aliasMemo").value);if(!camp||!current||!old)throw new Error("Camp / 현재 라우트 / 이전 라우트를 입력하세요.");const row={camp,route_label:current,route_norm:normalizeRoute(current),alias_route_label:old,alias_route_norm:normalizeRoute(old),memo:memo||null};setAliasStatus("freshbag 백엔드로 매핑 저장 중...");const result=await freshbagApi("/freshbag/alias/upsert",{row});setAliasStatus("매핑 저장 완료","ok");log({alias:"saved",api:FRESHBAG_API_BASE,row,result})}
  function clearAll(){parsedRows=[];fileName="";$("fileInput").value="";$("previewTable").querySelector("thead").innerHTML="";$("previewTable").querySelector("tbody").innerHTML="";updateSummary([]);log("초기화 완료");setStatus("대기 중")}
  function run(fn,target="main"){fn().catch(e=>{console.error(e);if(target==="alias")setAliasStatus(e.message||String(e),"bad");else setStatus(e.message||String(e),"bad")})}
  initYears();updateSummary([]);
  $("parseBtn").addEventListener("click",()=>run(parseFile));$("uploadBtn").addEventListener("click",()=>run(uploadRows));$("clearBtn").addEventListener("click",clearAll);$("saveAliasBtn").addEventListener("click",()=>run(saveAlias,"alias"));
  try{initSupabase();run(checkSession)}catch(e){setUserPill("세션 오류","bad");setStatus(e.message,"bad")}
})();
</script>
<script src="/board-menu.js"></script>
</body>
