<body>
  <div class="app">
    <header class="topbar">
      <div class="brand"><a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기"><img src="/favicon.ico" alt="Maroowell" /></a><div class="brandText"><h1>정산 통계 조회</h1><p>maroowell_account 기반 월별·일별·요일별·노선별 수량 통계</p></div></div>
      <div class="topSpacer"></div><div id="userBadge" class="userBadge">-</div><button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>
    <main class="wrap">
      <section class="card"><div class="cardHead"><h2>조회 조건</h2><span id="stateText" class="muted">대기 중</span></div><div class="cardBody"><div class="toolbar">
        <div class="field"><label for="yearSelect">정산 연도</label><select id="yearSelect" class="select"></select></div>
        <div class="field"><label for="monthSelect">정산 월</label><select id="monthSelect" class="select"></select></div>
        <div class="field"><label for="rangeSelect">조회 범위</label><select id="rangeSelect" class="select"><option value="month">선택 월</option><option value="year">연도 전체</option></select></div>
        <div class="field"><label for="campSelect">캠프</label><select id="campSelect" class="select"><option value="">전체 캠프</option></select></div>
        <div class="field"><label for="waveSelect">주/야</label><select id="waveSelect" class="select"><option value="">전체</option><option value="주간">주간</option><option value="야간">야간</option><option value="WAVE2">WAVE2</option><option value="WAVE1">WAVE1</option></select></div>
        <div class="field"><label for="routeModeSelect">노선 기준</label><select id="routeModeSelect" class="select"><option value="base">노선 묶음 예: 213</option><option value="exact">상세 라우트 예: 213A</option></select></div>
        <div class="field"><label for="searchInput">검색</label><input id="searchInput" class="input" type="text" placeholder="캠프 / 노선 / ID / 배송유형" autocomplete="off" /></div>
        <button id="btnLoad" class="btn primary" type="button">조회</button><button id="btnExcel" class="btn ok" type="button">엑셀 다운로드</button><button id="btnReset" class="btn" type="button">초기화</button>
      </div><div id="statusText" class="status">정산 연도와 월을 선택하고 조회를 누르세요.</div><div id="summaryGrid" class="pillGrid"></div></div></section>
      <section class="card"><div class="cardHead"><h2>노선 변경 / 캠프 변경 묶음 규칙</h2><div class="right"><button id="btnSaveAlias" class="btn copy" type="button">규칙 저장</button><button id="btnResetAlias" class="btn" type="button">기본값</button></div></div><div class="cardBody"><div class="aliasBox"><div><textarea id="aliasText" class="textarea" spellcheck="false"></textarea><div class="hint">형식: <b>현재캠프|현재노선 = 과거노선, 과거캠프|과거노선</b><br>예시: <b>대구3|213 = 329</b> → 대구3의 과거 329 노선을 현재 213 노선으로 합산합니다.</div></div><div class="muted">노선 기준이 <b>노선 묶음</b>일 때 적용됩니다.<br>213A, 213B 같은 상세 라우트는 기본적으로 213으로 묶습니다.<br>담당 캠프까지 바뀐 경우에는 <b>대구3|213 = 구캠프명|329</b>처럼 입력하면 됩니다.</div></div></div></section>
      <section class="card"><div class="cardHead"><h2>노선별 수량 통계</h2><span id="routeNote" class="muted">-</span></div><div class="tableWrap"><table id="routeTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section>
      <div class="grid2"><section class="subCard"><div class="subCardHead"><h3>일별 수량 통계</h3><span id="dailyNote" class="muted">-</span></div><div class="tableWrap"><table id="dailyTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section><section class="subCard"><div class="subCardHead"><h3>요일별 수량 통계</h3><span id="weekdayNote" class="muted">-</span></div><div class="tableWrap"><table id="weekdayTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section></div>
      <section class="card"><div class="cardHead"><h2>월별 수량 통계</h2><span id="monthlyNote" class="muted">-</span></div><div class="tableWrap"><table id="monthlyTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section>
    </main>
  </div>
  <div id="accessDenied" class="accessDenied"><div class="accessCard"><h2>접근 권한 없음</h2><p id="accessDeniedText">최고관리자 권한이 필요합니다.</p><div id="accessDeniedEmail" class="accessMeta"></div><div class="accessActions"><button id="deniedHomeBtn" class="btn" type="button">홈으로</button><button id="deniedLogoutBtn" class="btn danger" type="button">로그아웃</button></div></div></div>
  <script>
    (async function(){
      "use strict";
      const CONFIG=window.MARUWELL_CONFIG||{},SUPABASE_URL=CONFIG.SUPABASE_URL,SUPABASE_ANON_KEY=CONFIG.SUPABASE_ANON_KEY,LOGIN_PATH=CONFIG.PATHS?.login||"/login.html",HOME_PATH=CONFIG.PATHS?.index||"/zipcode_search",TABLE_NAME="maroowell_account",ALIAS_STORAGE_KEY="maroowell_account_route_alias_rules_v1";
      const DEFAULT_ALIAS_TEXT=["# 현재캠프|현재노선 = 과거노선, 과거캠프|과거노선","# 예시: 대구3 213 노선이 예전에는 329였으면 아래처럼 둡니다.","대구3|213 = 329"].join("\n"),WEEKDAYS=["일","월","화","수","목","금","토"];
      const els={userBadge:gid("userBadge"),btnLogout:gid("btnLogout"),yearSelect:gid("yearSelect"),monthSelect:gid("monthSelect"),rangeSelect:gid("rangeSelect"),campSelect:gid("campSelect"),waveSelect:gid("waveSelect"),routeModeSelect:gid("routeModeSelect"),searchInput:gid("searchInput"),aliasText:gid("aliasText"),btnSaveAlias:gid("btnSaveAlias"),btnResetAlias:gid("btnResetAlias"),btnLoad:gid("btnLoad"),btnExcel:gid("btnExcel"),btnReset:gid("btnReset"),stateText:gid("stateText"),statusText:gid("statusText"),summaryGrid:gid("summaryGrid"),routeTable:gid("routeTable"),dailyTable:gid("dailyTable"),weekdayTable:gid("weekdayTable"),monthlyTable:gid("monthlyTable"),routeNote:gid("routeNote"),dailyNote:gid("dailyNote"),weekdayNote:gid("weekdayNote"),monthlyNote:gid("monthlyNote"),accessDenied:gid("accessDenied"),accessDeniedText:gid("accessDeniedText"),accessDeniedEmail:gid("accessDeniedEmail"),deniedHomeBtn:gid("deniedHomeBtn"),deniedLogoutBtn:gid("deniedLogoutBtn")};
      const state={session:null,user:null,access:null,rows:[],rawRows:[],filteredRows:[],stats:null};
      const supabaseClient=SUPABASE_URL&&SUPABASE_ANON_KEY&&window.supabase?window.supabase.createClient(SUPABASE_URL,SUPABASE_ANON_KEY,{auth:{storage:window.sessionStorage,persistSession:true,autoRefreshToken:true,detectSessionInUrl:true}}):null;
      function gid(id){return document.getElementById(id)}
      function clean(v){return String(v??"").trim()}function esc(v){return String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#39;")}function num(v){const n=Number(v||0);return Number.isFinite(n)?n:0}function int(v){return Math.round(num(v))}function money(v){return num(v).toLocaleString("ko-KR")}function count(v){return int(v).toLocaleString("ko-KR")}function setStatus(text,type){els.statusText.textContent=text||"";els.statusText.className=type?`status ${type}`:"status"}function setBusy(b){els.btnLoad.disabled=b;els.btnExcel.disabled=b;els.stateText.textContent=b?"처리 중":"READY"}function isoMonth(d){return clean(d).slice(0,7)}function weekdayOf(d){const dt=new Date(`${d}T00:00:00`);return Number.isFinite(dt.getTime())?dt.getDay():-1}function weekdayLabel(d){const w=weekdayOf(d);return w>=0?WEEKDAYS[w]:""}
      function isLossRow(row){const source=clean(row.source_sheet).replace(/\s+/g,"").toLowerCase(),classify=clean(row.classify).replace(/\s+/g,"").toLowerCase();return source==="분실파손list"||classify==="분실파손"||classify.includes("분실")||classify.includes("파손")}function isRawRow(row){return !isLossRow(row)}function classifyRawOk(row){const c=clean(row.classify);return !c||!/분실|파손/i.test(c)}
      function normalizeWave(v){const raw=clean(v).toUpperCase();if(raw==="WAVE2"||raw==="2W"||raw==="주간")return"주간";if(raw==="WAVE1"||raw==="1W"||raw==="야간")return"야간";return clean(v)||"-"}
      function routeTokens(v){const raw=clean(v);return raw?raw.split(/[,\s/]+/).map(clean).filter(Boolean):[]}function routeBase(v){const token=routeTokens(v)[0]||clean(v);if(!token)return"-";const m=token.match(/^(?:[A-Za-z가-힣_]*)(\d+)/);return m?m[1]:token}function routeExact(v){return routeTokens(v)[0]||clean(v)||"-"}function aliasKey(c,r){return`${clean(c)}||${clean(r)}`}
      function parseAliasRules(text){const map=new Map(),errors=[];String(text||"").split(/\r?\n/).forEach((line,i)=>{const original=line;line=line.replace(/#.*$/,"").trim();if(!line)return;const parts=line.split("=");if(parts.length<2){errors.push(`${i+1}행: = 기호가 없습니다.`);return}const left=clean(parts.shift()),right=clean(parts.join("=")),lp=left.split("|").map(clean).filter(Boolean);if(lp.length<2){errors.push(`${i+1}행: 왼쪽은 현재캠프|현재노선 형식이어야 합니다. (${original})`);return}const cc=lp[0],cr=lp[1],aliases=right.split(",").map(clean).filter(Boolean);if(!aliases.length){errors.push(`${i+1}행: 오른쪽 과거 노선이 비어 있습니다.`);return}map.set(aliasKey(cc,cr),{camp:cc,route:cr});aliases.forEach(a=>{const ap=a.split("|").map(clean).filter(Boolean),ac=ap.length>=2?ap[0]:cc,ar=ap.length>=2?ap[1]:ap[0];if(ac&&ar)map.set(aliasKey(ac,ar),{camp:cc,route:cr})})});return{map,errors}}
      function normalizedRouteGroup(row,aliasMap){const mode=els.routeModeSelect.value,oc=clean(row.camp)||"-",or=mode==="exact"?routeExact(row.route):routeBase(row.route);if(mode!=="base")return{camp:oc,route:or,originalCamp:oc,originalRoute:or,changed:false};const a=aliasMap.get(aliasKey(oc,or));return a?{camp:a.camp,route:a.route,originalCamp:oc,originalRoute:or,changed:a.camp!==oc||a.route!==or}:{camp:oc,route:or,originalCamp:oc,originalRoute:or,changed:false}}
      function newMetric(extra={}){return{rows:0,parcel:0,return:0,quantity:0,default_price:0,freshbag_incentive_price:0,freshbag_return:0,freshbag_total:0,total_price:0,settlement_total:0,price_sum:0,price_count:0,dateSet:new Set(),idSet:new Set(),originalRouteSet:new Set(),first_date:"",last_date:"",uncontracted:0,...extra}}
      function addMetric(t,row){const p=num(row.parcel),r=num(row.return),def=num(row.default_price),fi=num(row.freshbag_incentive_price),fr=num(row.freshbag_return),tp=num(row.total_price),price=num(row.price);t.rows++;t.parcel+=p;t.return+=r;t.quantity+=p+r;t.default_price+=def;t.freshbag_incentive_price+=fi;t.freshbag_return+=fr;t.freshbag_total+=fi+fr;t.total_price+=tp;t.settlement_total+=tp+fr;t.price_sum+=price;t.price_count+=price?1:0;const d=clean(row.delivery_date);if(d){t.dateSet.add(d);if(!t.first_date||d<t.first_date)t.first_date=d;if(!t.last_date||d>t.last_date)t.last_date=d}const id=clean(row.id);if(id)t.idSet.add(id);const or=clean(row.__originalRoute||row.route);if(or)t.originalRouteSet.add(or);if(clean(row.classify).includes("미계약"))t.uncontracted++}
      function finalizeMetric(m){const days=m.dateSet?.size||0;return{...m,days,ids:m.idSet?.size||0,original_routes:Array.from(m.originalRouteSet||[]).sort((a,b)=>a.localeCompare(b,"ko",{numeric:true,sensitivity:"base"})).join(", "),avg_day:days?m.quantity/days:0,avg_price:m.price_count?m.price_sum/m.price_count:0}}
      function initPeriodSelects(){const now=new Date(),cy=now.getFullYear(),cm=now.getMonth()+1,years=[];for(let y=cy+1;y>=cy-8;y--)years.push(y);els.yearSelect.innerHTML=years.map(y=>`<option value="${y}">${y}년</option>`).join("");els.monthSelect.innerHTML=Array.from({length:12},(_,i)=>`<option value="${i+1}">${i+1}월</option>`).join("");els.yearSelect.value=String(cy);els.monthSelect.value=String(cm)}function initAliasText(){els.aliasText.value=localStorage.getItem(ALIAS_STORAGE_KEY)||DEFAULT_ALIAS_TEXT}
      function getSelectedPeriod(){const y=Number(els.yearSelect.value),m=Number(els.monthSelect.value);if(!Number.isInteger(y)||y<2000||y>2100)throw new Error("정산 연도를 선택하세요.");if(!Number.isInteger(m)||m<1||m>12)throw new Error("정산 월을 선택하세요.");return{date_year:y,date_month:m,range:els.rangeSelect.value}}
      function showAccessDenied(msg){els.accessDeniedText.textContent=msg||"최고관리자 권한이 필요합니다.";els.accessDeniedEmail.textContent=state.user?.email?`현재 계정: ${state.user.email}`:"로그인 계정을 확인할 수 없습니다.";els.accessDenied.classList.add("show");document.documentElement.style.visibility="visible"}
      async function logout(){try{if(supabaseClient)await supabaseClient.auth.signOut()}catch{}location.href=LOGIN_PATH}
      async function checkAccess(){if(!supabaseClient){showAccessDenied("Supabase 설정을 찾지 못했습니다. config.js를 확인하세요.");return false}const{data:sd,error:se}=await supabaseClient.auth.getSession();if(se)throw se;state.session=sd?.session||null;state.user=state.session?.user||null;if(!state.user){location.href=`${LOGIN_PATH}?next=${encodeURIComponent(location.pathname)}`;return false}els.userBadge.textContent=state.user.email||state.user.id||"로그인";const{data,error}=await supabaseClient.rpc("mw_my_access").maybeSingle();if(error)throw error;state.access=data||null;const ok=data?.is_maroowell===true&&data?.is_admin===true&&Number(data?.max_role_level||0)>=90;if(!ok){showAccessDenied("최고관리자 권한이 필요합니다.\n조건: 마루웰 권한 + 관리자 권한 + role_level 90 이상");return false}document.documentElement.style.visibility="visible";return true}
      async function fetchAccountRows(period){const pageSize=1000,out=[];for(let from=0;from<100000;from+=pageSize){let q=supabaseClient.from(TABLE_NAME).select("*").eq("date_year",period.date_year);if(period.range!=="year")q=q.eq("date_month",period.date_month);q=q.order("delivery_date",{ascending:true,nullsFirst:false}).order("camp",{ascending:true,nullsFirst:false}).order("wave",{ascending:true,nullsFirst:false}).order("route",{ascending:true,nullsFirst:false}).range(from,from+pageSize-1);const{data,error}=await q;if(error)throw error;const rows=Array.isArray(data)?data:[];out.push(...rows);if(rows.length<pageSize)break}return out}
      function rebuildCampOptions(rows){const selected=els.campSelect.value,camps=Array.from(new Set(rows.map(r=>clean(r.camp)).filter(Boolean))).sort((a,b)=>a.localeCompare(b,"ko",{numeric:true,sensitivity:"base"}));els.campSelect.innerHTML=`<option value="">전체 캠프</option>`+camps.map(c=>`<option value="${esc(c)}">${esc(c)}</option>`).join("");if(selected&&camps.includes(selected))els.campSelect.value=selected}
      function baseFilteredRows(){const q=clean(els.searchInput.value).toLowerCase(),camp=clean(els.campSelect.value),wave=clean(els.waveSelect.value),aliasMap=parseAliasRules(els.aliasText.value).map;return state.rawRows.filter(row=>{const g=normalizedRouteGroup(row,aliasMap),rw=normalizeWave(row.wave);if(camp&&g.camp!==camp&&clean(row.camp)!==camp)return false;if(wave){const wn=normalizeWave(wave);if(rw!==wn&&clean(row.wave)!==wave)return false}if(q){const hay=[row.classify,row.id,row.route,g.route,row.delivery_date,row.camp,g.camp,row.wave,rw].map(clean).join(" ").toLowerCase();if(!hay.includes(q))return false}return true})}
      function buildStats(){const alias=parseAliasRules(els.aliasText.value);if(alias.errors.length)setStatus(`노선 묶음 규칙 오류가 있습니다.\n${alias.errors.join("\n")}`,"warn");const aliasMap=alias.map,filtered=baseFilteredRows();state.filteredRows=filtered;const total=newMetric(),routeMap=new Map(),dailyMap=new Map(),weekdayMap=new Map(),monthlyMap=new Map();filtered.forEach(row=>{const g=normalizedRouteGroup(row,aliasMap),wave=normalizeWave(row.wave),date=clean(row.delivery_date),month=isoMonth(date)||`${row.date_year||""}-${String(row.date_month||"").padStart(2,"0")}`,weekday=weekdayLabel(date);row.__groupCamp=g.camp;row.__groupRoute=g.route;row.__originalCamp=g.originalCamp;row.__originalRoute=g.originalRoute;row.__groupChanged=g.changed;row.__waveNorm=wave;addMetric(total,row);const rk=`${g.camp}||${wave}||${g.route}`;if(!routeMap.has(rk))routeMap.set(rk,newMetric({camp:g.camp,wave,route:g.route,originalGroupSet:new Set()}));const rm=routeMap.get(rk);rm.originalGroupSet.add(`${g.originalCamp} ${g.originalRoute}`);addMetric(rm,row);if(date){const dk=`${date}||${g.camp}||${wave}`;if(!dailyMap.has(dk))dailyMap.set(dk,newMetric({date,weekday,camp:g.camp,wave}));addMetric(dailyMap.get(dk),row)}if(weekday){const wn=weekdayOf(date),wk=`${wn}||${weekday}||${g.camp}||${wave}`;if(!weekdayMap.has(wk))weekdayMap.set(wk,newMetric({weekday_no:wn,weekday,camp:g.camp,wave}));addMetric(weekdayMap.get(wk),row)}if(month){const mk=`${month}||${g.camp}||${wave}`;if(!monthlyMap.has(mk))monthlyMap.set(mk,newMetric({month,camp:g.camp,wave}));addMetric(monthlyMap.get(mk),row)}});const routeRows=Array.from(routeMap.values()).map(m=>{const fm=finalizeMetric(m);fm.original_groups=Array.from(m.originalGroupSet||[]).sort((a,b)=>a.localeCompare(b,"ko",{numeric:true,sensitivity:"base"})).join(", ");return fm}).sort((a,b)=>b.quantity-a.quantity||a.camp.localeCompare(b.camp,"ko",{numeric:true,sensitivity:"base"})||a.wave.localeCompare(b.wave,"ko",{numeric:true,sensitivity:"base"})||a.route.localeCompare(