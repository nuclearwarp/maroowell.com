<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />
  <title>마루웰 스케줄</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    html { visibility:hidden; }

    :root{
      --bg:#081120;
      --bg2:#0b1424;
      --panel:#101b2f;
      --panel2:#0d1728;
      --line:rgba(255,255,255,.11);
      --line2:rgba(255,255,255,.18);
      --txt:#eaf2ff;
      --muted:#9fb0d0;
      --blue:#60a5fa;
      --green:#16a34a;
      --red:#dc2626;
      --yellow:#f59e0b;
      --cell:#111827;
      --head:#27364d;
      --camp:#bcd0ef;
      --week:#ffdf6a;
      --shadow:0 16px 42px rgba(0,0,0,.28);
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      min-height:100%;
      background:var(--bg);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    body{overflow:hidden}

    button,input,select,textarea{font-family:inherit}

    .app{
      height:100vh;
      height:100dvh;
      display:grid;
      grid-template-rows:auto auto 1fr;
      background:linear-gradient(180deg,var(--bg),#060b13);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:12px 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,#0b1424,#07101d);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
    }

    .logoButton{
      width:34px;
      height:34px;
      border:1px solid transparent;
      border-radius:12px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      flex:0 0 auto;
      cursor:pointer;
      background:rgba(255,255,255,.03);
      transition:background .15s ease,border-color .15s ease,transform .15s ease;
    }

    .logoButton:hover{
      background:rgba(255,255,255,.10);
      border-color:rgba(255,255,255,.18);
      transform:translateY(-1px);
    }

    .logoButton img{
      width:28px;
      height:28px;
      display:block;
    }

    .brandText{min-width:0}

    .brandText h1{
      margin:0;
      font-size:22px;
      line-height:1.05;
      letter-spacing:-.04em;
    }

    .brandText p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .topSpacer{flex:1}

    .userBadge{
      display:inline-flex;
      align-items:center;
      min-height:34px;
      max-width:220px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.05);
      color:#bfdbfe;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .btn{
      height:38px;
      padding:0 13px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.07);
      color:var(--txt);
      font-size:13px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
      touch-action:manipulation;
    }

    .btn:hover{background:rgba(255,255,255,.11)}
    .btn.primary{background:rgba(37,99,235,.75);border-color:rgba(147,197,253,.45)}
    .btn.ok{background:rgba(22,163,74,.55);border-color:rgba(134,239,172,.35)}
    .btn.warn{background:rgba(245,158,11,.34);border-color:rgba(253,230,138,.35)}
    .btn.danger{background:rgba(185,28,28,.42);border-color:rgba(252,165,165,.35);color:#fecaca}
    .btn:disabled{opacity:.55;cursor:not-allowed}

    .toolbar{
      display:grid;
      grid-template-columns:160px 150px 180px 1fr auto auto auto auto auto;
      gap:10px;
      align-items:end;
      padding:12px 14px;
      border-bottom:1px solid var(--line);
      background:var(--panel2);
      position:relative;
      z-index:10;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:5px;
      min-width:0;
    }

    .field label{
      color:#bfdbfe;
      font-size:12px;
      font-weight:900;
    }

    .input,
    .select,
    .weekButton{
      width:100%;
      height:42px;
      border-radius:12px;
      border:1px solid var(--line2);
      background:#0b1220;
      color:var(--txt);
      padding:0 12px;
      font-size:14px;
      font-weight:800;
      outline:none;
    }

    .input:focus,
    .select:focus,
    .weekButton:focus{
      border-color:rgba(96,165,250,.75);
      box-shadow:0 0 0 3px rgba(96,165,250,.12);
    }

    .weekButton{
      display:flex;
      align-items:center;
      justify-content:space-between;
      cursor:pointer;
    }

    .weekButton span:first-child{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .weekButton .chev{
      color:#bfdbfe;
      font-size:12px;
      margin-left:8px;
    }

    .weekPickerWrap{
      position:relative;
    }

    .weekPopup{
      position:absolute;
      top:calc(100% + 8px);
      left:0;
      width:316px;
      max-width:calc(100vw - 24px);
      border:1px solid rgba(148,163,184,.38);
      border-radius:16px;
      background:#f8fafc;
      color:#0f172a;
      box-shadow:0 24px 70px rgba(0,0,0,.38);
      padding:12px;
      display:none;
      z-index:100;
    }

    .weekPopup.open{
      display:block;
    }

    .weekPopupHeader{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
    }

    .weekMonthTitle{
      font-weight:1000;
      font-size:15px;
      color:#0f172a;
    }

    .weekNav{
      display:flex;
      gap:6px;
    }

    .weekNav button{
      width:34px;
      height:32px;
      border-radius:10px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      font-weight:1000;
      cursor:pointer;
    }

    .weekGrid{
      display:grid;
      grid-template-columns:repeat(7,1fr);
      gap:3px;
    }

    .weekDow{
      height:24px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:12px;
      font-weight:1000;
      color:#475569;
    }

    .weekDay{
      height:32px;
      border:0;
      background:transparent;
      border-radius:8px;
      color:#0f172a;
      font-size:13px;
      font-weight:800;
      cursor:pointer;
    }

    .weekDay.other{
      color:#94a3b8;
    }

    .weekDay.today{
      box-shadow:inset 0 0 0 2px rgba(37,99,235,.35);
    }

    .weekDay.selected{
      background:#2563eb;
      color:#fff;
    }

    .weekRowHighlight{
      background:#dbeafe!important;
    }

    .weekDay.selected.weekRowHighlight{
      background:#2563eb!important;
      color:#fff!important;
    }

    .weekPopupFooter{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-top:10px;
      gap:8px;
      font-size:12px;
      color:#475569;
      font-weight:900;
    }

    .weekPopupFooter button{
      height:30px;
      padding:0 10px;
      border-radius:10px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      font-weight:1000;
      cursor:pointer;
    }

    .weekBtns{
      display:flex;
      gap:6px;
      align-items:center;
    }

    .metaLine{
      grid-column:1 / -1;
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
      min-height:24px;
      color:#b7c7e6;
      font-size:12px;
      font-weight:800;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:4px;
      padding:5px 10px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.06);
      color:#dbeafe;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{color:#bbf7d0}
    .pill.warn{color:#fde68a}
    .pill.err{color:#fecaca}

    .main{
      min-height:0;
      display:grid;
      grid-template-columns:1fr 330px;
      gap:0;
    }

    .boardWrap{
      min-width:0;
      min-height:0;
      overflow:auto;
      padding:14px;
      background:#08101d;
    }

    .side{
      min-height:0;
      overflow:auto;
      border-left:1px solid var(--line);
      background:linear-gradient(180deg,var(--panel),#09111f);
      padding:14px;
    }

    .card{
      border:1px solid var(--line);
      border-radius:18px;
      background:rgba(255,255,255,.045);
      box-shadow:0 10px 28px rgba(0,0,0,.18);
      padding:14px;
      margin-bottom:12px;
    }

    .cardTitle{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
      font-size:15px;
      font-weight:1000;
      letter-spacing:-.03em;
    }

    .smallText{
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      line-height:1.55;
    }

    .driverList{
      display:flex;
      flex-direction:column;
      gap:8px;
      max-height:360px;
      overflow:auto;
      padding-right:4px;
    }

    .driverItem{
      border:1px solid var(--line);
      border-radius:13px;
      padding:10px;
      background:rgba(255,255,255,.04);
    }

    .driverName{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      font-size:13px;
      font-weight:1000;
      color:#fff;
    }

    .driverName span{
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .driverMeta{
      margin-top:5px;
      color:#cbd5e1;
      font-size:11px;
      font-weight:800;
      line-height:1.45;
      word-break:break-word;
    }

    .scheduleBoard{
      min-width:980px;
      border:1px solid var(--line2);
      border-radius:18px;
      overflow:hidden;
      background:#0e1728;
      box-shadow:var(--shadow);
    }

    .boardHeader{
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:12px;
      padding:14px 16px;
      background:linear-gradient(180deg,#17233a,#111c30);
      border-bottom:1px solid var(--line);
    }

    .boardTitle{min-width:0}

    .boardTitle h2{
      margin:0;
      font-size:22px;
      line-height:1.15;
      letter-spacing:-.04em;
    }

    .boardTitle p{
      margin:6px 0 0;
      color:#bfdbfe;
      font-size:13px;
      font-weight:900;
    }

    .boardActions{
      display:flex;
      gap:8px;
      align-items:center;
      flex:0 0 auto;
    }

    table.scheduleTable{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      background:#0f1728;
    }

    .scheduleTable th,
    .scheduleTable td{
      border-right:1px solid rgba(255,255,255,.12);
      border-bottom:1px solid rgba(255,255,255,.12);
      text-align:center;
      vertical-align:middle;
    }

    .scheduleTable th:last-child,
    .scheduleTable td:last-child{border-right:none}

    .scheduleTable tr:last-child td{border-bottom:none}

    .scheduleTable th{
      height:42px;
      padding:7px 6px;
      background:var(--head);
      color:#fff;
      font-size:13px;
      font-weight:1000;
      line-height:1.15;
      white-space:nowrap;
    }

    .scheduleTable th.sun{color:#ff4444}

    .weekCell{
      width:110px;
      background:var(--week)!important;
      color:#111827!important;
      font-size:16px!important;
      font-weight:1000!important;
    }

    .campCell{
      width:110px;
      background:var(--camp)!important;
      color:#0f172a!important;
      font-size:17px!important;
      font-weight:1000!important;
    }

    .routeHead{width:150px}

    .routeCell{
      width:150px;
      padding:0;
      background:#d8ead2;
      color:#111827;
      font-weight:1000;
    }

    .routeInner{
      display:flex;
      align-items:center;
      gap:6px;
      min-height:42px;
      padding:6px 8px;
    }

    .expander{
      width:24px;
      height:24px;
      border-radius:8px;
      border:1px solid rgba(15,23,42,.25);
      background:rgba(255,255,255,.6);
      color:#111827;
      font-weight:1000;
      cursor:pointer;
      flex:0 0 auto;
    }

    .expander.empty{
      visibility:hidden;
      pointer-events:none;
    }

    .routeLabel{
      flex:1;
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      text-align:left;
      font-size:14px;
    }

    .childRoute .routeCell{background:#eef7e9}

    .childRoute .routeLabel{
      padding-left:18px;
      font-size:13px;
      color:#334155;
    }

    .childBadge{
      display:inline-flex;
      align-items:center;
      height:20px;
      padding:0 7px;
      border-radius:999px;
      background:#334155;
      color:white;
      font-size:11px;
      font-weight:900;
      margin-left:4px;
    }

    .cellEdit{
      min-width:0;
      width:100%;
      height:42px;
      border:0;
      border-radius:0;
      padding:5px 7px;
      background:var(--cell);
      color:#f8fafc;
      font-size:13px;
      font-weight:900;
      text-align:center;
      outline:none;
    }

    .cellEdit:focus{
      box-shadow:inset 0 0 0 3px rgba(96,165,250,.65);
      background:#0b1220!important;
      color:#fff!important;
    }

    .cellEdit.dirty{box-shadow:inset 0 -3px 0 rgba(245,158,11,.85)}
    .cellEdit.hasValue{color:#0f172a}

    .cellEdit::placeholder{
      color:rgba(148,163,184,.8);
      font-weight:800;
    }

    .emptyBoard{
      padding:48px 16px;
      text-align:center;
      color:#cbd5e1;
      font-weight:900;
      border:1px dashed var(--line2);
      border-radius:18px;
      background:rgba(255,255,255,.035);
    }

    .legendGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:8px;
    }

    .legendItem{
      display:flex;
      align-items:center;
      gap:8px;
      min-width:0;
      font-size:12px;
      font-weight:900;
      color:#dbeafe;
    }

    .legendColor{
      width:20px;
      height:20px;
      border-radius:6px;
      border:1px solid rgba(255,255,255,.25);
      flex:0 0 auto;
    }

    .captureArea{background:#0e1728}

    .captureArea.export{
      width:1280px!important;
      max-width:none!important;
      min-width:1280px!important;
      border-radius:0!important;
      box-shadow:none!important;
    }

    .captureHost{
      position:fixed;
      left:-200000px;
      top:0;
      width:auto;
      height:auto;
      overflow:visible;
      background:#0e1728;
      padding:24px;
      z-index:-1;
    }

    .warnLine{
      color:#fde68a;
      font-size:12px;
      font-weight:900;
      line-height:1.45;
    }

    .okLine{
      color:#bbf7d0;
      font-size:12px;
      font-weight:900;
      line-height:1.45;
    }

    @media(max-width:1080px){
      body{overflow:auto}

      .app{
        min-height:100dvh;
        height:auto;
        display:block;
      }

      .topbar{
        position:sticky;
        top:0;
        z-index:20;
      }

      .brandText h1{font-size:19px}
      .brandText p{display:none}
      .userBadge{display:none}

      .toolbar{
        position:sticky;
        top:57px;
        z-index:19;
        grid-template-columns:1fr 1fr;
        align-items:end;
      }

      .toolbar > .btn,
      .toolbar > .weekBtns{
        width:100%;
      }

      .toolbar .btn{width:100%}

      .weekBtns{
        display:grid;
        grid-template-columns:1fr 1fr;
      }

      .metaLine{grid-column:1 / -1}

      .main{display:block}

      .boardWrap{
        padding:10px;
        overflow:auto;
      }

      .side{
        border-left:none;
        border-top:1px solid var(--line);
      }

      .scheduleBoard{min-width:920px}

      .weekPopup{
        position:fixed;
        left:12px;
        right:12px;
        top:150px;
        width:auto;
      }
    }

    @media(max-width:560px){
      .topbar{padding:10px}

      .logoButton{
        width:32px;
        height:32px;
      }

      .logoButton img{
        width:24px;
        height:24px;
      }

      .brandText h1{font-size:18px}

      .btn{
        height:36px;
        padding:0 10px;
        font-size:12px;
      }

      .toolbar{
        top:49px;
        grid-template-columns:1fr;
        gap:8px;
        padding:10px;
      }

      .field label{font-size:11px}

      .input,
      .select,
      .weekButton{
        height:40px;
        font-size:13px;
      }

      .metaLine{font-size:11px}
      .boardWrap{padding:8px}

      .boardHeader{
        align-items:flex-start;
        flex-direction:column;
      }

      .boardActions{
        width:100%;
        display:grid;
        grid-template-columns:1fr 1fr;
      }

      .boardActions .btn{width:100%}
    }
  </style>
</head>

<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기">
          <img src="/favicon.ico" alt="Maroowell" />
        </a>
        <div class="brandText">
          <h1>마루웰 스케줄</h1>
          <p>캠프 / 주야 / 주차별 입차 스케줄 등록</p>
        </div>
      </div>

      <div class="topSpacer"></div>

      <div id="userBadge" class="userBadge">-</div>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <section class="toolbar">
      <div class="field">
        <label for="campInput">Camp</label>
        <input id="campInput" class="input" type="text" placeholder="예: M익산1, 일산2" autocomplete="off" />
      </div>

      <div class="field">
        <label for="waveSelect">주/야</label>
        <select id="waveSelect" class="select">
          <option value="WAVE2">주간</option>
          <option value="WAVE1">야간</option>
        </select>
      </div>

      <div class="field weekPickerWrap">
        <label>주차</label>
        <button id="weekButton" class="weekButton" type="button">
          <span id="weekButtonText">-</span>
          <span class="chev">▼</span>
        </button>

        <div id="weekPopup" class="weekPopup">
          <div class="weekPopupHeader">
            <div id="weekMonthTitle" class="weekMonthTitle">-</div>
            <div class="weekNav">
              <button id="btnPickerPrev" type="button">‹</button>
              <button id="btnPickerNext" type="button">›</button>
            </div>
          </div>

          <div id="weekGrid" class="weekGrid"></div>

          <div class="weekPopupFooter">
            <button id="btnPickerToday" type="button">오늘</button>
            <span>주 행을 클릭하면 일~토 주차가 선택됩니다.</span>
          </div>
        </div>
      </div>

      <div class="field">
        <label for="searchInput">검색</label>
        <input id="searchInput" class="input" type="text" placeholder="라우트 / 기사 / ID" autocomplete="off" />
      </div>

      <div class="weekBtns">
        <button id="btnPrevWeek" class="btn" type="button">이전주</button>
        <button id="btnNextWeek" class="btn" type="button">다음주</button>
      </div>

      <button id="btnLoad" class="btn primary" type="button">불러오기</button>
      <button id="btnSave" class="btn ok" type="button">전체 저장</button>
      <button id="btnCopyImage" class="btn warn" type="button">이미지 복사</button>
      <button id="btnReset" class="btn" type="button">초기화</button>

      <div class="metaLine">
        <span id="statePill" class="pill ok">READY</span>
        <span id="weekPill" class="pill">-</span>
        <span id="rowPill" class="pill">라우트 0</span>
        <span id="dirtyPill" class="pill">미저장 0</span>
        <span id="apiPill" class="pill ok">Worker API</span>
        <span id="statusText">캠프와 주/야를 선택하고 불러오기를 누르세요.</span>
      </div>
    </section>

    <main class="main">
      <section class="boardWrap">
        <div id="boardRoot" class="scheduleBoard captureArea">
          <div class="boardHeader">
            <div class="boardTitle">
              <h2 id="boardTitle">스케줄</h2>
              <p id="boardSubTitle">-</p>
            </div>

            <div class="boardActions">
              <button id="btnCollapseAll" class="btn" type="button">전체 접기</button>
              <button id="btnExpandAll" class="btn" type="button">전체 펼치기</button>
            </div>
          </div>

          <div id="tableHost">
            <div class="emptyBoard">
              캠프를 입력하고 불러오기를 누르면 라우트 스케줄 표가 표시됩니다.
            </div>
          </div>
        </div>
      </section>

      <aside class="side">
        <div class="card">
          <div class="cardTitle">
            <span>사용 방법</span>
          </div>
          <div class="smallText">
            기본은 서브 라우트 단위로 입력됩니다.<br />
            <b>▶</b> 버튼이 있는 라우트는 클릭하면 서서브가 펼쳐집니다.<br />
            셀에 기사명을 입력한 뒤 <b>전체 저장</b>을 누르면 저장됩니다.
          </div>
        </div>

        <div class="card">
          <div class="cardTitle">
            <span>계정 / 기사 참고</span>
            <span id="driverCountText" class="pill">0명</span>
          </div>
          <div id="driverList" class="driverList">
            <div class="smallText">기사 정보가 없습니다.</div>
          </div>
        </div>

        <div class="card">
          <div class="cardTitle">
            <span>색상 기준</span>
          </div>
          <div id="legendGrid" class="legendGrid"></div>
        </div>

        <div class="card">
          <div class="cardTitle">
            <span>상태</span>
          </div>
          <div id="detailStatus" class="smallText">대기중</div>
        </div>
      </aside>
    </main>
  </div>

  <datalist id="driverOptions"></datalist>

  <script>
    (async function(){
      "use strict";

      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY;
      const LOGIN_PATH = CONFIG.PATHS?.login || "/login.html";
      const SCHEDULE_API_BASE = String(
        CONFIG.SCHEDULE_API_BASE ||
        CONFIG.SCHEDULE_API_URL ||
        "https://schedule.maroowell.com"
      ).replace(/\/+$/,"");

      const DAYS = ["일","월","화","수","목","금","토"];
      const WAVE_LABEL = { WAVE1:"야간", WAVE2:"주간" };
      const WAVE_ALIASES = {
        WAVE1:["WAVE1","W1","야간","NIGHT","N"],
        WAVE2:["WAVE2","W2","주간","DAY","D"]
      };

      const els = {
        userBadge:document.getElementById("userBadge"),
        btnLogout:document.getElementById("btnLogout"),
        campInput:document.getElementById("campInput"),
        waveSelect:document.getElementById("waveSelect"),
        weekButton:document.getElementById("weekButton"),
        weekButtonText:document.getElementById("weekButtonText"),
        weekPopup:document.getElementById("weekPopup"),
        weekMonthTitle:document.getElementById("weekMonthTitle"),
        weekGrid:document.getElementById("weekGrid"),
        btnPickerPrev:document.getElementById("btnPickerPrev"),
        btnPickerNext:document.getElementById("btnPickerNext"),
        btnPickerToday:document.getElementById("btnPickerToday"),
        searchInput:document.getElementById("searchInput"),
        btnPrevWeek:document.getElementById("btnPrevWeek"),
        btnNextWeek:document.getElementById("btnNextWeek"),
        btnLoad:document.getElementById("btnLoad"),
        btnSave:document.getElementById("btnSave"),
        btnCopyImage:document.getElementById("btnCopyImage"),
        btnReset:document.getElementById("btnReset"),
        btnCollapseAll:document.getElementById("btnCollapseAll"),
        btnExpandAll:document.getElementById("btnExpandAll"),
        statePill:document.getElementById("statePill"),
        weekPill:document.getElementById("weekPill"),
        rowPill:document.getElementById("rowPill"),
        dirtyPill:document.getElementById("dirtyPill"),
        apiPill:document.getElementById("apiPill"),
        statusText:document.getElementById("statusText"),
        detailStatus:document.getElementById("detailStatus"),
        boardRoot:document.getElementById("boardRoot"),
        boardTitle:document.getElementById("boardTitle"),
        boardSubTitle:document.getElementById("boardSubTitle"),
        tableHost:document.getElementById("tableHost"),
        driverList:document.getElementById("driverList"),
        driverCountText:document.getElementById("driverCountText"),
        driverOptions:document.getElementById("driverOptions"),
        legendGrid:document.getElementById("legendGrid")
      };

      const state = {
        session:null,
        email:"",
        userId:"",
        accessToken:"",
        camp:"",
        wave:"WAVE2",
        baseDate:todayIso(),
        weekStart:"",
        weekEnd:"",
        weekDates:[],
        isoYear:0,
        isoWeek:0,
        weekLabel:"",
        pickerMonth:null,
        routesRaw:[],
        routeParents:[],
        displayRows:[],
        schedules:[],
        scheduleMap:new Map(),
        driversRaw:[],
        drivers:[],
        driverByName:new Map(),
        expanded:new Set(),
        dirty:new Map(),
        loading:false
      };

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth:{
              storage:window.sessionStorage,
              persistSession:true,
              autoRefreshToken:true,
              detectSessionInUrl:true
            }
          })
        : null;

      function clean(v){ return String(v ?? "").trim(); }
      function compact(v){ return clean(v).replace(/\s+/g,""); }

      function normalizeWave(v){
        const raw = compact(v).toUpperCase();
        if(raw === "야간" || raw === "NIGHT" || raw === "N" || raw === "W1" || raw === "WAVE1") return "WAVE1";
        if(raw === "주간" || raw === "DAY" || raw === "D" || raw === "W2" || raw === "WAVE2") return "WAVE2";
        return "WAVE2";
      }

      function waveLabel(v){
        return WAVE_LABEL[normalizeWave(v)] || v || "-";
      }

      function esc(v){
        return String(v ?? "")
          .replace(/&/g,"&amp;")
          .replace(/</g,"&lt;")
          .replace(/>/g,"&gt;")
          .replace(/"/g,"&quot;")
          .replace(/'/g,"&#39;");
      }

      function todayIso(){
        return toIso(new Date());
      }

      function toIso(d){
        if(!(d instanceof Date) || Number.isNaN(d.getTime())) return "";
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2,"0");
        const day = String(d.getDate()).padStart(2,"0");
        return `${y}-${m}-${day}`;
      }

      function parseIso(v){
        const m = clean(v).match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if(!m) return null;
        return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
      }

      function addDays(iso, days){
        const d = parseIso(iso) || new Date();
        d.setDate(d.getDate() + days);
        return toIso(d);
      }

      function sundayOf(iso){
        const d = parseIso(iso) || new Date();
        d.setDate(d.getDate() - d.getDay());
        return toIso(d);
      }

      function weekDatesFromStart(startIso){
        return Array.from({ length:7 }, (_,i) => addDays(startIso, i));
      }

      function isoWeekInfoFromMondayRef(startIso){
        const sunday = parseIso(startIso) || new Date();
        const ref = new Date(sunday);
        ref.setDate(ref.getDate() + 1);

        const target = new Date(Date.UTC(ref.getFullYear(), ref.getMonth(), ref.getDate()));
        const dayNum = target.getUTCDay() || 7;
        target.setUTCDate(target.getUTCDate() + 4 - dayNum);

        const isoYear = target.getUTCFullYear();
        const yearStart = new Date(Date.UTC(isoYear, 0, 1));
        const isoWeek = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);

        return {
          isoYear,
          isoWeek,
          weekLabel:`${isoYear} - ${isoWeek}W`
        };
      }

      function dateLabel(iso){
        const d = parseIso(iso);
        if(!d) return iso;
        return `${d.getMonth() + 1}/${d.getDate()} ${DAYS[d.getDay()]}`;
      }

      function mdLabel(iso){
        const d = parseIso(iso);
        if(!d) return iso;
        return `${d.getMonth() + 1}/${d.getDate()}`;
      }

      function weekRangeLabel(){
        if(!state.weekDates.length) return "-";
        return `${mdLabel(state.weekDates[0])} ~ ${mdLabel(state.weekDates[6])}`;
      }

      function normalizeRoutePart(v){
        return clean(v).replace(/[^0-9A-Za-z가-힣]/g,"").toUpperCase();
      }

      function normalizeRouteLabel(v){
        return normalizeRoutePart(v);
      }

      function routeBaseLabel(route, sub){
        return normalizeRoutePart(route) + normalizeRoutePart(sub);
      }

      function routeChildLabel(route, sub, subSub){
        return routeBaseLabel(route, sub) + normalizeRoutePart(subSub);
      }

      function sortText(a,b){
        return String(a || "").localeCompare(String(b || ""), "ko", { numeric:true, sensitivity:"base" });
      }

      function setState(kind, text){
        els.statePill.className = "pill " + (kind || "ok");
        els.statePill.textContent = text || "READY";
      }

      function setStatus(text){
        els.statusText.textContent = text || "";
      }

      function setDetail(text, good){
        els.detailStatus.className = good ? "okLine" : "smallText";
        els.detailStatus.textContent = text || "";
      }

      function updateWeekState(){
        state.weekStart = sundayOf(state.baseDate);
        state.weekDates = weekDatesFromStart(state.weekStart);
        state.weekEnd = state.weekDates[6];

        const w = isoWeekInfoFromMondayRef(state.weekStart);
        state.isoYear = w.isoYear;
        state.isoWeek = w.isoWeek;
        state.weekLabel = w.weekLabel;

        els.weekButtonText.textContent = weekRangeLabel();
        els.weekPill.textContent = `${weekRangeLabel()} / ${state.weekLabel}`;
      }

      function bgForName(name){
        const n = compact(name);
        if(!n) return "#111827";

        let hash = 0;
        for(let i = 0; i < n.length; i++){
          hash = (hash * 31 + n.charCodeAt(i)) >>> 0;
        }

        const colors = [
          "#bfdbfe",
          "#bbf7d0",
          "#fde68a",
          "#fecaca",
          "#ddd6fe",
          "#bae6fd",
          "#fbcfe8",
          "#fed7aa",
          "#ccfbf1",
          "#e9d5ff"
        ];

        return colors[hash % colors.length];
      }

      function textColorForBg(){
        return "#0f172a";
      }

      async function ensureAuth(){
        if(!supabase){
          document.documentElement.style.visibility = "visible";
          alert("Supabase 설정을 찾을 수 없습니다.");
          return false;
        }

        const { data } = await supabase.auth.getSession();
        state.session = data?.session || null;

        if(!state.session){
          location.href = LOGIN_PATH;
          return false;
        }

        state.email = state.session.user?.email || "";
        state.userId = state.session.user?.id || "";
        state.accessToken = state.session.access_token || "";

        els.userBadge.textContent = state.email || "로그인";

        return true;
      }

      async function apiFetch(path, options){
        const { data } = await supabase.auth.getSession();
        const token = data?.session?.access_token;

        if(!token){
          location.href = LOGIN_PATH;
          throw new Error("로그인 세션이 없습니다.");
        }

        const res = await fetch(SCHEDULE_API_BASE + path, {
          ...(options || {}),
          headers:{
            "Content-Type":"application/json",
            "Authorization":`Bearer ${token}`,
            ...(options?.headers || {})
          }
        });

        const text = await res.text();
        let json = null;

        try{
          json = text ? JSON.parse(text) : null;
        } catch {
          json = { ok:false, error:text };
        }

        if(!res.ok || json?.ok === false){
          const msg = json?.error || json?.message || `API 오류 ${res.status}`;
          const err = new Error(msg);
          err.status = res.status;
          err.detail = json?.detail || json;
          throw err;
        }

        return json;
      }

      async function checkAccess(){
        try{
          const me = await apiFetch("/me");
          if(me?.ok){
            return true;
          }
        } catch(e){
          console.error(e);
          document.documentElement.style.visibility = "visible";
          alert("스케줄 접근 권한이 없거나 Worker API 연결에 실패했습니다.\n" + (e?.message || e));
          location.href = "/";
          return false;
        }

        return false;
      }

      function campMatches(infoCamp, selectedCamp){
        const a = compact(infoCamp).toUpperCase();
        const b = compact(selectedCamp).toUpperCase();
        if(!a || !b) return false;
        return a === b || a.includes(b) || b.includes(a);
      }

      function waveMatches(infoWave, selectedWave){
        const raw = compact(infoWave).toUpperCase();
        if(!raw) return true;

        const selected = normalizeWave(selectedWave);
        const aliases = WAVE_ALIASES[selected] || [selected];

        return aliases.some(x => raw === compact(x).toUpperCase() || raw.includes(compact(x).toUpperCase()));
      }

      function parseSubAccounts(v){
        const raw = clean(v);
        if(!raw) return [];

        return raw
          .split(/[\n,;]+/)
          .map(s => clean(s))
          .filter(Boolean);
      }

      function buildDrivers(){
        const filtered = state.driversRaw
          .map(r => ({
            raw:r,
            name:clean(r.person_name || r.name),
            camp:clean(r.camp_code || r.camp),
            wave:clean(r.wave_raw || r.wave),
            coupangId:clean(r.coupang_id),
            subAccounts:Array.isArray(r.sub_accounts) ? r.sub_accounts : parseSubAccounts(r.sub_account_info),
            position:clean(r.position_title)
          }))
          .filter(d => d.name)
          .sort((a,b) => {
            const aw = waveMatches(a.wave, state.wave) ? 0 : 1;
            const bw = waveMatches(b.wave, state.wave) ? 0 : 1;
            if(aw !== bw) return aw - bw;
            return sortText(a.name, b.name);
          });

        state.drivers = filtered;
        state.driverByName.clear();

        for(const d of filtered){
          state.driverByName.set(compact(d.name), d);
        }
      }

      function renderDrivers(){
        els.driverCountText.textContent = `${state.drivers.length}명`;

        els.driverOptions.innerHTML = state.drivers.map(d => {
          const label = [d.name, d.coupangId, d.subAccounts.join(" ")].filter(Boolean).join(" / ");
          return `<option value="${esc(d.name)}" label="${esc(label)}"></option>`;
        }).join("");

        if(!state.drivers.length){
          els.driverList.innerHTML = `<div class="smallText">선택 캠프 기준 기사 정보가 없습니다.</div>`;
          return;
        }

        els.driverList.innerHTML = state.drivers.map(d => {
          const waveOk = waveMatches(d.wave, state.wave);
          const sub = d.subAccounts.length ? d.subAccounts.map(esc).join("<br>") : "-";
          return `
            <div class="driverItem">
              <div class="driverName">
                <span>${esc(d.name)}</span>
                <span class="pill ${waveOk ? "ok" : ""}">${esc(d.wave || "공통")}</span>
              </div>
              <div class="driverMeta">
                ID: ${esc(d.coupangId || "-")}<br>
                부계정: ${sub}<br>
                캠프: ${esc(d.camp || state.camp || "-")}
              </div>
            </div>
          `;
        }).join("");
      }

      function buildRoutes(){
        const rows = state.routesRaw
          .filter(r => r.is_active !== false)
          .filter(r => campMatches(r.camp, state.camp))
          .sort((a,b) => {
            const so = Number(a.sort_order || 0) - Number(b.sort_order || 0);
            if(so !== 0) return so;

            const aParent = clean(a.parent_route_label) || routeBaseLabel(a.route, a.sub);
            const bParent = clean(b.parent_route_label) || routeBaseLabel(b.route, b.sub);
            const parentCmp = sortText(aParent, bParent);
            if(parentCmp !== 0) return parentCmp;

            const aSub = clean(a.sub_sub);
            const bSub = clean(b.sub_sub);
            return sortText(aSub, bSub);
          });

        const parentMap = new Map();

        for(const r of rows){
          const parentLabel = normalizeRouteLabel(
            clean(r.parent_route_label) ||
            routeBaseLabel(r.route, r.sub) ||
            clean(r.route_label)
          );

          const childLabel = normalizeRouteLabel(
            clean(r.route_label) ||
            routeChildLabel(r.route, r.sub, r.sub_sub)
          );

          if(!parentLabel && !childLabel) continue;

          const key = parentLabel || childLabel;

          if(!parentMap.has(key)){
            parentMap.set(key, {
              key,
              route:String(r.route || ""),
              sub:String(r.sub || ""),
              label:key,
              description:clean(r.description),
              memo:clean(r.memo),
              subPackage:clean(r.sub_package),
              sortOrder:Number(r.sort_order || 0),
              children:[]
            });
          }

          const parent = parentMap.get(key);
          const subSub = clean(r.sub_sub);
          const isChild = subSub && childLabel && childLabel !== key;

          if(isChild){
            parent.children.push({
              key:childLabel,
              route:String(r.route || ""),
              sub:String(r.sub || ""),
              subSub,
              label:childLabel,
              description:clean(r.description),
              memo:clean(r.memo),
              subPackage:clean(r.sub_package),
              sortOrder:Number(r.sort_order || 0)
            });
          }
        }

        state.routeParents = Array.from(parentMap.values()).map(p => {
          const dedup = new Map();

          for(const c of p.children){
            if(!dedup.has(c.key)) dedup.set(c.key, c);
          }

          p.children = Array.from(dedup.values())
            .sort((a,b) => sortText(a.subSub, b.subSub) || sortText(a.label, b.label));

          return p;
        });

        buildDisplayRows();
      }

      function buildDisplayRows(){
        const q = compact(els.searchInput.value).toUpperCase();
        const out = [];

        for(const p of state.routeParents){
          const parentMatch = !q || compact(p.label + p.description + p.memo + p.subPackage).toUpperCase().includes(q);
          const childMatches = p.children.filter(c => {
            if(!q) return true;
            return compact(c.label + c.description + c.memo + c.subPackage).toUpperCase().includes(q);
          });

          if(parentMatch || childMatches.length){
            out.push({ type:"parent", ...p });

            if(state.expanded.has(p.key)){
              const childrenToShow = q ? childMatches : p.children;
              for(const c of childrenToShow){
                out.push({ type:"child", parentKey:p.key, ...c });
              }
            }
          }
        }

        state.displayRows = out;
      }

      function scheduleKey(date, routeLabel){
        return `${date}||${state.camp}||${state.wave}||${normalizeRouteLabel(routeLabel)}`;
      }

      function scheduleLookupKey(date, routeLabel){
        return `${date}||${state.wave}||${normalizeRouteLabel(routeLabel)}`;
      }

      function makeScheduleMap(){
        state.scheduleMap.clear();

        for(const r of state.schedules){
          const normalizedWave = normalizeWave(r.wave);
          const route = normalizeRouteLabel(r.route_label);
          const key = `${r.schedule_date}||${normalizedWave}||${route}`;
          state.scheduleMap.set(key, r);
        }
      }

      async function loadAll(){
        state.camp = clean(els.campInput.value);
        state.wave = normalizeWave(els.waveSelect.value);
        els.waveSelect.value = state.wave;
        updateWeekState();

        if(!state.camp){
          alert("Camp를 입력하세요.");
          return;
        }

        state.loading = true;
        setState("warn","LOAD");
        setStatus("스케줄 데이터를 불러오는 중입니다.");
        els.btnLoad.disabled = true;
        els.btnSave.disabled = true;

        try{
          const params = new URLSearchParams({
            camp:state.camp,
            wave:state.wave,
            week_start:state.weekStart
          });

          const json = await apiFetch("/schedule/week?" + params.toString());

          state.routesRaw = json.routes || [];
          state.schedules = (json.schedules || []).map(r => ({
            ...r,
            wave:normalizeWave(r.wave),
            route_label:normalizeRouteLabel(r.route_label)
          }));
          state.driversRaw = json.drivers || [];

          buildDrivers();
          makeScheduleMap();
          buildRoutes();
          render();

          setState("ok","READY");
          setStatus(`조회 완료: 라우트 ${state.routeParents.length}개 / 스케줄 ${state.schedules.length}개 / 기사 ${state.drivers.length}명`);
          setDetail(`Worker API 조회 완료 · ${waveLabel(state.wave)} · ${weekRangeLabel()}`, true);
        } catch(e){
          console.error(e);
          setState("err","ERROR");
          setStatus("불러오기 실패: " + (e?.message || e));
          alert("불러오기 실패: " + (e?.message || e));
        } finally {
          state.loading = false;
          els.btnLoad.disabled = false;
          els.btnSave.disabled = false;
        }
      }

      function render(){
        buildDisplayRows();
        renderHeader();
        renderTable();
        renderDrivers();
        renderLegend();
        updatePills();
      }

      function renderHeader(){
        els.boardTitle.textContent = `${state.camp || "-"} / ${waveLabel(state.wave)}`;
        els.boardSubTitle.textContent = `${weekRangeLabel()} · ${state.weekLabel} · DB: ${state.wave}`;
      }

      function renderLegend(){
        const names = Array.from(new Set(
          state.schedules
            .map(r => clean(r.driver_name))
            .filter(Boolean)
        )).slice(0, 20);

        if(!names.length){
          els.legendGrid.innerHTML = `<div class="smallText">등록된 기사명이 생기면 색상 기준이 표시됩니다.</div>`;
          return;
        }

        els.legendGrid.innerHTML = names.map(name => `
          <div class="legendItem">
            <span class="legendColor" style="background:${bgForName(name)}"></span>
            <span>${esc(name)}</span>
          </div>
        `).join("");
      }

      function valueForCell(date, routeLabel){
        const normalized = normalizeRouteLabel(routeLabel);
        const dirtyKey = scheduleKey(date, normalized);

        if(state.dirty.has(dirtyKey)){
          return state.dirty.get(dirtyKey).driver_name || "";
        }

        const found = state.scheduleMap.get(scheduleLookupKey(date, normalized));
        return clean(found?.driver_name);
      }

      function renderTable(){
        if(!state.routeParents.length){
          els.tableHost.innerHTML = `
            <div class="emptyBoard">
              조회된 라우트가 없습니다.<br>
              Camp명이 maroowell_route_info.camp 값과 같은지 확인하세요.
            </div>
          `;
          return;
        }

        const rows = state.displayRows;
        const weekRowSpan = Math.max(rows.length, 1);

        let html = `
          <table class="scheduleTable">
            <colgroup>
              <col style="width:110px">
              <col style="width:110px">
              <col style="width:150px">
              ${state.weekDates.map(() => `<col style="width:120px">`).join("")}
            </colgroup>
            <thead>
              <tr>
                <th>Week</th>
                <th>Camp</th>
                <th class="routeHead">Route</th>
                ${state.weekDates.map((d,i) => `
                  <th class="${i === 0 ? "sun" : ""}">${esc(dateLabel(d))}</th>
                `).join("")}
              </tr>
            </thead>
            <tbody>
        `;

        rows.forEach((row, rowIndex) => {
          const hasChildren = row.type === "parent" && row.children && row.children.length > 0;
          const isExpanded = state.expanded.has(row.key);
          const routeClass = row.type === "child" ? "childRoute" : "";

          html += `<tr class="${routeClass}">`;

          if(rowIndex === 0){
            html += `<td class="weekCell" rowspan="${weekRowSpan}">${esc(weekRangeLabel())}</td>`;
            html += `<td class="campCell" rowspan="${weekRowSpan}">${esc(state.camp)}</td>`;
          }

          html += `
            <td class="routeCell">
              <div class="routeInner">
                <button
                  class="expander ${hasChildren ? "" : "empty"}"
                  type="button"
                  data-expand="${esc(row.key)}"
                  title="서서브 펼치기/접기"
                >${isExpanded ? "▼" : "▶"}</button>
                <div class="routeLabel" title="${esc(row.description || row.memo || row.subPackage || "")}">
                  ${esc(row.label)}
                  ${row.type === "child" ? `<span class="childBadge">${esc(row.subSub)}</span>` : ""}
                </div>
              </div>
            </td>
          `;

          state.weekDates.forEach(date => {
            const val = valueForCell(date, row.label);
            const has = !!compact(val);
            const bg = has ? bgForName(val) : "";
            const color = has ? textColorForBg(bg) : "";
            const dirty = state.dirty.has(scheduleKey(date, row.label));

            html += `
              <td>
                <input
                  class="cellEdit ${has ? "hasValue" : ""} ${dirty ? "dirty" : ""}"
                  style="${has ? `background:${bg};color:${color};` : ""}"
                  list="driverOptions"
                  value="${esc(val)}"
                  placeholder="-"
                  data-date="${esc(date)}"
                  data-route="${esc(row.label)}"
                  data-row-order="${rowIndex}"
                  title="${esc(cellTitle(val))}"
                />
              </td>
            `;
          });

          html += `</tr>`;
        });

        html += `
            </tbody>
          </table>
        `;

        els.tableHost.innerHTML = html;

        els.tableHost.querySelectorAll("[data-expand]").forEach(btn => {
          btn.addEventListener("click", e => {
            const key = e.currentTarget.dataset.expand;
            if(!key) return;

            if(state.expanded.has(key)) state.expanded.delete(key);
            else state.expanded.add(key);

            render();
          });
        });

        els.tableHost.querySelectorAll(".cellEdit").forEach(input => {
          input.addEventListener("input", onCellInput);
          input.addEventListener("change", onCellInput);
          input.addEventListener("focus", e => e.currentTarget.select());
        });
      }

      function cellTitle(name){
        const d = state.driverByName.get(compact(name));
        if(!d) return name || "";

        return [
          d.name,
          d.coupangId ? "ID: " + d.coupangId : "",
          d.subAccounts.length ? "부계정: " + d.subAccounts.join(" / ") : "",
          d.wave ? "wave: " + d.wave : ""
        ].filter(Boolean).join("\n");
      }

      function onCellInput(e){
        const input = e.currentTarget;
        const date = input.dataset.date;
        const routeLabel = normalizeRouteLabel(input.dataset.route);
        const rowOrder = Number(input.dataset.rowOrder || 0);
        const value = clean(input.value);
        const key = scheduleKey(date, routeLabel);

        state.dirty.set(key, {
          schedule_date:date,
          camp:state.camp,
          wave:state.wave,
          route_label:routeLabel,
          driver_name:value || null,
          memo:null,
          row_order:rowOrder,
          cell_color:value ? bgForName(value) : null,
          is_active:!!value
        });

        if(value){
          const bg = bgForName(value);
          input.classList.add("hasValue");
          input.style.background = bg;
          input.style.color = textColorForBg(bg);
          input.title = cellTitle(value);
        } else {
          input.classList.remove("hasValue");
          input.style.background = "";
          input.style.color = "";
          input.title = "";
        }

        input.classList.add("dirty");
        updatePills();
      }

      function updatePills(){
        els.rowPill.textContent = `라우트 ${state.displayRows.length}`;
        els.dirtyPill.textContent = `미저장 ${state.dirty.size}`;
      }

      async function saveAll(){
        if(!state.camp || !state.weekDates.length){
          alert("먼저 불러오기를 해주세요.");
          return;
        }

        if(state.dirty.size === 0){
          alert("저장할 변경사항이 없습니다.");
          return;
        }

        const records = Array.from(state.dirty.values()).map(item => ({
          schedule_date:item.schedule_date,
          route_label:normalizeRouteLabel(item.route_label),
          driver_name:item.driver_name,
          memo:item.memo,
          row_order:item.row_order,
          cell_color:item.cell_color,
          is_active:item.is_active
        }));

        setState("warn","SAVE");
        setStatus(`저장 중: ${records.length}건`);
        els.btnSave.disabled = true;

        try{
          const json = await apiFetch("/schedule/save", {
            method:"POST",
            body:JSON.stringify({
              camp:state.camp,
              wave:state.wave,
              week_start:state.weekStart,
              records
            })
          });

          state.dirty.clear();
          await loadAll();

          setState("ok","READY");
          setStatus(`저장 완료: ${json.saved || records.length}건`);
          setDetail("저장 완료", true);
        } catch(e){
          console.error(e);
          setState("err","ERROR");
          setStatus("저장 실패: " + (e?.message || e));
          alert("저장 실패: " + (e?.message || e));
        } finally {
          els.btnSave.disabled = false;
        }
      }

      async function copyImage(){
        if(!window.htmlToImage){
          alert("이미지 변환 라이브러리를 불러오지 못했습니다.");
          return;
        }

        const clone = els.boardRoot.cloneNode(true);
        clone.classList.add("export");

        clone.querySelectorAll("input.cellEdit").forEach(input => {
          const div = document.createElement("div");
          div.textContent = input.value || "-";
          div.style.cssText = input.getAttribute("style") || "";
          div.style.minHeight = "42px";
          div.style.display = "flex";
          div.style.alignItems = "center";
          div.style.justifyContent = "center";
          div.style.fontSize = "13px";
          div.style.fontWeight = "900";
          div.style.padding = "5px 7px";
          div.style.background = input.value ? (input.style.background || bgForName(input.value)) : "#111827";
          div.style.color = input.value ? "#0f172a" : "#94a3b8";
          input.replaceWith(div);
        });

        clone.querySelectorAll("button").forEach(btn => {
          if(btn.classList.contains("expander")){
            const span = document.createElement("span");
            span.textContent = btn.textContent || "";
            span.style.display = "inline-flex";
            span.style.alignItems = "center";
            span.style.justifyContent = "center";
            span.style.width = "24px";
            span.style.height = "24px";
            span.style.borderRadius = "8px";
            span.style.background = "rgba(255,255,255,.65)";
            span.style.color = "#111827";
            span.style.fontWeight = "1000";
            btn.replaceWith(span);
          } else {
            btn.remove();
          }
        });

        const host = document.createElement("div");
        host.className = "captureHost";
        host.appendChild(clone);
        document.body.appendChild(host);

        setState("warn","IMAGE");
        setStatus("이미지 생성 중입니다.");
        els.btnCopyImage.disabled = true;

        try{
          const blob = await window.htmlToImage.toBlob(clone, {
            cacheBust:true,
            pixelRatio:2,
            backgroundColor:"#0e1728",
            width:clone.scrollWidth,
            height:clone.scrollHeight,
            style:{
              transform:"none",
              transformOrigin:"top left"
            }
          });

          if(!blob) throw new Error("이미지 blob 생성 실패");

          if(navigator.clipboard && window.ClipboardItem){
            await navigator.clipboard.write([
              new ClipboardItem({ "image/png":blob })
            ]);
            setStatus("이미지 복사 완료");
          } else {
            const url = URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = url;
            a.download = `마루웰_스케줄_${state.camp}_${waveLabel(state.wave)}_${weekRangeLabel()}.png`.replace(/[\\/:*?"<>|]/g,"_");
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
            setStatus("클립보드 복사가 지원되지 않아 PNG로 다운로드했습니다.");
          }

          setState("ok","READY");
        } catch(e){
          console.error(e);
          setState("err","ERROR");
          alert("이미지 복사 실패: " + (e?.message || e));
        } finally {
          host.remove();
          els.btnCopyImage.disabled = false;
        }
      }

      function resetFilters(){
        els.campInput.value = "";
        els.searchInput.value = "";
        state.camp = "";
        state.routesRaw = [];
        state.routeParents = [];
        state.displayRows = [];
        state.schedules = [];
        state.scheduleMap.clear();
        state.dirty.clear();
        renderHeader();
        els.tableHost.innerHTML = `
          <div class="emptyBoard">
            캠프를 입력하고 불러오기를 누르면 라우트 스케줄 표가 표시됩니다.
          </div>
        `;
        updatePills();
        setStatus("초기화 완료");
      }

      function openWeekPicker(){
        state.pickerMonth = state.pickerMonth || firstOfMonth(parseIso(state.weekStart) || new Date());
        renderWeekPicker();
        els.weekPopup.classList.add("open");
      }

      function closeWeekPicker(){
        els.weekPopup.classList.remove("open");
      }

      function firstOfMonth(d){
        return new Date(d.getFullYear(), d.getMonth(), 1);
      }

      function addMonths(d, months){
        return new Date(d.getFullYear(), d.getMonth() + months, 1);
      }

      function sameIso(a,b){
        return clean(a) === clean(b);
      }

      function renderWeekPicker(){
        const month = state.pickerMonth || firstOfMonth(new Date());
        const y = month.getFullYear();
        const m = month.getMonth();

        els.weekMonthTitle.textContent = `${y}년 ${m + 1}월`;

        const first = new Date(y, m, 1);
        const gridStart = new Date(first);
        gridStart.setDate(first.getDate() - first.getDay());

        const selectedStart = state.weekStart;
        const today = todayIso();

        let html = "";

        DAYS.forEach(d => {
          html += `<div class="weekDow">${esc(d)}</div>`;
        });

        for(let r = 0; r < 6; r++){
          const rowStart = new Date(gridStart);
          rowStart.setDate(gridStart.getDate() + r * 7);
          const rowStartIso = toIso(rowStart);
          const rowEndIso = addDays(rowStartIso, 6);
          const isSelectedRow = sameIso(rowStartIso, selectedStart);

          for(let c = 0; c < 7; c++){
            const d = new Date(rowStart);
            d.setDate(rowStart.getDate() + c);
            const iso = toIso(d);
            const other = d.getMonth() !== m;
            const selected = isSelectedRow;
            const isToday = iso === today;

            html += `
              <button
                type="button"
                class="weekDay ${other ? "other" : ""} ${isToday ? "today" : ""} ${selected ? "selected weekRowHighlight" : ""}"
                data-week-start="${esc(rowStartIso)}"
                data-week-end="${esc(rowEndIso)}"
                title="${esc(mdLabel(rowStartIso) + " ~ " + mdLabel(rowEndIso))}"
              >${d.getDate()}</button>
            `;
          }
        }

        els.weekGrid.innerHTML = html;

        els.weekGrid.querySelectorAll(".weekDay").forEach(btn => {
          btn.addEventListener("mouseenter", () => {
            const ws = btn.dataset.weekStart;
            els.weekGrid.querySelectorAll(`[data-week-start="${CSS.escape(ws)}"]`).forEach(x => x.classList.add("weekRowHighlight"));
          });

          btn.addEventListener("mouseleave", () => {
            els.weekGrid.querySelectorAll(".weekDay").forEach(x => {
              if(!x.classList.contains("selected")) x.classList.remove("weekRowHighlight");
            });
          });

          btn.addEventListener("click", () => {
            const ws = btn.dataset.weekStart;
            state.baseDate = ws;
            state.weekStart = ws;
            state.weekDates = weekDatesFromStart(ws);
            state.weekEnd = state.weekDates[6];

            const w = isoWeekInfoFromMondayRef(ws);
            state.isoYear = w.isoYear;
            state.isoWeek = w.isoWeek;
            state.weekLabel = w.weekLabel;

            state.dirty.clear();
            closeWeekPicker();

            els.weekButtonText.textContent = weekRangeLabel();
            els.weekPill.textContent = `${weekRangeLabel()} / ${state.weekLabel}`;
            renderHeader();
            updatePills();

            if(state.camp){
              loadAll();
            }
          });
        });
      }

      function bind(){
        els.waveSelect.value = state.wave;

        els.btnLogout.addEventListener("click", async () => {
          try{ await supabase.auth.signOut(); } catch {}
          location.href = LOGIN_PATH;
        });

        els.btnLoad.addEventListener("click", loadAll);
        els.btnSave.addEventListener("click", saveAll);
        els.btnCopyImage.addEventListener("click", copyImage);
        els.btnReset.addEventListener("click", resetFilters);

        els.btnPrevWeek.addEventListener("click", () => {
          state.baseDate = addDays(state.weekStart || state.baseDate, -7);
          state.dirty.clear();
          updateWeekState();
          state.pickerMonth = firstOfMonth(parseIso(state.weekStart) || new Date());
          renderHeader();
          renderWeekPicker();
          if(state.camp) loadAll();
        });

        els.btnNextWeek.addEventListener("click", () => {
          state.baseDate = addDays(state.weekStart || state.baseDate, 7);
          state.dirty.clear();
          updateWeekState();
          state.pickerMonth = firstOfMonth(parseIso(state.weekStart) || new Date());
          renderHeader();
          renderWeekPicker();
          if(state.camp) loadAll();
        });

        els.weekButton.addEventListener("click", e => {
          e.stopPropagation();
          if(els.weekPopup.classList.contains("open")) closeWeekPicker();
          else openWeekPicker();
        });

        els.btnPickerPrev.addEventListener("click", e => {
          e.stopPropagation();
          state.pickerMonth = addMonths(state.pickerMonth || new Date(), -1);
          renderWeekPicker();
        });

        els.btnPickerNext.addEventListener("click", e => {
          e.stopPropagation();
          state.pickerMonth = addMonths(state.pickerMonth || new Date(), 1);
          renderWeekPicker();
        });

        els.btnPickerToday.addEventListener("click", e => {
          e.stopPropagation();
          state.baseDate = todayIso();
          updateWeekState();
          state.pickerMonth = firstOfMonth(parseIso(state.weekStart) || new Date());
          renderWeekPicker();
          renderHeader();
          if(state.camp) loadAll();
        });

        document.addEventListener("click", e => {
          if(!e.target.closest(".weekPickerWrap")){
            closeWeekPicker();
          }
        });

        document.addEventListener("keydown", e => {
          if(e.key === "Escape") closeWeekPicker();
        });

        els.waveSelect.addEventListener("change", () => {
          state.wave = normalizeWave(els.waveSelect.value);
          els.waveSelect.value = state.wave;
          state.dirty.clear();
          if(state.camp) loadAll();
          else renderHeader();
        });

        els.campInput.addEventListener("keydown", e => {
          if(e.key === "Enter") loadAll();
        });

        els.searchInput.addEventListener("input", () => {
          render();
        });

        els.btnCollapseAll.addEventListener("click", () => {
          state.expanded.clear();
          render();
        });

        els.btnExpandAll.addEventListener("click", () => {
          state.routeParents.forEach(p => {
            if(p.children && p.children.length) state.expanded.add(p.key);
          });
          render();
        });

        window.addEventListener("beforeunload", e => {
          if(state.dirty.size > 0){
            e.preventDefault();
            e.returnValue = "";
          }
        });
      }

      async function boot(){
        bind();
        updateWeekState();
        state.pickerMonth = firstOfMonth(parseIso(state.weekStart) || new Date());
        renderWeekPicker();
        renderHeader();
        updatePills();

        const authed = await ensureAuth();
        if(!authed) return;

        const ok = await checkAccess();
        if(!ok) return;

        document.documentElement.style.visibility = "visible";
        setState("ok","READY");
        els.apiPill.textContent = "Worker API";
        setStatus("캠프와 주/야를 선택하고 불러오기를 누르세요.");
      }

      boot().catch(e => {
        console.error(e);
        document.documentElement.style.visibility = "visible";
        setState("err","ERROR");
        setStatus(e?.message || String(e));
      });
    })();
  </script>
</body>
</html>
