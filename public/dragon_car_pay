<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>용차 정산서</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0f1a2d;
      --panel2:#0c1524;
      --line:rgba(255,255,255,.08);
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;
      --ok:#1a5a3a;
      --warn:#6a4b13;
      --danger:#6b1b1b;

      --paper:#ffffff;
      --paperLine:#d7deea;
      --paperHead:#eef3f8;
      --paperTxt:#0f172a;
      --paperMuted:#64748b;

      --headerH:56px;
      --toolbarH:58px;
      --statusH:44px;
    }

    * { box-sizing:border-box; }

    html, body{
      margin:0;
      height:100%;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }

    body{ overflow:hidden; }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--headerH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }

    .spacer{ flex:1; }

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }

    .btn:hover{ background:var(--btn2); }
    .btn.ok{ background:rgba(26,90,58,.35); border-color:rgba(0,255,140,.18); }
    .btn.warn{ background:rgba(106,75,19,.35); border-color:rgba(255,180,0,.18); }
    .btn.danger{ background:rgba(107,27,27,.35); border-color:rgba(255,60,60,.22); color:#ffccd3; }
    .btn:disabled{ opacity:.55; cursor:not-allowed; }

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:var(--panel2);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .toolGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolGroup label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .toolbar input{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbar input:focus{
      border-color:rgba(96,165,250,.55);
    }

    .modeTabs{
      display:flex;
      gap:8px;
    }

    .modeBtn{
      height:38px;
      min-width:92px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.04);
      color:#dce8ff;
      font-weight:900;
      cursor:pointer;
    }

    .modeBtn.active{
      background:rgba(59,130,246,.18);
      border-color:rgba(96,165,250,.5);
      color:#fff;
    }

    .main{
      min-height:0;
      display:grid;
      grid-template-columns:320px 1fr;
    }

    .sidebar{
      min-height:0;
      border-right:1px solid var(--line);
      background:linear-gradient(180deg,var(--panel),#0b1321);
      display:flex;
      flex-direction:column;
    }

    .sideSection{
      padding:12px;
      border-bottom:1px solid var(--line);
    }

    .sideTitle{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:10px;
    }

    .summaryGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .summaryCard{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:14px;
      padding:12px;
    }

    .summaryLabel{
      font-size:11px;
      color:var(--muted);
      font-weight:900;
      margin-bottom:4px;
    }

    .summaryValue{
      font-size:20px;
      line-height:1.05;
      font-weight:900;
      color:#fff;
    }

    .summaryValue.blue{ color:#bfdbfe; }
    .summaryValue.red{ color:#fecaca; }
    .summaryValue.green{ color:#bbf7d0; }

    .groupList{
      min-height:0;
      overflow:auto;
      padding:10px;
    }

    .groupItem{
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      border-radius:16px;
      padding:12px;
      margin-bottom:10px;
      cursor:pointer;
      transition:.14s ease;
    }

    .groupItem:hover{
      border-color:rgba(255,255,255,.18);
      background:rgba(255,255,255,.07);
    }

    .groupItem.active{
      border-color:rgba(96,165,250,.55);
      background:rgba(59,130,246,.12);
      box-shadow:inset 0 0 0 1px rgba(96,165,250,.22);
    }

    .groupName{
      font-weight:900;
      color:#fff;
      line-height:1.3;
      margin-bottom:8px;
      word-break:break-word;
      white-space:pre-line;
    }

    .groupMeta{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:6px 10px;
      font-size:12px;
      color:#d3def5;
    }

    .groupMeta b{
      color:#fff;
      font-weight:900;
    }

    .content{
      min-width:0;
      min-height:0;
      overflow:auto;
      background:#0d1523;
      padding:18px;
    }

    .statementPage{
      width:min(1100px, 100%);
      margin:0 auto;
      background:var(--paper);
      color:var(--paperTxt);
      border-radius:20px;
      box-shadow:0 20px 60px rgba(0,0,0,.26);
      overflow:hidden;
    }

    .statementTop{
      padding:22px 26px 14px;
      border-bottom:1px solid var(--paperLine);
      background:linear-gradient(180deg,#ffffff,#f8fbff);
    }

    .statementTitle{
      font-size:30px;
      line-height:1.1;
      font-weight:900;
      letter-spacing:-.02em;
      margin-bottom:14px;
    }

    .infoGrid{
      display:grid;
      grid-template-columns:repeat(4, minmax(120px,1fr));
      gap:10px;
    }

    .infoBox{
      border:1px solid var(--paperLine);
      border-radius:14px;
      padding:12px 14px;
      background:#fff;
    }

    .infoLabel{
      font-size:11px;
      color:var(--paperMuted);
      font-weight:900;
      margin-bottom:5px;
    }

    .infoValue{
      font-size:18px;
      line-height:1.1;
      font-weight:900;
      color:var(--paperTxt);
      word-break:break-word;
      white-space:pre-line;
    }

    .statementBody{
      padding:18px 26px 26px;
      display:grid;
      gap:16px;
    }

    .summaryRow{
      display:grid;
      grid-template-columns:repeat(6, minmax(120px,1fr));
      gap:10px;
    }

    .sumCard{
      border:1px solid var(--paperLine);
      border-radius:14px;
      padding:12px 14px;
      background:#fbfdff;
    }

    .sumLabel{
      font-size:11px;
      color:var(--paperMuted);
      font-weight:900;
      margin-bottom:5px;
    }

    .sumValue{
      font-size:20px;
      line-height:1.05;
      font-weight:900;
      color:var(--paperTxt);
      font-variant-numeric:tabular-nums;
    }

    .sumValue.blue{ color:#1d4ed8; }
    .sumValue.red{ color:#b91c1c; }
    .sumValue.green{ color:#166534; }

    .blockTitle{
      font-size:14px;
      font-weight:900;
      color:#0f172a;
      margin-bottom:8px;
    }

    .paperTableWrap{
      overflow:auto;
      border:1px solid var(--paperLine);
      border-radius:16px;
    }

    table.paperTable{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      min-width:1050px;
    }

    .paperTable th,
    .paperTable td{
      border-right:1px solid var(--paperLine);
      border-bottom:1px solid var(--paperLine);
    }

    .paperTable th:first-child,
    .paperTable td:first-child{
      border-left:none;
    }

    .paperTable th{
      background:var(--paperHead);
      padding:10px 8px;
      text-align:center;
      font-size:12px;
      font-weight:900;
      color:#0f172a;
      white-space:nowrap;
    }

    .paperTable td{
      background:#fff;
      padding:10px 8px;
      font-size:12px;
      color:#0f172a;
      line-height:1.4;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .paperTable tbody tr:nth-child(even) td{
      background:#fbfdff;
    }

    .paperTable td.center{ text-align:center; }
    .paperTable td.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .noteBox{
      border:1px solid var(--paperLine);
      border-radius:14px;
      padding:14px;
      background:#fbfdff;
      min-height:80px;
      line-height:1.6;
      font-size:13px;
      color:#334155;
      white-space:pre-line;
    }

    .emptyState{
      width:min(1100px, 100%);
      margin:0 auto;
      padding:28px;
      border:1px dashed rgba(255,255,255,.14);
      border-radius:20px;
      text-align:center;
      color:#c1d0ea;
      background:rgba(255,255,255,.03);
      font-weight:900;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{ color:#bbf7d0; }
    .pill.warn{ color:#fde68a; }
    .pill.err{ color:#fecaca; }

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{ display:flex; }

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width:1280px){
      .summaryRow,
      .infoGrid{
        grid-template-columns:repeat(2, minmax(120px,1fr));
      }
    }

    @media (max-width:900px){
      .main{ grid-template-columns:1fr; }
      .sidebar{ max-height:300px; }
      .btn{ padding:0 10px; font-size:12px; }
      .toolbar{ padding:8px; gap:8px; }
      .summaryRow,
      .infoGrid{
        grid-template-columns:1fr;
      }
      .statementTop,
      .statementBody{
        padding-left:16px;
        padding-right:16px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>용차 정산서</b>
        <small>월별 업체 / 기사 정산서 생성기</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnDownloadPng" class="btn ok" type="button">PNG 저장</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="toolGroup">
        <label for="monthInput">정산월</label>
        <input id="monthInput" type="text" placeholder="예: 2026-04 / 26년 4월" />
      </div>

      <div class="toolGroup">
        <label>정산서 종류</label>
        <div class="modeTabs">
          <button id="btnModeVendor" class="modeBtn active" type="button">업체 정산서</button>
          <button id="btnModeDriver" class="modeBtn" type="button">기사 정산서</button>
        </div>
      </div>

      <div class="toolGroup">
        <label for="searchInput">검색</label>
        <input id="searchInput" type="text" placeholder="업체 / Order / 기사 / 캠프 / 라우트" />
      </div>

      <div class="toolGroup">
        <button id="btnClearSearch" class="btn" type="button">검색 초기화</button>
      </div>
    </div>

    <div class="main">
      <aside class="sidebar">
        <div class="sideSection">
          <div class="sideTitle">현재 조회</div>
          <div class="summaryGrid">
            <div class="summaryCard">
              <div class="summaryLabel">정산월</div>
              <div id="sideMonth" class="summaryValue">-</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">정산서 수</div>
              <div id="sideGroupCount" class="summaryValue blue">0</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">월 총금액</div>
              <div id="sideAmount" class="summaryValue">₩0</div>
            </div>
            <div class="summaryCard">
              <div class="summaryLabel">미입금</div>
              <div id="sideUnpaid" class="summaryValue red">₩0</div>
            </div>
          </div>
        </div>

        <div class="sideSection">
          <div class="sideTitle">정산서 목록</div>
        </div>

        <div id="groupList" class="groupList"></div>
      </aside>

      <main class="content">
        <div id="statementCapture" class="statementPage" style="display:none">
          <div class="statementTop">
            <div id="statementTitle" class="statementTitle">용차 정산서</div>

            <div class="infoGrid">
              <div class="infoBox">
                <div class="infoLabel">정산월</div>
                <div id="infoMonth" class="infoValue">-</div>
              </div>
              <div class="infoBox">
                <div class="infoLabel">구분</div>
                <div id="infoMode" class="infoValue">-</div>
              </div>
              <div class="infoBox">
                <div class="infoLabel">업체</div>
                <div id="infoVendor" class="infoValue">-</div>
              </div>
              <div class="infoBox">
                <div class="infoLabel">Order / 기사</div>
                <div id="infoTarget" class="infoValue">-</div>
              </div>
            </div>
          </div>

          <div class="statementBody">
            <div class="summaryRow">
              <div class="sumCard">
                <div class="sumLabel">총금액</div>
                <div id="sumAmount" class="sumValue">₩0</div>
              </div>
              <div class="sumCard">
                <div class="sumLabel">입금금액</div>
                <div id="sumPaid" class="sumValue blue">₩0</div>
              </div>
              <div class="sumCard">
                <div class="sumLabel">미입금금액</div>
                <div id="sumUnpaid" class="sumValue red">₩0</div>
              </div>
              <div class="sumCard">
                <div class="sumLabel">배송 수량</div>
                <div id="sumParcel" class="sumValue">0</div>
              </div>
              <div class="sumCard">
                <div class="sumLabel">반품 수량</div>
                <div id="sumReturn" class="sumValue">0</div>
              </div>
              <div class="sumCard">
                <div class="sumLabel">행 수</div>
                <div id="sumRows" class="sumValue green">0</div>
              </div>
            </div>

            <div>
              <div class="blockTitle">정산 상세</div>
              <div class="paperTableWrap">
                <table class="paperTable">
                  <colgroup>
                    <col style="width:110px" />
                    <col style="width:160px" />
                    <col style="width:130px" />
                    <col style="width:90px" />
                    <col style="width:170px" />
                    <col style="width:90px" />
                    <col style="width:90px" />
                    <col style="width:90px" />
                    <col style="width:120px" />
                    <col style="width:120px" />
                    <col style="width:110px" />
                    <col style="width:170px" />
                  </colgroup>
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>연결 벤더</th>
                      <th>Order</th>
                      <th>캠프</th>
                      <th>라우트</th>
                      <th>주/야</th>
                      <th>배송</th>
                      <th>반품</th>
                      <th>단가</th>
                      <th>금액</th>
                      <th>입금여부</th>
                      <th>비고</th>
                    </tr>
                  </thead>
                  <tbody id="statementTableBody"></tbody>
                </table>
              </div>
            </div>

            <div>
              <div class="blockTitle">메모</div>
              <div id="statementNotes" class="noteBox">-</div>
            </div>
          </div>
        </div>

        <div id="emptyState" class="emptyState">
          월을 선택하고, 좌측에서 업체 또는 기사를 선택하면 정산서가 생성됩니다.
        </div>
      </main>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillGroups" class="pill">정산서 0</span>
      <span id="statusText" class="statusText">업체는 vendor_id + order_name 기준, 기사는 delivery_driver 기준입니다.</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 최고관리자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INDEX_PATH = PATHS?.index || "/index.html";

      const ACCESS_TABLE = "user_access";
      const DATA_TABLE = "dragon_car";

      const $ = (sel) => document.querySelector(sel);

      const dom = {
        monthInput: $("#monthInput"),
        searchInput: $("#searchInput"),

        btnReload: $("#btnReload"),
        btnDownloadPng: $("#btnDownloadPng"),
        btnLogout: $("#btnLogout"),
        btnClearSearch: $("#btnClearSearch"),
        btnModeVendor: $("#btnModeVendor"),
        btnModeDriver: $("#btnModeDriver"),

        sideMonth: $("#sideMonth"),
        sideGroupCount: $("#sideGroupCount"),
        sideAmount: $("#sideAmount"),
        sideUnpaid: $("#sideUnpaid"),
        groupList: $("#groupList"),

        statementCapture: $("#statementCapture"),
        emptyState: $("#emptyState"),
        statementTitle: $("#statementTitle"),
        infoMonth: $("#infoMonth"),
        infoMode: $("#infoMode"),
        infoVendor: $("#infoVendor"),
        infoTarget: $("#infoTarget"),
        sumAmount: $("#sumAmount"),
        sumPaid: $("#sumPaid"),
        sumUnpaid: $("#sumUnpaid"),
        sumParcel: $("#sumParcel"),
        sumReturn: $("#sumReturn"),
        sumRows: $("#sumRows"),
        statementTableBody: $("#statementTableBody"),
        statementNotes: $("#statementNotes"),

        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillGroups: $("#pillGroups"),
        statusText: $("#statusText"),

        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout")
      };

      const state = {
        session: null,
        viewerEmail: "",
        viewerUserId: "",
        month: defaultMonth(),
        mode: "vendor",
        allRows: [],
        monthRows: [],
        groups: [],
        selectedGroupKey: ""
      };

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function defaultMonth() {
        const now = new Date();
        return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}`;
      }

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function toNumber(v) {
        if (v == null || v === "") return 0;
        const n = Number(String(v).replace(/[^\d.-]/g, ""));
        return Number.isFinite(n) ? n : 0;
      }

      function formatNumber(v) {
        return new Intl.NumberFormat("ko-KR").format(toNumber(v));
      }

      function formatCurrency(v) {
        return "₩" + formatNumber(v);
      }

      function formatDate(v) {
        const s = normalizeText(v);
        if (!s) return "";
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;

        const m1 = s.match(/^(\d{4})[./-](\d{1,2})[./-](\d{1,2})$/);
        if (m1) {
          return `${m1[1]}-${String(Number(m1[2])).padStart(2, "0")}-${String(Number(m1[3])).padStart(2, "0")}`;
        }

        const m2 = s.match(/^(\d{2})[./-](\d{1,2})[./-](\d{1,2})$/);
        if (m2) {
          const year = toFullYear(m2[1]);
          return `${year}-${String(Number(m2[2])).padStart(2, "0")}-${String(Number(m2[3])).padStart(2, "0")}`;
        }

        const d = new Date(s);
        if (!Number.isNaN(d.getTime())) {
          const yy = d.getFullYear();
          const mm = String(d.getMonth() + 1).padStart(2, "0");
          const dd = String(d.getDate()).padStart(2, "0");
          return `${yy}-${mm}-${dd}`;
        }

        return s;
      }

      function toFullYear(yearText) {
        const s = normalizeText(yearText);
        if (!s) return "";
        if (s.length === 4) return s;
        if (s.length === 2) return String(2000 + Number(s));
        return s;
      }

      function normalizeMonth(v) {
        const s = normalizeText(v);
        if (!s) return "";

        const cleaned = s.replaceAll(".", "-").replaceAll("/", "-");
        let m = cleaned.match(/^(\d{4})-(\d{1,2})$/);
        if (m) return `${m[1]}-${String(Number(m[2])).padStart(2, "0")}`;

        m = cleaned.match(/^(\d{2})-(\d{1,2})$/);
        if (m) return `${toFullYear(m[1])}-${String(Number(m[2])).padStart(2, "0")}`;

        m = s.match(/^(\d{4})\s*년\s*(\d{1,2})\s*월$/);
        if (m) return `${m[1]}-${String(Number(m[2])).padStart(2, "0")}`;

        m = s.match(/^(\d{2})\s*년\s*(\d{1,2})\s*월$/);
        if (m) return `${toFullYear(m[1])}-${String(Number(m[2])).padStart(2, "0")}`;

        return "";
      }

      function monthFromDateText(v) {
        const s = normalizeText(v);
        if (!s) return "";

        let m = s.match(/^(\d{4})[./-](\d{1,2})[./-](\d{1,2})$/);
        if (m) return `${m[1]}-${String(Number(m[2])).padStart(2, "0")}`;

        m = s.match(/^(\d{2})[./-](\d{1,2})[./-](\d{1,2})$/);
        if (m) return `${toFullYear(m[1])}-${String(Number(m[2])).padStart(2, "0")}`;

        const d = new Date(s);
        if (!Number.isNaN(d.getTime())) {
          return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
        }

        return "";
      }

      function resolveRowMonth(row) {
        return (
          normalizeMonth(row.settlement_month) ||
          monthFromDateText(row.order_date) ||
          monthFromDateText(row.settlement_day) ||
          ""
        );
      }

      function normalizeBool(v) {
        if (v === true || v === "true" || v === "TRUE" || v === "t" || v === "1" || v === 1) return true;
        if (v === false || v === "false" || v === "FALSE" || v === "f" || v === "0" || v === 0) return false;
        return null;
      }

      function boolText(v, yesLabel, noLabel) {
        const b = normalizeBool(v);
        if (b === true) return yesLabel;
        if (b === false) return noLabel;
        return "-";
      }

      function effectiveAmount(row) {
        const raw = normalizeText(row.amount);
        if (raw) return toNumber(raw);
        return (toNumber(row.parcel) + toNumber(row.return_count)) * toNumber(row.price);
      }

      function isPaid(row) {
        return normalizeBool(row.payment_confirm) === true;
      }

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";
        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setMode(mode) {
        state.mode = mode;
        dom.btnModeVendor.classList.toggle("active", mode === "vendor");
        dom.btnModeDriver.classList.toggle("active", mode === "driver");
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "이 페이지는 최고관리자만 접근할 수 있습니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";
        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function requireAdmin() {
        if (!supabase || !supabase.auth) {
          alert("Supabase 설정을 확인하세요.");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();

          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          state.session = session;
          state.viewerEmail = normalizeText(session.user?.email || "");
          state.viewerUserId = normalizeText(session.user?.id || "");

          if (!state.viewerUserId) {
            showAccessDenied(state.viewerEmail, "로그인 사용자 ID를 확인할 수 없습니다.");
            return false;
          }

          const { data: accessRow, error } = await supabase
            .from(ACCESS_TABLE)
            .select("user_id, email, is_maroowell, is_admin")
            .eq("user_id", state.viewerUserId)
            .maybeSingle();

          if (error) {
            console.error(error);
            showAccessDenied(state.viewerEmail, "권한 테이블 조회 실패: " + error.message);
            return false;
          }

          if (!accessRow?.is_admin) {
            showAccessDenied(state.viewerEmail, "이 페이지는 최고관리자만 접근할 수 있습니다.");
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          console.error(e);
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      async function fetchRows() {
        try {
          setStatus("데이터 불러오는 중...", "warn");

          const { data, error } = await supabase
            .from(DATA_TABLE)
            .select("*")
            .order("id", { ascending: false });

          if (error) throw error;

          state.allRows = Array.isArray(data) ? data : [];
          rebuildView();
        } catch (e) {
          console.error(e);
          state.allRows = [];
          rebuildView();
          setStatus("불러오기 실패: " + (e?.message || String(e)), "err");
        }
      }

      function buildGroups() {
        const targetMonth = normalizeMonth(state.month);
        const q = normalizeLower(dom.searchInput.value);

        const rows = state.allRows.filter(row => resolveRowMonth(row) === targetMonth);
        state.monthRows = rows;

        const map = new Map();

        for (const row of rows) {
          let key = "";
          let name = "";
          let vendor = "";
          let target = "";

          if (state.mode === "vendor") {
            vendor = normalizeText(row.vendor_id) || "미지정 업체";
            target = normalizeText(row.order_name) || "미지정 Order";
            key = `${vendor}||${target}`;
            name = `${vendor}\n${target}`;
          } else {
            target = normalizeText(row.delivery_driver) || "미지정 기사";
            key = target;
            name = target;
          }

          const searchBag = [
            row.vendor_id,
            row.order_name,
            row.delivery_driver,
            row.camp,
            row.route,
            row.dragon_car_note
          ].map(normalizeLower).join(" | ");

          if (q && !searchBag.includes(q)) continue;

          if (!map.has(key)) {
            map.set(key, {
              key,
              mode: state.mode,
              name,
              vendor,
              target,
              rows: [],
              amount: 0,
              paidAmount: 0,
              unpaidAmount: 0,
              parcel: 0,
              returnCount: 0,
              noteSet: new Set(),
              vendorSet: new Set(),
              orderSet: new Set(),
              driverSet: new Set()
            });
          }

          const g = map.get(key);
          const amt = effectiveAmount(row);

          g.rows.push(row);
          g.amount += amt;
          g.parcel += toNumber(row.parcel);
          g.returnCount += toNumber(row.return_count);

          if (isPaid(row)) g.paidAmount += amt;
          else g.unpaidAmount += amt;

          const note = normalizeText(row.dragon_car_note);
          if (note) g.noteSet.add(note);

          const v = normalizeText(row.vendor_id);
          const o = normalizeText(row.order_name);
          const d = normalizeText(row.delivery_driver);

          if (v) g.vendorSet.add(v);
          if (o) g.orderSet.add(o);
          if (d) g.driverSet.add(d);
        }

        state.groups = Array.from(map.values())
          .map(group => ({
            ...group,
            noteText: Array.from(group.noteSet).join("\n• "),
            rowCount: group.rows.length,
            vendorText: Array.from(group.vendorSet).join("\n"),
            orderText: Array.from(group.orderSet).join("\n"),
            driverText: Array.from(group.driverSet).join("\n")
          }))
          .sort((a, b) => {
            if (b.amount !== a.amount) return b.amount - a.amount;
            return a.name.localeCompare(b.name, "ko");
          });

        if (!state.selectedGroupKey || !state.groups.some(g => g.key === state.selectedGroupKey)) {
          state.selectedGroupKey = state.groups[0]?.key || "";
        }
      }

      function getSelectedGroup() {
        return state.groups.find(g => g.key === state.selectedGroupKey) || null;
      }

      function renderSidebar() {
        const targetMonth = normalizeMonth(state.month);
        dom.sideMonth.textContent = targetMonth || "-";
        dom.sideGroupCount.textContent = String(state.groups.length);

        const totalAmount = state.groups.reduce((acc, g) => acc + g.amount, 0);
        const totalUnpaid = state.groups.reduce((acc, g) => acc + g.unpaidAmount, 0);

        dom.sideAmount.textContent = formatCurrency(totalAmount);
        dom.sideUnpaid.textContent = formatCurrency(totalUnpaid);

        if (!state.groups.length) {
          dom.groupList.innerHTML = `<div class="emptyState" style="width:auto;margin:0;padding:18px;">해당 월 데이터가 없습니다.</div>`;
          return;
        }

        dom.groupList.innerHTML = state.groups.map(group => {
          const active = group.key === state.selectedGroupKey ? "active" : "";
          return `
            <div class="groupItem ${active}" data-group-key="${escapeHtml(group.key)}">
              <div class="groupName">${escapeHtml(group.name)}</div>
              <div class="groupMeta">
                <div>총금액 <b>${escapeHtml(formatCurrency(group.amount))}</b></div>
                <div>미입금 <b>${escapeHtml(formatCurrency(group.unpaidAmount))}</b></div>
                <div>배송 <b>${escapeHtml(formatNumber(group.parcel))}</b></div>
                <div>반품 <b>${escapeHtml(formatNumber(group.returnCount))}</b></div>
              </div>
            </div>
          `;
        }).join("");
      }

      function renderStatement() {
        const group = getSelectedGroup();

        dom.pillRows.textContent = "행 " + state.monthRows.length;
        dom.pillGroups.textContent = "정산서 " + state.groups.length;

        if (!group) {
          dom.statementCapture.style.display = "none";
          dom.emptyState.style.display = "block";
          setStatus("정산서를 선택해줘.", "warn");
          return;
        }

        dom.statementCapture.style.display = "block";
        dom.emptyState.style.display = "none";

        const sortedRows = [...group.rows].sort((a, b) => {
          return formatDate(a.order_date).localeCompare(formatDate(b.order_date))
            || String(a.id ?? "").localeCompare(String(b.id ?? ""));
        });

        dom.statementTitle.textContent = state.mode === "vendor" ? "업체 용차 정산서" : "기사 용차 정산서";
        dom.infoMonth.textContent = normalizeMonth(state.month);
        dom.infoMode.textContent = state.mode === "vendor" ? "업체 기준" : "기사 기준";
        dom.infoVendor.textContent =
          state.mode === "vendor"
            ? (group.vendorText || "-")
            : (group.vendorText || "혼합");
        dom.infoTarget.textContent =
          state.mode === "vendor"
            ? (group.orderText || "-")
            : (group.driverText || "-");

        dom.sumAmount.textContent = formatCurrency(group.amount);
        dom.sumPaid.textContent = formatCurrency(group.paidAmount);
        dom.sumUnpaid.textContent = formatCurrency(group.unpaidAmount);
        dom.sumParcel.textContent = formatNumber(group.parcel);
        dom.sumReturn.textContent = formatNumber(group.returnCount);
        dom.sumRows.textContent = String(group.rowCount);

        dom.statementTableBody.innerHTML = sortedRows.map(row => `
          <tr>
            <td class="center">${escapeHtml(formatDate(row.order_date))}</td>
            <td>${escapeHtml(normalizeText(row.vendor_id))}</td>
            <td>${escapeHtml(normalizeText(row.order_name))}</td>
            <td class="center">${escapeHtml(normalizeText(row.camp))}</td>
            <td>${escapeHtml(normalizeText(row.route))}</td>
            <td class="center">${escapeHtml(normalizeText(row.wave))}</td>
            <td class="right">${escapeHtml(formatNumber(row.parcel))}</td>
            <td class="right">${escapeHtml(formatNumber(row.return_count))}</td>
            <td class="right">${escapeHtml(formatCurrency(row.price))}</td>
            <td class="right">${escapeHtml(formatCurrency(effectiveAmount(row)))}</td>
            <td class="center">${escapeHtml(boolText(row.payment_confirm, "입금", "미입금"))}</td>
            <td>${escapeHtml(normalizeText(row.dragon_car_note))}</td>
          </tr>
        `).join("");

        dom.statementNotes.textContent = group.noteText ? "• " + group.noteText : "-";
        setStatus("정산서 생성 완료", "ok");
      }

      function rebuildView() {
        state.month = normalizeMonth(state.month) || defaultMonth();
        dom.monthInput.value = state.month;
        buildGroups();
        renderSidebar();
        renderStatement();
      }

      async function downloadCurrentStatementPng() {
        const group = getSelectedGroup();
        if (!group) {
          alert("저장할 정산서가 없습니다.");
          return;
        }

        try {
          setStatus("PNG 생성 중...", "warn");

          const dataUrl = await window.htmlToImage.toPng(dom.statementCapture, {
            pixelRatio: 2,
            backgroundColor: "#ffffff",
            cacheBust: true
          });

          const safeVendor = (group.vendorText || "").replace(/[\\/:*?"<>|]/g, "_").replace(/\s+/g, "_");
          const safeTarget = (state.mode === "vendor" ? group.orderText : group.driverText).replace(/[\\/:*?"<>|]/g, "_").replace(/\s+/g, "_");
          const safeName = `${normalizeMonth(state.month)}_${state.mode === "vendor" ? "업체" : "기사"}_${safeVendor}_${safeTarget}`;

          const a = document.createElement("a");
          a.href = dataUrl;
          a.download = `${safeName}.png`;
          document.body.appendChild(a);
          a.click();
          a.remove();

          setStatus("PNG 저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("PNG 저장 실패: " + (e?.message || String(e)), "err");
        }
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", async () => {
          state.month = normalizeMonth(dom.monthInput.value) || state.month || defaultMonth();
          dom.monthInput.value = state.month;
          await fetchRows();
        });

        dom.monthInput.addEventListener("keydown", async (e) => {
          if (e.key !== "Enter") return;
          e.preventDefault();
          dom.btnReload.click();
        });

        dom.btnModeVendor.addEventListener("click", () => {
          setMode("vendor");
          rebuildView();
        });

        dom.btnModeDriver.addEventListener("click", () => {
          setMode("driver");
          rebuildView();
        });

        dom.searchInput.addEventListener("input", rebuildView);

        dom.btnClearSearch.addEventListener("click", () => {
          dom.searchInput.value = "";
          rebuildView();
        });

        dom.btnDownloadPng.addEventListener("click", downloadCurrentStatementPng);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.btnDeniedHome.addEventListener("click", () => location.replace(INDEX_PATH));
        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        document.body.addEventListener("click", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const item = target.closest("[data-group-key]");
          if (item) {
            state.selectedGroupKey = item.getAttribute("data-group-key") || "";
            renderSidebar();
            renderStatement();
          }
        });
      }

      bindEvents();
      dom.monthInput.value = state.month;
      setMode("vendor");

      if (!(await requireAdmin())) return;
      await fetchRows();
    })();
  </script>
</body>
</html>
