      function ensureDeductionModal() {
        if (state.deduction.root) return;

        const root = document.createElement("div");
        root.className = "deductionOverlay hidden";
        root.innerHTML = `
          <div class="deductionModal" role="dialog" aria-modal="true">
            <div class="deductionHead">
              <div>
                <div class="deductionTitle">용차 차감 관리</div>
