      }

      .scheduleTable th{
        min-height:48px;
        padding:6px 4px;
        font-size:12px
      }

      .weekCell{
        width:104px!important;
        font-size:14px!important
      }

      .campCell{
        width:96px!important;
        font-size:15px!important
      }

      .routeHead,
      .routeCell{
        width:136px!important
      }

      .routeInner{
        min-height:38px;
