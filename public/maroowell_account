      function graphStats(rows,metric){
        const values=(rows||[])
          .map(row => ({ row, value:Number(row.value) }))
          .filter(item => Number.isFinite(item.value));

        if(!values.length) return null;

        let max=values[0],min=values[0],sum=0;

        values.forEach(item => {
          sum += item.value;
          if(item.value > max.value) max=item;
          if(item.value < min.value) min=item;
        });

        return {
          max,
          min,
          avg:sum / values.length,
          metric
        };
      }

      function drawColoredRuns(ctx,runs,x,y,maxWidth,lineHeight=20){
        let cursor=x;
        let lineY=y;

        runs.forEach(run => {
          const chars=String(run.text || "").split("");
          let buffer="";

          ctx.fillStyle=run.color || "#334155";

          chars.forEach(ch => {
            const next=buffer + ch;
            const nextWidth=ctx.measureText(next).width;

            if(buffer && cursor + nextWidth > maxWidth){
              ctx.fillText(buffer,cursor,lineY);
              cursor += ctx.measureText(buffer).width;
              buffer=ch;
            }else{
              buffer=next;
            }
          });

          if(buffer){
            if(cursor + ctx.measureText(buffer).width > maxWidth){
              cursor=x;
              lineY += lineHeight;
            }

            ctx.fillText(buffer,cursor,lineY);
            cursor += ctx.measureText(buffer).width;
          }
        });

        return lineY;
      }

      function drawGraphStats(ctx,data,graphFont,x,y,maxWidth){
        const stats=graphStats(data.rows,data.metric);

        if(!stats) return y;

        const label = item => String(item?.row?.label || "");
        const value = v => formatGraphValue(v,data.metric);

        ctx.font=`600 14px ${graphFont}`;
        ctx.textAlign="left";
        ctx.textBaseline="middle";

        const runs=[
          { text:`최고수량 ${value(stats.max.value)} (${label(stats.max)})`, color:"#dc2626" },
          { text:" / ", color:"#64748b" },
          { text:`최저수량 ${value(stats.min.value)} (${label(stats.min)})`, color:"#2563eb" },
          { text:" / ", color:"#64748b" },
          { text:`평균수량 ${value(stats.avg)}`, color:"#a16207" }
        ];

        return drawColoredRuns(ctx,runs,x,y,maxWidth,20);
      }

