        }

        dom.emptyState.style.display = "none";
        dom.statementCapture.style.display = "block";
        dom.statementCapture.className = g.mode === "driver" ? "driverSheet" : "invoicePage";
        dom.statementCapture.innerHTML = g.mode === "driver" ? renderDriverStatement(g) : renderVendorStatement(g);
      }

      function vendorRowsHtml(infos){
        let html = infos.map(i => `
          <tr>
            <td>${esc(dateText(i.date, state.month))}</td>
