      clearRouteDetail();
      return;
    }

    const code = routeCodeOf(selectedRoute);
    const polys = polygonsForSelectedRoute();
    const points = pointsForSelectedRoute();

    $("selectedRouteText").textContent = code;
    $("polygonInfoText").textContent = `${polys.length}개`;

    $("routeDetail").className = "";
    $("routeDetail").innerHTML = `
      <div class="detailTitle">${esc(code)} · ${esc(selectedRoute.camp || "")}</div>
      <div class="detailMeta">
        <div>Route: ${esc(selectedRoute.route || "")}</div>
        <div>Sub: ${esc(selectedRoute.sub || "")}</div>
        <div>Sub-sub: ${esc(selectedRoute.sub_sub || "")}</div>
        <div>설명: ${esc(selectedRoute.description || "")}</div>
        <div>정보: ${esc(selectedRoute.info || selectedRoute.memo || "")}</div>
        <div>서브패키지: ${esc(selectedRoute.sub_package || "")}</div>
        <div>폴리곤 ${polys.length}개 / 포인트 ${points.length}개</div>
