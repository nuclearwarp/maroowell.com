        const chartW=width-112;
        const chartH=360;

        ctx.strokeStyle="#cbd5e1";
        ctx.lineWidth=1;
        ctx.beginPath();
        ctx.moveTo(chartX,chartY);
        ctx.lineTo(chartX,chartY+chartH);
