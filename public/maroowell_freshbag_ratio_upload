<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>마루웰 회수율 업로드</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

  <style>
    :root{
      --bg:#0b1220;
      --card:#121a2d;
      --line:rgba(255,255,255,.12);
      --txt:#e6eefc;
      --muted:#9fb0d2;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      min-height:100vh;
      background:linear-gradient(180deg,#0b1220,#070b13);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    .wrap{
      max-width:1540px;
      margin:0 auto;
      padding:22px 18px 44px;
    }

    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:18px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .brand img{
      width:34px;
      height:34px;
    }

    .title{
      font-size:28px;
      font-weight:950;
      letter-spacing:-.6px;
      line-height:1.15;
    }

    .sub{
      color:var(--muted);
      font-size:14px;
      margin-top:5px;
      line-height:1.45;
    }

    .grid{
      display:grid;
      grid-template-columns:430px 1fr;
      gap:16px;
    }

    .card{
      background:rgba(18,26,45,.9);
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 18px 60px rgba(0,0,0,.25);
    }

    .sectionTitle{
      font-size:17px;
      font-weight:950;
      margin:0 0 12px;
    }

    .field{
      margin-bottom:12px;
    }

    .field label{
      display:block;
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin:0 0 6px 2px;
    }

    input,select{
      width:100%;
      height:42px;
      border-radius:12px;
      border:1px solid var(--line);
      background:rgba(0,0,0,.25);
      color:var(--txt);
      padding:0 12px;
      outline:none;
    }

    input[type=file]{
      height:auto;
      padding:11px;
    }

    select option{
      background:#111827;
      color:#fff;
    }

    input:focus,select:focus{
      border-color:rgba(96,165,250,.55);
      box-shadow:0 0 0 2px rgba(96,165,250,.12);
    }

    .row{
      display:flex;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    button{
      min-height:42px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(59,130,246,.24);
      color:#fff;
      padding:0 18px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
    }

    button:hover{background:rgba(59,130,246,.36)}
    button.secondary{background:rgba(255,255,255,.07)}
    button.secondary:hover{background:rgba(255,255,255,.12)}
    button.ok{background:rgba(34,197,94,.18);border-color:rgba(34,197,94,.32)}
    button.ok:hover{background:rgba(34,197,94,.28)}
    button.danger{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.32)}
    button.danger:hover{background:rgba(239,68,68,.28)}

    .status{
      font-size:13px;
      color:var(--muted);
      margin-top:10px;
      line-height:1.55;
      white-space:pre-wrap;
    }

    .status.ok{color:#bbf7d0}
    .status.bad{color:#fecaca}
    .status.warn{color:#fde68a}

    .muted{
      color:var(--muted);
      line-height:1.55;
      font-size:13px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      min-height:32px;
      padding:0 12px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.06);
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .summary{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:12px;
    }

    .summary .pill strong{
      color:#fff;
      margin-left:5px;
    }

    pre{
      white-space:pre-wrap;
      word-break:break-word;
      background:rgba(0,0,0,.28);
      border:1px solid var(--line);
      border-radius:14px;
      padding:14px;
      max-height:420px;
      overflow:auto;
      font:12px/1.5 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      color:#dbeafe;
      margin:0;
    }

    .tableWrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:rgba(0,0,0,.18);
      max-height:620px;
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:100%;
      min-width:980px;
      font-size:13px;
    }

    th,td{
      border-right:1px solid rgba(255,255,255,.12);
      border-bottom:1px solid rgba(255,255,255,.12);
      padding:7px 9px;
      text-align:center;
      white-space:nowrap;
    }

    th{
      position:sticky;
      top:0;
      background:#263247;
      color:#fff;
      font-weight:950;
      z-index:2;
    }

    td{
      background:rgba(255,255,255,.025);
    }

    .percent{
      color:#7dd3fc;
      font-weight:950;
    }

    .kindDaily{
      color:#bfdbfe;
      font-weight:950;
    }

    .kindTotal{
      color:#bbf7d0;
      font-weight:950;
    }

    .badCell{
      color:#fecaca;
      font-weight:950;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
      line-height:1.6;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media(max-width:980px){
      .grid{grid-template-columns:1fr}
      .top{align-items:flex-start;flex-direction:column}
      .row button{width:100%}
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <a href="#" id="mwBoardMenuToggle"><img src="/favicon.ico" alt="MarooWell"></a>
        <div>
          <div class="title">마루웰 회수율 업로드</div>
          <div class="sub">엑셀/CSV에서 일자별 회수율과 월 누적 회수율을 추출해 DB에 저장합니다. 최고관리자만 접근 가능합니다.</div>
        </div>
      </div>
      <div class="pill" id="userPill">세션 확인 중</div>
    </div>

    <div class="grid">
      <div>
        <div class="card">
          <div class="sectionTitle">엑셀 업로드</div>

          <div class="field">
            <label>기본 연도</label>
            <select id="yearSelect"></select>
          </div>

          <div class="field">
            <label>파일</label>
            <input id="fileInput" type="file" accept=".xlsx,.xls,.csv" />
          </div>

          <div class="row">
            <button id="parseBtn">파일 분석</button>
            <button id="uploadBtn" class="ok">DB 업로드</button>
            <button id="clearBtn" class="secondary">초기화</button>
          </div>

          <div class="status" id="statusText">대기 중</div>

          <div class="summary">
            <span class="pill">일자별 <strong id="countDaily">0</strong></span>
            <span class="pill">월누적 <strong id="countTotal">0</strong></span>
            <span class="pill">날짜 <strong id="countDates">0</strong></span>
            <span class="pill">캠프 <strong id="countCamps">0</strong></span>
            <span class="pill">라우트 <strong id="countRoutes">0</strong></span>
          </div>

          <div class="muted" style="margin-top:12px">
            저장 방식:<br>
            1) <b>Title 2026.05.02</b> 같은 단일 일자 블록은 일자별 테이블에 저장<br>
            2) <b>2026.03.26 ~ 2026.04.25</b>처럼 쿠팡 정산월 전체 기간인 블록만 월 누적 테이블에 저장<br>
            3) <b>2026.04.26 ~ 2026.05.02</b> 같은 주간/중간 기간 블록은 월 누적으로 저장하지 않음<br><br>
            W2는 조회 화면에서 <b>주간</b>, W1은 <b>야간</b>으로 표시됩니다.
          </div>
        </div>

        <div class="card">
          <div class="sectionTitle">주의사항</div>
          <div class="muted">
            일자별 업로드는 <b>date + wave + camp + route</b> 기준으로 덮어쓰기됩니다.<br>
            월 누적 업로드는 <b>data_year + month_no + wave + camp + route</b> 기준으로 덮어쓰기됩니다.<br><br>
            Route는 저장 시 자동으로 <b>126_A → 126A</b>처럼 정규화됩니다.
          </div>
        </div>
      </div>

      <div>
        <div class="card">
          <div class="sectionTitle">추출 결과 미리보기</div>
          <div class="tableWrap">
            <table id="previewTable">
              <thead></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>

        <div class="card">
          <div class="sectionTitle">로그</div>
          <pre id="logOutput">아직 분석 결과가 없습니다.</pre>
        </div>
      </div>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">최고관리자 권한이 필요합니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="deniedHomeBtn" class="secondary" type="button">홈으로</button>
        <button id="deniedLogoutBtn" class="danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};

  const DAILY_TABLE = "maroowell_freshbag_ration";
  const TOTAL_TABLE = "maroowell_freshbag_ration_month_total";

  let supabaseClient = null;
  let currentUser = null;
  let fileName = "";
  let canUpload = false;

  let dailyRows = [];
  let totalRows = [];
  let parsedRows = [];

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg;
    $("statusText").className = type ? "status " + type : "status";
  }

  function log(value) {
    $("logOutput").textContent = typeof value === "string" ? value : JSON.stringify(value, null, 2);
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function headerKey(v) {
    return clean(v)
      .replace(/\s+/g, "")
      .replace(/_/g, "")
      .replace(/[()（）\[\]{}]/g, "")
      .toLowerCase();
  }

  function waveLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "W2") return "주간";
    if (s === "W1") return "야간";
    return s;
  }

  function uniqueCount(arr) {
    return new Set(arr.filter(Boolean)).size;
  }

  function initYears() {
    const now = new Date().getFullYear();
    const years = [];

    for (let y = now + 1; y >= now - 8; y--) {
      years.push(y);
    }

    $("yearSelect").innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join("");
    $("yearSelect").value = String(now);
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  function showAccessDenied(detail = "") {
    $("accessDenied").classList.add("show");
    $("accessDeniedText").textContent = detail || "최고관리자 권한이 필요합니다.";
    $("accessDeniedEmail").textContent = currentUser?.email
      ? `현재 로그인: ${currentUser.email}`
      : "현재 로그인 이메일을 확인할 수 없습니다.";
    document.documentElement.style.visibility = "visible";
  }

  async function checkSuperAdmin() {
    if (!supabaseClient) initSupabase();

    const { data: sessionData, error: sessionError } = await supabaseClient.auth.getSession();
    if (sessionError) throw sessionError;

    currentUser = sessionData?.session?.user;

    if (!currentUser) {
      const loginPath = cfg.PATHS?.login || "/login.html";
      location.href = loginPath + "?next=" + encodeURIComponent(location.pathname);
      return false;
    }

    $("userPill").textContent = currentUser.email || currentUser.id;

    const { data: access, error: accessError } = await supabaseClient
      .rpc("mw_my_access")
      .maybeSingle();

    if (accessError) {
      showAccessDenied(accessError.message);
      return false;
    }

    canUpload =
      access?.is_maroowell === true &&
      access?.is_admin === true &&
      Number(access?.max_role_level || 0) >= 90;

    if (!canUpload) {
      showAccessDenied("최고관리자 권한이 필요합니다.\n조건: 마루웰 권한 + 관리자 권한 + role_level 90 이상");
      return false;
    }

    document.documentElement.style.visibility = "visible";
    return true;
  }

  function pad2(n) {
    return String(Number(n)).padStart(2, "0");
  }

  function isoDate(y, m, d) {
    return `${y}-${pad2(m)}-${pad2(d)}`;
  }

  function parseIsoDate(iso) {
    const [y, m, d] = String(iso).split("-").map(Number);
    return new Date(y, m - 1, d);
  }

  function addMonths(date, count) {
    return new Date(date.getFullYear(), date.getMonth() + count, date.getDate());
  }

  function sameYearMonth(a, b) {
    return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth();
  }

  function excelSerialToDate(serial) {
    const n = Number(serial);
    if (!Number.isFinite(n)) return null;

    const utcDays = Math.floor(n - 25569);
    const utcValue = utcDays * 86400;
    const dateInfo = new Date(utcValue * 1000);

    if (Number.isNaN(dateInfo.getTime())) return null;

    return isoDate(dateInfo.getUTCFullYear(), dateInfo.getUTCMonth() + 1, dateInfo.getUTCDate());
  }

  function parseDateValue(v, defaultYear = null) {
    if (v instanceof Date && !Number.isNaN(v.getTime())) {
      return isoDate(v.getFullYear(), v.getMonth() + 1, v.getDate());
    }

    if (typeof v === "number") {
      return excelSerialToDate(v);
    }

    let s = clean(v);
    if (!s) return null;

    s = s
      .replace(/^date\s*[:：]?\s*/i, "")
      .replace(/^날짜\s*[:：]?\s*/i, "")
      .replace(/\([^)]*\)/g, "")
      .trim();

    let m = s.match(/(20\d{2})[.\-/년\s]+(\d{1,2})[.\-/월\s]+(\d{1,2})/);
    if (m) return isoDate(m[1], m[2], m[3]);

    m = s.match(/(\d{1,2})[.\-/월\s]+(\d{1,2})/);
    if (m && defaultYear) return isoDate(defaultYear, m[1], m[2]);

    if (/^\d{5}(\.\d+)?$/.test(s)) return excelSerialToDate(Number(s));

    return null;
  }

  function extractDateInfoFromText(value, defaultYear) {
    const s = clean(value);
    if (!s) return null;

    const full = Array.from(
      s.matchAll(/(20\d{2})[.\-/년\s]+(\d{1,2})[.\-/월\s]+(\d{1,2})/g)
    ).map(m => isoDate(m[1], m[2], m[3]));

    if (full.length >= 2 && /[~∼～]/.test(s)) {
      const start = full[0];
      const end = full[full.length - 1];
      return makeRangeInfo(start, end);
    }

    if (full.length === 1) {
      return {
        kind: "daily",
        date: full[0]
      };
    }

    const short = Array.from(
      s.matchAll(/(\d{1,2})[.\-/월\s]+(\d{1,2})/g)
    ).map(m => defaultYear ? isoDate(defaultYear, m[1], m[2]) : null).filter(Boolean);

    if (short.length >= 2 && /[~∼～]/.test(s)) {
      return makeRangeInfo(short[0], short[short.length - 1]);
    }

    if (short.length === 1) {
      return {
        kind: "daily",
        date: short[0]
      };
    }

    const single = parseDateValue(s, defaultYear);
    if (single) {
      return {
        kind: "daily",
        date: single
      };
    }

    return null;
  }

  function makeRangeInfo(startIso, endIso) {
    const start = parseIsoDate(startIso);
    const end = parseIsoDate(endIso);

    const isFullCoupangMonth =
      start.getDate() === 26 &&
      end.getDate() === 25 &&
      sameYearMonth(addMonths(start, 1), end);

    if (!isFullCoupangMonth) {
      return {
        kind: "ignore_range",
        period_start: startIso,
        period_end: endIso
      };
    }

    return {
      kind: "month_total",
      period_start: startIso,
      period_end: endIso,
      data_year: end.getFullYear(),
      month_no: end.getMonth() + 1
    };
  }

  function parsePercentValue(v) {
    if (v === null || v === undefined || v === "") return null;

    if (typeof v === "number") {
      if (!Number.isFinite(v)) return null;
      const val = v > 0 && v <= 1 ? v * 100 : v;
      if (val < 0 || val > 1000) throw new Error(`퍼센트 범위를 벗어났습니다: ${v}`);
      return Math.round(val * 100) / 100;
    }

    const raw = clean(v);
    if (!raw) return null;

    if (raw === "해당" || raw === "미해당" || raw.includes("해당")) return null;

    const hasPercent = raw.includes("%");

    const normalized = raw
      .replace(/,/g, "")
      .replace(/%/g, "")
      .replace(/[^\d.\-]/g, "");

    if (!normalized || normalized === "." || normalized === "-") return null;

    const n = Number(normalized);
    if (!Number.isFinite(n)) return null;

    const val = !hasPercent && n > 0 && n <= 1 ? n * 100 : n;

    if (val < 0 || val > 1000) {
      throw new Error(`퍼센트 범위를 벗어났습니다: ${raw}`);
    }

    return Math.round(val * 100) / 100;
  }

  function isPercentLikeValue(v) {
    try {
      return parsePercentValue(v) !== null;
    } catch {
      return false;
    }
  }

  function scorePercentColumn(rows, colIndex, startRow, maxScan = 40) {
    let score = 0;

    for (let r = startRow; r < Math.min(rows.length, startRow + maxScan); r++) {
      const row = rows[r] || [];
      if (isPercentLikeValue(row[colIndex])) score++;
    }

    return score;
  }

  function parseWhich(v) {
    const key = headerKey(v);
    if (!key) return 0;

    if (
      key.includes("가중요인1") ||
      key.includes("가중1") ||
      key.includes("gajoong1") ||
      key.includes("factor1") ||
      key.includes("요인1") ||
      key === "1"
    ) return 1;

    if (
      key.includes("가중요인2") ||
      key.includes("가중2") ||
      key.includes("gajoong2") ||
      key.includes("factor2") ||
      key.includes("요인2") ||
      key === "2"
    ) return 2;

    return 0;
  }

  function findIndexByCandidates(keys, candidates) {
    return keys.findIndex(key => candidates.some(c => key === c || key.includes(c)));
  }

  function findLongHeader(rows) {
    for (let r = 0; r < Math.min(rows.length, 100); r++) {
      const row = rows[r] || [];
      const keys = row.map(headerKey);

      const dateIdx = findIndexByCandidates(keys, ["date", "날짜", "일자"]);
      const waveIdx = findIndexByCandidates(keys, ["wave", "웨이브", "주야간"]);
      const campIdx = findIndexByCandidates(keys, ["camp", "캠프"]);
      const routeIdx = findIndexByCandidates(keys, ["route", "라우트", "노선"]);
      const g1Idx = findIndexByCandidates(keys, ["gajoong1", "가중요인1", "가중1", "요인1"]);
      const g2Idx = findIndexByCandidates(keys, ["gajoong2", "가중요인2", "가중2", "요인2"]);

      if (dateIdx >= 0 && waveIdx >= 0 && campIdx >= 0 && routeIdx >= 0 && g1Idx >= 0 && g2Idx >= 0) {
        return { rowIndex:r, dateIdx, waveIdx, campIdx, routeIdx, g1Idx, g2Idx };
      }
    }

    return null;
  }

  function findBaseHeader(rows) {
    for (let r = 0; r < Math.min(rows.length, 100); r++) {
      const row = rows[r] || [];
      const keys = row.map(headerKey);

      const waveIdx = findIndexByCandidates(keys, ["wave", "웨이브", "주야간"]);
      const campIdx = findIndexByCandidates(keys, ["camp", "캠프"]);
      const routeIdx = findIndexByCandidates(keys, ["route", "라우트", "노선"]);

      if (waveIdx >= 0 && campIdx >= 0 && routeIdx >= 0) {
        return { rowIndex:r, row, keys, waveIdx, campIdx, routeIdx };
      }
    }

    return null;
  }

  function findBlockInfoNear(rows, headerRowIndex, startCol, endCol) {
    const defaultYear = Number($("yearSelect").value);
    const candidates = [];

    for (let r = Math.max(0, headerRowIndex - 5); r <= headerRowIndex; r++) {
      const row = rows[r] || [];

      for (let c = startCol; c <= endCol; c++) {
        const info = extractDateInfoFromText(row[c], defaultYear);
        if (info) candidates.push(info);
      }
    }

    const monthTotal = candidates.find(item => item.kind === "month_total");
    if (monthTotal) return monthTotal;

    const daily = candidates.find(item => item.kind === "daily");
    if (daily) return daily;

    const ignored = candidates.find(item => item.kind === "ignore_range");
    if (ignored) return ignored;

    return null;
  }

  function findRepeatedWideBlocks(rows, header) {
    const headerRow = rows[header.rowIndex] || [];
    const keys = headerRow.map(headerKey);
    const waveColumns = [];

    for (let c = 0; c < keys.length; c++) {
      const key = keys[c];

      if (
        key === "wave" ||
        key.includes("wave") ||
        key.includes("웨이브") ||
        key.includes("주야간")
      ) {
        waveColumns.push(c);
      }
    }

    const blocks = [];

    for (const waveIdx of waveColumns) {
      const searchEnd = Math.min(keys.length - 1, waveIdx + 12);
      let campIdx = -1;
      let routeIdx = -1;

      for (let c = waveIdx + 1; c <= searchEnd; c++) {
        if (campIdx < 0 && (keys[c] === "camp" || keys[c].includes("camp") || keys[c].includes("캠프"))) {
          campIdx = c;
        }

        if (routeIdx < 0 && (keys[c] === "route" || keys[c].includes("route") || keys[c].includes("라우트") || keys[c].includes("노선"))) {
          routeIdx = c;
        }
      }

      if (campIdx < 0 || routeIdx < 0) continue;

      const nextWaveIdx = waveColumns.find(c => c > waveIdx) || keys.length;
      const blockEnd = nextWaveIdx - 1;
      const info = findBlockInfoNear(rows, header.rowIndex, waveIdx, blockEnd);

      if (!info || info.kind === "ignore_range") continue;

      const g1Candidates = [];
      const g2Candidates = [];

      for (let c = routeIdx + 1; c <= blockEnd; c++) {
        const which = parseWhich(headerRow[c]);
        if (which === 1) g1Candidates.push(c);
        if (which === 2) g2Candidates.push(c);
      }

      const dataStart = header.rowIndex + 1;

      const pickBestPercentColumn = (candidates) => {
        if (!candidates.length) return -1;

        const scored = candidates
          .map(colIndex => ({
            colIndex,
            score: scorePercentColumn(rows, colIndex, dataStart)
          }))
          .sort((a, b) => b.score - a.score);

        return scored.length ? scored[0].colIndex : -1;
      };

      const g1Idx = pickBestPercentColumn(g1Candidates);
      const g2Idx = pickBestPercentColumn(g2Candidates);

      if (g1Idx < 0 && g2Idx < 0) continue;

      blocks.push({
        ...info,
        waveIdx,
        campIdx,
        routeIdx,
        g1Idx,
        g2Idx,
        blockStart: waveIdx,
        blockEnd
      });
    }

    return {
      dataStart: header.rowIndex + 1,
      columns: blocks
    };
  }

  async function readWorkbook(file) {
    const buffer = await file.arrayBuffer();

    const wb = XLSX.read(buffer, {
      type: "array",
      cellDates: true
    });

    const sheetName = wb.SheetNames[0];
    const ws = wb.Sheets[sheetName];

    const rows = XLSX.utils.sheet_to_json(ws, {
      header: 1,
      raw: true,
      defval: ""
    });

    return { sheetName, rows };
  }

  function parseLongRows(rows, header) {
    const outDaily = [];
    const defaultYear = Number($("yearSelect").value);

    for (let r = header.rowIndex + 1; r < rows.length; r++) {
      const row = rows[r] || [];

      const date = parseDateValue(row[header.dateIdx], defaultYear);
      const wave = clean(row[header.waveIdx]);
      const camp = clean(row[header.campIdx]);
      const route = clean(row[header.routeIdx]);
      const routeNorm = normalizeRoute(route);

      if (!date || !wave || !camp || !routeNorm) continue;

      const g1 = parsePercentValue(row[header.g1Idx]);
      const g2 = parsePercentValue(row[header.g2Idx]);

      if (g1 === null && g2 === null) continue;

      outDaily.push({
        kind: "daily",
        date,
        wave,
        camp,
        route: routeNorm,
        gajoong1: g1,
        gajoong2: g2,
        source_file_name: fileName
      });
    }

    return {
      dailyRows: outDaily,
      totalRows: []
    };
  }

  function parseWideRows(rows, header, wideInfo) {
    const outDaily = [];
    const outTotal = [];
    let skippedEmptyCount = 0;
    let skippedInvalidCount = 0;
    const invalidSamples = [];

    for (let r = wideInfo.dataStart; r < rows.length; r++) {
      const row = rows[r] || [];

      for (const block of wideInfo.columns) {
        const wave = clean(row[block.waveIdx ?? header.waveIdx]);
        const camp = clean(row[block.campIdx ?? header.campIdx]);
        const route = clean(row[block.routeIdx ?? header.routeIdx]);
        const routeNorm = normalizeRoute(route);

        if (!wave || !camp || !routeNorm) continue;

        const rawG1 = block.g1Idx >= 0 ? row[block.g1Idx] : "";
        const rawG2 = block.g2Idx >= 0 ? row[block.g2Idx] : "";

        let g1 = null;
        let g2 = null;

        try {
          g1 = parsePercentValue(rawG1);
          g2 = parsePercentValue(rawG2);
        } catch (e) {
          skippedInvalidCount++;

          if (invalidSamples.length < 10) {
            invalidSamples.push({
              row: r + 1,
              kind: block.kind,
              date: block.date || null,
              data_year: block.data_year || null,
              month_no: block.month_no || null,
              wave,
              camp,
              route: routeNorm,
              rawG1: clean(rawG1),
              rawG2: clean(rawG2),
              error: e.message || String(e)
            });
          }

          continue;
        }

        if (g1 === null && g2 === null) {
          skippedEmptyCount++;
          continue;
        }

        if (block.kind === "daily") {
          outDaily.push({
            kind: "daily",
            date: block.date,
            wave,
            camp,
            route: routeNorm,
            gajoong1: g1,
            gajoong2: g2,
            source_file_name: fileName
          });
        }

        if (block.kind === "month_total") {
          outTotal.push({
            kind: "month_total",
            data_year: block.data_year,
            month_no: block.month_no,
            period_start: block.period_start,
            period_end: block.period_end,
            wave,
            camp,
            route: routeNorm,
            gajoong1: g1,
            gajoong2: g2,
            source_file_name: fileName
          });
        }
      }
    }

    parseWideRows.lastSkipped = {
      skippedEmptyCount,
      skippedInvalidCount,
      invalidSamples
    };

    return {
      dailyRows: outDaily,
      totalRows: outTotal
    };
  }

  function dedupeDaily(rows) {
    const map = new Map();

    for (const row of rows) {
      const key = `${row.date}||${row.wave}||${row.camp}||${normalizeRoute(row.route)}`;
      map.set(key, {
        ...row,
        route: normalizeRoute(row.route),
        gajoong1: row.gajoong1 === undefined ? null : row.gajoong1,
        gajoong2: row.gajoong2 === undefined ? null : row.gajoong2
      });
    }

    return Array.from(map.values()).sort(sortRows);
  }

  function dedupeTotal(rows) {
    const map = new Map();

    for (const row of rows) {
      const key = `${row.data_year}||${row.month_no}||${row.wave}||${row.camp}||${normalizeRoute(row.route)}`;
      map.set(key, {
        ...row,
        route: normalizeRoute(row.route),
        gajoong1: row.gajoong1 === undefined ? null : row.gajoong1,
        gajoong2: row.gajoong2 === undefined ? null : row.gajoong2
      });
    }

    return Array.from(map.values()).sort((a, b) => {
      return (
        Number(a.data_year) - Number(b.data_year) ||
        Number(a.month_no) - Number(b.month_no) ||
        String(a.camp).localeCompare(String(b.camp), "ko", { numeric:true }) ||
        String(a.wave).localeCompare(String(b.wave), "ko", { numeric:true }) ||
        String(a.route).localeCompare(String(b.route), "ko", { numeric:true })
      );
    });
  }

  function sortRows(a, b) {
    return (
      String(a.date || "").localeCompare(String(b.date || "")) ||
      String(a.camp).localeCompare(String(b.camp), "ko", { numeric:true }) ||
      String(a.wave).localeCompare(String(b.wave), "ko", { numeric:true }) ||
      String(a.route).localeCompare(String(b.route), "ko", { numeric:true })
    );
  }

  function parseRows(rows) {
    parseWideRows.lastSkipped = null;

    const longHeader = findLongHeader(rows);

    if (longHeader) {
      const parsed = parseLongRows(rows, longHeader);

      return {
        mode: "long",
        headerRow: longHeader.rowIndex + 1,
        blocks: [],
        skipped: null,
        dailyRows: dedupeDaily(parsed.dailyRows),
        totalRows: dedupeTotal(parsed.totalRows)
      };
    }

    const baseHeader = findBaseHeader(rows);

    if (!baseHeader) {
      throw new Error("Wave / Camp / Route 헤더를 찾지 못했습니다.");
    }

    const wideInfo = findRepeatedWideBlocks(rows, baseHeader);

    if (!wideInfo.columns.length) {
      throw new Error("일자별 또는 월 누적 가중요인 블록을 찾지 못했습니다.");
    }

    const parsed = parseWideRows(rows, baseHeader, wideInfo);

    return {
      mode: "wide",
      headerRow: baseHeader.rowIndex + 1,
      dataStartRow: wideInfo.dataStart + 1,
      blocks: wideInfo.columns.map(item => ({
        kind: item.kind,
        date: item.date || null,
        data_year: item.data_year || null,
        month_no: item.month_no || null,
        period_start: item.period_start || null,
        period_end: item.period_end || null,
        waveIdx: item.waveIdx,
        campIdx: item.campIdx,
        routeIdx: item.routeIdx,
        g1Idx: item.g1Idx,
        g2Idx: item.g2Idx
      })),
      skipped: parseWideRows.lastSkipped || null,
      dailyRows: dedupeDaily(parsed.dailyRows),
      totalRows: dedupeTotal(parsed.totalRows)
    };
  }

  function renderSummary() {
    $("countDaily").textContent = dailyRows.length.toLocaleString();
    $("countTotal").textContent = totalRows.length.toLocaleString();
    $("countDates").textContent = uniqueCount(dailyRows.map(row => row.date)).toLocaleString();
    $("countCamps").textContent = uniqueCount(parsedRows.map(row => row.camp)).toLocaleString();
    $("countRoutes").textContent = uniqueCount(parsedRows.map(row => row.route)).toLocaleString();
  }

  function renderPreview() {
    const thead = $("previewTable").querySelector("thead");
    const tbody = $("previewTable").querySelector("tbody");

    thead.innerHTML = `
      <tr>
        <th>구분</th>
        <th>date/month</th>
        <th>기간</th>
        <th>Wave</th>
        <th>주야간</th>
        <th>Camp</th>
        <th>Route</th>
        <th>가중1 %</th>
        <th>가중2 %</th>
        <th>source</th>
      </tr>
    `;

    const sample = parsedRows.slice(0, 700);

    if (!sample.length) {
      tbody.innerHTML = `<tr><td colspan="10">추출 데이터 없음</td></tr>`;
      return;
    }

    tbody.innerHTML = sample.map(row => {
      const isTotal = row.kind === "month_total";

      return `
        <tr>
          <td class="${isTotal ? "kindTotal" : "kindDaily"}">${isTotal ? "월누적" : "일자별"}</td>
          <td>${esc(isTotal ? `${row.data_year}-${String(row.month_no).padStart(2, "0")}` : row.date)}</td>
          <td>${esc(isTotal ? `${row.period_start} ~ ${row.period_end}` : "")}</td>
          <td>${esc(row.wave)}</td>
          <td>${esc(waveLabel(row.wave))}</td>
          <td>${esc(row.camp)}</td>
          <td>${esc(row.route)}</td>
          <td class="${row.gajoong1 === null ? "badCell" : "percent"}">${row.gajoong1 === null ? "" : esc(row.gajoong1.toFixed(2) + "%")}</td>
          <td class="${row.gajoong2 === null ? "badCell" : "percent"}">${row.gajoong2 === null ? "" : esc(row.gajoong2.toFixed(2) + "%")}</td>
          <td>${esc(row.source_file_name)}</td>
        </tr>
      `;
    }).join("");
  }

  async function parseFile() {
    const file = $("fileInput").files?.[0];

    if (!file) throw new Error("파일을 선택하세요.");

    fileName = file.name;
    dailyRows = [];
    totalRows = [];
    parsedRows = [];

    setStatus("파일 분석 중...", "warn");

    const { sheetName, rows } = await readWorkbook(file);
    const result = parseRows(rows);

    dailyRows = result.dailyRows;
    totalRows = result.totalRows;
    parsedRows = [...totalRows, ...dailyRows];

    renderPreview();
    renderSummary();

    log({
      file: file.name,
      sheet: sheetName,
      mode: result.mode,
      headerRow: result.headerRow,
      dataStartRow: result.dataStartRow || result.headerRow + 1,
      blocks: result.blocks || [],
      skipped: result.skipped || null,
      dailyRows: dailyRows.length,
      monthTotalRows: totalRows.length,
      dailyDates: Array.from(new Set(dailyRows.map(row => row.date))).slice(0, 50),
      monthTotals: totalRows.slice(0, 20),
      sample: parsedRows.slice(0, 20)
    });

    if (!dailyRows.length && !totalRows.length) {
      setStatus("추출된 회수율 데이터가 없습니다. 로그의 blocks/g1Idx/g2Idx를 확인하세요.", "bad");
      return;
    }

    const msg = [
      `분석 완료`,
      `일자별 ${dailyRows.length.toLocaleString()}건`,
      `월누적 ${totalRows.length.toLocaleString()}건`
    ].join(" / ");

    setStatus(msg, "ok");
  }

  function chunk(arr, size) {
    const out = [];

    for (let i = 0; i < arr.length; i += size) {
      out.push(arr.slice(i, i + size));
    }

    return out;
  }

  async function uploadRows() {
    if (!canUpload) throw new Error("최고관리자만 업로드할 수 있습니다.");
    if (!dailyRows.length && !totalRows.length) throw new Error("먼저 파일 분석을 실행하세요.");

    const ok = confirm(
      `DB 업로드를 진행할까요?\n\n` +
      `일자별: ${dailyRows.length.toLocaleString()}건\n` +
      `월누적: ${totalRows.length.toLocaleString()}건\n\n` +
      `동일 기준 데이터는 새 값으로 덮어쓰기됩니다.`
    );

    if (!ok) return;

    let doneDaily = 0;
    let doneTotal = 0;

    if (dailyRows.length) {
      setStatus(`일자별 업로드 중... 0 / ${dailyRows.length.toLocaleString()}`, "warn");

      for (const batch of chunk(dailyRows, 500)) {
        const payload = batch.map(row => ({
          date: row.date,
          wave: row.wave,
          camp: row.camp,
          route: row.route,
          gajoong1: row.gajoong1,
          gajoong2: row.gajoong2,
          source_file_name: row.source_file_name
        }));

        const { error } = await supabaseClient
          .from(DAILY_TABLE)
          .upsert(payload, {
            onConflict: "date,wave,camp,route_norm"
          });

        if (error) throw error;

        doneDaily += batch.length;
        setStatus(`일자별 업로드 중... ${doneDaily.toLocaleString()} / ${dailyRows.length.toLocaleString()}`, "warn");
      }
    }

    if (totalRows.length) {
      setStatus(`월누적 업로드 중... 0 / ${totalRows.length.toLocaleString()}`, "warn");

      for (const batch of chunk(totalRows, 500)) {
        const payload = batch.map(row => ({
          data_year: row.data_year,
          month_no: row.month_no,
          period_start: row.period_start,
          period_end: row.period_end,
          wave: row.wave,
          camp: row.camp,
          route: row.route,
          gajoong1: row.gajoong1,
          gajoong2: row.gajoong2,
          source_file_name: row.source_file_name
        }));

        const { error } = await supabaseClient
          .from(TOTAL_TABLE)
          .upsert(payload, {
            onConflict: "data_year,month_no,wave,camp,route_norm"
          });

        if (error) throw error;

        doneTotal += batch.length;
        setStatus(`월누적 업로드 중... ${doneTotal.toLocaleString()} / ${totalRows.length.toLocaleString()}`, "warn");
      }
    }

    setStatus(
      `업로드 완료: 일자별 ${dailyRows.length.toLocaleString()}건 / 월누적 ${totalRows.length.toLocaleString()}건`,
      "ok"
    );
  }

  function clearAll() {
    dailyRows = [];
    totalRows = [];
    parsedRows = [];
    fileName = "";

    $("fileInput").value = "";
    $("previewTable").querySelector("thead").innerHTML = "";
    $("previewTable").querySelector("tbody").innerHTML = "";

    renderSummary();
    log("초기화 완료");
    setStatus("대기 중");
  }

  async function signOut() {
    try {
      await supabaseClient?.auth?.signOut();
    } catch {}

    location.href = cfg.PATHS?.login || "/login.html";
  }

  function bindEvents() {
    $("parseBtn").addEventListener("click", () => run(parseFile));
    $("uploadBtn").addEventListener("click", () => run(uploadRows));
    $("clearBtn").addEventListener("click", clearAll);

    $("deniedHomeBtn").addEventListener("click", () => {
      location.href = cfg.PATHS?.index || "/index.html";
    });

    $("deniedLogoutBtn").addEventListener("click", signOut);
  }

  function run(fn) {
    Promise.resolve()
      .then(fn)
      .catch(e => {
        console.error(e);
        setStatus(e.message || String(e), "bad");
        log({
          error: e.message || String(e),
          stack: e.stack || null
        });
      });
  }

  initYears();
  bindEvents();

  try {
    initSupabase();

    run(async () => {
      const ok = await checkSuperAdmin();
      if (!ok) return;

      renderSummary();
      setStatus("최고관리자 확인 완료. 파일을 선택하고 분석하세요.", "ok");
    });
  } catch (e) {
    document.documentElement.style.visibility = "visible";
    setStatus(e.message || String(e), "bad");
    log(e.message || String(e));
  }
})();
</script>

