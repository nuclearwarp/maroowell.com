        ctx.stroke();

        ctx.fillStyle="#64748b";
        ctx.font=`400 11px ${graphFont}`;
        ctx.textAlign="right";
        ctx.textBaseline="middle";

        for(let i=0;i<=4;i++){
          const y=chartY+chartH-(chartH*i/4);
