<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰 정산</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0c1524;
      --line:rgba(255,255,255,.08);
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;

      --sheet:#ffffff;
      --sheetLine:#d8dee8;
      --sheetHead:#eef3f8;
      --sheetText:#111827;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      min-height:100%;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }

    body{
      overflow:auto;
    }

    html, body,
    input, select, button, textarea {
      color-scheme: dark;
    }

    .app{
      min-height:100vh;
      display:flex;
      flex-direction:column;
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      min-height:56px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
      flex:0 0 auto;
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
      letter-spacing:.1px;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }

    .spacer{flex:1}

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }

    .btn:hover{background:var(--btn2)}
    .btn.ok{background:rgba(26,90,58,.35);border-color:rgba(0,255,140,.18)}
    .btn.warn{background:rgba(106,75,19,.35);border-color:rgba(255,180,0,.18)}
    .btn:disabled{opacity:.55;cursor:not-allowed}

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:10px 12px;
      background:var(--panel);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
      flex:0 0 auto;
    }

    .toolbarGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolbarGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolbar label{
      font-size:12px;
      color:#cfe0ff;
      font-weight:800;
      white-space:nowrap;
    }

    .input,
    .select{
      height:38px;
      min-width:160px;
      border-radius:10px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.06);
      color:#eef4ff;
      padding:0 10px;
      outline:none;
      appearance:auto;
      -webkit-appearance:auto;
    }

    .select option,
    .select optgroup{
      background:#162237;
      color:#eef4ff;
    }

    .select:disabled,
    .input:disabled{
      opacity:.7;
      color:#cbd5e1;
    }

    .fileInput{
      min-width:280px;
      padding:7px 10px;
    }

    .main{
      display:grid;
      grid-template-columns:420px 1fr;
      gap:12px;
      padding:12px;
      align-items:start;
      flex:1 0 auto;
    }

    .sidebar,
    .content{
      display:flex;
      flex-direction:column;
      gap:12px;
      align-self:start;
    }

    .card{
      background:linear-gradient(180deg, rgba(15,26,45,.98), rgba(8,14,26,.98));
      border:1px solid rgba(255,255,255,.10);
      border-radius:18px;
      box-shadow:0 14px 40px rgba(0,0,0,.24);
      overflow:hidden;
    }

    .cardHead{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:14px 16px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .cardTitle{
      font-size:15px;
      font-weight:900;
      letter-spacing:.1px;
    }

    .cardSub{
      margin-top:4px;
      font-size:12px;
      color:var(--muted);
      line-height:1.45;
    }

    .cardBody{
      padding:14px 16px;
    }

    .stats{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }

    .stat{
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.03);
      border-radius:14px;
      padding:12px;
    }

    .stat span{
      display:block;
      font-size:12px;
      color:var(--muted);
      font-weight:800;
    }

    .stat b{
      display:block;
      margin-top:6px;
      font-size:20px;
      font-weight:900;
    }

    .helperBox{
      margin-top:12px;
      border:1px dashed rgba(255,255,255,.14);
      background:rgba(255,255,255,.03);
      border-radius:14px;
      padding:12px 14px;
      font-size:12px;
      color:#d5e4ff;
      line-height:1.6;
    }

    .listWrap{
      max-height:320px;
      overflow-x:auto;
      overflow-y:scroll;
      cursor:grab;
      user-select:none;
      -webkit-user-select:none;
      scrollbar-gutter: stable both-edges;
    }

    .listWrap.dragging{
      cursor:grabbing;
    }

    .previewWrap{
      overflow-x:auto;
      overflow-y:visible;
      padding:12px 16px 16px;
      background:#0b1220;
      cursor:grab;
      user-select:none;
      -webkit-user-select:none;
      scrollbar-gutter: stable both-edges;
    }

    .previewWrap.dragging{
      cursor:grabbing;
    }

    .listWrap::-webkit-scrollbar,
    .previewWrap::-webkit-scrollbar{
      width:12px;
      height:12px;
    }

    .listWrap::-webkit-scrollbar-track,
    .previewWrap::-webkit-scrollbar-track{
      background:rgba(255,255,255,.05);
      border-radius:999px;
    }

    .listWrap::-webkit-scrollbar-thumb,
    .previewWrap::-webkit-scrollbar-thumb{
      background:rgba(148,163,184,.55);
      border-radius:999px;
      border:2px solid transparent;
      background-clip:padding-box;
    }

    .listWrap::-webkit-scrollbar-thumb:hover,
    .previewWrap::-webkit-scrollbar-thumb:hover{
      background:rgba(148,163,184,.8);
      background-clip:padding-box;
    }

    .simpleTable{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
    }

    .simpleTable th,
    .simpleTable td{
      border-bottom:1px solid rgba(255,255,255,.08);
      padding:10px 8px;
      font-size:12px;
      vertical-align:middle;
      text-align:left;
    }

    .simpleTable th{
      position:sticky;
      top:0;
      background:#0d1729;
      z-index:1;
      color:#cfe0ff;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .simpleTable td{
      color:#edf3ff;
    }

    .simpleTable tbody tr:hover td{
      background:rgba(255,255,255,.03);
    }

    .simpleTable tbody tr.selected td{
      background:rgba(96,165,250,.12);
    }

    .simpleTable td.right,
    .simpleTable th.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .simpleTable td.center,
    .simpleTable th.center{
      text-align:center;
    }

    .clickableRow{
      cursor:pointer;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:4px 10px;
      border-radius:999px;
      font-size:11px;
      font-weight:900;
      border:1px solid rgba(255,255,255,.12);
      white-space:nowrap;
    }

    .pill.ok{color:#bbf7d0}
    .pill.warn{color:#fde68a}
    .pill.err{color:#fecaca}

    .tabRow{
      display:flex;
      gap:8px;
      padding:12px 16px 0;
      flex-wrap:wrap;
    }

    .tabBtn{
      height:36px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      color:#dce8ff;
      font-size:12px;
      font-weight:900;
      cursor:pointer;
    }

    .tabBtn.active{
      background:rgba(96,165,250,.16);
      border-color:rgba(96,165,250,.45);
      color:#f8fbff;
    }

    .sheet{
      width:1100px;
      min-height:1520px;
      margin:0 auto;
      background:var(--sheet);
      color:var(--sheetText);
      border:1px solid var(--sheetLine);
      box-shadow:0 18px 60px rgba(0,0,0,.18);
      user-select:text;
      -webkit-user-select:text;
    }

    .sheetHeader{
      padding:22px 24px 12px;
      border-bottom:1px solid var(--sheetLine);
    }

    .sheetTitle{
      font-size:28px;
      font-weight:900;
      letter-spacing:.3px;
      text-align:center;
    }

    .sheetMeta{
      margin-top:16px;
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
      font-size:13px;
    }

    .metaBox{
      border:1px solid var(--sheetLine);
      padding:10px 12px;
      background:#fafcff;
      min-height:62px;
    }

    .metaBox b{
      display:block;
      font-size:12px;
      margin-bottom:6px;
      color:#475569;
    }

    .metaBox div{
      font-size:13px;
      font-weight:800;
      line-height:1.45;
      word-break:break-word;
    }

    .sheetSection{
      padding:16px 24px 0;
    }

    .sheetSectionTitle{
      font-size:15px;
      font-weight:900;
      margin-bottom:8px;
    }

    .sheetTable{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
    }

    .sheetTable th,
    .sheetTable td{
      border:1px solid var(--sheetLine);
      padding:9px 8px;
      font-size:12px;
      text-align:center;
      word-break:break-word;
      vertical-align:middle;
    }

    .sheetTable th{
      background:var(--sheetHead);
      font-weight:900;
    }

    .sheetTable td.num{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .sheetTable td.left{
      text-align:left;
    }

    .sheetNote{
      margin:18px 24px 24px;
      padding:12px 14px;
      border:1px dashed #cdd6e4;
      background:#fafcff;
      color:#475569;
      font-size:12px;
      line-height:1.6;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      min-height:42px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
      flex:0 0 auto;
      position:sticky;
      bottom:0;
      z-index:20;
    }

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{
      display:flex;
    }

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width:1400px){
      .main{grid-template-columns:390px 1fr}
      .sheet{
        transform-origin:top center;
        transform:scale(.88);
        margin-bottom:-180px;
      }
    }

    @media (max-width:1100px){
      .main{grid-template-columns:1fr}
      .sheet{
        width:100%;
        min-width:980px;
        transform:none;
        margin-bottom:0;
      }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a id="mwBoardMenuToggle" href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>

      <div class="titleBox">
        <b>마루웰 정산</b>
        <small>쿠팡 원본 정산서 → Main / 신형 / 구형 정산 미리보기</small>
      </div>

      <div class="spacer"></div>

      <button id="btnRefreshMaster" class="btn warn" type="button">기사정보 새로고침</button>
      <button id="btnSavePng" class="btn ok" type="button" disabled>현재 정산서 PNG 저장</button>
    </div>

    <div class="toolbar">
      <div class="toolbarGroup">
        <label for="fileWorkbook">쿠팡 원본 정산서</label>
        <input id="fileWorkbook" class="input fileInput" type="file" accept=".xlsx,.xls" />
      </div>

      <div class="toolbarGroup">
        <label for="selectDriver">기사 선택</label>
        <select id="selectDriver" class="select" disabled>
          <option value="">기사 없음</option>
        </select>
      </div>

      <div class="toolbarGroup">
        <label for="selectMonth">정산월</label>
        <input id="selectMonth" class="input" type="month" />
      </div>
    </div>

    <div class="main">
      <div class="sidebar">
        <section class="card">
          <div class="cardHead">
            <div>
              <div class="cardTitle">원본 / 기사정보 현황</div>
              <div class="cardSub">원본 업로드 후 /master 기사정보와 비교해서 자동 매칭합니다.</div>
            </div>
          </div>

          <div class="cardBody">
            <div class="stats">
              <div class="stat">
                <span>정산Raw 행 수</span>
                <b id="statRawRows">0</b>
              </div>
              <div class="stat">
                <span>분실파손List 행 수</span>
                <b id="statLossRows">0</b>
              </div>
              <div class="stat">
                <span>원본 고유 ID 수</span>
                <b id="statIds">0</b>
              </div>
              <div class="stat">
                <span>기사정보 수</span>
                <b id="statMasterRows">0</b>
              </div>
              <div class="stat">
                <span>자동 매칭 ID 수</span>
                <b id="statAutoMatched">0</b>
              </div>
              <div class="stat">
                <span>미매칭 후보 ID 수</span>
                <b id="statUnmatched">0</b>
              </div>
            </div>

            <div class="helperBox" id="helperText">
              아직 원본 파일이 업로드되지 않았습니다.
            </div>
          </div>
        </section>

        <section class="card">
          <div class="cardHead">
            <div>
              <div class="cardTitle">미매칭 / 서브 계정 후보</div>
              <div class="cardSub">자동으로 잡히지 않는 ID를 현재 정산에서만 기사에게 임시 귀속합니다.</div>
            </div>
          </div>

          <div class="cardBody listWrap" id="unmatchedWrap">
            <table class="simpleTable">
              <thead>
                <tr>
                  <th class="center" style="width:90px;">상태</th>
                  <th>원본 ID</th>
                  <th class="right" style="width:95px;">배송</th>
                  <th class="right" style="width:95px;">반품</th>
                  <th style="width:150px;">귀속 기사</th>
                </tr>
              </thead>
              <tbody id="unmatchedBody">
                <tr>
                  <td colspan="5" style="color:#9fb0cf;">아직 표시할 미매칭 후보가 없습니다.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div class="content">
        <section class="card">
          <div class="cardHead">
            <div>
              <div class="cardTitle">정산 Main 리스트</div>
              <div class="cardSub">자동 매칭 + 임시 귀속까지 반영한 기사별 정산 요약입니다. 행을 누르면 아래 미리보기가 바뀝니다.</div>
            </div>
          </div>

          <div class="cardBody listWrap" id="mainListWrap" style="padding-top:0;">
            <table class="simpleTable">
              <thead>
                <tr>
                  <th>기사명</th>
                  <th style="width:90px;">camp</th>
                  <th style="width:80px;">wave</th>
                  <th>대표 ID</th>
                  <th class="center" style="width:80px;">연결ID</th>
                  <th class="right" style="width:90px;">배송</th>
                  <th class="right" style="width:90px;">반품</th>
                  <th class="right" style="width:110px;">총금액</th>
                  <th class="right" style="width:100px;">차감</th>
                  <th class="right" style="width:110px;">예상지급</th>
                </tr>
              </thead>
              <tbody id="mainListBody">
                <tr>
                  <td colspan="10" style="color:#9fb0cf;">원본 업로드 후 정산 Main 리스트가 생성됩니다.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="card">
          <div class="cardHead">
            <div>
              <div class="cardTitle">정산서 미리보기</div>
              <div class="cardSub">현재 선택된 기사 기준으로 Main / 신형 / 구형 서식을 전환합니다.</div>
            </div>
          </div>

          <div class="tabRow">
            <button class="tabBtn active" data-tab="main" type="button">정산 Main</button>
            <button class="tabBtn" data-tab="new" type="button">신형 정산</button>
            <button class="tabBtn" data-tab="old" type="button">구형 정산</button>
          </div>

          <div class="previewWrap" id="previewWrap">
            <div id="captureTarget" class="sheet">
              <div class="sheetHeader">
                <div id="sheetTitle" class="sheetTitle">마루웰 정산 Main</div>

                <div class="sheetMeta">
                  <div class="metaBox">
                    <b>정산월</b>
                    <div id="metaMonth">-</div>
                  </div>
                  <div class="metaBox">
                    <b>기사명</b>
                    <div id="metaDriver">-</div>
                  </div>
                  <div class="metaBox">
                    <b>대표 ID</b>
                    <div id="metaId">-</div>
                  </div>
                  <div class="metaBox">
                    <b>캠프 / wave</b>
                    <div id="metaCampWave">-</div>
                  </div>
                  <div class="metaBox">
                    <b>급여정보</b>
                    <div id="metaPayroll">-</div>
                  </div>
                  <div class="metaBox">
                    <b>사업자정보</b>
                    <div id="metaBusiness">-</div>
                  </div>
                </div>
              </div>

              <div class="sheetSection">
                <div class="sheetSectionTitle">정산 요약</div>
                <table class="sheetTable">
                  <colgroup>
                    <col style="width:20%">
                    <col style="width:20%">
                    <col style="width:20%">
                    <col style="width:20%">
                    <col style="width:20%">
                  </colgroup>
                  <thead>
                    <tr>
                      <th>배송건수</th>
                      <th>반품건수</th>
                      <th>총금액</th>
                      <th>분실차감</th>
                      <th>예상지급액</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td id="sumDelivery" class="num">0</td>
                      <td id="sumReturn" class="num">0</td>
                      <td id="sumAmount" class="num">0</td>
                      <td id="sumLoss" class="num">0</td>
                      <td id="sumFinal" class="num">0</td>
                    </tr>
                  </tbody>
                </table>
              </div>

