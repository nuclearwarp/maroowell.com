<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />
  <title>마루웰 스케줄</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    html{visibility:hidden}
    :root{
      --bg:#081120;--panel:#101b2f;--panel2:#0d1728;--line:rgba(255,255,255,.11);--line2:rgba(255,255,255,.18);
      --txt:#eaf2ff;--muted:#9fb0d0;--cell:#111827;--head:#27364d;--camp:#bcd0ef;--route:#d8ead2;--week:#ffdf6a;
      --shadow:0 16px 42px rgba(0,0,0,.28)
    }
    *{box-sizing:border-box}
    html,body{margin:0;min-height:100%;background:var(--bg);color:var(--txt);font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif}
    body{overflow:hidden}
    button,input,select,textarea{font-family:inherit}
    .app{height:100vh;height:100dvh;display:grid;grid-template-rows:auto auto 1fr;background:linear-gradient(180deg,var(--bg),#060b13)}
    .topbar{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid var(--line);background:linear-gradient(180deg,#0b1424,#07101d)}
    .brand{display:flex;align-items:center;gap:10px;min-width:0}
    .logoButton{width:34px;height:34px;border:1px solid transparent;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;flex:0 0 auto;cursor:pointer;background:rgba(255,255,255,.03);transition:.15s}
    .logoButton:hover{background:rgba(255,255,255,.10);border-color:rgba(255,255,255,.18);transform:translateY(-1px)}
    .logoButton img{width:28px;height:28px;display:block}
    .brandText{min-width:0}
    .brandText h1{margin:0;font-size:22px;line-height:1.05;letter-spacing:-.04em}
    .brandText p{margin:4px 0 0;color:var(--muted);font-size:12px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .topSpacer{flex:1}
    .userBadge{display:inline-flex;align-items:center;min-height:34px;max-width:220px;padding:0 12px;border-radius:999px;border:1px solid var(--line2);background:rgba(255,255,255,.05);color:#bfdbfe;font-size:12px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .btn{height:38px;padding:0 13px;border-radius:999px;border:1px solid var(--line2);background:rgba(255,255,255,.07);color:var(--txt);font-size:13px;font-weight:900;cursor:pointer;white-space:nowrap;touch-action:manipulation}
    .btn:hover{background:rgba(255,255,255,.11)}
    .btn.primary{background:rgba(37,99,235,.75);border-color:rgba(147,197,253,.45)}
    .btn.ok{background:rgba(22,163,74,.55);border-color:rgba(134,239,172,.35)}
    .btn.warn{background:rgba(245,158,11,.34);border-color:rgba(253,230,138,.35)}
    .btn.excel{background:rgba(20,120,70,.7);border-color:rgba(134,239,172,.35)}
    .btn.copy{background:rgba(14,116,144,.55);border-color:rgba(103,232,249,.35)}
    .btn.danger{background:rgba(185,28,28,.42);border-color:rgba(252,165,165,.35);color:#fecaca}
    .btn:disabled{opacity:.55;cursor:not-allowed}

    .toolbar{display:grid;grid-template-columns:160px 150px 180px minmax(230px,1fr) auto auto auto auto auto auto auto;gap:10px;align-items:end;padding:12px 14px;border-bottom:1px solid var(--line);background:var(--panel2);position:relative;z-index:10}
    .field{display:flex;flex-direction:column;gap:5px;min-width:0}
    .field label{color:#bfdbfe;font-size:12px;font-weight:900}
    .input,.select,.weekButton{width:100%;height:42px;border-radius:12px;border:1px solid var(--line2);background:#0b1220;color:var(--txt);padding:0 12px;font-size:14px;font-weight:800;outline:none}
    .input:focus,.select:focus,.weekButton:focus{border-color:rgba(96,165,250,.75);box-shadow:0 0 0 3px rgba(96,165,250,.12)}
    .weekButton{display:flex;align-items:center;justify-content:space-between;cursor:pointer}
    .weekButton span:first-child{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .weekButton .chev{color:#bfdbfe;font-size:12px;margin-left:8px}
    .weekPickerWrap{position:relative}
    .weekPopup{position:absolute;top:calc(100% + 8px);left:0;width:316px;max-width:calc(100vw - 24px);border:1px solid rgba(148,163,184,.38);border-radius:16px;background:#f8fafc;color:#0f172a;box-shadow:0 24px 70px rgba(0,0,0,.38);padding:12px;display:none;z-index:100}
    .weekPopup.open{display:block}
    .weekPopupHeader{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}
    .weekMonthTitle{font-weight:1000;font-size:15px;color:#0f172a}
    .weekNav{display:flex;gap:6px}
    .weekNav button{width:34px;height:32px;border-radius:10px;border:1px solid #cbd5e1;background:#fff;color:#0f172a;font-weight:1000;cursor:pointer}
    .weekGrid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
    .weekDow{height:24px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:1000;color:#475569}
    .weekDay{height:32px;border:0;background:transparent;border-radius:8px;color:#0f172a;font-size:13px;font-weight:800;cursor:pointer}
    .weekDay.other{color:#94a3b8}
    .weekDay.today{box-shadow:inset 0 0 0 2px rgba(37,99,235,.35)}
    .weekDay.selected{background:#2563eb;color:#fff}
    .weekRowHighlight{background:#dbeafe!important}
    .weekDay.selected.weekRowHighlight{background:#2563eb!important;color:#fff!important}
    .weekPopupFooter{display:flex;align-items:center;justify-content:space-between;margin-top:10px;gap:8px;font-size:12px;color:#475569;font-weight:900}
    .weekPopupFooter button{height:30px;padding:0 10px;border-radius:10px;border:1px solid #cbd5e1;background:#fff;color:#0f172a;font-weight:1000;cursor:pointer}
    .weekBtns{display:flex;gap:6px;align-items:center}
    .metaLine{grid-column:1 / -1;display:flex;align-items:center;gap:8px;flex-wrap:wrap;min-height:24px;color:#b7c7e6;font-size:12px;font-weight:800}
    .pill{display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:999px;border:1px solid var(--line2);background:rgba(255,255,255,.06);color:#dbeafe;font-size:12px;font-weight:900;white-space:nowrap}
    .pill.ok{color:#bbf7d0}.pill.warn{color:#fde68a}.pill.err{color:#fecaca}

    .main{min-height:0;display:block;overflow:hidden}
    .boardWrap{min-width:0;min-height:0;height:100%;overflow:auto;padding:14px;background:#08101d}
    .scheduleBoard{min-width:980px;border:1px solid var(--line2);border-radius:18px;overflow:hidden;background:#0e1728;box-shadow:var(--shadow)}
    .boardHeader{display:flex;align-items:flex-end;justify-content:space-between;gap:12px;padding:14px 16px;background:linear-gradient(180deg,#17233a,#111c30);border-bottom:1px solid var(--line)}
    .boardTitle{min-width:0}
    .boardTitle h2{margin:0;font-size:22px;line-height:1.15;letter-spacing:-.04em}
    .boardTitle p{margin:6px 0 0;color:#bfdbfe;font-size:13px;font-weight:900}
    .boardActions{display:flex;gap:8px;align-items:center;flex:0 0 auto}

    table.scheduleTable{width:100%;border-collapse:separate;border-spacing:0;table-layout:fixed;background:#0f1728}
    .scheduleTable th,.scheduleTable td{border-right:1px solid rgba(255,255,255,.12);border-bottom:1px solid rgba(255,255,255,.12);text-align:center;vertical-align:middle}
    .scheduleTable th:last-child,.scheduleTable td:last-child{border-right:none}
    .scheduleTable tr:last-child td{border-bottom:none}
    .scheduleTable th{min-height:54px;padding:7px 6px;background:var(--head);color:#fff;font-size:13px;font-weight:1000;line-height:1.15;white-space:nowrap}
    .scheduleTable th.sun{color:#ff4444}
    .dayHeader{display:flex;flex-direction:column;align-items:center;gap:5px}
    .dayActions{display:flex;gap:4px;align-items:center;justify-content:center;flex-wrap:wrap}
    .dayBtn{height:21px;padding:0 6px;border-radius:999px;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.09);color:#dbeafe;font-size:10px;font-weight:1000;cursor:pointer}
    .dayBtn.share{color:#bbf7d0}.dayBtn.copy{color:#bae6fd}.dayBtn.paste{color:#fde68a}

    .weekCell{width:120px;background:var(--week)!important;color:#111827!important;font-size:16px!important;font-weight:1000!important}
    .campCell{width:110px;background:var(--camp)!important;color:#0f172a!important;font-size:17px!important;font-weight:1000!important}
    .routeHead{width:160px}
    .routeCell{width:160px;padding:0;background:var(--route);color:#111827;font-weight:1000}
    .routeCell.off{background:#fecaca;color:#7f1d1d}
    .routeInner{display:flex;align-items:center;gap:6px;min-height:42px;padding:6px 8px}
    .routeLabel{flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:left;font-size:14px}
    .expander{width:25px;height:25px;border-radius:999px;border:1px solid rgba(15,23,42,.25);background:rgba(255,255,255,.72);color:#111827;font-weight:1000;cursor:pointer;flex:0 0 auto;line-height:1}
    .expander.empty{visibility:hidden;pointer-events:none}
    .childRoute .routeCell{background:#eef7e9}
    .childRoute .routeLabel{padding-left:18px;font-size:13px;color:#334155}
    .childBadge{display:inline-flex;align-items:center;height:20px;padding:0 7px;border-radius:999px;background:#334155;color:white;font-size:11px;font-weight:900;margin-left:4px}
    .cellEdit{min-width:0;width:100%;height:42px;border:0;border-radius:0;padding:5px 7px;background:var(--cell);color:#f8fafc;font-size:13px;font-weight:900;text-align:center;outline:none}
    .cellEdit:focus{box-shadow:inset 0 0 0 3px rgba(96,165,250,.65);background:#0b1220!important;color:#fff!important}
    .cellEdit.dirty{box-shadow:inset 0 -3px 0 rgba(245,158,11,.85)}
    .cellEdit.hasValue{color:#0f172a}
    .cellEdit.offConflict{
      background:#7f1d1d!important;
      color:#fff!important;
      box-shadow:inset 0 0 0 3px rgba(248,113,113,.95), inset 0 -3px 0 rgba(250,204,21,.95)!important;
    }
    .cellEdit.offConflict:focus{
      background:#7f1d1d!important;
      color:#fff!important;
      box-shadow:inset 0 0 0 3px rgba(254,202,202,.95), inset 0 -3px 0 rgba(250,204,21,.95)!important;
    }
    .cellEdit::placeholder{color:rgba(148,163,184,.8);font-weight:800}

    .emptyBoard{padding:48px 16px;text-align:center;color:#cbd5e1;font-weight:900;border:1px dashed var(--line2);border-radius:18px;background:rgba(255,255,255,.035)}
    .suggestBox{position:fixed;display:none;z-index:2147482000;width:320px;max-height:290px;overflow:auto;border:1px solid rgba(148,163,184,.42);border-radius:14px;background:#0f172a;box-shadow:0 20px 60px rgba(0,0,0,.45);padding:6px}
    .suggestBox.open{display:block}
    .suggestItem{width:100%;display:block;text-align:left;border:1px solid transparent;border-radius:11px;background:transparent;color:#eaf2ff;padding:9px 10px;cursor:pointer}
    .suggestItem:hover,.suggestItem.active{background:rgba(96,165,250,.18);border-color:rgba(96,165,250,.35)}
    .suggestTop{display:flex;align-items:center;justify-content:space-between;gap:8px;font-size:13px;font-weight:1000}
    .suggestType{flex:0 0 auto;border-radius:999px;padding:2px 8px;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.08);color:#bfdbfe;font-size:11px;font-weight:1000}
    .suggestMeta{margin-top:4px;color:#b6c4dc;font-size:11px;font-weight:800;line-height:1.45}

    .captureArea{background:#0e1728}
    .captureArea.export{width:1280px!important;max-width:none!important;min-width:1280px!important;border-radius:0!important;box-shadow:none!important}
    .captureHost{position:fixed;left:-200000px;top:0;width:auto;height:auto;overflow:visible;background:#0e1728;padding:24px;z-index:-1}

    @media(max-width:1080px){
      body{overflow:auto}.app{min-height:100dvh;height:auto;display:block}.topbar{position:sticky;top:0;z-index:20}
      .brandText h1{font-size:19px}.brandText p{display:none}.userBadge{display:none}
      .toolbar{position:sticky;top:57px;z-index:19;grid-template-columns:1fr 1fr;align-items:end}
      .toolbar>.btn,.toolbar>.weekBtns{width:100%}.toolbar .btn{width:100%}.weekBtns{display:grid;grid-template-columns:1fr 1fr}
      .metaLine{grid-column:1 / -1}.main{display:block;overflow:visible}.boardWrap{padding:10px;overflow:auto;height:auto}
      .scheduleBoard{min-width:920px}.weekPopup{position:fixed;left:12px;right:12px;top:150px;width:auto}
    }
    @media(max-width:560px){
      .topbar{padding:10px}.logoButton{width:32px;height:32px}.logoButton img{width:24px;height:24px}.brandText h1{font-size:18px}
      .btn{height:36px;padding:0 10px;font-size:12px}.toolbar{top:49px;grid-template-columns:1fr;gap:8px;padding:10px}
      .field label{font-size:11px}.input,.select,.weekButton{height:40px;font-size:13px}.metaLine{font-size:11px}.boardWrap{padding:8px}
      .boardHeader{align-items:flex-start;flex-direction:column}.boardActions{width:100%;display:grid;grid-template-columns:1fr}.boardActions .btn{width:100%}
      .suggestBox{width:calc(100vw - 20px)}
    }
  </style>
</head>

<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기">
          <img src="/favicon.ico" alt="Maroowell" />
        </a>
        <div class="brandText">
          <h1>마루웰 스케줄</h1>
          <p>캠프 / 주야 / 주차별 입차 스케줄 등록</p>
        </div>
      </div>
      <div class="topSpacer"></div>
      <div id="userBadge" class="userBadge">-</div>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <section class="toolbar">
      <div class="field">
        <label for="campInput">Camp</label>
        <input id="campInput" class="input" type="text" placeholder="예: M익산1, 대구3" autocomplete="off" />
      </div>

      <div class="field">
        <label for="waveSelect">주/야</label>
        <select id="waveSelect" class="select">
          <option value="WAVE2">주간</option>
          <option value="WAVE1">야간</option>
        </select>
      </div>

      <div class="field weekPickerWrap">
        <label>주차</label>
        <button id="weekButton" class="weekButton" type="button">
          <span id="weekButtonText">-</span>
          <span class="chev">▼</span>
        </button>
        <div id="weekPopup" class="weekPopup">
          <div class="weekPopupHeader">
            <div id="weekMonthTitle" class="weekMonthTitle">-</div>
            <div class="weekNav">
              <button id="btnPickerPrev" type="button">‹</button>
              <button id="btnPickerNext" type="button">›</button>
            </div>
          </div>
          <div id="weekGrid" class="weekGrid"></div>
          <div class="weekPopupFooter">
            <button id="btnPickerToday" type="button">오늘</button>
            <span>주 행을 클릭하면 일~토 주차가 선택됩니다.</span>
          </div>
        </div>
      </div>

      <div class="field">
        <label for="searchInput">검색</label>
        <input id="searchInput" class="input" type="text" placeholder="라우트 / 기사 / ID" autocomplete="off" />
      </div>

      <div class="weekBtns">
        <button id="btnPrevWeek" class="btn" type="button">이전주</button>
        <button id="btnNextWeek" class="btn" type="button">다음주</button>
      </div>

      <button id="btnLoad" class="btn primary" type="button">불러오기</button>
      <button id="btnSave" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportMeta" class="btn excel" type="button">엑셀 생성</button>
      <button id="btnCopyImage" class="btn warn" type="button">이미지 복사</button>
      <button id="btnReset" class="btn" type="button">초기화</button>

      <div class="metaLine">
        <span id="statePill" class="pill ok">READY</span>
        <span id="weekPill" class="pill">-</span>
        <span id="rowPill" class="pill">라우트 0</span>
        <span id="dirtyPill" class="pill">미저장 0</span>
        <span id="apiPill" class="pill ok">Worker API</span>
        <span id="statusText">캠프와 주/야를 선택하고 불러오기를 누르세요.</span>
      </div>
    </section>

    <main class="main">
      <section id="boardWrap" class="boardWrap">
        <div id="boardRoot" class="scheduleBoard captureArea">
          <div class="boardHeader">
            <div class="boardTitle">
              <h2 id="boardTitle">스케줄</h2>
              <p id="boardSubTitle">-</p>
            </div>
            <div class="boardActions">
              <button id="btnImportWeek" class="btn copy" type="button">다른 주차 불러와 덮기</button>
            </div>
          </div>
          <div id="tableHost">
            <div class="emptyBoard">캠프를 입력하고 불러오기를 누르면 라우트 스케줄 표가 표시됩니다.</div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div id="suggestBox" class="suggestBox"></div>

  <script>
    (async function(){
      "use strict";

      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY;
      const LOGIN_PATH = CONFIG.PATHS?.login || "/login.html";
      const SCHEDULE_API_BASE = String(CONFIG.SCHEDULE_API_BASE || CONFIG.SCHEDULE_API_URL || "https://schedule.maroowell.com").replace(/\/+$/,"");

      const META_VENDOR_NAME = CONFIG.METAADMIN_VENDOR_NAME || "마루웰/MARUL";
      const META_BUSINESS_NO = CONFIG.METAADMIN_BUSINESS_NO || "2591501828";
      const META_WORK_STATUS = CONFIG.METAADMIN_WORK_STATUS || "출근";
      const OFF_ROUTE_LABEL = "휴무자";

      const DAYS = ["일","월","화","수","목","금","토"];
      const WAVE_LABEL = { WAVE1:"야간", WAVE2:"주간" };
      const WAVE_ALIASES = {
        WAVE1:["WAVE1","W1","야간","NIGHT","N"],
        WAVE2:["WAVE2","W2","주간","DAY","D"]
      };

      const LIGHT_PALETTE = [
        "#e9d5ff","#bae6fd","#fde68a","#bbf7d0","#fecaca","#bfdbfe","#fbcfe8","#fed7aa","#ccfbf1","#ddd6fe",
        "#d9f99d","#fef3c7","#cffafe","#fae8ff","#dcfce7","#fee2e2","#e0f2fe","#fce7f3","#ede9fe","#ecfccb",
        "#dbeafe","#ffedd5","#fef9c3","#f5d0fe","#c7d2fe","#fecdd3","#e2e8f0","#fef2f2","#f0fdf4","#eff6ff","#fff7ed"
      ];

      const els = {
        userBadge:document.getElementById("userBadge"),
        btnLogout:document.getElementById("btnLogout"),
        campInput:document.getElementById("campInput"),
        waveSelect:document.getElementById("waveSelect"),
        weekButton:document.getElementById("weekButton"),
        weekButtonText:document.getElementById("weekButtonText"),
        weekPopup:document.getElementById("weekPopup"),
        weekMonthTitle:document.getElementById("weekMonthTitle"),
        weekGrid:document.getElementById("weekGrid"),
        btnPickerPrev:document.getElementById("btnPickerPrev"),
        btnPickerNext:document.getElementById("btnPickerNext"),
        btnPickerToday:document.getElementById("btnPickerToday"),
        searchInput:document.getElementById("searchInput"),
        btnPrevWeek:document.getElementById("btnPrevWeek"),
        btnNextWeek:document.getElementById("btnNextWeek"),
        btnLoad:document.getElementById("btnLoad"),
        btnSave:document.getElementById("btnSave"),
        btnExportMeta:document.getElementById("btnExportMeta"),
        btnCopyImage:document.getElementById("btnCopyImage"),
        btnReset:document.getElementById("btnReset"),
        btnImportWeek:document.getElementById("btnImportWeek"),
        statePill:document.getElementById("statePill"),
        weekPill:document.getElementById("weekPill"),
        rowPill:document.getElementById("rowPill"),
        dirtyPill:document.getElementById("dirtyPill"),
        apiPill:document.getElementById("apiPill"),
        statusText:document.getElementById("statusText"),
        boardRoot:document.getElementById("boardRoot"),
        boardTitle:document.getElementById("boardTitle"),
        boardSubTitle:document.getElementById("boardSubTitle"),
        tableHost:document.getElementById("tableHost"),
        boardWrap:document.getElementById("boardWrap"),
        suggestBox:document.getElementById("suggestBox")
      };

      const state = {
        session:null,email:"",userId:"",accessToken:"",
        camp:"",wave:"WAVE2",
        baseDate:todayIso(),weekStart:"",weekEnd:"",weekDates:[],isoYear:0,isoWeek:0,weekLabel:"",
        pickerMonth:null,
        routesRaw:[],routeParents:[],displayRows:[],routeLookup:new Map(),
        schedules:[],scheduleMap:new Map(),
        driversRaw:[],driverAccounts:[],accountByDisplay:new Map(),accountByExportName:new Map(),accountById:new Map(),personColorMap:new Map(),
        expanded:new Set(),dirty:new Map(),loading:false,suggestInput:null,dayClipboard:null
      };

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth:{storage:window.sessionStorage,persistSession:true,autoRefreshToken:true,detectSessionInUrl:true}
          })
        : null;

      function clean(v){return String(v ?? "").trim()}
      function compact(v){return clean(v).replace(/\s+/g,"")}
      function keyOf(v){return compact(v).toUpperCase()}
      function esc(v){return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;")}

      function normalizeWave(v){
        const raw = compact(v).toUpperCase();
        if(raw==="야간"||raw==="NIGHT"||raw==="N"||raw==="W1"||raw==="WAVE1") return "WAVE1";
        if(raw==="주간"||raw==="DAY"||raw==="D"||raw==="W2"||raw==="WAVE2") return "WAVE2";
        return "WAVE2";
      }

      function waveLabel(v){return WAVE_LABEL[normalizeWave(v)] || v || "-"}
      function metaRotationByWave(wave){return normalizeWave(wave)==="WAVE1" ? "D1,D2,F3" : "1회전,2회전"}

      function todayIso(){return toIso(new Date())}
      function toIso(d){
        if(!(d instanceof Date)||Number.isNaN(d.getTime())) return "";
        return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
      }
      function parseIso(v){
        const m=clean(v).match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if(!m) return null;
        return new Date(Number(m[1]),Number(m[2])-1,Number(m[3]));
      }
      function addDays(iso,days){const d=parseIso(iso)||new Date();d.setDate(d.getDate()+days);return toIso(d)}
      function daysBetween(a,b){const da=parseIso(a),db=parseIso(b);if(!da||!db)return 0;return Math.round((da-db)/86400000)}
      function sundayOf(iso){const d=parseIso(iso)||new Date();d.setDate(d.getDate()-d.getDay());return toIso(d)}
      function weekDatesFromStart(startIso){return Array.from({length:7},(_,i)=>addDays(startIso,i))}
      function isoWeekInfoFromMondayRef(startIso){
        const sunday=parseIso(startIso)||new Date();
        const ref=new Date(sunday);ref.setDate(ref.getDate()+1);
        const target=new Date(Date.UTC(ref.getFullYear(),ref.getMonth(),ref.getDate()));
        const dayNum=target.getUTCDay()||7;
        target.setUTCDate(target.getUTCDate()+4-dayNum);
        const isoYear=target.getUTCFullYear();
        const yearStart=new Date(Date.UTC(isoYear,0,1));
        const isoWeek=Math.ceil((((target-yearStart)/86400000)+1)/7);
        return {isoYear,isoWeek,weekLabel:`${isoYear} - ${isoWeek}W`};
      }
      function dateLabel(iso){const d=parseIso(iso);return d?`${d.getMonth()+1}/${d.getDate()} ${DAYS[d.getDay()]}`:iso}
      function mdLabel(iso){const d=parseIso(iso);return d?`${d.getMonth()+1}/${d.getDate()}`:iso}
      function weekRangeLabel(){return state.weekDates.length?`${mdLabel(state.weekDates[0])} ~ ${mdLabel(state.weekDates[6])}`:"-"}

      function normalizeDateInput(v){
        const raw=clean(v);
        if(!raw) return "";
        let m=raw.match(/^(20\d{2})[-./년\s]+(\d{1,2})[-./월\s]+(\d{1,2})/);
        if(m) return toIso(new Date(Number(m[1]),Number(m[2])-1,Number(m[3])));
        m=raw.match(/^(\d{1,2})[-./\s]+(\d{1,2})$/);
        if(m) return toIso(new Date(state.isoYear || new Date().getFullYear(),Number(m[1])-1,Number(m[2])));
        const d=new Date(raw);
        return Number.isNaN(d.getTime()) ? "" : toIso(d);
      }

      function normalizeRoutePart(v){return clean(v).replace(/[^0-9A-Za-z가-힣]/g,"").toUpperCase()}
      function normalizeRouteLabel(v){return normalizeRoutePart(v)}
      function routeBaseLabel(route,sub){return normalizeRoutePart(route)+normalizeRoutePart(sub)}
      function routeChildLabel(route,sub,subSub){return routeBaseLabel(route,sub)+normalizeRoutePart(subSub)}
      function isOffRoute(v){return normalizeRouteLabel(v)===normalizeRouteLabel(OFF_ROUTE_LABEL)}
      function sortText(a,b){return String(a||"").localeCompare(String(b||""),"ko",{numeric:true,sensitivity:"base"})}

      function setState(kind,text){els.statePill.className="pill "+(kind||"ok");els.statePill.textContent=text||"READY"}
      function setStatus(text){els.statusText.textContent=text||""}
      function updateWeekState(){
        state.weekStart=sundayOf(state.baseDate);
        state.weekDates=weekDatesFromStart(state.weekStart);
        state.weekEnd=state.weekDates[6];
        const w=isoWeekInfoFromMondayRef(state.weekStart);
        state.isoYear=w.isoYear;state.isoWeek=w.isoWeek;state.weekLabel=w.weekLabel;
        els.weekButtonText.textContent=weekRangeLabel();
        els.weekPill.textContent=`${weekRangeLabel()} / ${state.weekLabel}`;
      }

      function assignColorKey(key){
        const k=clean(key)||"-";
        if(state.personColorMap.has(k)) return state.personColorMap.get(k);
        const color=LIGHT_PALETTE[state.personColorMap.size % LIGHT_PALETTE.length];
        state.personColorMap.set(k,color);
        return color;
      }
      function colorForValue(value){
        const account=resolveAccount(value);
        const key=account?.colorKey || account?.ownerName || clean(value) || "-";
        return assignColorKey(key);
      }
      function textColorForBg(){return "#0f172a"}

      function splitPersonNames(value){
        return clean(value)
          .split(/[,\n/、，]+/)
          .map(v=>clean(v))
          .filter(Boolean);
      }

      function personKeyCandidates(value){
        const raw=clean(value);
        if(!raw) return [];
        const acc=resolveAccount(raw);
        return [
          raw,
          acc?.displayName,
          acc?.ownerName,
          acc?.exportName,
          acc?.exportId
        ].map(keyOf).filter(Boolean);
      }

      function assignedPersonKeySetForDate(date){
        const set=new Set();
        const labels=allRouteLabels({includeOff:false});

        for(const routeLabel of labels){
          const value=valueForCell(date,routeLabel);
          if(!value) continue;

          personKeyCandidates(value).forEach(k=>set.add(k));
        }

        return set;
      }

      function offConflictNames(date,value){
        const names=splitPersonNames(value);
        if(!names.length) return [];

        const assigned=assignedPersonKeySetForDate(date);
        const conflicts=[];

        for(const name of names){
          const keys=personKeyCandidates(name);
          if(keys.some(k=>assigned.has(k))){
            conflicts.push(name);
          }
        }

        return conflicts;
      }

      function offCellHasConflict(date,value){
        return offConflictNames(date,value).length > 0;
      }

      async function ensureAuth(){
        if(!supabase){
          document.documentElement.style.visibility="visible";
          alert("Supabase 설정을 찾을 수 없습니다.");
          return false;
        }
        const {data}=await supabase.auth.getSession();
        state.session=data?.session||null;
        if(!state.session){location.href=LOGIN_PATH;return false}
        state.email=state.session.user?.email||"";
        state.userId=state.session.user?.id||"";
        state.accessToken=state.session.access_token||"";
        els.userBadge.textContent=state.email||"로그인";
        return true;
      }

      async function apiFetch(path,options){
        const {data}=await supabase.auth.getSession();
        const token=data?.session?.access_token;
        if(!token){location.href=LOGIN_PATH;throw new Error("로그인 세션이 없습니다.")}
        const res=await fetch(SCHEDULE_API_BASE+path,{
          ...(options||{}),
          headers:{"Content-Type":"application/json","Authorization":`Bearer ${token}`,...(options?.headers||{})}
        });
        const text=await res.text();
        let json=null;
        try{json=text?JSON.parse(text):null}catch{json={ok:false,error:text}}
        if(!res.ok||json?.ok===false){
          const err=new Error(json?.error||json?.message||`API 오류 ${res.status}`);
          err.status=res.status;err.detail=json?.detail||json;throw err;
        }
        return json;
      }

      async function checkAccess(){
        try{const me=await apiFetch("/me");if(me?.ok)return true}
        catch(e){
          console.error(e);
          document.documentElement.style.visibility="visible";
          alert("스케줄 접근 권한이 없거나 Worker API 연결에 실패했습니다.\n"+(e?.message||e));
          location.href="/";
          return false;
        }
        return false;
      }

      function campMatches(infoCamp,selectedCamp){
        const a=compact(infoCamp).toUpperCase(),b=compact(selectedCamp).toUpperCase();
        if(!a||!b)return false;
        return a===b||a.includes(b)||b.includes(a);
      }
      function waveMatches(infoWave,selectedWave){
        const raw=compact(infoWave).toUpperCase();
        if(!raw)return true;
        const selected=normalizeWave(selectedWave);
        const aliases=WAVE_ALIASES[selected]||[selected];
        return aliases.some(x=>raw===compact(x).toUpperCase()||raw.includes(compact(x).toUpperCase()));
      }

      function parseSubAccounts(v){
        const raw=clean(v);
        if(!raw)return [];
        return raw.split(/[\n;]+/).map(s=>clean(s)).filter(Boolean).flatMap(line=>{
          if(line.includes(",")){
            const parts=line.split(",").map(x=>clean(x)).filter(Boolean);
            if(parts.length>=2&&parts.every(x=>!/[/:：]/.test(x))) return parts.map(x=>({id:x,adminName:""}));
          }
          return [line];
        }).map(item=>{
          if(typeof item==="object")return item;
          const text=clean(item);
          const slash=text.split(/\s*[/／]\s*/).map(x=>clean(x)).filter(Boolean);
          if(slash.length>=2)return {id:slash[0],adminName:slash.slice(1).join(" / ")};
          const colon=text.split(/\s*[:：]\s*/).map(x=>clean(x)).filter(Boolean);
          if(colon.length>=2)return {id:colon[0],adminName:colon.slice(1).join(" ")};
          const parts=text.split(/\s+/).map(x=>clean(x)).filter(Boolean);
          if(parts.length>=2)return {id:parts[0],adminName:parts.slice(1).join(" ")};
          return {id:text,adminName:""};
        }).filter(x=>x.id||x.adminName);
      }

      function buildDriverAccounts(){
        state.driverAccounts=[];
        state.accountByDisplay.clear();
        state.accountByExportName.clear();
        state.accountById.clear();
        state.personColorMap.clear();

        const drivers=state.driversRaw.map(r=>({
          raw:r,
          name:clean(r.person_name||r.name),
          camp:clean(r.camp_code||r.camp),
          wave:clean(r.wave_raw||r.wave),
          coupangId:clean(r.coupang_id),
          subAccounts:Array.isArray(r.sub_accounts)
            ? r.sub_accounts.map(x=>typeof x==="object"?x:(parseSubAccounts(x)[0]||{id:clean(x),adminName:""}))
            : parseSubAccounts(r.sub_account_info),
          position:clean(r.position_title)
        })).filter(d=>d.name).sort((a,b)=>{
          const aw=waveMatches(a.wave,state.wave)?0:1,bw=waveMatches(b.wave,state.wave)?0:1;
          if(aw!==bw)return aw-bw;
          return sortText(a.name,b.name);
        });

        const seen=new Set();

        for(const d of drivers){
          const baseName=d.name;
          assignColorKey(baseName);

          addAccount({
            displayName:baseName,ownerName:baseName,exportName:baseName,exportId:d.coupangId,
            accountType:"본계정",colorKey:baseName,camp:d.camp,wave:d.wave,
            search:[baseName,d.coupangId,d.camp,d.wave,"본계정"].join(" ")
          },seen);

          d.subAccounts.forEach((sub,idx)=>{
            const displayName=`${baseName}${idx+2}`;
            addAccount({
              displayName,
              ownerName:baseName,
              exportName:clean(sub.adminName)||baseName,
              exportId:clean(sub.id),
              accountType:"서브계정",
              colorKey:baseName,
              camp:d.camp,
              wave:d.wave,
              search:[displayName,baseName,clean(sub.adminName),clean(sub.id),d.camp,d.wave,"서브계정"].join(" ")
            },seen);
          });
        }

        state.driverAccounts.sort((a,b)=>{
          const ao=sortText(a.ownerName,b.ownerName);
          if(ao!==0)return ao;
          return sortText(a.displayName,b.displayName);
        });

        for(const acc of state.driverAccounts){
          state.accountByDisplay.set(keyOf(acc.displayName),acc);
          if(acc.exportName) state.accountByExportName.set(keyOf(acc.exportName),acc);
          if(acc.exportId) state.accountById.set(keyOf(acc.exportId),acc);
        }
      }

      function addAccount(account,seen){
        const k=keyOf(account.displayName);
        if(!k||seen.has(k))return;
        seen.add(k);
        state.driverAccounts.push(account);
      }

      function resolveAccount(value){
        const raw=clean(value);
        if(!raw)return null;
        const k=keyOf(raw);
        return state.accountByDisplay.get(k) || state.accountByExportName.get(k) || state.accountById.get(k) || {
          displayName:raw,ownerName:raw,exportName:raw,exportId:"",accountType:"직접입력",colorKey:raw,search:raw
        };
      }

      function buildRoutes(){
        const rows=state.routesRaw.filter(r=>r.is_active!==false).filter(r=>campMatches(r.camp,state.camp)).sort((a,b)=>{
          const so=Number(a.sort_order||0)-Number(b.sort_order||0);
          if(so!==0)return so;
          const aParent=clean(a.parent_route_label)||routeBaseLabel(a.route,a.sub);
          const bParent=clean(b.parent_route_label)||routeBaseLabel(b.route,b.sub);
          const pc=sortText(aParent,bParent);
          if(pc!==0)return pc;
          return sortText(clean(a.sub_sub),clean(b.sub_sub));
        });

        const parentMap=new Map();
        state.routeLookup.clear();

        for(const r of rows){
          const parentLabel=normalizeRouteLabel(clean(r.parent_route_label)||routeBaseLabel(r.route,r.sub)||clean(r.route_label));
          const childLabel=normalizeRouteLabel(clean(r.route_label)||routeChildLabel(r.route,r.sub,r.sub_sub));
          if(!parentLabel&&!childLabel)continue;
          const key=parentLabel||childLabel;

          if(!parentMap.has(key)){
            parentMap.set(key,{
              key,route:String(r.route||""),sub:String(r.sub||""),label:key,
              description:clean(r.description),memo:clean(r.memo),subPackage:clean(r.sub_package),
              sortOrder:Number(r.sort_order||0),children:[]
            });
          }

          state.routeLookup.set(key,{label:key,parentKey:key,isChild:false});

          const parent=parentMap.get(key);
          const subSub=clean(r.sub_sub);
          const isChild=subSub&&childLabel&&childLabel!==key;

          if(isChild){
            const child={key:childLabel,route:String(r.route||""),sub:String(r.sub||""),subSub,label:childLabel,description:clean(r.description),memo:clean(r.memo),subPackage:clean(r.sub_package),sortOrder:Number(r.sort_order||0)};
            parent.children.push(child);
            state.routeLookup.set(childLabel,{label:childLabel,parentKey:key,isChild:true,subSub});
          }
        }

        state.routeParents=Array.from(parentMap.values()).map(p=>{
          const dedup=new Map();
          for(const c of p.children){if(!dedup.has(c.key))dedup.set(c.key,c)}
          p.children=Array.from(dedup.values()).sort((a,b)=>sortText(a.subSub,b.subSub)||sortText(a.label,b.label));
          return p;
        });

        state.routeParents.push({
          key:OFF_ROUTE_LABEL,
          label:OFF_ROUTE_LABEL,
          route:"",
          sub:"",
          description:"휴무자",
          memo:"",
          subPackage:"",
          sortOrder:999999,
          children:[],
          isOff:true
        });
        state.routeLookup.set(normalizeRouteLabel(OFF_ROUTE_LABEL),{label:OFF_ROUTE_LABEL,parentKey:OFF_ROUTE_LABEL,isChild:false,isOff:true});

        state.expanded.clear();
        for(const p of state.routeParents){
          if(p.children && p.children.length) state.expanded.add(p.key);
        }

        buildDisplayRows();
      }

      function buildDisplayRows(){
        const q=compact(els.searchInput.value).toUpperCase();
        const out=[];

        for(const p of state.routeParents){
          const parentMatch=!q||compact(p.label+p.description+p.memo+p.subPackage).toUpperCase().includes(q);
          const childMatches=(p.children||[]).filter(c=>!q||compact(c.label+c.description+c.memo+c.subPackage).toUpperCase().includes(q));

          if(parentMatch||childMatches.length){
            out.push({type:"parent",...p});
            if(state.expanded.has(p.key)){
              for(const c of (q?childMatches:p.children||[])) out.push({type:"child",parentKey:p.key,...c});
            }
          }
        }

        state.displayRows=out;
      }

      function allRouteLabels(options){
        const includeOff=options?.includeOff!==false;
        const labels=[];
        for(const p of state.routeParents){
          if(includeOff || !p.isOff) labels.push(p.label);
          for(const c of p.children||[]) labels.push(c.label);
        }
        return Array.from(new Set(labels.map(normalizeRouteLabel).filter(Boolean)));
      }

      function adminRouteLabel(routeLabel){
        const n=normalizeRouteLabel(routeLabel);
        if(isOffRoute(n))return "";
        const info=state.routeLookup.get(n);
        if(info?.isChild && info.parentKey) return normalizeRouteLabel(info.parentKey);
        return n;
      }

      function scheduleKey(date,routeLabel){return `${date}||${state.camp}||${state.wave}||${normalizeRouteLabel(routeLabel)}`}
      function scheduleLookupKey(date,routeLabel){return `${date}||${state.wave}||${normalizeRouteLabel(routeLabel)}`}

      function makeScheduleMap(){
        state.scheduleMap.clear();
        for(const r of state.schedules){
          const normalizedWave=normalizeWave(r.wave);
          const route=normalizeRouteLabel(r.route_label);
          state.scheduleMap.set(`${r.schedule_date}||${normalizedWave}||${route}`,r);

          const colorKey=r.driver_owner_name || resolveAccount(r.driver_display_name||r.driver_name)?.colorKey || r.driver_name;
          if(colorKey) assignColorKey(colorKey);
        }
      }

      async function loadAll(){
        state.camp=clean(els.campInput.value);
        state.wave=normalizeWave(els.waveSelect.value);
        els.waveSelect.value=state.wave;
        updateWeekState();

        if(!state.camp){alert("Camp를 입력하세요.");return}

        hideSuggest();
        state.loading=true;
        setState("warn","LOAD");
        setStatus("스케줄 데이터를 불러오는 중입니다.");
        els.btnLoad.disabled=true;
        els.btnSave.disabled=true;

        try{
          const params=new URLSearchParams({camp:state.camp,wave:state.wave,week_start:state.weekStart});
          const json=await apiFetch("/schedule/week?"+params.toString());

          state.routesRaw=json.routes||[];
          state.schedules=(json.schedules||[]).map(r=>({...r,wave:normalizeWave(r.wave),route_label:normalizeRouteLabel(r.route_label)}));
          state.driversRaw=json.drivers||[];

          buildDriverAccounts();
          makeScheduleMap();
          buildRoutes();
          render();

          setState("ok","READY");
          setStatus(`조회 완료: 라우트 ${state.routeParents.length-1}개 / 스케줄 ${state.schedules.length}개 / 기사 ${state.driverAccounts.length}개 계정`);
        }catch(e){
          console.error(e);
          setState("err","ERROR");
          setStatus("불러오기 실패: "+(e?.message||e));
          alert("불러오기 실패: "+(e?.message||e));
        }finally{
          state.loading=false;
          els.btnLoad.disabled=false;
          els.btnSave.disabled=false;
        }
      }

      function render(){
        buildDisplayRows();
        renderHeader();
        renderTable();
        updatePills();
      }

      function renderHeader(){
        els.boardTitle.textContent=`${state.camp||"-"} / ${waveLabel(state.wave)}`;
        els.boardSubTitle.textContent=`${weekRangeLabel()} · ${state.weekLabel} · DB: ${state.wave}`;
      }

      function valueForCell(date,routeLabel){
        const normalized=normalizeRouteLabel(routeLabel);
        const dirtyKey=scheduleKey(date,normalized);
        if(state.dirty.has(dirtyKey)){
          const d=state.dirty.get(dirtyKey);
          return clean(d.driver_display_name||d.driver_name);
        }
        const found=state.scheduleMap.get(scheduleLookupKey(date,normalized));
        return clean(found?.driver_display_name||found?.driver_name);
      }

      function rowForCell(date,routeLabel){
        const normalized=normalizeRouteLabel(routeLabel);
        return state.dirty.get(scheduleKey(date,normalized)) || state.scheduleMap.get(scheduleLookupKey(date,normalized)) || null;
      }

      function renderTable(){
        if(!state.routeParents.length){
          els.tableHost.innerHTML=`<div class="emptyBoard">조회된 라우트가 없습니다.<br>Camp명이 maroowell_route_info.camp 값과 같은지 확인하세요.</div>`;
          return;
        }

        const rows=state.displayRows;
        const weekRowSpan=Math.max(rows.length,1);

        let html=`
          <table class="scheduleTable">
            <colgroup>
              <col style="width:120px">
              <col style="width:110px">
              <col style="width:160px">
              ${state.weekDates.map(()=>`<col style="width:130px">`).join("")}
            </colgroup>
            <thead>
              <tr>
                <th>Week</th>
                <th>Camp</th>
                <th class="routeHead">Route</th>
                ${state.weekDates.map((d,i)=>`
                  <th class="${i===0?"sun":""}">
                    <div class="dayHeader">
                      <div>${esc(dateLabel(d))}</div>
                      <div class="dayActions">
                        <button class="dayBtn share" type="button" data-day-action="share" data-date="${esc(d)}">공유</button>
                        <button class="dayBtn copy" type="button" data-day-action="copy" data-date="${esc(d)}">복사</button>
                        <button class="dayBtn paste" type="button" data-day-action="paste" data-date="${esc(d)}">붙여넣기</button>
                      </div>
                    </div>
                  </th>
                `).join("")}
              </tr>
            </thead>
            <tbody>
        `;

        rows.forEach((row,rowIndex)=>{
          const hasChildren=row.type==="parent"&&row.children&&row.children.length>0;
          const isExpanded=state.expanded.has(row.key);
          const routeClass=row.type==="child"?"childRoute":"";
          const offClass=row.isOff?"off":"";

          html+=`<tr class="${routeClass}">`;

          if(rowIndex===0){
            html+=`<td class="weekCell" rowspan="${weekRowSpan}">${esc(state.weekLabel)}</td>`;
            html+=`<td class="campCell" rowspan="${weekRowSpan}">${esc(state.camp)}</td>`;
          }

          html+=`
            <td class="routeCell ${offClass}">
              <div class="routeInner">
                <div class="routeLabel" title="${esc(row.description||row.memo||row.subPackage||"")}">
                  ${esc(row.label)}
                  ${row.type==="child"?`<span class="childBadge">${esc(row.subSub)}</span>`:""}
                </div>
                <button class="expander ${hasChildren?"":"empty"}" type="button" data-expand="${esc(row.key)}" title="서서브 펼치기/접기">${isExpanded?"▼":"▶"}</button>
              </div>
            </td>
          `;

          state.weekDates.forEach(date=>{
            const val=valueForCell(date,row.label);
            const has=!!compact(val);
            const isOff=row.isOff;
            const conflicts=isOff ? offConflictNames(date,val) : [];
            const conflict=conflicts.length>0;
            const bg=has&&!conflict?colorForValue(val):"";
            const color=has&&!conflict?textColorForBg(bg):"";
            const dirty=state.dirty.has(scheduleKey(date,row.label));
            const title=conflict
              ? `확인 필요: 휴무자인 ${conflicts.join(", ")}이(가) 같은 날짜 배정에 남아 있습니다.`
              : cellTitle(val);

            html+=`
              <td>
                <input
                  class="cellEdit ${has?"hasValue":""} ${dirty?"dirty":""} ${conflict?"offConflict":""}"
                  style="${has&&!conflict?`background:${bg};color:${color};`:""}"
                  value="${esc(val)}"
                  placeholder="-"
                  autocomplete="off"
                  data-date="${esc(date)}"
                  data-route="${esc(row.label)}"
                  data-row-order="${rowIndex}"
                  title="${esc(title)}"
                />
              </td>
            `;
          });

          html+=`</tr>`;
        });

        html+=`</tbody></table>`;
        els.tableHost.innerHTML=html;

        els.tableHost.querySelectorAll("[data-expand]").forEach(btn=>{
          btn.addEventListener("click",e=>{
            const key=e.currentTarget.dataset.expand;
            if(!key)return;
            if(state.expanded.has(key))state.expanded.delete(key);
            else state.expanded.add(key);
            render();
          });
        });

        els.tableHost.querySelectorAll(".cellEdit").forEach(input=>{
          input.addEventListener("input",onCellInput);
          input.addEventListener("focus",e=>{e.currentTarget.select();showSuggest(e.currentTarget)});
          input.addEventListener("keyup",e=>{
            if(e.key==="Escape"){hideSuggest();e.currentTarget.blur();return}
            showSuggest(e.currentTarget);
          });
        });

        els.tableHost.querySelectorAll("[data-day-action]").forEach(btn=>{
          btn.addEventListener("click",e=>{
            e.preventDefault();
            e.stopPropagation();
            const action=btn.dataset.dayAction;
            const date=btn.dataset.date;
            if(action==="share") sharePddForDate(date);
            if(action==="copy") copyDay(date);
            if(action==="paste") pasteDay(date);
          });
        });
      }

      function cellTitle(name){
        const d=resolveAccount(name);
        if(!d)return name||"";
        return [d.displayName,d.accountType?"구분: "+d.accountType:"",d.exportId?"ID: "+d.exportId:"",d.exportName?"엑셀 이름: "+d.exportName:""].filter(Boolean).join("\n");
      }

      function makeDirtyRecord({date,routeLabel,value,rowOrder,source}){
        const account=value?resolveAccount(value):null;
        return {
          schedule_date:date,
          camp:state.camp,
          wave:state.wave,
          route_label:normalizeRouteLabel(routeLabel),
          driver_name:value||null,
          driver_display_name:value||null,
          driver_owner_name:clean(source?.driver_owner_name)||account?.ownerName||value||null,
          driver_export_name:clean(source?.driver_export_name)||account?.exportName||value||null,
          driver_coupang_id:clean(source?.driver_coupang_id)||account?.exportId||null,
          driver_account_type:clean(source?.driver_account_type)||account?.accountType||null,
          memo:clean(source?.memo)||null,
          row_order:Number(rowOrder||source?.row_order||0),
          cell_color:value?colorForValue(value):null,
          is_active:!!value
        };
      }

      function applyInputVisual(input,value){
        const date=input.dataset.date;
        const routeLabel=normalizeRouteLabel(input.dataset.route);
        const has=!!compact(value);
        const isOff=isOffRoute(routeLabel);
        const conflicts=isOff ? offConflictNames(date,value) : [];
        const conflict=conflicts.length>0;

        input.classList.toggle("hasValue",has);
        input.classList.toggle("offConflict",conflict);

        if(!has){
          input.style.background="";
          input.style.color="";
          input.title="";
          return;
        }

        if(conflict){
          input.style.background="";
          input.style.color="";
          input.title=`확인 필요: 휴무자인 ${conflicts.join(", ")}이(가) 같은 날짜 배정에 남아 있습니다.`;
          return;
        }

        const bg=colorForValue(value);
        input.style.background=bg;
        input.style.color=textColorForBg(bg);
        input.title=cellTitle(value);
      }

      function refreshOffConflictForDate(date){
        const route=normalizeRouteLabel(OFF_ROUTE_LABEL);
        const input=els.tableHost.querySelector(`.cellEdit[data-date="${CSS.escape(date)}"][data-route="${CSS.escape(route)}"]`);
        if(input){
          applyInputVisual(input,clean(input.value));
        }
      }

      function onCellInput(e){
        const input=e.currentTarget;
        const date=input.dataset.date;
        const routeLabel=normalizeRouteLabel(input.dataset.route);
        const rowOrder=Number(input.dataset.rowOrder||0);
        const value=clean(input.value);
        const key=scheduleKey(date,routeLabel);

        state.dirty.set(key,makeDirtyRecord({date,routeLabel,value,rowOrder}));

        applyInputVisual(input,value);

        if(!isOffRoute(routeLabel)){
          refreshOffConflictForDate(date);
        }

        input.classList.add("dirty");
        updatePills();
      }

      function showSuggest(input){
        if(isOffRoute(input.dataset.route)){
          hideSuggest();
          return;
        }

        state.suggestInput=input;
        const q=keyOf(input.value);
        let list=state.driverAccounts.filter(acc=>!q||keyOf(acc.search).includes(q));
        if(!list.length&&q) list=state.driverAccounts.filter(acc=>keyOf(acc.ownerName).includes(q));
        list=list.slice(0,40);

        if(!list.length){hideSuggest();return}

        els.suggestBox.innerHTML=list.map((acc,idx)=>`
          <button class="suggestItem" type="button" data-idx="${idx}" data-display="${esc(acc.displayName)}">
            <div class="suggestTop">
              <span>${esc(acc.displayName)}</span>
              <span class="suggestType">${esc(acc.accountType)}</span>
            </div>
            <div class="suggestMeta">ID: ${esc(acc.exportId||"-")} · 엑셀 이름: ${esc(acc.exportName||"-")}</div>
          </button>
        `).join("");

        els.suggestBox.querySelectorAll(".suggestItem").forEach(btn=>{
          btn.addEventListener("mousedown",e=>{
            e.preventDefault();
            const display=btn.getAttribute("data-display")||"";
            if(state.suggestInput){
              state.suggestInput.value=display;
              onCellInput({currentTarget:state.suggestInput});
              state.suggestInput.focus();
            }
            hideSuggest();
          });
        });

        const rect=input.getBoundingClientRect();
        const width=Math.max(280,Math.min(360,rect.width+130));
        let left=rect.left,top=rect.bottom+6;
        if(left+width>window.innerWidth-8)left=window.innerWidth-width-8;
        if(top+290>window.innerHeight-8)top=Math.max(8,rect.top-296);
        els.suggestBox.style.left=`${Math.max(8,left)}px`;
        els.suggestBox.style.top=`${top}px`;
        els.suggestBox.style.width=`${width}px`;
        els.suggestBox.classList.add("open");
      }

      function hideSuggest(){
        els.suggestBox.classList.remove("open");
        els.suggestBox.innerHTML="";
        state.suggestInput=null;
      }

      function updatePills(){
        els.rowPill.textContent=`라우트 ${Math.max(0,state.displayRows.length-1)}`;
        els.dirtyPill.textContent=`미저장 ${state.dirty.size}`;
      }

