          return false;
        }

        return false;
      }

      function campMatches(infoCamp, selectedCamp){
        const a = compact(infoCamp).toUpperCase();
        const b = compact(selectedCamp).toUpperCase();
        if(!a || !b) return false;
        return a === b || a.includes(b) || b.includes(a);
      }

      function waveMatches(infoWave, selectedWave){
        const raw = compact(infoWave).toUpperCase();
        if(!raw) return true;

        const selected = normalizeWave(selectedWave);
        const aliases = WAVE_ALIASES[selected] || [selected];

        return aliases.some(x => raw === compact(x).toUpperCase() || raw.includes(compact(x).toUpperCase()));
      }

      function parseSubAccounts(v){
        const raw = clean(v);
        if(!raw) return [];

        return raw
          .split(/[\n;]+/)
          .map(s => clean(s))
          .filter(Boolean)
          .flatMap(line => {
            if(line.includes(",")){
              const parts = line.split(",").map(x => clean(x)).filter(Boolean);
              if(parts.length >= 2 && parts.every(x => !/[/:：]/.test(x))){
                return parts.map(x => ({ id:x, adminName:"" }));
              }
            }
            return [line];
          })
          .map(item => {
            if(typeof item === "object") return item;

            const text = clean(item);
            const slash = text.split(/\s*[/／]\s*/).map(x => clean(x)).filter(Boolean);
            if(slash.length >= 2){
              return { id:slash[0], adminName:slash.slice(1).join(" / ") };
            }

            const colon = text.split(/\s*[:：]\s*/).map(x => clean(x)).filter(Boolean);
            if(colon.length >= 2){
              return { id:colon[0], adminName:colon.slice(1).join(" ") };
            }

            const parts = text.split(/\s+/).map(x => clean(x)).filter(Boolean);
            if(parts.length >= 2){
              return { id:parts[0], adminName:parts.slice(1).join(" ") };
            }

            return { id:text, adminName:"" };
          })
          .filter(x => x.id || x.adminName);
      }

      function buildDriverAccounts(){
        state.driverAccounts = [];
        state.accountByDisplay.clear();
        state.accountByExportName.clear();
        state.accountById.clear();
        state.personColorMap.clear();

        const drivers = state.driversRaw
          .map(r => ({
            raw:r,
            name:clean(r.person_name || r.name),
            camp:clean(r.camp_code || r.camp),
            wave:clean(r.wave_raw || r.wave),
            coupangId:clean(r.coupang_id),
            subAccounts:Array.isArray(r.sub_accounts) ? r.sub_accounts.map(x => {
              if(typeof x === "object") return x;
              return parseSubAccounts(x)[0] || { id:clean(x), adminName:"" };
            }) : parseSubAccounts(r.sub_account_info),
            position:clean(r.position_title)
          }))
          .filter(d => d.name)
          .sort((a,b) => {
            const aw = waveMatches(a.wave, state.wave) ? 0 : 1;
            const bw = waveMatches(b.wave, state.wave) ? 0 : 1;
            if(aw !== bw) return aw - bw;
            return sortText(a.name, b.name);
          });

        const seen = new Set();

        for(const d of drivers){
          const baseName = d.name;
          assignColorKey(baseName);

          const mainAccount = {
            displayName:baseName,
            ownerName:baseName,
            exportName:baseName,
            exportId:d.coupangId,
            accountType:"본계정",
            colorKey:baseName,
            camp:d.camp,
            wave:d.wave,
            search:[baseName, d.coupangId, d.camp, d.wave, "본계정"].join(" ")
          };

          addAccount(mainAccount, seen);

          d.subAccounts.forEach((sub, idx) => {
            const subNo = idx + 2;
            const subId = clean(sub.id);
            const adminName = clean(sub.adminName);
            const displayName = `${baseName}${subNo}`;

            const account = {
              displayName,
              ownerName:baseName,
              exportName:adminName || baseName,
              exportId:subId,
              accountType:"서브계정",
              colorKey:baseName,
              camp:d.camp,
              wave:d.wave,
              search:[displayName, baseName, adminName, subId, d.camp, d.wave, "서브계정"].join(" ")
            };

            addAccount(account, seen);
          });
        }

        state.driverAccounts.sort((a,b) => {
          const ao = sortText(a.ownerName, b.ownerName);
          if(ao !== 0) return ao;
          return sortText(a.displayName, b.displayName);
        });

        for(const acc of state.driverAccounts){
          state.accountByDisplay.set(keyOf(acc.displayName), acc);
          if(acc.exportName) state.accountByExportName.set(keyOf(acc.exportName), acc);
          if(acc.exportId) state.accountById.set(keyOf(acc.exportId), acc);
        }
      }

      function addAccount(account, seen){
        const k = keyOf(account.displayName);
        if(!k || seen.has(k)) return;
        seen.add(k);
        state.driverAccounts.push(account);
      }

      function resolveAccount(value){
        const raw = clean(value);
        if(!raw) return null;

        const k = keyOf(raw);

        return (
          state.accountByDisplay.get(k) ||
          state.accountByExportName.get(k) ||
          state.accountById.get(k) ||
          {
            displayName:raw,
            ownerName:raw,
            exportName:raw,
            exportId:"",
            accountType:"직접입력",
            colorKey:raw,
            search:raw
          }
        );
      }

      function buildRoutes(){
        const rows = state.routesRaw
          .filter(r => r.is_active !== false)
          .filter(r => campMatches(r.camp, state.camp))
          .sort((a,b) => {
            const so = Number(a.sort_order || 0) - Number(b.sort_order || 0);
            if(so !== 0) return so;

            const aParent = clean(a.parent_route_label) || routeBaseLabel(a.route, a.sub);
            const bParent = clean(b.parent_route_label) || routeBaseLabel(b.route, b.sub);
            const parentCmp = sortText(aParent, bParent);
            if(parentCmp !== 0) return parentCmp;

            const aSub = clean(a.sub_sub);
            const bSub = clean(b.sub_sub);
            return sortText(aSub, bSub);
          });

        const parentMap = new Map();

        for(const r of rows){
          const parentLabel = normalizeRouteLabel(
            clean(r.parent_route_label) ||
            routeBaseLabel(r.route, r.sub) ||
            clean(r.route_label)
          );

          const childLabel = normalizeRouteLabel(
            clean(r.route_label) ||
            routeChildLabel(r.route, r.sub, r.sub_sub)
          );

          if(!parentLabel && !childLabel) continue;

          const key = parentLabel || childLabel;

          if(!parentMap.has(key)){
            parentMap.set(key, {
              key,
              route:String(r.route || ""),
              sub:String(r.sub || ""),
              label:key,
              description:clean(r.description),
              memo:clean(r.memo),
              subPackage:clean(r.sub_package),
              sortOrder:Number(r.sort_order || 0),
              children:[]
            });
          }

          const parent = parentMap.get(key);
          const subSub = clean(r.sub_sub);
          const isChild = subSub && childLabel && childLabel !== key;

          if(isChild){
            parent.children.push({
              key:childLabel,
              route:String(r.route || ""),
              sub:String(r.sub || ""),
              subSub,
              label:childLabel,
              description:clean(r.description),
              memo:clean(r.memo),
              subPackage:clean(r.sub_package),
              sortOrder:Number(r.sort_order || 0)
            });
          }
        }

        state.routeParents = Array.from(parentMap.values()).map(p => {
          const dedup = new Map();

          for(const c of p.children){
            if(!dedup.has(c.key)) dedup.set(c.key, c);
          }

          p.children = Array.from(dedup.values())
            .sort((a,b) => sortText(a.subSub, b.subSub) || sortText(a.label, b.label));

          return p;
        });

        buildDisplayRows();
      }

      function buildDisplayRows(){
        const q = compact(els.searchInput.value).toUpperCase();
        const out = [];

        for(const p of state.routeParents){
          const parentMatch = !q || compact(p.label + p.description + p.memo + p.subPackage).toUpperCase().includes(q);
          const childMatches = p.children.filter(c => {
            if(!q) return true;
            return compact(c.label + c.description + c.memo + c.subPackage).toUpperCase().includes(q);
          });

          if(parentMatch || childMatches.length){
            out.push({ type:"parent", ...p });

            if(state.expanded.has(p.key)){
              const childrenToShow = q ? childMatches : p.children;
              for(const c of childrenToShow){
                out.push({ type:"child", parentKey:p.key, ...c });
              }
            }
          }
        }

        state.displayRows = out;
      }

      function allRouteLabels(){
        const labels = [];

        for(const p of state.routeParents){
          labels.push(p.label);
          for(const c of p.children || []){
            labels.push(c.label);
          }
        }

        return Array.from(new Set(labels.map(normalizeRouteLabel).filter(Boolean)));
      }

      function scheduleKey(date, routeLabel){
        return `${date}||${state.camp}||${state.wave}||${normalizeRouteLabel(routeLabel)}`;
      }

      function scheduleLookupKey(date, routeLabel){
        return `${date}||${state.wave}||${normalizeRouteLabel(routeLabel)}`;
      }

      function makeScheduleMap(){
        state.scheduleMap.clear();

        for(const r of state.schedules){
          const normalizedWave = normalizeWave(r.wave);
          const route = normalizeRouteLabel(r.route_label);
          const key = `${r.schedule_date}||${normalizedWave}||${route}`;
          state.scheduleMap.set(key, r);

          const displayName = clean(r.driver_display_name || r.driver_name);
          if(displayName){
            assignColorKey(resolveAccount(displayName)?.colorKey || displayName);
          }
        }
      }

      async function loadAll(){
        state.camp = clean(els.campInput.value);
        state.wave = normalizeWave(els.waveSelect.value);
        els.waveSelect.value = state.wave;
        updateWeekState();

        if(!state.camp){
          alert("Camp를 입력하세요.");
