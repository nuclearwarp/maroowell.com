<!doctype html>
<html lang="ko">
<head>
  <script>
    (() => {
      try {
        if (new URLSearchParams(location.search).get("embed") === "1") {
          document.documentElement.classList.add("mw-embed");
        }
      } catch {}
    })();
  </script>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>마루웰 회수율 업로드</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

  <style>
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --card:#ffffff;
      --soft:#f8fafc;
      --line:#d8e0ee;
      --line2:#cbd5e1;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --green:#16a34a;
      --red:#dc2626;
      --shadow:0 12px 30px rgba(15,23,42,.08);
      --font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      min-height:100vh;
      background:
        radial-gradient(circle at 16% 0%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 86% 0%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,#f6f8fc 100%);
      color:var(--txt);
      font-family:var(--font);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
      font-weight:400;
    }

    body,
    input,
    select,
    table,
    th,
    td,
    pre,
    button,
    .title,
    .sub,
    .sectionTitle,
    .field label,
    .summaryLabel,
    .summaryValue,
    .pill,
    .muted,
    .guideBox,
    .status,
    .percent,
    .kindDaily,
    .kindTotal,
    .badCell{
      font-weight:400 !important;
      letter-spacing:-0.015em !important;
      text-shadow:none !important;
      -webkit-text-stroke:0 transparent !important;
    }

    b,strong{font-weight:520}

    .wrap{
      max-width:1540px;
      margin:0 auto;
      padding:18px 16px 44px;
    }

    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:16px;
      padding:14px 16px;
      border:1px solid var(--line);
      border-radius:22px;
      background:rgba(255,255,255,.96);
      box-shadow:var(--shadow);
      backdrop-filter:blur(12px);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .brand a{
      display:flex;
      align-items:center;
      justify-content:center;
      width:34px;
      height:34px;
      min-width:34px;
      border:0;
      border-radius:0;
      background:transparent;
      box-shadow:none;
      padding:0;
    }

    .brand img{
      width:32px;
      height:32px;
      object-fit:contain;
      filter:drop-shadow(0 2px 4px rgba(15,23,42,.10));
    }

    .title{
      color:#0f172a;
      font-size:24px;
      font-weight:520 !important;
      letter-spacing:-.04em !important;
      line-height:1.15;
      word-break:keep-all;
    }

    .sub{
      color:#64748b;
      font-size:13px;
      margin-top:5px;
      line-height:1.45;
      word-break:keep-all;
    }

    .grid{
      display:grid;
      grid-template-columns:minmax(360px,430px) 1fr;
      gap:16px;
      align-items:start;
    }

    .card{
      background:rgba(255,255,255,.96);
      border:1px solid var(--line);
      border-radius:20px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:var(--shadow);
    }

    .sectionTitle{
      font-size:17px;
      font-weight:520 !important;
      letter-spacing:-.03em;
      margin:0 0 12px;
      display:flex;
      align-items:center;
      gap:8px;
    }

    .sectionTitle::before{
      content:"";
      width:8px;
      height:20px;
      border-radius:999px;
      background:linear-gradient(180deg,#60a5fa,#2563eb);
      display:inline-block;
    }

    .field{margin-bottom:12px}

    .field label{
      display:block;
      font-size:12px;
      color:#64748b;
      font-weight:450 !important;
      margin:0 0 6px 2px;
    }

    input,select{
      width:100%;
      height:42px;
      border-radius:12px;
      border:1px solid var(--line2);
      background:#f8fafc;
      color:#0f172a;
      padding:0 12px;
      outline:none;
      font-family:var(--font);
      font-size:13px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.75);
    }

    input[type=file]{
      height:auto;
      min-height:42px;
      padding:10px 12px;
      cursor:pointer;
    }

    input::placeholder{color:#94a3b8}
    select option{background:#fff;color:#0f172a}

    input:focus,select:focus{
      border-color:#60a5fa;
      background:#fff;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
    }

    .row{
      display:flex;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    button{
      min-height:42px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:#fff;
      color:#0f172a;
      padding:0 18px;
      font-family:var(--font);
      font-size:13px;
      font-weight:480 !important;
      cursor:pointer;
      white-space:nowrap;
      box-shadow:0 1px 0 rgba(255,255,255,.85),0 4px 12px rgba(15,23,42,.05);
    }

    button:hover{background:#f8fbff;border-color:#93c5fd}
    button.primary{background:linear-gradient(180deg,#3b82f6,#2563eb);border-color:#2563eb;color:#fff;box-shadow:0 8px 18px rgba(37,99,235,.18)}
    button.primary:hover{background:linear-gradient(180deg,#2563eb,#1d4ed8)}
    button.ok{background:linear-gradient(180deg,#22c55e,#16a34a);border-color:#16a34a;color:#fff;box-shadow:0 8px 18px rgba(22,163,74,.18)}
    button.ok:hover{background:linear-gradient(180deg,#22c55e,#15803d)}
    button.secondary{background:#f8fafc;color:#334155}
    button.secondary:hover{background:#eff6ff;color:#0f172a}
    button.danger{background:#fff5f5;border-color:#fecaca;color:#dc2626}
    button.danger:hover{background:#fee2e2}

    .status{
      font-size:13px;
      color:#64748b;
      margin-top:10px;
      line-height:1.55;
      white-space:pre-wrap;
      word-break:keep-all;
    }

    .status.ok{color:#15803d}
    .status.bad{color:#dc2626}
    .status.warn{color:#a16207}

    .muted{
      color:#64748b;
      line-height:1.55;
      font-size:13px;
      word-break:keep-all;
    }

    .pill{
      display:inline-flex;
      align-items:center;
