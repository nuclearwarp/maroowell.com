        hideSuggest();

        state.loading = true;
        setState("warn","LOAD");
        setStatus("스케줄 데이터를 불러오는 중입니다.");
        els.btnLoad.disabled = true;
        els.btnSave.disabled = true;

        try{
          const params = new URLSearchParams({
            camp:state.camp,
            wave:state.wave,
            week_start:state.weekStart
          });

          const json = await apiFetch("/schedule/week?" + params.toString());

          state.routesRaw = json.routes || [];
          state.schedules = (json.schedules || []).map(r => ({
            ...r,
            wave:normalizeWave(r.wave),
            route_label:normalizeRouteLabel(r.route_label)
          }));
          state.driversRaw = json.drivers || [];

          buildDriverAccounts();
          makeScheduleMap();
          buildRoutes();
          render();

          setState("ok","READY");
          setStatus(`조회 완료: 라우트 ${state.routeParents.length}개 / 스케줄 ${state.schedules.length}개 / 계정 ${state.driverAccounts.length}개`);
        } catch(e){
          console.error(e);
          setState("err","ERROR");
          setStatus("불러오기 실패: " + (e?.message || e));
          alert("불러오기 실패: " + (e?.message || e));
        } finally {
          state.loading = false;
          els.btnLoad.disabled = false;
          els.btnSave.disabled = false;
        }
      }

      function render(){
        buildDisplayRows();
        renderHeader();
        renderTable();
        updatePills();
