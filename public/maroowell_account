      function summaryPill(label,value,cls){return`<div class="pill"><span>${esc(label)}</span><b class="${cls||""}">${esc(value)}</b></div>`}function renderSummary(){const s=state.stats?.total||newMetric(),p=getSelectedPeriod(),pt=p.range==="year"?`${p.date_year}년`:`${p.date_year}.${String(p.date_month).padStart(2,"0")}`;els.summaryGrid.innerHTML=[summaryPill("조회 범위",pt,"blueText"),summaryPill("집계 행",count(s.rows)),summaryPill("일자 수",count(s.days)),summaryPill("배송",count(s.parcel)),summaryPill("반품",count(s.return)),summaryPill("총수량",count(s.quantity),"money"),summaryPill("일평균",s.avg_day?s.avg_day.toLocaleString("ko-KR",{maximumFractionDigits:1}):"0","warnText"),summaryPill("총금액",money(s.settlement_total),"money")].join("")}
