<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />
  <title>정산 업로드</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --card:#ffffff;
      --line:#d8e0ee;
      --line2:#cbd5e1;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --green:#16a34a;
      --red:#dc2626;
      --yellow:#a16207;
      --purple:#7c3aed;
      --shadow:0 12px 30px rgba(15,23,42,.08);
      --font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      min-height:100%;
      background:
        radial-gradient(circle at 16% 0%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 86% 0%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,#f6f8fc 100%);
      color:var(--txt);
      font-family:var(--font);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
    }

    body{overflow:auto}

    body,
    button,
    input,
    select,
    table,
    th,
    td,
    .brandText h1,
    .brandText p,
    .btn,
    .status,
    .muted,
    .pill,
    .pill span,
    .pill b,
    .checkLine{
      font-weight:400 !important;
      letter-spacing:-0.018em;
      text-shadow:none;
      -webkit-text-stroke:0 transparent;
    }

    b,strong{font-weight:520}

    .app{
      min-height:100dvh;
      background:transparent;
    }

    .topbar{
      position:sticky;
      top:0;
      z-index:30;
      display:flex;
      align-items:center;
      gap:12px;
      padding:12px 16px;
      border-bottom:1px solid var(--line);
      background:rgba(255,255,255,.94);
      box-shadow:0 8px 24px rgba(15,23,42,.06);
      backdrop-filter:blur(12px);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .logoButton{
      width:38px;
      height:38px;
      border:0;
      border-radius:12px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      flex:0 0 auto;
      cursor:pointer;
      background:transparent;
    }

    .logoButton:hover{background:#f8fafc}

    .logoButton img{
      width:32px;
      height:32px;
      display:block;
      filter:drop-shadow(0 4px 8px rgba(15,23,42,.10));
    }

    .brandText{min-width:0}

    .brandText h1{
      margin:0;
      font-size:25px;
      line-height:1.08;
      letter-spacing:-.045em;
      color:#0f172a;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .brandText p{
      margin:5px 0 0;
      color:#64748b;
      font-size:12px;
      line-height:1.35;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .topSpacer{flex:1}

    .userBadge{
      display:inline-flex;
      align-items:center;
      min-height:34px;
      max-width:280px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid var(--line);
      background:#f8fafc;
      color:#64748b;
      font-size:12px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      flex:0 1 auto;
    }

    .btn{
      min-height:40px;
      padding:0 16px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      font-size:13px;
      cursor:pointer;
      white-space:nowrap;
      touch-action:manipulation;
      box-shadow:0 1px 0 rgba(255,255,255,.85),0 4px 12px rgba(15,23,42,.04);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      line-height:1.1;
      font-family:var(--font);
    }

    .btn:hover{background:#f8fbff;border-color:#93c5fd}
    .btn.primary{background:linear-gradient(180deg,#3b82f6,#2563eb);border-color:#2563eb;color:#fff;box-shadow:0 8px 18px rgba(37,99,235,.18)}
    .btn.ok{background:linear-gradient(180deg,#22c55e,#16a34a);border-color:#16a34a;color:#fff;box-shadow:0 8px 18px rgba(22,163,74,.16)}
    .btn.warn{background:#fffbeb;border-color:#fde68a;color:#a16207}
    .btn.copy{background:#ecfeff;border-color:#a5f3fc;color:#0e7490}
    .btn.danger{background:#fff5f5;border-color:#fecaca;color:#dc2626}
    .btn:disabled{opacity:.58;cursor:not-allowed;box-shadow:none}

    .main{
      max-width:1680px;
      margin:0 auto;
      padding:16px 14px 44px;
    }

    .layout{
      display:grid;
      grid-template-columns:430px minmax(0,1fr);
      gap:14px;
      align-items:start;
    }

    .card{
      border:1px solid var(--line);
      border-radius:20px;
      background:rgba(255,255,255,.94);
      box-shadow:var(--shadow);
      overflow:hidden;
      margin-bottom:14px;
      backdrop-filter:blur(12px);
    }

    .cardHead{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:14px 16px;
      border-bottom:1px solid #edf2f7;
      background:#ffffff;
    }

    .cardHead h2{
      margin:0;
      color:#0f172a;
      font-size:18px;
      font-weight:480 !important;
      letter-spacing:-.035em;
      line-height:1.15;
    }

    .cardBody{padding:16px}

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
      margin-bottom:12px;
    }

    .field label{
      color:#64748b;
      font-size:12px;
      font-weight:420 !important;
      margin-left:2px;
    }

    .input,.select{
      width:100%;
      min-height:42px;
      border-radius:13px;
      border:1px solid #cbd5e1;
      background:#f8fafc;
      color:#0f172a;
      padding:0 12px;
      font-size:13px;
      outline:none;
      font-family:var(--font);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.75);
    }

    .input[type=file]{
      height:auto;
      padding:10px 12px;
      line-height:1.5;
    }

    .select option{
      background:#fff;
      color:#0f172a;
    }

    .input:focus,.select:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
      background:#fff;
    }

    .twoCols{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .row{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      align-items:center;
      margin-top:12px;
    }

    .checkLine{
      display:grid;
      grid-template-columns:auto 1fr;
      gap:9px;
      align-items:start;
      padding:11px 12px;
      border:1px solid #d8e0ee;
      border-radius:15px;
      background:#f8fafc;
      color:#334155;
      font-size:12px;
      line-height:1.5;
      margin-bottom:10px;
    }

    .checkLine input{
      width:16px;
      height:16px;
      margin-top:2px;
      accent-color:#2563eb;
    }

    .status{
      margin-top:12px;
      color:#64748b;
      font-size:13px;
      line-height:1.55;
      white-space:pre-wrap;
    }

    .status.ok{color:#15803d}
    .status.warn{color:#a16207}
    .status.err{color:#dc2626}

    .muted{
      color:#64748b;
      font-size:12px;
      line-height:1.55;
    }

    .pillGrid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:8px;
      margin-top:12px;
    }

    .pill{
      min-width:0;
      padding:10px;
      border-radius:15px;
      border:1px solid var(--line);
      background:#f8fafc;
    }

    .pill span{
      display:block;
      color:#64748b;
      font-size:11px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .pill b{
      display:block;
      margin-top:5px;
      font-size:18px;
      line-height:1;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .errorBox{
      display:none;
      border:1px solid #fecaca;
      border-radius:18px;
      background:#fff5f5;
      padding:12px;
      margin-bottom:14px;
    }

    .errorBox.show{display:block}

    .errorBox h3{
      margin:0 0 8px;
      color:#dc2626;
      font-size:15px;
      font-weight:520 !important;
    }

    .errorList{
      display:grid;
      gap:7px;
      max-height:260px;
      overflow:auto;
    }

    .errorItem{
      border:1px solid #fecaca;
      border-radius:13px;
      background:#ffffff;
      padding:9px 10px;
      color:#991b1b;
      font-size:12px;
      line-height:1.45;
    }

    .errorItem b{color:#111827;font-weight:520!important}
    .errorItem small{display:block;color:#dc2626;margin-top:3px}

    .tableWrap{
      width:100%;
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:#ffffff;
      max-height:720px;
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:100%;
      min-width:1540px;
      font-size:12px;
      color:#0f172a;
    }

    th,td{
      border-right:1px solid #d8e0ee;
      border-bottom:1px solid #d8e0ee;
      padding:7px 8px;
      text-align:center;
      white-space:nowrap;
      vertical-align:middle;
    }

    th{
      position:sticky;
      top:0;
      z-index:2;
      background:#dbeafe;
      color:#0f172a;
      font-weight:460 !important;
    }

    td{
      background:#ffffff;
      color:#0f172a;
      font-weight:380 !important;
    }

    tbody tr:nth-child(even) td{
      background:#f8fafc;
    }

    tr.invalid td{
      background:#fff5f5!important;
      color:#991b1b;
    }

    tr.exempt td{
      background:#fffbeb!important;
    }

    tr:hover td{
      background:#eff6ff!important;
    }

    .left{text-align:left}
    .money{font-variant-numeric:tabular-nums;text-align:right}
    .okText{color:#15803d;font-weight:520!important}
    .warnText{color:#a16207;font-weight:520!important}
    .badText{color:#dc2626;font-weight:520!important}
    .infoText{color:#2563eb;font-weight:520!important}
    .emptyBox{padding:30px 12px;text-align:center;color:#64748b}

    .progressBox{
      height:10px;
      border-radius:999px;
      background:#e2e8f0;
      overflow:hidden;
      margin-top:12px;
      display:none;
    }

    .progressBox.show{
      display:block;
    }

    .progressBar{
      height:100%;
      width:0%;
      background:linear-gradient(90deg,#3b82f6,#22c55e);
      transition:width .18s ease;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg,rgba(246,248,252,.96),rgba(255,255,255,.98));
      z-index:2147483000;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(540px, calc(100vw - 24px));
      border:1px solid var(--line);
      border-radius:22px;
      background:#fff;
      box-shadow:0 24px 70px rgba(15,23,42,.16);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 10px;
      font-size:24px;
      line-height:1.2;
      font-weight:520;
    }

    .accessCard p{
      margin:0;
      color:#64748b;
      line-height:1.65;
      white-space:pre-wrap;
      font-size:14px;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid var(--line);
      background:#f8fafc;
      color:#0f172a;
      font-size:13px;
      line-height:1.6;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media(max-width:1080px){
      .layout{grid-template-columns:1fr}
      .topbar{padding:10px;flex-wrap:wrap;align-items:flex-start}
      .brand{width:100%}
      .brandText h1{font-size:21px;white-space:normal}
      .brandText p{font-size:12px;white-space:normal}
      .topSpacer{display:none}
      .userBadge{max-width:100%;margin-left:50px}
    }

    @media(max-width:560px){
      .main{padding:10px 8px 34px}
      .twoCols{grid-template-columns:1fr}
      .row .btn{width:100%}
      .pillGrid{grid-template-columns:1fr}
      .topbar .btn{min-height:34px;padding:0 10px;font-size:12px}
      .card,.tableWrap{border-radius:18px}
    }
  </style>
</head>

<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기">
          <img src="/favicon.ico" alt="Maroowell" />
        </a>
        <div class="brandText">
          <h1>정산 업로드</h1>
          <p>정산원천데이터 / 분실및파손 추출 · 월별 등록 · 금액 교차검증</p>
        </div>
      </div>
      <div class="topSpacer"></div>
      <div id="userBadge" class="userBadge">세션 확인 중</div>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <main class="main">
      <div class="layout">
        <section>
          <div class="card">
            <div class="cardHead">
              <h2>정산서 파일</h2>
            </div>
            <div class="cardBody">
              <div class="twoCols">
                <div class="field">
                  <label for="yearSelect">정산 연도</label>
                  <select id="yearSelect" class="select"></select>
                </div>
                <div class="field">
                  <label for="monthSelect">정산 월</label>
                  <select id="monthSelect" class="select"></select>
                </div>
              </div>

              <div class="field">
                <label for="fileInput">정산서 파일</label>
                <input id="fileInput" class="input" type="file" accept=".xlsx,.xls" />
              </div>

              <div class="checkLine">
                <input id="maroowellOnlyCheck" type="checkbox" checked />
                <div>
                  업체명이 <b>마루웰</b>인 행만 업로드합니다.<br>
                  업체명 컬럼이 비어 있으면 행은 유지합니다.
                </div>
              </div>

              <div class="checkLine">
                <input id="replaceMonthCheck" type="checkbox" checked />
                <div>
                  업로드 전 <b>선택 연도/월 데이터만 삭제 후 재등록</b><br>
                  정산 조회와 같은 <b>maroowellaccount 백엔드</b>를 통해 저장합니다.
                </div>
              </div>

              <div class="row">
                <button id="btnParse" class="btn primary" type="button">정산서 읽기</button>
                <button id="btnUpload" class="btn ok" type="button" disabled>백엔드 업로드</button>
                <button id="btnReset" class="btn" type="button">초기화</button>
              </div>

              <div id="progressBox" class="progressBox">
                <div id="progressBar" class="progressBar"></div>
              </div>

              <div id="statusText" class="status">정산서 파일을 선택하고 정산서 읽기를 누르세요.</div>

              <div class="pillGrid">
                <div class="pill"><span>추출 행</span><b id="countRows">0</b></div>
                <div class="pill"><span>검증 오류</span><b id="countErrors">0</b></div>
                <div class="pill"><span>예외 행</span><b id="countExempt">0</b></div>
                <div class="pill"><span>스킵 행</span><b id="countSkipped">0</b></div>
                <div class="pill"><span>기본금액</span><b id="sumDefault">0</b></div>
                <div class="pill"><span>프백 인센티브</span><b id="sumFreshbagIncentive">0</b></div>
                <div class="pill"><span>프백 회수</span><b id="sumFreshbagReturn">0</b></div>
                <div class="pill"><span>정산합계</span><b id="sumTotal">0</b></div>
              </div>
            </div>
          </div>
        </section>

        <section>
          <div id="validationBox" class="errorBox">
            <h3>금액 검증 오류</h3>
            <div id="validationList" class="errorList"></div>
          </div>

          <div class="card">
            <div class="cardHead">
              <h2>미리보기</h2>
              <span class="muted" id="previewNote">최대 500행 표시 / 오류 상단 · 예외 하단</span>
            </div>
            <div class="tableWrap">
              <table id="previewTable">
                <thead></thead>
                <tbody>
                  <tr><td><div class="emptyBox">아직 추출된 데이터가 없습니다.</div></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">최고관리자 권한이 필요합니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="deniedHomeBtn" class="btn" type="button">홈으로</button>
        <button id="deniedLogoutBtn" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function(){
      "use strict";

      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY;
      const LOGIN_PATH = CONFIG.PATHS?.login || "/login.html";
      const HOME_PATH = CONFIG.PATHS?.index || "/zipcode_search";
      const ACCOUNT_API_BASE = String(
        CONFIG.MAROOWELL_ACCOUNT_API_BASE ||
        CONFIG.ACCOUNT_API_BASE ||
        CONFIG.BACKENDS?.maroowellAccount ||
        CONFIG.BACKENDS?.maroowell_account ||
        "https://maroowellaccount.brain-0f6.workers.dev"
      ).replace(/\/+$/, "");

      const REQUIRED_SHEET_NAME = "정산원천데이터";
      const LOSS_SHEET_NAME = "분실및파손";
      const UPLOAD_CHUNK_SIZE = 500;
      const MONEY_TOLERANCE = 1;

      const els = {
        userBadge: document.getElementById("userBadge"),
        btnLogout: document.getElementById("btnLogout"),
        yearSelect: document.getElementById("yearSelect"),
        monthSelect: document.getElementById("monthSelect"),
        fileInput: document.getElementById("fileInput"),
        maroowellOnlyCheck: document.getElementById("maroowellOnlyCheck"),
        replaceMonthCheck: document.getElementById("replaceMonthCheck"),
        btnParse: document.getElementById("btnParse"),
        btnUpload: document.getElementById("btnUpload"),
        btnReset: document.getElementById("btnReset"),
        progressBox: document.getElementById("progressBox"),
        progressBar: document.getElementById("progressBar"),
        statusText: document.getElementById("statusText"),
        previewTable: document.getElementById("previewTable"),
        previewNote: document.getElementById("previewNote"),
        validationBox: document.getElementById("validationBox"),
        validationList: document.getElementById("validationList"),
        countRows: document.getElementById("countRows"),
        countErrors: document.getElementById("countErrors"),
        countExempt: document.getElementById("countExempt"),
        countSkipped: document.getElementById("countSkipped"),
        sumDefault: document.getElementById("sumDefault"),
        sumFreshbagIncentive: document.getElementById("sumFreshbagIncentive"),
        sumFreshbagReturn: document.getElementById("sumFreshbagReturn"),
        sumTotal: document.getElementById("sumTotal"),
        accessDenied: document.getElementById("accessDenied"),
        accessDeniedText: document.getElementById("accessDeniedText"),
        accessDeniedEmail: document.getElementById("accessDeniedEmail"),
        deniedHomeBtn: document.getElementById("deniedHomeBtn"),
        deniedLogoutBtn: document.getElementById("deniedLogoutBtn")
      };

      const state = {
        user:null,
        session:null,
        access:null,
        rows:[],
        skipped:[],
        fileName:"",
        canUpload:false
      };

      const supabaseClient = SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth:{
              storage:window.sessionStorage,
              persistSession:true,
              autoRefreshToken:true,
              detectSessionInUrl:true
            }
          })
        : null;

      function clean(v){ return String(v ?? "").trim(); }
      function compact(v){ return clean(v).replace(/\s+/g,"").replace(/_/g,"").toLowerCase(); }
      function esc(v){ return String(v ?? "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#39;"); }

      function setStatus(message, type = ""){
        els.statusText.textContent = message;
        els.statusText.className = type ? "status " + type : "status";
      }

      function setProgress(done, total){
        if(!total){
          els.progressBox.classList.remove("show");
          els.progressBar.style.width = "0%";
          return;
        }
        els.progressBox.classList.add("show");
        const pct = Math.max(0, Math.min(100, (done / total) * 100));
        els.progressBar.style.width = pct.toFixed(1) + "%";
      }

      function log(){
        // 화면을 단순하게 유지하기 위해 내부 로그는 UI에 출력하지 않습니다.
      }

      function money(v){
        const n = Number(v || 0);
        if(!Number.isFinite(n)) return "0";
        return Math.round(n).toLocaleString("ko-KR");
      }

      function parseNumber(v){
        if(v === null || v === undefined || v === "") return 0;
        if(typeof v === "number"){
          return Number.isFinite(v) ? v : 0;
        }

        const s = clean(v)
          .replace(/,/g,"")
          .replace(/원/g,"")
          .replace(/₩/g,"")
          .replace(/\s+/g,"");

        if(!s || s === "-" || s === ".") return 0;

        const n = Number(s.replace(/[^\d.-]/g,""));
        return Number.isFinite(n) ? n : 0;
      }

      function parseIntCount(v){ return Math.round(parseNumber(v)); }
      function hasValue(v){ return !(v === null || v === undefined || clean(v) === ""); }
      function roundMoney(v){ const n = Number(v || 0); return Number.isFinite(n) ? Math.round(n) : 0; }
      function normalizeRoute(v){ return clean(v).toUpperCase().replace(/[^0-9A-Z가-힣]/g, ""); }
      function pad2(v){ return String(Number(v)).padStart(2, "0"); }

      function excelSerialToIso(serial){
        const n = Number(serial);
        if(!Number.isFinite(n)) return null;

        const utcDays = Math.floor(n - 25569);
        const dateInfo = new Date(utcDays * 86400 * 1000);

        if(Number.isNaN(dateInfo.getTime())) return null;

        return `${dateInfo.getUTCFullYear()}-${pad2(dateInfo.getUTCMonth() + 1)}-${pad2(dateInfo.getUTCDate())}`;
      }

      function parseDateValue(v){
        if(v instanceof Date && !Number.isNaN(v.getTime())){
          return `${v.getFullYear()}-${pad2(v.getMonth() + 1)}-${pad2(v.getDate())}`;
        }

        if(typeof v === "number") return excelSerialToIso(v);

        const s = clean(v);
        if(!s) return null;

        if(/^\d{5}(\.\d+)?$/.test(s)) return excelSerialToIso(Number(s));

        let m = s.match(/(20\d{2})[.\-/년\s]+(\d{1,2})[.\-/월\s]+(\d{1,2})/);
        if(m) return `${m[1]}-${pad2(m[2])}-${pad2(m[3])}`;

        m = s.match(/^(\d{1,2})[.\-/월]\s*(\d{1,2})/);
        if(m){
          const year = Number(els.yearSelect.value || new Date().getFullYear());
          return `${year}-${pad2(m[1])}-${pad2(m[2])}`;
        }

        return null;
      }

      function isBlankDataRow(row){
        return !row || row.every(v => !hasValue(v));
      }

      function isUncontractedRoute(classify){
        const key = compact(classify);
        return key.includes("미계약") || key.includes("미계약라우트");
      }

      function isFreshbagIncentiveRow(classify){
        const key = compact(classify);
        return (
          key.includes("프레시백") ||
          key.includes("프레쉬백") ||
          key.includes("freshbag") ||
          key.includes("인센티브")
        );
      }

      function findColumnContains(headers, names, fallback = -1, forbidden = []){
        const keys = headers.map(compact);
        const candidates = names.map(compact);
        const forbiddenKeys = forbidden.map(compact);

        for(const c of candidates){
          const exact = keys.findIndex(k => k === c && !forbiddenKeys.some(f => k.includes(f)));
          if(exact >= 0) return exact;
        }

        for(const c of candidates){
          const partial = keys.findIndex(k => {
            if(!k || !c) return false;
            if(forbiddenKeys.some(f => k.includes(f))) return false;

            /*
              중요:
              이전 로직은 헤더가 너무 짧아도 후보명에 포함되면 매칭했습니다.
              그래서 "추가 인센티브 가중요인 금액" 컬럼을 찾을 때
              앞쪽의 "추가 인센티브" 단가 컬럼이 먼저 잡혀 프백 인센티브 금액 검증이 전부 틀어졌습니다.
              컬럼명 매칭은 실제 헤더(k)가 후보명(c)을 포함하는 방향만 허용합니다.
            */
            return k.includes(c);
          });
          if(partial >= 0) return partial;
        }

        return fallback;
      }

      function findHeaderRow(rows){
        for(let r = 0; r < Math.min(rows.length, 50); r++){
          const keys = (rows[r] || []).map(compact);
          const hasClassify = keys.some(k => k === "구분" || k.includes("구분"));
          const hasId = keys.some(k => k === "id" || k.includes("아이디"));
          const hasRoute = keys.some(k => k === "route" || k.includes("라우트"));
          const hasTotal = keys.some(k => k.includes("총금액") || k.includes("total"));
          if(hasClassify && hasId && hasRoute && hasTotal) return r;
        }

        return 0;
      }

      function detectYearMonthFromFileName(name){
        const s = clean(name);
        const m = s.match(/(20\d{2})\s*년\s*(\d{1,2})\s*월/);
        if(!m) return;

        const year = Number(m[1]);
        const month = Number(m[2]);

        if(year && month >= 1 && month <= 12){
          els.yearSelect.value = String(year);
          els.monthSelect.value = String(month);
        }
      }

      function buildColumnMap(headers){
        return {
          classify: findColumnContains(headers, ["구분"], 0),
          id: findColumnContains(headers, ["ID", "아이디"], 1),
          route: findColumnContains(headers, ["Route", "라우트"], 2),
          deliveryDate: findColumnContains(headers, ["배송일자", "배송일", "일자"], 3),
          camp: findColumnContains(headers, ["캠프명", "캠프", "Camp"], 4),
          wave: findColumnContains(headers, ["배송유형", "주간심야", "주야", "Wave"], 5),
          vendor: findColumnContains(headers, ["업체명", "업체", "Vendor"], 6),
          driverName: findColumnContains(headers, ["이름", "기사명", "성명", "배송기사"], -1),
          parcel: findColumnContains(headers, ["배송건수", "배송수량", "파슬", "parcel"], 7),
          returnCount: findColumnContains(headers, ["반품", "운송장", "return"], 8),
          price: findColumnContains(headers, ["단가", "반품동일", "price"], 9),
          defaultPrice: findColumnContains(headers, ["기본배송단가금액", "기본금액", "기본배송금액", "defaultprice", "baseprice"], -1),
          totalPrice: findColumnContains(headers, ["총금액", "총액", "totalprice", "total"], 10),
          freshbagIncentive: findColumnContains(headers, [
            "추가인센티브",
            "프백인센",
            "freshbagincentive"
          ], -1, ["가중요인", "금액", "회수", "단가금액", "price"]),
          freshbagPrice: findColumnContains(headers, [
            "추가인센티브가중요인금액",
            "추가인센티브가중요인",
            "프백인센티브금액",
            "프레시백인센티브금액",
            "freshbagincentiveprice",
            "freshbagprice"
          ], -1),
          freshbagReturn: findColumnContains(headers, [
            "프레시백회수인센티브",
            "프레쉬백회수인센티브",
            "프백회수인센티브",
            "프레시백회수금액",
            "프레쉬백회수금액",
            "freshbagreturn",
            "freshbagreturnprice"
          ], -1)
        };
      }

      function validateAmounts(data, meta){
        const classify = data.classify || "";
        const errors = [];
        const notes = [];
        const qty = Number(data.parcel || 0) + Number(data["return"] || 0);
        const price = Number(data.price || 0);
        const freshbagUnit = Number(data.freshbag_incentive || 0);

        if(isUncontractedRoute(classify)){
          notes.push("미계약 라우트: 계약 단가 기준이 없어 금액 검증식 예외 처리");
          return {
            hasError:false,
            exempt:true,
            errors,
            notes,
            expectedDefault:null,
            expectedFreshbag:null,
            expectedTotal:null,
            defaultDiff:0,
            freshbagDiff:0,
            totalDiff:0
          };
        }

        if(isFreshbagIncentiveRow(classify) && qty === 0 && price === 0){
          notes.push("프백 인센티브 단독 행: 배송/반품 수량 검증 대상 아님");
          return {
            hasError:false,
            exempt:false,
            errors,
            notes,
            expectedDefault:null,
            expectedFreshbag:null,
            expectedTotal:null,
            defaultDiff:0,
            freshbagDiff:0,
            totalDiff:0
          };
        }

        const expectedDefault = roundMoney(qty * price);
        const expectedFreshbag = roundMoney(qty * freshbagUnit);
        const expectedTotal = roundMoney(expectedDefault + expectedFreshbag);

        const defaultCompareValue = meta.hasExplicitDefaultPrice ? roundMoney(meta.sourceDefault) : expectedDefault;
        const freshbagCompareValue = meta.hasExplicitFreshbagTotal
          ? roundMoney(
              meta.sourceFreshbagPrice ??
              meta.sourceFreshbagTotal ??
              data.freshbag_incentive_price ??
              expectedFreshbag
            )
          : expectedFreshbag;
        const totalCompareValue = roundMoney(meta.sourceTotal);

        const defaultDiff = roundMoney(defaultCompareValue - expectedDefault);
        const freshbagDiff = roundMoney(freshbagCompareValue - expectedFreshbag);
        const totalDiff = roundMoney(totalCompareValue - expectedTotal);

        if(Math.abs(defaultDiff) > MONEY_TOLERANCE){
          errors.push(`기본금액 차이 ${money(defaultDiff)}원`);
        }

        if(Math.abs(freshbagDiff) > MONEY_TOLERANCE){
          errors.push(`프백 인센티브 차이 ${money(freshbagDiff)}원`);
        }

        if(Math.abs(totalDiff) > MONEY_TOLERANCE){
          errors.push(`총금액 차이 ${money(totalDiff)}원`);
        }

        return {
          hasError:errors.length > 0,
          exempt:false,
          errors,
          notes,
          expectedDefault,
          expectedFreshbag,
          expectedTotal,
          defaultDiff,
          freshbagDiff,
          totalDiff
        };
      }

      function convertRow(row, col, rowNo){
        const classify = clean(col.classify >= 0 ? row[col.classify] : "");
        const driverId = clean(col.id >= 0 ? row[col.id] : "");
        const route = clean(col.route >= 0 ? row[col.route] : "");
        const deliveryDate = parseDateValue(col.deliveryDate >= 0 ? row[col.deliveryDate] : null);
        const camp = clean(col.camp >= 0 ? row[col.camp] : "");
        const wave = clean(col.wave >= 0 ? row[col.wave] : "");
        const companyName = clean(col.vendor >= 0 ? row[col.vendor] : "");
        const driverName = clean(col.driverName >= 0 ? row[col.driverName] : "");
        const parcel = parseIntCount(col.parcel >= 0 ? row[col.parcel] : 0);
        const returnCount = parseIntCount(col.returnCount >= 0 ? row[col.returnCount] : 0);
        const price = parseNumber(col.price >= 0 ? row[col.price] : 0);
        const freshbagIncentive = parseNumber(col.freshbagIncentive >= 0 ? row[col.freshbagIncentive] : 0);
        const explicitDefault = col.defaultPrice >= 0 ? parseNumber(row[col.defaultPrice]) : null;
        const sourceFreshbagTotal = col.freshbagPrice >= 0 ? parseNumber(row[col.freshbagPrice]) : null;
        const freshbagReturn = col.freshbagReturn >= 0 ? parseNumber(row[col.freshbagReturn]) : 0;
