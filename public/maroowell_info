<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰 정보</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <style>
    html{visibility:hidden}

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0c1524;
      --line:rgba(255,255,255,.08);
      --line2:#d4dbe5;
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;
      --ok:#1a5a3a;
      --warn:#6a4b13;
      --danger:#6b1b1b;

      --sheetBg:#eef3f8;
      --headBg:#dde7f3;
      --filterBg:#edf3fb;
      --cellBg:#ffffff;
      --cellAlt:#f8fbff;
      --cellTxt:#0f172a;

      --resignBg:#ffd9d6;
      --resignAlt:#ffd0cc;
      --resignBorder:#f1b7b0;

      --vehicleWarn:#fff1a8;
      --vehicleWarnBorder:#e2c44d;

      --dirtyBg:#e0eeff;
      --dirtyBorder:#60a5fa;

      --topbarH:56px;
      --toolbarH:58px;
      --statusH:44px;
    }

    *{box-sizing:border-box}
    html,body{
      margin:0;
      height:100%;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }
    body{overflow:hidden}

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--topbarH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
      letter-spacing:.1px;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }

    .spacer{flex:1}

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }

    .btn:hover{background:var(--btn2)}
    .btn.ok{background:rgba(26,90,58,.35);border-color:rgba(0,255,140,.18)}
    .btn.warn{background:rgba(106,75,19,.35);border-color:rgba(255,180,0,.18)}
    .btn.danger{background:rgba(107,27,27,.35);border-color:rgba(255,60,60,.22);color:#ffccd3}
    .btn:disabled{opacity:.6;cursor:not-allowed}

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:var(--panel);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .group{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .group:last-child{
      border-right:none;
      padding-right:0;
    }

    .toggle{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      font-size:12px;
      font-weight:900;
      color:#d9e5ff;
      white-space:nowrap;
    }

    .toggle input{
      margin:0;
      width:16px;
      height:16px;
      accent-color:#2563eb;
      cursor:pointer;
    }

    .helper{
      color:#c7d3ea;
      font-size:12px;
      white-space:nowrap;
    }

    .sheetWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .sheetInner{
      min-width:3450px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
    }

    th,td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child,td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:4;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:13px;
      font-weight:900;
      white-space:nowrap;
    }

    thead tr.filterRow th{
      top:43px;
      z-index:3;
      background:var(--filterBg);
      padding:6px;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    tbody tr.resigned-row td{
      background:var(--resignBg) !important;
      border-bottom-color:var(--resignBorder);
    }

    tbody tr.resigned-row:nth-child(even) td{
      background:var(--resignAlt) !important;
    }

    td.vehicle-warn{
      background:var(--vehicleWarn) !important;
      box-shadow:inset 0 0 0 1px var(--vehicleWarnBorder);
    }

    td.dirty-cell{
      box-shadow:inset 0 0 0 2px var(--dirtyBorder);
      background:var(--dirtyBg) !important;
    }

    .cellView{
      min-height:44px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:0 10px;
      font-size:13px;
      line-height:1.35;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .cellView.center{justify-content:center;text-align:center}
    .cellView.right{justify-content:flex-end;text-align:right;font-variant-numeric:tabular-nums}
    .cellView.code{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px}

    .cellInput,
    .cellSelect{
      width:100%;
      min-height:44px;
      border:none;
      outline:none;
      background:transparent;
      color:var(--cellTxt);
      padding:10px 10px;
      font:inherit;
      border-radius:0;
    }

    .cellInput{
      font-size:13px;
      line-height:1.35;
    }

    .cellInput.code{
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:12px;
    }

    .cellInput.center,
    .cellSelect.center{
      text-align:center;
    }

    .cellInput.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .cellInput::placeholder{
      color:#94a3b8;
    }

    .cellSelect{
      cursor:pointer;
      text-align:center;
    }

    .filterInput{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      outline:none;
    }

    .filterInput:focus{
      border-color:#60a5fa;
    }

    .chip{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:44px;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .chip.ok{
      background:#d9f0c7;
      color:#46691c;
    }

    .chip.no{
      background:#ffd6d0;
      color:#a33d2c;
    }

    .rowActionBtn{
      width:34px;
      height:34px;
      border-radius:10px;
      border:1px solid #d4dbe5;
      background:#fff;
      color:#64748b;
      cursor:pointer;
      font-size:16px;
      font-weight:900;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }

    .rowActionBtn:hover{
      background:#f8fafc;
      border-color:#cbd5e1;
    }

    .rowActionBtn.delete{
      color:#b91c1c;
      border-color:#fecaca;
      background:#fff5f5;
    }

    .emptyDataRow td{
      padding:20px 14px;
      text-align:center;
      color:#64748b;
      font-weight:800;
      background:#f8fbff !important;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{color:#bbf7d0}
    .pill.warn{color:#fde68a}
    .pill.err{color:#fecaca}

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width:980px){
      .toolbar{padding:8px}
      .btn{padding:0 10px;font-size:12px}
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a id="mwBoardMenuToggle" href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>마루웰 정보</b>
        <small>직원 / 정산 베이스 정보 관리</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnAddRow" class="btn warn" type="button">행 추가</button>
      <button id="btnSaveAll" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="group">
        <label class="toggle" for="toggleIncludeResigned">
          <input id="toggleIncludeResigned" type="checkbox" />
          <span>퇴사 포함</span>
        </label>
      </div>

      <div class="group">
        <label class="toggle" for="toggleOnlyChanged">
          <input id="toggleOnlyChanged" type="checkbox" />
          <span>변경 행만 보기</span>
        </label>
      </div>

      <div class="group">
        <button id="btnClearFilters" class="btn" type="button">필터 초기화</button>
      </div>

      <div class="group">
        <span class="helper">필터칸에서 <b>!키워드</b> 또는 <b>-키워드</b> 입력 시 제외 검색</span>
      </div>
    </div>

    <div class="sheetWrap">
      <div class="sheetInner">
        <table>
          <colgroup>
            <col style="width:80px" />
            <col style="width:120px" />
            <col style="width:130px" />
            <col style="width:110px" />
            <col style="width:100px" />
            <col style="width:90px" />
            <col style="width:120px" />
            <col style="width:130px" />
            <col style="width:150px" />
            <col style="width:150px" />
            <col style="width:170px" />
            <col style="width:120px" />
            <col style="width:170px" />
            <col style="width:150px" />
            <col style="width:150px" />
            <col style="width:130px" />
            <col style="width:150px" />
            <col style="width:110px" />
            <col style="width:120px" />
            <col style="width:120px" />
            <col style="width:120px" />
            <col style="width:90px" />
            <col style="width:72px" />
          </colgroup>

          <thead>
            <tr>
              <th>순번</th>
              <th>이름</th>
              <th>연락처</th>
              <th>직책</th>
              <th>camp</th>
              <th>wave</th>
              <th>coupang_id</th>
              <th>차량 번호</th>
              <th>주민번호</th>
              <th>운송자격증번호</th>
              <th>서브 계정</th>
              <th>급여 은행</th>
              <th>급여 계좌</th>
              <th>사업자 상호</th>
              <th>사업자 번호</th>
              <th>입사일</th>
              <th>비상 연락처</th>
              <th>관계</th>
              <th>고정 수수료</th>
              <th>고정 단가</th>
              <th>용차 수수료</th>
              <th>고용산재</th>
              <th>삭제</th>
            </tr>
            <tr class="filterRow">
              <th></th>
              <th><input class="filterInput" data-filter="person_name" placeholder="이름 / !이우람" /></th>
              <th><input class="filterInput" data-filter="contact_phone" placeholder="연락처" /></th>
              <th><input class="filterInput" data-filter="position_title" placeholder="직책 / !퇴사" /></th>
              <th><input class="filterInput" data-filter="camp_code" placeholder="camp" /></th>
              <th><input class="filterInput" data-filter="wave" placeholder="주간 / 야간 / !주간" /></th>
              <th><input class="filterInput" data-filter="coupang_id" placeholder="ID" /></th>
              <th><input class="filterInput" data-filter="vehicle_plate_number" placeholder="차량 번호 / !배" /></th>
              <th><input class="filterInput" data-filter="resident_registration_number" placeholder="주민번호" /></th>
              <th><input class="filterInput" data-filter="transport_qualification_number" placeholder="자격증번호" /></th>
              <th><input class="filterInput" data-filter="sub_account_info" placeholder="서브 계정" /></th>
              <th><input class="filterInput" data-filter="payroll_bank_name" placeholder="은행" /></th>
              <th><input class="filterInput" data-filter="payroll_account_number" placeholder="계좌" /></th>
              <th><input class="filterInput" data-filter="business_name" placeholder="사업자 상호" /></th>
              <th><input class="filterInput" data-filter="business_registration_number" placeholder="사업자 번호" /></th>
              <th><input class="filterInput" data-filter="hire_date" placeholder="2025 / !2024" /></th>
              <th><input class="filterInput" data-filter="emergency_contact_phone" placeholder="비상 연락처" /></th>
              <th><input class="filterInput" data-filter="emergency_contact_relationship" placeholder="관계" /></th>
              <th><input class="filterInput" data-filter="fixed_commission_amount" placeholder="고정 수수료" /></th>
              <th><input class="filterInput" data-filter="fixed_unit_price" placeholder="고정 단가" /></th>
              <th><input class="filterInput" data-filter="dragon_car_commission" placeholder="용차 수수료 / !8%" /></th>
              <th><input class="filterInput" data-filter="employment_accident_insurance" placeholder="O / X / !X" /></th>
              <th></th>
            </tr>
          </thead>

          <tbody id="sheetBody"></tbody>
        </table>
      </div>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillDirty" class="pill warn">변경 0</span>
      <span id="statusText" class="statusText">기본값은 퇴사 숨김입니다.</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const INDEX_PATH = PATHS?.index || "/index.html";
      const LOGIN_PATH = PATHS?.login || "/login.html";

      const ACCESS_TABLE = "user_access";
      const DATA_TABLE = "maroowell_info";

      const DATA_COLUMNS = [
        "person_name",
        "contact_phone",
        "position_title",
        "camp_code",
        "wave",
        "coupang_id",
        "vehicle_plate_number",
        "resident_registration_number",
        "transport_qualification_number",
        "sub_account_info",
        "payroll_bank_name",
        "payroll_account_number",
        "business_name",
        "business_registration_number",
        "hire_date",
        "emergency_contact_phone",
        "emergency_contact_relationship",
        "fixed_commission_amount",
        "fixed_unit_price",
        "dragon_car_commission",
        "employment_accident_insurance"
      ];

      const COLUMN_CONFIG = [
        { key: "pk_id", label: "순번", type: "readonly", className: "right code center" },
        { key: "person_name", label: "이름" },
        { key: "contact_phone", label: "연락처", className: "code" },
        { key: "position_title", label: "직책", className: "center" },
        { key: "camp_code", label: "camp", className: "center" },
        { key: "wave", label: "wave", type: "select", options: ["", "주간", "야간", "주/야"], className: "center" },
        { key: "coupang_id", label: "coupang_id", className: "code" },
        { key: "vehicle_plate_number", label: "차량 번호", className: "center" },
        { key: "resident_registration_number", label: "주민번호", className: "code" },
        { key: "transport_qualification_number", label: "운송자격증번호", className: "code" },
        { key: "sub_account_info", label: "서브 계정" },
        { key: "payroll_bank_name", label: "급여 은행", className: "center" },
        { key: "payroll_account_number", label: "급여 계좌", className: "code" },
        { key: "business_name", label: "사업자 상호" },
        { key: "business_registration_number", label: "사업자 번호", className: "code" },
        { key: "hire_date", label: "입사일", type: "date", className: "center code" },
        { key: "emergency_contact_phone", label: "비상 연락처", className: "code" },
        { key: "emergency_contact_relationship", label: "관계", className: "center" },
        { key: "fixed_commission_amount", label: "고정 수수료", className: "right code" },
        { key: "fixed_unit_price", label: "고정 단가", className: "right code" },
        { key: "dragon_car_commission", label: "용차 수수료", className: "right code" },
        { key: "employment_accident_insurance", label: "고용산재", type: "select", options: ["", "O", "X"], className: "center" }
      ];

      const $ = (sel) => document.querySelector(sel);

      const dom = {
        sheetBody: $("#sheetBody"),
        btnReload: $("#btnReload"),
        btnAddRow: $("#btnAddRow"),
        btnSaveAll: $("#btnSaveAll"),
        btnExportCsv: $("#btnExportCsv"),
        btnClearFilters: $("#btnClearFilters"),
        btnLogout: $("#btnLogout"),
        toggleIncludeResigned: $("#toggleIncludeResigned"),
        toggleOnlyChanged: $("#toggleOnlyChanged"),
        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillDirty: $("#pillDirty"),
        statusText: $("#statusText"),
        filterInputs: Array.from(document.querySelectorAll(".filterInput")),
        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout")
      };

      const state = {
        rows: [],
        filteredRows: [],
        loading: false,
        viewerEmail: "",
        viewerUserId: "",
        session: null,
        accessRow: null,
        deletedIds: new Set(),
        tempSeq: 0
      };

      function getSupabaseProjectRef(url) {
        try {
          const host = new URL(url).hostname || "";
          return host.split(".")[0] || "";
        } catch {
          return "";
        }
      }

      function createSupabaseSessionBridge(url) {
        const projectRef = getSupabaseProjectRef(url);
        const prefixes = projectRef ? [
          "sb-" + projectRef + "-auth-token",
          "sb-" + projectRef + "-auth-token-code-verifier"
        ] : [];
        const origin = window.location.origin;
        const channelName = projectRef ? ("mw-auth-bridge:" + projectRef) : "";
        const tabId = (Date.now().toString(36) + Math.random().toString(36).slice(2));
        const pending = new Map();
        let channel = null;
        let started = false;

        function matchesKey(key) {
          return !!key && prefixes.some(prefix => key === prefix || key.startsWith(prefix));
        }

        function readEntries(storage) {
          const target = storage || window.sessionStorage;
          const rows = [];
          try {
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (!matchesKey(key)) continue;
              rows.push({ key, value: target.getItem(key) });
            }
          } catch {}
          return rows;
        }

        function hasSession(storage) {
          return readEntries(storage).some(row =>
            row.key.includes("-auth-token") &&
            !row.key.includes("code-verifier") &&
            !!row.value
          );
        }

        function writeEntries(entries, storage) {
          const target = storage || window.sessionStorage;
          try {
            for (const row of entries || []) {
              if (!row || !matchesKey(row.key)) continue;
              if (row.value == null) target.removeItem(row.key);
              else target.setItem(row.key, row.value);
            }
          } catch {}
        }

        function clearSession(storage) {
          const target = storage || window.sessionStorage;
          try {
            const keys = [];
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (matchesKey(key)) keys.push(key);
            }
            keys.forEach(key => target.removeItem(key));
          } catch {}
        }

        function resolvePending(requestId, entries) {
          const item = pending.get(requestId);
          if (!item) return;
          pending.delete(requestId);
          clearTimeout(item.timer);
          if (Array.isArray(entries) && entries.length) writeEntries(entries, window.sessionStorage);
          item.resolve(hasSession(window.sessionStorage));
        }

        function handleSyncState(syncState) {
          if (syncState === "SIGNED_OUT") {
            clearSession(window.sessionStorage);
            return;
          }
          if (syncState === "SESSION_UPDATED" && !hasSession(window.sessionStorage)) {
            requestSessionCopy(1200).catch(() => {});
          }
        }

        function onWindowMessage(event) {
          if (event.origin !== origin) return;
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              event.source?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              }, origin);
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function onChannelMessage(event) {
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              channel?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              });
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function start() {
          if (started || !projectRef) return;
          started = true;
          window.addEventListener("message", onWindowMessage);
          try {
            if ("BroadcastChannel" in window) {
              channel = new BroadcastChannel(channelName);
              channel.addEventListener("message", onChannelMessage);
            }
          } catch {}
        }

        function requestSessionCopy(timeoutMs) {
          start();
          if (!projectRef) return Promise.resolve(false);
          if (hasSession(window.sessionStorage)) return Promise.resolve(true);

          const requestId = tabId + ":" + Date.now().toString(36) + Math.random().toString(36).slice(2);
          const payload = {
            type: "MW_SESSION_REQUEST",
            projectRef,
            requestId,
            fromTabId: tabId
          };

          return new Promise(resolve => {
            const timer = window.setTimeout(() => {
              pending.delete(requestId);
              resolve(hasSession(window.sessionStorage));
            }, Math.max(300, Number(timeoutMs) || 900));

            pending.set(requestId, { resolve, timer });

            try { channel?.postMessage(payload); } catch {}
            try {
              if (window.opener && window.opener !== window) {
                window.opener.postMessage(payload, origin);
              }
            } catch {}
          });
        }

        function broadcastAuthState(syncState) {
          start();
          const payload = {
            type: "MW_AUTH_SYNC",
            projectRef,
            state: syncState,
            fromTabId: tabId
          };
          try { channel?.postMessage(payload); } catch {}
          try {
            if (window.opener && window.opener !== window) {
              window.opener.postMessage(payload, origin);
            }
          } catch {}
        }

        return {
          start,
          requestSessionCopy,
          broadcastAuthState
        };
      }

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();

      const sessionBridge = createSupabaseSessionBridge(SUPABASE_URL);
      sessionBridge.start();
      await sessionBridge.requestSessionCopy(1200);

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";
        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnAddRow.disabled = !!on;
        dom.btnSaveAll.disabled = !!on;
        dom.btnExportCsv.disabled = !!on;
        dom.btnClearFilters.disabled = !!on;
        if (on) setStatus(text || "처리 중...", "warn");
      }

      function formatDateForInput(v) {
        const s = normalizeText(v);
        if (!s) return "";
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
        if (/^\d{4}\.\d{1,2}\.\d{1,2}$/.test(s)) {
          const [y, m, d] = s.split(".");
          return `${y.padStart(4, "0")}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
        }
        return s;
      }

      function normalizeLoadedRow(row) {
        const out = { ...(row || {}) };
        for (const key of DATA_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }
        out.hire_date = formatDateForInput(out.hire_date);
        out.__dirty = false;
        out.__isNew = false;
        out.__dirtyFields = {};
        return out;
      }

      function rowId(row) {
        return row.pk_id ?? row.__temp_id;
      }

      function isResigned(row) {
        return normalizeText(row.position_title).includes("퇴사");
      }

      function isVehicleWarn(row) {
        return /[배아바사자]/.test(normalizeText(row.vehicle_plate_number));
      }

      function blankRow() {
        const row = {
          __temp_id: "new_" + (++state.tempSeq),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {}
        };
        for (const key of DATA_COLUMNS) row[key] = "";
        return row;
      }

      function hasAnyValue(row) {
        return DATA_COLUMNS.some(key => normalizeText(row[key]));
      }

      function valueForSave(key, value) {
        const v = normalizeText(value);
        if (!v) return null;
        if (key === "hire_date") return v;
        return v;
      }

      function updatePills() {
        const visibleCount = state.filteredRows.length;
        const dirtyCount = state.rows.filter(row => row.__dirty).length + state.deletedIds.size;
        dom.pillRows.textContent = "행 " + visibleCount;
        dom.pillDirty.textContent = "변경 " + dirtyCount;
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";
        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
          sessionBridge.broadcastAuthState("SIGNED_OUT");
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function requireAuthAndAccess() {
        if (!supabase || !supabase.auth) {
          alert("Supabase 설정을 확인하세요.");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();

          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          state.session = session;
          state.viewerEmail = normalizeText(session.user?.email || "");
          state.viewerUserId = normalizeText(session.user?.id || "");

          supabase.auth.onAuthStateChange((evt, s) => {
            if (evt === "SIGNED_OUT" || !s) {
              sessionBridge.broadcastAuthState("SIGNED_OUT");
              const next = safeNextPath(location.pathname + location.search + location.hash);
              location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
              return;
            }
            if (evt === "SIGNED_IN" || evt === "TOKEN_REFRESHED" || evt === "USER_UPDATED") {
              sessionBridge.broadcastAuthState("SESSION_UPDATED");
            }
          });

          if (!state.viewerUserId) {
            showAccessDenied(state.viewerEmail, "로그인 사용자 ID를 확인할 수 없습니다.");
            return false;
          }

          const { data: accessRow, error: accessError } = await supabase
            .from(ACCESS_TABLE)
            .select("user_id, email, is_maroowell, is_admin")
            .eq("user_id", state.viewerUserId)
            .maybeSingle();

          if (accessError) {
            console.error(accessError);
            showAccessDenied(state.viewerEmail, "권한 테이블 조회 실패: " + accessError.message);
            return false;
          }

          state.accessRow = accessRow || null;

          if (!accessRow?.is_maroowell) {
            showAccessDenied(state.viewerEmail, "이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.");
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          console.error(e);
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      function parseFilterExpression(raw) {
        const text = normalizeText(raw);
        if (!text) return { include: [], exclude: [] };

        const tokens = text.split(/\s+/).filter(Boolean);
        const include = [];
        const exclude = [];

        for (const token of tokens) {
          if (token.startsWith("!") || token.startsWith("-")) {
            const x = normalizeLower(token.slice(1));
            if (x) exclude.push(x);
          } else {
            include.push(normalizeLower(token));
          }
        }

        return { include, exclude };
      }

      function matchFilter(value, expr) {
        const actual = normalizeLower(value);
        const parsed = parseFilterExpression(expr);

        for (const token of parsed.include) {
          if (!actual.includes(token)) return false;
        }
        for (const token of parsed.exclude) {
          if (actual.includes(token)) return false;
        }
        return true;
      }

      function getRowValue(row, key) {
        if (key === "hire_date") return formatDateForInput(row.hire_date);
        return normalizeText(row[key]);
      }

      function findRowById(id) {
        return state.rows.find(row => String(rowId(row)) === String(id)) || null;
      }

      function applyFilters() {
        state.filteredRows = state.rows.filter(row => {
          if (row.pk_id && state.deletedIds.has(row.pk_id)) return false;
          if (!dom.toggleIncludeResigned.checked && isResigned(row)) return false;
          if (dom.toggleOnlyChanged.checked && !row.__dirty) return false;

          for (const input of dom.filterInputs) {
            const key = input.dataset.filter;
            const expr = input.value || "";
            if (!normalizeText(expr)) continue;
            if (!matchFilter(getRowValue(row, key), expr)) return false;
          }

          return true;
        });

        renderTable();
        updatePills();

        if (!state.rows.length) {
          setStatus("데이터가 없습니다.", "warn");
        } else if (state.filteredRows.length !== state.rows.length) {
          setStatus(`필터 결과 ${state.filteredRows.length}건`, "ok");
        } else {
          setStatus(`전체 ${state.rows.length}건 로드 완료`, "ok");
        }
      }

      function buildDataCell(row, col) {
        const rid = rowId(row);
        const value = getRowValue(row, col.key);
        const classes = [];
        if (row.__dirtyFields?.[col.key]) classes.push("dirty-cell");
        if (col.key === "vehicle_plate_number" && isVehicleWarn(row)) classes.push("vehicle-warn");

        if (col.type === "readonly") {
          const displayValue = row.pk_id ?? "NEW";
          return `
            <td data-col="${escapeHtml(col.key)}" class="${classes.join(" ")}">
              <div class="cellView ${col.className || ""}">${escapeHtml(displayValue)}</div>
            </td>
          `;
        }

        if (col.type === "select") {
          const options = (col.options || []).map(opt => {
            const selected = String(opt) === String(value) ? "selected" : "";
            const label = opt || "-";
            return `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(label)}</option>`;
          }).join("");

          return `
            <td data-col="${escapeHtml(col.key)}" class="${classes.join(" ")}">
              <select
                class="cellSelect ${col.className || ""}"
                data-row-id="${escapeHtml(rid)}"
                data-key="${escapeHtml(col.key)}"
              >${options}</select>
            </td>
          `;
        }

        const inputType = col.type === "date" ? "date" : "text";

        return `
          <td data-col="${escapeHtml(col.key)}" class="${classes.join(" ")}">
            <input
              class="cellInput ${col.className || ""}"
              type="${inputType}"
              value="${escapeHtml(value)}"
              data-row-id="${escapeHtml(rid)}"
              data-key="${escapeHtml(col.key)}"
              autocomplete="off"
            />
          </td>
        `;
      }

      function renderTable() {
        if (!state.filteredRows.length) {
          dom.sheetBody.innerHTML = `
            <tr class="emptyDataRow">
              <td colspan="23">조회 결과가 없습니다.</td>
            </tr>
          `;
          return;
        }

        dom.sheetBody.innerHTML = state.filteredRows.map(row => {
          const rid = rowId(row);
          const trClass = isResigned(row) ? "resigned-row" : "";
          const cells = COLUMN_CONFIG.map(col => buildDataCell(row, col)).join("");

          return `
            <tr data-row="${escapeHtml(rid)}" class="${trClass}">
              ${cells}
              <td class="${row.__dirty ? "dirty-cell" : ""}">
                <div class="cellView center">
                  <button class="rowActionBtn delete" type="button" data-delete-row="${escapeHtml(rid)}">✕</button>
                </div>
              </td>
            </tr>
          `;
        }).join("");
      }

      function updateRowDom(row) {
        const rid = rowId(row);
        const tr = dom.sheetBody.querySelector(`tr[data-row="${CSS.escape(String(rid))}"]`);
        if (!tr) return;

        tr.classList.toggle("resigned-row", isResigned(row));

        for (const col of COLUMN_CONFIG) {
          const td = tr.querySelector(`td[data-col="${col.key}"]`);
          if (!td) continue;
          td.classList.toggle("dirty-cell", !!row.__dirtyFields?.[col.key]);
          if (col.key === "vehicle_plate_number") {
            td.classList.toggle("vehicle-warn", isVehicleWarn(row));
          }
        }

        const deleteTd = tr.lastElementChild;
        if (deleteTd) deleteTd.classList.toggle("dirty-cell", !!row.__dirty);
        updatePills();
      }

      function markRowDirty(row, key, value) {
        if (!row) return;
        row[key] = value;
        row.__dirty = true;
        row.__dirtyFields = row.__dirtyFields || {};
        row.__dirtyFields[key] = true;
      }

      function addRow() {
        state.rows.push(blankRow());
        applyFilters();
        setStatus("새 행이 추가되었습니다.", "ok");
      }

      function deleteRow(rowIdValue) {
        const row = findRowById(rowIdValue);
        if (!row) return;

        const label = normalizeText(row.person_name) || normalizeText(row.contact_phone) || String(rowIdValue);
        const ok = confirm(`삭제 대상으로 표시할까요?\n저장해야 실제 반영됩니다.\n\n대상: ${label}`);
        if (!ok) return;

        if (row.__isNew) {
          state.rows = state.rows.filter(r => String(rowId(r)) !== String(rowIdValue));
        } else if (row.pk_id) {
          state.deletedIds.add(row.pk_id);
          row.__dirty = true;
        }

        applyFilters();
        setStatus("삭제 대상으로 표시했습니다. 전체 저장 시 반영됩니다.", "warn");
      }

      function cleanPayload(row, includePk) {
        const obj = {};
        if (includePk && row.pk_id != null) obj.pk_id = row.pk_id;
        for (const key of DATA_COLUMNS) {
          obj[key] = valueForSave(key, row[key]);
        }
        return obj;
      }

      async function fetchRows() {
        try {
          setLoading(true, "데이터 불러오는 중...");
          state.deletedIds.clear();

          const { data, error } = await supabase
            .from(DATA_TABLE)
            .select("*")
            .order("pk_id", { ascending: true });

          if (error) throw error;

          state.rows = Array.isArray(data) ? data.map(normalizeLoadedRow) : [];
          applyFilters();
        } catch (e) {
          console.error(e);
          state.rows = [];
          state.filteredRows = [];
          renderTable();
          updatePills();
          setStatus("불러오기 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      async function saveAll() {
        try {
          setLoading(true, "저장 중...");

          const deleteIds = Array.from(state.deletedIds).filter(Boolean);
          const dirtyRows = state.rows.filter(row => row.__dirty && !(row.pk_id && state.deletedIds.has(row.pk_id)));
          const updateRows = dirtyRows.filter(row => !row.__isNew && row.pk_id != null);
          const newRows = dirtyRows.filter(row => row.__isNew && hasAnyValue(row));

          if (!deleteIds.length && !updateRows.length && !newRows.length) {
            setStatus("저장할 변경사항이 없습니다.", "warn");
            return;
          }

          if (deleteIds.length) {
            const { error } = await supabase
              .from(DATA_TABLE)
              .delete()
              .in("pk_id", deleteIds);
            if (error) throw error;
          }

          if (updateRows.length) {
            const payload = updateRows.map(row => cleanPayload(row, true));
            const { error } = await supabase
              .from(DATA_TABLE)
              .upsert(payload, { onConflict: "pk_id" });
            if (error) throw error;
          }

          if (newRows.length) {
            const payload = newRows.map(row => cleanPayload(row, false));
            const { error } = await supabase
              .from(DATA_TABLE)
              .insert(payload);
            if (error) throw error;
          }

          await fetchRows();
          setStatus("저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("저장 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      function clearFilters() {
        dom.filterInputs.forEach(el => { el.value = ""; });
        dom.toggleOnlyChanged.checked = false;
        applyFilters();
      }

      function exportCsv() {
        const rows = state.filteredRows.filter(row => !(row.pk_id && state.deletedIds.has(row.pk_id)));
        if (!rows.length) {
          alert("내보낼 데이터가 없습니다.");
          return;
        }

        const headers = ["pk_id", ...DATA_COLUMNS];
        const lines = [
          headers.join(","),
          ...rows.map(row => {
            return headers.map(key => {
              const raw = key === "pk_id" ? (row.pk_id ?? "") : getRowValue(row, key);
              const escaped = String(raw ?? "").replaceAll('"', '""');
              return `"${escaped}"`;
            }).join(",");
          })
        ];

        const csv = "\uFEFF" + lines.join("\n");
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        const now = new Date();
        const stamp = [
          now.getFullYear(),
          String(now.getMonth() + 1).padStart(2, "0"),
          String(now.getDate()).padStart(2, "0"),
          "_",
          String(now.getHours()).padStart(2, "0"),
          String(now.getMinutes()).padStart(2, "0")
        ].join("");

        a.href = url;
        a.download = `maroowell_info_${stamp}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      function bindTableEvents() {
        dom.sheetBody.addEventListener("input", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!rowIdValue || !key) return;

          const row = findRowById(rowIdValue);
          if (!row) return;

          markRowDirty(row, key, target.value);

          if (key === "position_title" && !dom.toggleIncludeResigned.checked && isResigned(row)) {
            applyFilters();
            return;
          }

          updateRowDom(row);
        });

        dom.sheetBody.addEventListener("change", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!rowIdValue || !key) return;

          const row = findRowById(rowIdValue);
          if (!row) return;

          markRowDirty(row, key, target.value);

          if (key === "position_title" && !dom.toggleIncludeResigned.checked && isResigned(row)) {
            applyFilters();
            return;
          }

          updateRowDom(row);
        });

        dom.sheetBody.addEventListener("click", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const deleteId = target.getAttribute("data-delete-row");
          if (deleteId) deleteRow(deleteId);
        });
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", fetchRows);
        dom.btnAddRow.addEventListener("click", addRow);
        dom.btnSaveAll.addEventListener("click", saveAll);
        dom.btnExportCsv.addEventListener("click", exportCsv);
        dom.btnClearFilters.addEventListener("click", clearFilters);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.toggleIncludeResigned.addEventListener("change", applyFilters);
        dom.toggleOnlyChanged.addEventListener("change", applyFilters);

        dom.filterInputs.forEach(el => {
          el.addEventListener("input", applyFilters);
        });

        dom.btnDeniedHome.addEventListener("click", () => {
          location.replace(INDEX_PATH);
        });

        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        bindTableEvents();
      }

      bindEvents();

      if (!(await requireAuthAndAccess())) return;
      await fetchRows();
    })();
  </script>
<script>
  window.MW_BOARD_MENU_MODE = "admin";
</script>
<script src="/board-menu.js"></script>
</body>
