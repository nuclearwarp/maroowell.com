  function attachmentPathOf(row) {
    return row?.file_url || "";
  }

  function isHttpUrl(value) {
    return /^https?:\/\//i.test(String(value || ""));
  }

  function clearAttachmentsState() {
    attachmentRows = [];
    attachmentSignedUrls = new Map();
    $("attachmentFileInput").value = "";
    $("attachmentCaptionInput").value = "";
    setAttachmentStatus("");
    renderAttachments();
  }

  function safeFileName(name) {
    const raw = String(name || "image");
    const ext = raw.split(".").pop().toLowerCase().replace(/[^a-z0-9]/g, "") || "jpg";
    const base = raw.replace(/\.[^.]+$/, "").replace(/[^\w가-힣.-]+/g, "_").slice(0, 60) || "image";
    return `${base}.${ext}`;
  }

  async function signAttachmentUrls() {
    attachmentSignedUrls = new Map();

    for (const row of attachmentRows) {
      const path = attachmentPathOf(row);
      if (!path) continue;

      if (isHttpUrl(path)) {
        attachmentSignedUrls.set(row.id, path);
        continue;
      }

      const { data: signed, error: signError } = await supabaseClient
        .storage
        .from(ATTACHMENT_BUCKET)
        .createSignedUrl(path, 60 * 60);

      if (!signError && signed?.signedUrl) {
        attachmentSignedUrls.set(row.id, signed.signedUrl);
      }
    }
  }

  async function loadAttachments(pointId, showErrors = true) {
    attachmentRows = [];
    attachmentSignedUrls = new Map();

    if (!pointId) {
      renderAttachments();
      return;
    }

    const { data, error } = await supabaseClient
      .from(TABLE_ATTACHMENT)
      .select(`
        id,
        point_id,
        file_url,
        file_name,
        file_type,
        file_size,
        caption,
        sort_order,
        created_at,
        is_active
      `)
      .eq("point_id", pointId)
      .eq("is_active", true)
      .order("sort_order", { ascending:true })
      .order("created_at", { ascending:true });

    if (error) {
      attachmentRows = [];
      renderAttachments();

      if (showErrors) {
        throw error;
      }

      console.warn("attachment query skipped:", error);
      return;
    }

    attachmentRows = data || [];
    await signAttachmentUrls();
    renderAttachments();
  }

  function renderAttachments() {
    $("attachmentCount").textContent = `${attachmentRows.length.toLocaleString()}장`;

    if (!attachmentRows.length) {
      $("attachmentList").innerHTML = `<div class="detailEmpty" style="grid-column:1/-1">첨부 이미지가 없습니다.</div>`;
      return;
    }

    $("attachmentList").innerHTML = attachmentRows.map(row => {
      const url = attachmentSignedUrls.get(row.id) || "";
      const name = row.file_name || "image";
      const caption = row.caption || "";

      return `
        <div class="attachmentCard" data-attachment-id="${esc(row.id)}">
          ${url ? `<img class="attachmentThumb" src="${esc(url)}" alt="${esc(name)}" data-action="open-attachment" data-url="${esc(url)}" data-caption="${esc(caption)}">` : `<div class="attachmentThumb"></div>`}
          <div class="attachmentMeta">
            <div class="attachmentName">${esc(name)}</div>
            <div class="attachmentCaption">${esc(caption)}</div>
          </div>
          <div class="attachmentActions">
            <button type="button" class="secondary" data-action="open-attachment" data-url="${esc(url)}" data-caption="${esc(caption)}">보기</button>
            <button type="button" class="danger" data-action="delete-attachment" data-id="${esc(row.id)}">삭제</button>
          </div>
        </div>
      `;
    }).join("");
  }

  async function uploadAttachments() {
    if (!selectedPoint?.id) {
      setAttachmentStatus("먼저 포인트를 저장하거나 선택하세요.", "bad");
      return;
    }

    const files = Array.from($("attachmentFileInput").files || []);

    if (!files.length) {
      setAttachmentStatus("업로드할 이미지를 선택하세요.", "bad");
      return;
    }

    const caption = clean($("attachmentCaptionInput").value);
    let uploaded = 0;

    setAttachmentStatus("이미지 업로드 중...", "warn");

    for (const file of files) {
      if (!file.type.startsWith("image/")) continue;

      const fileName = safeFileName(file.name);
      const path = `${selectedPoint.id}/${Date.now()}_${Math.random().toString(36).slice(2, 8)}_${fileName}`;

      const { error: uploadError } = await supabaseClient
        .storage
        .from(ATTACHMENT_BUCKET)
        .upload(path, file, {
          cacheControl: "3600",
          upsert: false,
          contentType: file.type || "image/jpeg"
        });

      if (uploadError) throw uploadError;

      const payload = {
        point_id: selectedPoint.id,
        file_url: path,
        file_name: file.name,
        file_type: file.type,
        file_size: file.size,
        caption: caption || null,
        sort_order: attachmentRows.length + uploaded,
        is_active: true
      };

      const { error: insertError } = await supabaseClient
        .from(TABLE_ATTACHMENT)
        .insert(payload);

      if (insertError) throw insertError;

      uploaded++;
    }

    $("attachmentFileInput").value = "";
    $("attachmentCaptionInput").value = "";

    await loadAttachments(selectedPoint.id, true);
    setAttachmentStatus(`이미지 업로드 완료: ${uploaded}장`, "ok");
  }

  async function deleteAttachment(id) {
    const row = attachmentRows.find(item => item.id === id);
    if (!row) return;

    const ok = confirm("이 이미지를 삭제할까요?");
    if (!ok) return;

    const path = attachmentPathOf(row);

    if (path && !isHttpUrl(path)) {
      await supabaseClient
        .storage
        .from(ATTACHMENT_BUCKET)
        .remove([path]);
    }

    const { error } = await supabaseClient
      .from(TABLE_ATTACHMENT)
      .delete()
      .eq("id", id);

    if (error) throw error;

    await loadAttachments(selectedPoint?.id, true);
    setAttachmentStatus("이미지 삭제 완료", "ok");
  }

