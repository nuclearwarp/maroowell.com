  function clearRouteDetail() {
    $("selectedRouteText").textContent = "선택 없음";
    $("routeDetail").className = "detailEmpty";
    $("routeDetail").innerHTML = "좌측에서 라우트를 선택하세요.";
    $("polygonInfoText").textContent = "선택 없음";
