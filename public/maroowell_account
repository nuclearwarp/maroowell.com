        const rowPadY=9;
        const headerH=44;
        const captionH=captionText?68:0;
        const font="800 14px system-ui,-apple-system,'Noto Sans KR',Segoe UI,Roboto,Arial,sans-serif";
        const headerFont="1000 15px system-ui,-apple-system,'Noto Sans KR',Segoe UI,Roboto,Arial,sans-serif";
        const captionFont="1000 18px system-ui,-apple-system,'Noto Sans KR',Segoe UI,Roboto,Arial,sans-serif";
        const smallFont="800 12px system-ui,-apple-system,'Noto Sans KR',Segoe UI,Roboto,Arial,sans-serif";

        function isNumText(v){
          return /^-?[\d,]+(\.\d+)?$/.test(String(v||"").trim());
        }

        function isNumericColumn(name){
          return /일자$|배송|반품|총수량|일평균/.test(name||"");
        }

        function wrapText(text,maxWidth,fontValue){
          const raw=String(text??"");
          const hardLines=raw.split(/\n/);
          ctx.font=fontValue||font;
          const lines=[];

          hardLines.forEach(part=>{
            const words=part.split(/(\s+)/).filter(v=>v!=="");
            let line="";

            if(!words.length){
              lines.push("");
              return;
            }

            words.forEach(word=>{
              const next=line+word;
              if(ctx.measureText(next).width<=maxWidth||!line){
                line=next;
                return;
              }
              lines.push(line.trimEnd());
              line=word.trimStart();
            });

            if(line)lines.push(line.trimEnd());
          });

          return lines.length?lines:[""];
        }

        function maxColumnWidth(index){
          const header=headers[index]||"";
          if(/원본/.test(header))return 360;
          if(/기간/.test(header))return 230;
          if(/배송일자|정산월/.test(header))return 135;
          if(/캠프/.test(header))return 120;
          if(/주\/야/.test(header))return 95;
          if(/노선/.test(header))return 110;
          if(/일평균/.test(header))return 120;
          if(/배송|반품|총수량|일자/.test(header))return 125;
          return 140;
        }

        function minColumnWidth(index){
          const header=headers[index]||"";
          if(/원본/.test(header))return 260;
          if(/기간/.test(header))return 190;
          if(/배송일자|정산월/.test(header))return 120;
          if(/캠프/.test(header))return 90;
          if(/노선/.test(header))return 80;
          return 78;
        }

        ctx.font=font;
        const widths=Array.from({length:colCount},(_,i)=>{
          const header=headers[i]||"";
          let w=ctx.measureText(header).width+padX*2;

          rows.forEach(row=>{
            const cell=String(row[i]||"");
            ctx.font=font;
            const lines=cell.split(/\n/);
            lines.forEach(line=>{
              w=Math.max(w,ctx.measureText(line).width+padX*2);
            });
          });

          return Math.ceil(Math.max(minColumnWidth(i),Math.min(maxColumnWidth(i),w)));
        });

        // 표가 너무 좁아져서 글자가 찢어지는 걸 방지한다.
        const tableW=widths.reduce((a,b)=>a+b,0);
        const lineH=22;

        const wrappedRows=rows.map(row=>row.map((cell,i)=>{
          const header=headers[i]||"";
          const usable=widths[i]-padX*2;
          const shouldWrap=/원본|기간/.test(header);
          if(shouldWrap)return wrapText(cell,usable,font);
          return String(cell??"").split(/\n/);
        }));

        const rowHeights=wrappedRows.map(row=>{
          const maxLines=Math.max(1,...row.map(lines=>lines.length));
          return Math.max(42,maxLines*lineH+rowPadY*2);
        });

        const tableH=captionH+headerH+rowHeights.reduce((a,b)=>a+b,0);
        canvas.width=Math.ceil(tableW*scale);
        canvas.height=Math.ceil(tableH*scale);
        canvas.style.width=tableW+"px";
        canvas.style.height=tableH+"px";
        ctx.scale(scale,scale);

        ctx.fillStyle="#ffffff";
        ctx.fillRect(0,0,tableW,tableH);

        function drawStatCaption(){
          if(!captionText)return;

          ctx.fillStyle="#ffffff";
          ctx.fillRect(0,0,tableW,captionH);

          ctx.font=captionFont;
          ctx.textBaseline="top";

          const parts=[];
          const re=/(최고수량\s[\d,.]+\s\([^)]+\)|최저수량\s[\d,.]+\s\([^)]+\)|평균수량\s[\d,.]+)/g;
          let last=0;
          let match;

          while((match=re.exec(captionText))){
            if(match.index>last)parts.push({text:captionText.slice(last,match.index),color:"#111827"});
            const text=match[0];
            const color=text.startsWith("최고수량")?"#2563eb":text.startsWith("최저수량")?"#ef4444":"#ca8a04";
            parts.push({text,color});
            last=re.lastIndex;
          }

          if(last<captionText.length)parts.push({text:captionText.slice(last),color:"#111827"});

          let x=16,y=14;
          const maxX=tableW-16;

          parts.forEach(part=>{
            const chars=String(part.text).split("");
            let buf="";
            ctx.fillStyle=part.color;

            chars.forEach(ch=>{
              const next=buf+ch;
              if(x+ctx.measureText(next).width>maxX&&buf){
                ctx.fillText(buf,x,y);
                x+=ctx.measureText(buf).width;
                x=16;
                y+=25;
                buf=ch;
              }else{
                buf=next;
              }
            });

            if(buf){
              ctx.fillText(buf,x,y);
              x+=ctx.measureText(buf).width;
            }
          });

          ctx.strokeStyle="#cfd8e3";
          ctx.lineWidth=1;
          ctx.beginPath();
          ctx.moveTo(0,captionH-.5);
          ctx.lineTo(tableW,captionH-.5);
          ctx.stroke();
        }

        function alignFor(index){
          const header=headers[index]||"";
          if(/원본/.test(header))return "left";
          if(isNumericColumn(header))return "right";
          return "center";
        }

        function cellColor(index,text){
          const header=headers[index]||"";
          if(/배송|총수량/.test(header))return "#047857";
          if(/일평균/.test(header))return "#a16207";
          return "#111827";
        }

        function drawCellText(textLines,x,y,w,h,index,bold=false){
          const align=alignFor(index);
          const header=headers[index]||"";
          ctx.font=bold?headerFont:font;
          ctx.textBaseline="middle";
          ctx.fillStyle=bold?"#0f172a":cellColor(index,textLines.join(" "));

          const totalTextH=textLines.length*lineH;
          let ty=y+h/2-totalTextH/2+lineH/2;

          textLines.forEach(line=>{
            let tx=x+w/2;
            ctx.textAlign="center";

            if(align==="left"){
              tx=x+padX;
              ctx.textAlign="left";
            }else if(align==="right"){
              tx=x+w-padX;
              ctx.textAlign="right";
            }

            ctx.fillText(line,tx,ty);
            ty+=lineH;
          });
        }

        drawStatCaption();

        let y=captionH;
        let x=0;

        ctx.strokeStyle="#cfd8e3";
        ctx.lineWidth=1;

        headers.forEach((header,i)=>{
          const w=widths[i];
          ctx.fillStyle="#dbe7f5";
          ctx.fillRect(x,y,w,headerH);
          ctx.strokeRect(x+.5,y+.5,w,headerH);
          drawCellText([header],x,y,w,headerH,i,true);
          x+=w;
        });

        y+=headerH;

        wrappedRows.forEach((row,rowIndex)=>{
          x=0;
          const h=rowHeights[rowIndex];
          const bg=rowIndex%2===1?"#f8fafc":"#ffffff";

          row.forEach((lines,i)=>{
            const w=widths[i];
            ctx.fillStyle=bg;
            ctx.fillRect(x,y,w,h);
            ctx.strokeStyle="#cfd8e3";
            ctx.strokeRect(x+.5,y+.5,w,h);
            drawCellText(lines,x,y,w,h,i,false);
            x+=w;
          });

          y+=h;
        });

        canvas.toBlob(async blob=>{
          if(!blob){
            alert("표 이미지 생성 실패");
            return;
          }

          if(navigator.clipboard&&window.ClipboardItem){
            await navigator.clipboard.write([new ClipboardItem({"image/png":blob})]);
            alert("표 전체 이미지를 클립보드에 복사했습니다.");
            return;
          }

          const a=document.createElement("a");
          a.href=URL.createObjectURL(blob);
          a.download=`${tableId}.png`;
          a.click();
          URL.revokeObjectURL(a.href);
        },"image/png");
      }
      function graphContextLabel(rows){const camp=clean(els.currentCampInput.value);const route=clean(els.currentRouteInput.value);if(camp||route)return` (${[camp,route].filter(Boolean).join(", ")})`;const camps=Array.from(new Set((rows||[]).map(r=>clean(r.camp)).filter(Boolean)));const routes=Array.from(new Set((rows||[]).map(r=>clean(r.route)).filter(Boolean)));if(camps.length===1&&routes.length===1)return` (${camps[0]}, ${routes[0]})`;if(camps.length===1)return` (${camps[0]})`;return""}
      function graphData(kind){if(!state.stats)return{title:"그래프",rows:[],metric:"quantity",kind:"route",stats:""};if(kind==="route"){const rows=state.stats.routeRows.slice(0,30);return{title:"노선별 총수량",rows:rows.map(r=>({label:`${r.camp} ${r.wave} ${r.route}`,value:r.quantity,parcel:r.parcel,ret:r.return,source:r})),metric:"quantity",kind:"route",stats:graphStatsText(rows,"route")}}if(kind==="daily"){const rows=state.stats.dailyRows;return{title:`일별 총수량${graphContextLabel(rows)}`,rows:rows.map(r=>({label:r.date,value:r.quantity,parcel:r.parcel,ret:r.return,source:r})),metric:"quantity",kind:"daily",stats:graphStatsText(rows,"daily")}}if(kind==="weekday"){const rows=state.stats.weekdayRows;return{title:`요일별 총수량${graphContextLabel(rows)}`,rows:rows.map(r=>({label:r.weekday,value:r.quantity,parcel:r.parcel,ret:r.return,source:r})),metric:"quantity",kind:"weekday",stats:graphStatsText(rows,"weekday")}}if(kind==="monthlyAvg"){const rows=state.stats.monthlyRows;return{title:`월별 일평균${graphContextLabel(rows)}`,rows:rows.map(r=>({label:r.month,value:r.avg_day,parcel:r.parcel,ret:r.return,source:r})),metric:"avg_day",kind:"monthly",stats:graphStatsText(rows,"monthly","avg_day")}}const rows=state.stats.monthlyRows;return{title:`월별 총수량${graphContextLabel(rows)}`,rows:rows.map(r=>({label:r.month,value:r.quantity,parcel:r.parcel,ret:r.return,source:r})),metric:"quantity",kind:"monthly",stats:graphStatsText(rows,"monthly")}}
      function drawGraphStatLine(ctx,parts,x,y,maxWidth){let cursor=x;ctx.font="800 13px system-ui,-apple-system,Segoe UI,sans-serif";for(const part of parts){ctx.fillStyle=part.color||"#334155";const pieces=String(part.text||"").split("");let buffer="";for(const ch of pieces){const next=buffer+ch;if(cursor+ctx.measureText(next).width>maxWidth&&buffer){ctx.fillText(buffer,cursor,y);cursor+=ctx.measureText(buffer).width;buffer=ch}else{buffer=next}}if(buffer){ctx.fillText(buffer,cursor,y);cursor+=ctx.measureText(buffer).width}}}
      function drawGraph(kind){const data=graphData(kind);state.currentGraph=kind;els.graphTitle.textContent=data.title;const canvas=els.graphCanvas;const rows=data.rows;const width=Math.max(900,rows.length*68+160),height=620;canvas.width=width*2;canvas.height=height*2;canvas.style.width=width+"px";canvas.style.height=height+"px";const ctx=canvas.getContext("2d");ctx.scale(2,2);ctx.fillStyle="#fff";ctx.fillRect(0,0,width,height);ctx.fillStyle="#111827";ctx.font="800 22px system-ui,-apple-system,Segoe UI,sans-serif";ctx.fillText(data.title,24,36);const parts=statParts(rows.map(r=>r.source).filter(Boolean),data.kind,data.metric);if(parts.length)drawGraphStatLine(ctx,parts,24,62,width-24);if(!rows.length){ctx.fillStyle="#111827";ctx.font="800 16px system-ui";ctx.fillText("조회된 그래프 데이터가 없습니다.",24,105);return}const max=Math.max(...rows.map(r=>Number(r.value)||0),1);const chartX=70,chartY=100,chartW=width-100,chartH=360;ctx.strokeStyle="#cbd5e1";ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(chartX,chartY);ctx.lineTo(chartX,chartY+chartH);ctx.lineTo(chartX+chartW,chartY+chartH);ctx.stroke();ctx.fillStyle="#64748b";ctx.font="700 11px system-ui";for(let i=0;i<=4;i++){const y=chartY+chartH-(chartH*i/4);const v=max*i/4;ctx.fillText(data.metric==="avg_day"?Number(v).toLocaleString("ko-KR",{maximumFractionDigits:1}):Math.round(v).toLocaleString("ko-KR"),8,y+4);ctx.strokeStyle="#e2e8f0";ctx.beginPath();ctx.moveTo(chartX,y);ctx.lineTo(chartX+chartW,y);ctx.stroke()}const gap=8,barW=Math.max(20,(chartW-(rows.length+1)*gap)/Math.max(rows.length,1));rows.forEach((r,i)=>{const x=chartX+gap+i*(barW+gap);const value=Number(r.value)||0;const h=chartH*(value/max);const y=chartY+chartH-h;ctx.fillStyle=data.metric==="avg_day"?"#16a34a":"#2563eb";ctx.fillRect(x,y,barW,h);ctx.fillStyle="#111827";ctx.font="800 11px system-ui";ctx.textAlign="center";ctx.fillText(data.metric==="avg_day"?value.toLocaleString("ko-KR",{maximumFractionDigits:1}):Math.round(value).toLocaleString("ko-KR"),x+barW/2,Math.max(y-6,chartY+12));ctx.save();ctx.translate(x+barW/2,chartY+chartH+14);ctx.rotate(-Math.PI/4);ctx.textAlign="right";ctx.font="700 10px system-ui";ctx.fillText(r.label,0,0);ctx.restore()});ctx.textAlign="left"}
      function openGraph(kind){drawGraph(kind);els.graphModal.classList.add("show")}function closeGraph(){els.graphModal.classList.remove("show")}async function copyGraph(){const canvas=els.graphCanvas;if(!canvas.width){alert("복사할 그래프가 없습니다.");return}canvas.toBlob(async blob=>{if(!blob){alert("그래프 이미지 생성 실패");return}if(navigator.clipboard&&window.ClipboardItem){await navigator.clipboard.write([new ClipboardItem({"image/png":blob})]);alert("그래프 이미지를 클립보드에 복사했습니다.");return}const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="account_graph.png";a.click();URL.revokeObjectURL(a.href)},"image/png")}
      function bind(){els.btnLogout.addEventListener("click",logout);els.deniedLogoutBtn.addEventListener("click",logout);els.deniedHomeBtn.addEventListener("click",()=>{location.href=HOME_PATH});els.btnLoad.addEventListener("click",loadRows);if(els.btnExcel)els.btnExcel.addEventListener("click",exportExcel);els.btnReset.addEventListener("click",resetTables);els.btnCloseGraph.addEventListener("click",closeGraph);els.graphModal.addEventListener("click",e=>{if(e.target===els.graphModal)closeGraph()});els.btnCopyGraph.addEventListener("click",copyGraph);document.querySelectorAll("[data-copy-table]").forEach(btn=>btn.addEventListener("click",()=>copyTable(btn.dataset.copyTable)));document.querySelectorAll("[data-graph]").forEach(btn=>btn.addEventListener("click",()=>openGraph(btn.dataset.graph)));const upperRouteInput=el=>{const s=el.selectionStart,e=el.selectionEnd;const v=el.value.toUpperCase();if(el.value!==v){el.value=v;try{el.setSelectionRange(s,e)}catch{}}};[els.currentRouteInput,els.pastRoutesInput].forEach(el=>el.addEventListener("input",()=>upperRouteInput(el)));[els.waveSelect,els.currentCampInput,els.currentRouteInput,els.pastRoutesInput,els.searchInput].forEach(el=>{el.addEventListener("input",()=>{if(state.rawRows.length)buildStats()});el.addEventListener("change",()=>{if(state.rawRows.length)buildStats()})});[els.yearSelect,els.startMonthSelect,els.endMonthSelect].forEach(el=>el.addEventListener("change",resetTables));els.searchInput.addEventListener("keydown",e=>{if(e.key==="Enter"&&state.rawRows.length)buildStats()})}
      async function boot(){initPeriodSelects();bind();renderAll();try{await checkAccess()}catch(err){console.error(err);showAccessDenied(err.message||String(err))}}
      boot();
    })();
  </script>
