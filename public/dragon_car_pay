      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              storage: window.sessionStorage,
              persistSession: true,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function getSupabaseProjectRef(url) {
        try {
          const host = new URL(url).hostname || "";
          return host.split(".")[0] || "";
        } catch {
          return "";
        }
      }

      function createSupabaseSessionBridge(url) {
        const projectRef = getSupabaseProjectRef(url);
        const prefixes = projectRef ? [
          "sb-" + projectRef + "-auth-token",
          "sb-" + projectRef + "-auth-token-code-verifier"
        ] : [];
        const origin = window.location.origin;
        const channelName = projectRef ? ("mw-auth-bridge:" + projectRef) : "";
        const tabId = Date.now().toString(36) + Math.random().toString(36).slice(2);
        const pending = new Map();
        let channel = null;
        let started = false;

        function matchesKey(key) {
          return !!key && prefixes.some(prefix => key === prefix || key.startsWith(prefix));
        }

        function readEntries(storage) {
          const target = storage || window.sessionStorage;
          const rows = [];
          try {
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (!matchesKey(key)) continue;
              rows.push({ key, value: target.getItem(key) });
            }
          } catch {}
          return rows;
        }

        function hasSession(storage) {
          return readEntries(storage).some(row =>
            row.key.includes("-auth-token") &&
            !row.key.includes("code-verifier") &&
            !!row.value
          );
        }

        function writeEntries(entries, storage) {
          const target = storage || window.sessionStorage;
          try {
            for (const row of entries || []) {
              if (!row || !matchesKey(row.key)) continue;
              if (row.value == null) target.removeItem(row.key);
              else target.setItem(row.key, row.value);
            }
          } catch {}
        }

        function clearSession(storage) {
          const target = storage || window.sessionStorage;
          try {
            const keys = [];
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (matchesKey(key)) keys.push(key);
            }
            keys.forEach(key => target.removeItem(key));
          } catch {}
        }

        function resolvePending(requestId, entries) {
          const item = pending.get(requestId);
          if (!item) return;
          pending.delete(requestId);
          clearTimeout(item.timer);
          if (Array.isArray(entries) && entries.length) writeEntries(entries, window.sessionStorage);
          item.resolve(hasSession(window.sessionStorage));
        }

        function handleSyncState(syncState) {
          if (syncState === "SIGNED_OUT") {
            clearSession(window.sessionStorage);
            return;
          }
          if (syncState === "SESSION_UPDATED" && !hasSession(window.sessionStorage)) {
            requestSessionCopy(1200).catch(() => {});
          }
        }

        function onWindowMessage(event) {
          if (event.origin !== origin) return;
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              event.source?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              }, origin);
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function onChannelMessage(event) {
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              channel?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              });
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function start() {
          if (started || !projectRef) return;
          started = true;
          window.addEventListener("message", onWindowMessage);
          try {
            if ("BroadcastChannel" in window) {
              channel = new BroadcastChannel(channelName);
              channel.onmessage = onChannelMessage;
            }
          } catch {}
        }

        function requestSessionCopy(timeoutMs) {
          start();
          if (!projectRef || hasSession(window.sessionStorage)) return Promise.resolve(true);
          const requestId = tabId + ":" + Date.now().toString(36) + Math.random().toString(36).slice(2);
          return new Promise(resolve => {
            const timer = setTimeout(() => {
              pending.delete(requestId);
              resolve(hasSession(window.sessionStorage));
            }, timeoutMs || 1000);
            pending.set(requestId, { resolve, timer });
            const msg = { type: "MW_SESSION_REQUEST", projectRef, requestId, fromTabId: tabId };
            try { window.postMessage(msg, origin); } catch {}
            try { channel?.postMessage(msg); } catch {}
          });
        }

        function broadcastAuthState(syncState) {
          start();
          const msg = { type: "MW_AUTH_SYNC", projectRef, state: syncState, fromTabId: tabId };
          try { window.postMessage(msg, origin); } catch {}
          try { channel?.postMessage(msg); } catch {}
        }

        return { start, requestSessionCopy, broadcastAuthState, clearSession };
      }

      const sessionBridge = createSupabaseSessionBridge(SUPABASE_URL || "");

      function normalizeKey(key) {
        return String(key || "").replace(/[^a-zA-Z0-9가-힣]/g, "").toLowerCase();
      }

      function valueByCandidates(row, candidates) {
        if (!row || !candidates) return "";
        for (const key of candidates) {
          if (Object.prototype.hasOwnProperty.call(row, key) && row[key] != null) return row[key];
        }
        const normalizedMap = new Map();
        for (const key of Object.keys(row)) normalizedMap.set(normalizeKey(key), key);
        for (const key of candidates) {
          const realKey = normalizedMap.get(normalizeKey(key));
          if (realKey && row[realKey] != null) return row[realKey];
        }
        return "";
      }

      function pick(row, groupKey) {
        return valueByCandidates(row, COLUMN_CANDIDATES[groupKey] || []);
      }

      function esc(value) {
        return String(value ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function normalizeText(value) {
        return String(value ?? "").trim();
      }

      function compactText(value) {
        return normalizeText(value).replace(/\s+/g, "");
      }

      function toNumber(value) {
        if (typeof value === "number") return Number.isFinite(value) ? value : 0;
        const text = String(value ?? "").trim();
        if (!text) return 0;
        const cleaned = text.replace(/[₩원,%\s]/g, "").replace(/,/g, "");
        const n = Number(cleaned);
        return Number.isFinite(n) ? n : 0;
      }

      function roundWon(value) {
        const n = Number(value);
        if (!Number.isFinite(n)) return 0;
        return Math.round(n);
      }

      function fmtMoney(value) {
        return "₩" + roundWon(value).toLocaleString("ko-KR");
      }

      function fmtSignedMoney(value) {
        const n = roundWon(value);
        if (n < 0) return "-" + fmtMoney(Math.abs(n));
        return fmtMoney(n);
      }

      function fmtNumber(value) {
        return roundWon(value).toLocaleString("ko-KR");
      }

      function parseRate(value, fallback) {
        const text = String(value ?? "").trim();
        if (!text) return fallback;
        if (/^0+(\.0+)?%?$/.test(text)) return 0;
        let n = toNumber(text);
        if (!Number.isFinite(n)) return fallback;
        if (text.includes("%") || n > 1) n = n / 100;
        if (n < 0) return 0;
        return n;
      }

      function defaultMonth() {
        const now = new Date();
        return now.getFullYear() + "-" + String(now.getMonth() + 1).padStart(2, "0");
      }

      function parseMonthInput(value) {
        const raw = String(value || "").trim();
        if (!raw) return defaultMonth();
        const direct = raw.match(/(20\d{2})\s*[-./년]\s*(\d{1,2})/);
        if (direct) return direct[1] + "-" + String(Number(direct[2])).padStart(2, "0");
        const short = raw.match(/(^|\D)(\d{2})\s*년\s*(\d{1,2})\s*월/);
        if (short) return "20" + short[2] + "-" + String(Number(short[3])).padStart(2, "0");
        const monthOnly = raw.match(/^(\d{1,2})$/);
        if (monthOnly) {
          const year = new Date().getFullYear();
          return year + "-" + String(Number(monthOnly[1])).padStart(2, "0");
        }
        return raw;
      }

      function formatMonthTitle(month) {
        const m = String(month || "").match(/^(\d{4})-(\d{2})$/);
        if (!m) return month || "-";
        return m[1] + "년 " + Number(m[2]) + "월";
      }

      function formatMonthShort(month) {
        const m = String(month || "").match(/^(\d{4})-(\d{2})$/);
        if (!m) return month || "-";
        return m[1] + ". " + Number(m[2]) + ".";
      }

      function isExcelSerialNumber(value) {
        return typeof value === "number" && value > 20000 && value < 80000;
      }

      function excelSerialToDate(value) {
        const utcDays = Math.floor(value - 25569);
        const utcValue = utcDays * 86400;
        return new Date(utcValue * 1000);
      }

      function parseDateValue(value) {
        if (value instanceof Date && !Number.isNaN(value.getTime())) return value;
        if (isExcelSerialNumber(value)) return excelSerialToDate(value);
        const raw = String(value ?? "").trim();
        if (!raw) return null;
        const iso = raw.match(/(20\d{2})[-./년\s]+(\d{1,2})[-./월\s]+(\d{1,2})/);
        if (iso) return new Date(Number(iso[1]), Number(iso[2]) - 1, Number(iso[3]));
        const md = raw.match(/^(\d{1,2})\s*[/.-]\s*(\d{1,2})/);
        if (md) {
          const year = Number(String(state.month || defaultMonth()).slice(0, 4)) || new Date().getFullYear();
          return new Date(year, Number(md[1]) - 1, Number(md[2]));
        }
        const d = new Date(raw);
        if (!Number.isNaN(d.getTime())) return d;
        return null;
      }

      function rowMonthKey(row) {
        const monthValue = normalizeText(pick(row, "month"));
        const parsedMonth = parseMonthInput(monthValue);
        if (/^\d{4}-\d{2}$/.test(parsedMonth)) return parsedMonth;
        const date = parseDateValue(pick(row, "date"));
        if (!date) return "";
        return date.getFullYear() + "-" + String(date.getMonth() + 1).padStart(2, "0");
      }

      function dayName(date) {
        if (!date) return "";
        return ["일", "월", "화", "수", "목", "금", "토"][date.getDay()] || "";
      }

      function formatDateCell(value) {
        const d = parseDateValue(value);
        if (!d) return normalizeText(value) || "-";
        return (d.getMonth() + 1) + "/" + d.getDate() + " " + dayName(d);
      }

      function isSunday(value) {
        const d = parseDateValue(value);
        return !!d && d.getDay() === 0;
      }

      function normalizeTaxStatus(value) {
        if (typeof value === "boolean") return value;
        const text = compactText(value).toLowerCase();
        if (!text) return false;
        if (["발행", "발행완료", "완료", "o", "y", "yes", "true", "1", "issued", "세금계산서발행"].includes(text)) return true;
        if (["미발행", "미", "무", "x", "n", "no", "false", "0", "notissued", "미완료"].includes(text)) return false;
        if (text.includes("미발행")) return false;
        if (text.includes("발행")) return true;
        return false;
      }

      function taxIssued(row) {
        return normalizeTaxStatus(pick(row, "tax"));
      }

      function taxLabelByBool(value) {
        return value ? "발행" : "미발행";
      }

      function yesLike(value) {
        if (typeof value === "boolean") return value;
        const text = compactText(value).toLowerCase();
        if (!text) return false;
        if (["o", "y", "yes", "true", "1", "가입", "대상", "적용"].includes(text)) return true;
        if (["x", "n", "no", "false", "0", "미가입", "제외", "미적용"].includes(text)) return false;
        return text.includes("o") || text.includes("가입") || text.includes("적용");
      }

      function rowInfo(row) {
        const unit = toNumber(pick(row, "unitPrice"));
        const qty = toNumber(pick(row, "quantity"));
        const returnQty = toNumber(pick(row, "returnQuantity"));
        let amount = toNumber(pick(row, "amount"));
        if (!amount && unit && qty) amount = unit * qty;
        const vendorId = normalizeText(pick(row, "vendorId"));
        const vendorById = vendorId ? state.vendorById.get(String(vendorId)) : null;
        const vendorName = normalizeText(pick(row, "vendorName")) || vendorDisplayName(vendorById) || (vendorId ? "업체 " + vendorId : "미지정 업체");
        const driverName = normalizeText(pick(row, "driver")) || "미지정 기사";
        return {
          row,
          rowId: normalizeText(pick(row, "rowId")),
          date: pick(row, "date"),
          camp: normalizeText(pick(row, "camp")),
          wave: normalizeText(pick(row, "wave")),
          route: normalizeText(pick(row, "route")),
          unit,
          qty,
          returnQty,
          amount: roundWon(amount),
          taxIssued: taxIssued(row),
          vendorId,
          vendorName,
          orderName: normalizeText(pick(row, "orderName")),
          driverName,
          memo: normalizeText(pick(row, "memo"))
        };
      }

      function vendorDisplayName(vendor) {
        if (!vendor) return "";
        return normalizeText(
          valueByCandidates(vendor, ["vendor_name", "company_name", "business_name", "name", "상호", "업체명"])
        );
      }

      function vendorSearchText(vendor) {
        if (!vendor) return "";
        return Object.values(vendor).map(v => normalizeText(v)).join(" ");
      }

      function driverInfoName(info) {
        return normalizeText(valueByCandidates(info, ["person_name", "name", "이름"]));
      }

      function getDriverInfo(name) {
        const key = compactText(name);
        if (!key) return null;
        return state.driverInfoByName.get(key) || null;
      }

      function driverBusinessName(name) {
        const info = getDriverInfo(name);
        return normalizeText(valueByCandidates(info, COLUMN_CANDIDATES.businessName)) || name || "-";
      }

      function driverBusinessNumber(name) {
        const info = getDriverInfo(name);
        return normalizeText(valueByCandidates(info, COLUMN_CANDIDATES.businessNumber)) || "-";
      }

      function driverPayrollBank(name) {
        const info = getDriverInfo(name);
        return normalizeText(valueByCandidates(info, COLUMN_CANDIDATES.payrollBank)) || "-";
      }

      function driverPayrollAccount(name) {
        const info = getDriverInfo(name);
        return normalizeText(valueByCandidates(info, COLUMN_CANDIDATES.payrollAccount)) || "-";
      }

      function getDriverCommissionRate(name) {
        if (ZERO_COMMISSION_DRIVER_NAMES.has(normalizeText(name))) return 0;
        const info = getDriverInfo(name);
        const raw = valueByCandidates(info, COLUMN_CANDIDATES.dragonCommission);
        return parseRate(raw, DEFAULT_DRAGON_COMMISSION_RATE);
      }

      function hasEmploymentAccidentInsurance(name) {
        const info = getDriverInfo(name);
        const raw = valueByCandidates(info, COLUMN_CANDIDATES.employmentInsurance);
        return yesLike(raw);
      }

      function computeTaxDetail(issuedAmount) {
        const supply = roundWon(issuedAmount / (1 + VAT_RATE));
        const vat = roundWon(issuedAmount - supply);
        return { supply, vat, total: roundWon(issuedAmount) };
      }

      function computeInsurance(issuedAmount, enabled) {
        if (!enabled) return 0;
        const detail = computeTaxDetail(issuedAmount);
        return roundWon(detail.supply * EMPLOYMENT_ACCIDENT_RATE);
      }

      function computeBaseSettlement(rows, name, mode) {
        const infos = rows.map(rowInfo);
        const totalAmount = infos.reduce((sum, item) => sum + item.amount, 0);
        const issuedAmount = infos.filter(item => item.taxIssued).reduce((sum, item) => sum + item.amount, 0);
        const unissuedAmount = totalAmount - issuedAmount;
        const taxDetail = computeTaxDetail(issuedAmount);
        const rate = mode === "driver" ? getDriverCommissionRate(name) : 0;
        const commission = mode === "driver" ? roundWon(totalAmount * rate) : 0;
        const insuranceEnabled = mode === "driver" ? hasEmploymentAccidentInsurance(name) : false;
        const insurance = mode === "driver" ? computeInsurance(issuedAmount, insuranceEnabled) : 0;
        const afterCommission = totalAmount - commission;
        const finalPay = afterCommission - insurance;

        return {
          rows,
          infos,
          totalAmount,
          issuedAmount,
          unissuedAmount,
          taxSupply: taxDetail.supply,
          taxVat: taxDetail.vat,
          commissionRate: rate,
          commission,
          insuranceEnabled,
          insurance,
          afterCommission,
          teamLeaderBonus: 0,
          finalPay
        };
      }

      function computeMonthDriverTotals(groups) {
        const driverGroups = groups.filter(group => group.mode === "driver" && group.name !== "미지정 기사");
        const baseCommission = driverGroups.reduce((sum, group) => sum + group.metrics.commission, 0);
        const baseInsurance = driverGroups.reduce((sum, group) => sum + group.metrics.insurance, 0);
        const leaderBonus = Math.max(0, roundWon((baseCommission - (baseInsurance * 0.5)) * 0.5));
        return { baseCommission, baseInsurance, leaderBonus };
      }

      function applyTeamLeaderBonus(group, leaderBonus) {
        if (!group || group.mode !== "driver" || group.name !== TEAM_LEADER_NAME || !leaderBonus) return;
        const metrics = group.metrics;
        metrics.teamLeaderBonus = leaderBonus;
        metrics.issuedAmount += leaderBonus;
        metrics.totalAmount += leaderBonus;
        const taxDetail = computeTaxDetail(metrics.issuedAmount);
        metrics.taxSupply = taxDetail.supply;
        metrics.taxVat = taxDetail.vat;
        metrics.afterCommission += leaderBonus;
        metrics.finalPay += leaderBonus;
      }

      function groupKeyVendor(info) {
        return "vendor:" + (info.vendorId || info.vendorName || "none") + ":" + (info.orderName || "");
      }

      function groupKeyDriver(info) {
        return "driver:" + (info.driverName || "none");
      }

      function rowMatchesSearch(info, query) {
        if (!query) return true;
        const haystack = [
          info.vendorId,
          info.vendorName,
          info.orderName,
          info.driverName,
          info.camp,
          info.wave,
          info.route,
          info.memo
        ].join(" ").toLowerCase();
        return haystack.includes(query.toLowerCase());
      }

      function buildGroups() {
        const query = normalizeText(dom.searchInput.value);
        state.monthRows = state.allRows.filter(row => rowMonthKey(row) === state.month);
        const filteredRows = state.monthRows.filter(row => rowMatchesSearch(rowInfo(row), query));
        const map = new Map();

        for (const row of filteredRows) {
          const info = rowInfo(row);
          const key = state.mode === "driver" ? groupKeyDriver(info) : groupKeyVendor(info);
          if (!map.has(key)) {
            map.set(key, {
              key,
              mode: state.mode,
              name: state.mode === "driver" ? info.driverName : info.vendorName,
              subtitle: state.mode === "driver"
                ? driverBusinessName(info.driverName)
                : (info.orderName || "Order 없음"),
              vendorId: info.vendorId,
              vendorName: info.vendorName,
              orderName: info.orderName,
              rows: []
            });
          }
          map.get(key).rows.push(row);
        }

        let groups = Array.from(map.values()).map(group => {
          group.rows.sort((a, b) => {
            const da = parseDateValue(pick(a, "date"));
            const db = parseDateValue(pick(b, "date"));
            return (da ? da.getTime() : 0) - (db ? db.getTime() : 0);
          });
          group.metrics = computeBaseSettlement(group.rows, group.name, group.mode);
          return group;
        });

        groups.sort((a, b) => {
          if (b.metrics.totalAmount !== a.metrics.totalAmount) return b.metrics.totalAmount - a.metrics.totalAmount;
          return String(a.name).localeCompare(String(b.name), "ko");
        });

        if (state.mode === "driver") {
          const baseDriverGroups = groups.map(group => ({ ...group, metrics: { ...group.metrics } }));
          state.monthDriverTotals = computeMonthDriverTotals(baseDriverGroups);
          const leaderGroup = groups.find(group => group.name === TEAM_LEADER_NAME);
          applyTeamLeaderBonus(leaderGroup, state.monthDriverTotals.leaderBonus);
        } else {
          state.monthDriverTotals = null;
