      function buildTypeSummaryRows(rawRows) {
        const map = new Map();

        for (const row of rawRows) {
          const type = normalizeText(row[state.rawCols.type]) || "기타";
          if (!map.has(type)) {
            map.set(type, {
              type,
              deliveryCount: 0,
              returnCount: 0,
              amountSum: 0
            });
          }

          const item = map.get(type);
          item.deliveryCount += toNumber(row[state.rawCols.delivery]);
          item.returnCount += toNumber(row[state.rawCols.return]);
          item.amountSum += toNumber(row[state.rawCols.amount]);
        }

        return Array.from(map.values()).sort((a, b) => a.type.localeCompare(b.type, "ko"));
      }

      function buildTypeSummaryMap(rawRows) {
        const rows = buildTypeSummaryRows(rawRows);
        const map = {};
        for (const row of rows) {
          map[row.type] = row;
        }
        return map;
      }

