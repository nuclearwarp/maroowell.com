<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}

    /* =========================================================
       Maroowell Freshbag white design override
       - 기능 로직은 유지하고 화면 디자인만 흰 배경 기준으로 정리
       - 문경감홍사과체 적용
       ========================================================= */
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --card:#ffffff;
      --line:#d8e0ee;
      --line2:#cbd5e1;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --red:#ef4444;
      --green:#16a34a;
      --yellow:#b77900;
      --cell:#ffffff;
      --head:#dbeafe;
      --sep:#94a3b8;
      --sepCamp:#64748b;
      --mw-font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    body{
      background:
        radial-gradient(circle at 16% 0%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 86% 0%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,#f6f8fc 100%);
      color:var(--txt);
      font-family:var(--mw-font);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
    }

    .wrap{
      max-width:1760px;
      padding:18px 16px 40px;
    }

    .top{
      background:rgba(255,255,255,.94);
      border:1px solid var(--line);
      border-radius:22px;
      padding:14px 16px;
      box-shadow:0 12px 30px rgba(15,23,42,.08);
      backdrop-filter:blur(12px);
    }

    .brand img{
      filter:drop-shadow(0 4px 8px rgba(15,23,42,.10));
    }

    .title{
      color:#0f172a;
      font-size:24px;
      font-weight:800;
      letter-spacing:-.04em;
    }

    .sub{
      color:#64748b;
      font-size:13px;
      font-weight:500;
    }

    .card{
      background:#ffffff;
      border:1px solid var(--line);
      border-radius:20px;
      box-shadow:0 12px 30px rgba(15,23,42,.08);
    }

    .presetRow{
      border-top:1px solid #edf2f7;
    }

    .field label,
    .hiddenMonthLabel{
      color:#64748b;
      font-weight:700;
    }

    input,select{
      border:1px solid #cbd5e1;
      background:#f8fafc;
      color:#0f172a;
      font-family:var(--mw-font);
      font-size:13px;
      font-weight:500;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.75);
    }

    select option{
      background:#fff;
      color:#0f172a;
    }

    input:focus,select:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
      background:#fff;
    }

    button{
      border:1px solid #cbd5e1;
      background:#ffffff;
      color:#0f172a;
      font-family:var(--mw-font);
      font-size:13px;
      font-weight:700;
      box-shadow:0 1px 0 rgba(255,255,255,.85), 0 4px 12px rgba(15,23,42,.04);
    }

    button:hover{
      background:#f8fbff;
      border-color:#93c5fd;
    }

    button.secondary{
      background:#f8fafc;
      color:#334155;
    }

    button.secondary:hover{
      background:#eff6ff;
    }

    button.ok{
      background:linear-gradient(180deg,#22c55e,#16a34a);
      border-color:#16a34a;
      color:#fff;
      box-shadow:0 8px 18px rgba(22,163,74,.18);
    }

    button.ok:hover{
      background:linear-gradient(180deg,#22c55e,#15803d);
    }

    button.danger{
      background:#fff5f5;
      border-color:#fecaca;
      color:#dc2626;
    }

    button.danger:hover{
      background:#fee2e2;
    }

    .pill{
      border:1px solid #d8e0ee;
      background:#f8fafc;
      color:#64748b;
      font-weight:650;
    }

    .pill strong{
      color:#0f172a;
    }

    .status{color:#64748b;font-weight:500}
    .status.ok{color:#15803d}
    .status.bad{color:#dc2626}
    .status.warn{color:#a16207}

    .hint{
      color:#64748b;
      font-weight:500;
    }

    .hiddenMonthChip{
      border-color:#bfdbfe;
      background:#eff6ff;
      color:#1d4ed8;
      font-weight:700;
    }

    .hiddenMonthChip:hover{background:#dbeafe}

    .hiddenMonthChip.all{
      border-color:#bbf7d0;
      background:#f0fdf4;
      color:#15803d;
    }

    .tableWrap{
      background:#ffffff;
      border:1px solid var(--line);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.7);
    }

    table{font-size:13px;color:#0f172a;}

    th,td{
      border-right:1px solid #d8e0ee;
      border-bottom:1px solid #d8e0ee;
    }

    th{
      background:#dbeafe;
      color:#0f172a;
      font-weight:700;
    }

    thead tr.monthSubRow th{
      background:#eff6ff;
      color:#0f172a;
      font-weight:700;
    }

    th.actionCol,
    th.sticky1,
    th.sticky2,
    th.sticky3{
      background:#dbeafe;
      color:#0f172a;
    }

    td.actionCol,
    td.sticky1,
    td.sticky2,
    td.sticky3{
      background:#f8fafc;
      color:#0f172a;
      font-weight:650;
    }

    td.sticky3{color:#1d4ed8;}

    th.monthGroup{
      border-left:2px solid #cbd5e1;
    }

    th.monthFirst,
    td.monthFirst{
      border-left:1px solid #cbd5e1;
    }

    .yes{
      background:#dff4ff;
      color:#075985;
      font-weight:700;
    }

    .no{
      background:#fff5f5;
      color:#dc2626;
      font-weight:700;
    }

    .miss{
      background:#fff7ed;
      color:#c2410c;
      font-weight:700;
    }

    .empty{
      background:#f8fafc;
      color:#94a3b8;
    }

    tr.routeSep td{border-top:2px solid #94a3b8;}
    tr.campSep td{border-top:3px solid #64748b;}

    td.editable:hover,
    td.editable:focus{
      outline:2px solid rgba(37,99,235,.35);
      background-color:#eff6ff;
    }

    .tableWrap input.editorInput,
    .tableWrap select.editorSelect{
      background:#fff;
      color:#0f172a;
      border:1px solid #93c5fd;
    }

    @media(max-width:900px){
      .top{align-items:stretch;}
      .title{font-size:21px;}
      .sub{font-size:12px;}
      .wrap{padding:12px 10px 28px;}
      .card{padding:12px;border-radius:18px;}
    }

  </style>
