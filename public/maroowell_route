      function parseFilterExpression(raw){const text=normalizeText(raw);if(!text)return{include:[],exclude:[]};const tokens=text.split(/\s+/).filter(Boolean);const include=[];const exclude=[];for(const token of tokens){if(token.startsWith("!")||token.startsWith("-")){const x=normalizeLower(token.slice(1));if(x)exclude.push(x)}else include.push(normalizeLower(token))}return{include,exclude}}function matchFilter(value,expr){const actual=normalizeLower(value);const parsed=parseFilterExpression(expr);for(const token of parsed.include)if(!actual.includes(token))return false;for(const token of parsed.exclude)if(actual.includes(token))return false;return true}function getRowValue(row,key){if(key==="contract_date")return formatDateForInput(row.contract_date);if(key==="wave")return normalizeWave(row.wave);if(NUMERIC_COLUMNS.has(key))return formatCurrencyForInput(row[key]);return normalizeText(row[key])}function getDisplayValue(row,key){const value=getRowValue(row,key);if(key==="wave")return value||"-";return value||"-"}function getEditableValue(row,key){if(key==="contract_date")return formatDateForInput(row.contract_date);if(key==="wave")return normalizeWave(row.wave);if(NUMERIC_COLUMNS.has(key))return formatCurrencyForInput(row[key]);return String(row[key]??"")}function findRowById(id){return state.rows.find(row=>String(rowId(row))===String(id))||null}function applyFilters(){state.filteredRows=state.rows.filter(row=>{if(row.seq&&state.deletedIds.has(row.seq))return false;if(dom.toggleOnlyChanged.checked&&!row.__dirty)return false;for(const input of dom.filterInputs){const key=input.dataset.filter;const expr=input.value||"";if(!normalizeText(expr))continue;if(!matchFilter(getRowValue(row,key),expr))return false}return true});renderTable();updatePills();if(!state.rows.length)setStatus("데이터가 없습니다.","warn");else if(state.filteredRows.length!==state.rows.length)setStatus(`필터 결과 ${state.filteredRows.length}건`,"ok");else setStatus(`전체 ${state.rows.length}건 로드 완료`,"ok")}
      function isEditing(row,colKey){return!!state.editingCell&&String(state.editingCell.rowId)===String(rowId(row))&&state.editingCell.key===colKey}function buildDisplayCell(row,col){const rid=rowId(row);const value=getDisplayValue(row,col.key);const tdClasses=[];if(row.__dirtyFields?.[col.key])tdClasses.push("dirty-cell");const displayClasses=["cellDisplay"];if(col.className)displayClasses.push(...col.className.split(" ").filter(Boolean));return `<td data-col="${escapeHtml(col.key)}" data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}" data-editable="1" class="${tdClasses.join(" ")}" title="더블클릭하여 수정"><div class="${displayClasses.join(" ")}">${escapeHtmlWithBreaks(value)}</div></td>`}function buildEditorCell(row,col){const rid=rowId(row);const value=getEditableValue(row,col.key);const className=col.className||"";if(col.type==="select"){const options=(col.options||[]).map(opt=>`<option value="${escapeHtml(opt)}" ${String(opt)===String(value)?"selected":""}>${escapeHtml(opt||"-")}</option>`).join("");return `<td data-col="${escapeHtml(col.key)}" class="dirty-cell"><select data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}" class="editSelect ${className} edit-control">${options}</select></td>`}if(col.type==="textarea")return `<td data-col="${escapeHtml(col.key)}" class="dirty-cell"><textarea data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}" class="editTextarea ${className} edit-control">${escapeHtml(value)}</textarea></td>`;const inputType=col.type==="date"?"date":"text";return `<td data-col="${escapeHtml(col.key)}" class="dirty-cell"><input data-row-id="${escapeHtml(rid)}" data-key="${escapeHtml(col.key)}" class="editInput ${className} edit-control" type="${inputType}" value="${escapeHtml(value)}" autocomplete="off" /></td>`}function buildDataCell(row,col){if(col.type==="readonly"){const displayValue=row.seq??"NEW";return `<td data-col="${escapeHtml(col.key)}" class="${row.__dirtyFields?.[col.key]?"dirty-cell":""}"><div class="cellDisplay ${col.className||""}">${escapeHtml(displayValue)}</div></td>`}return isEditing(row,col.key)?buildEditorCell(row,col):buildDisplayCell(row,col)}function renderTable(){if(!state.filteredRows.length){dom.sheetBody.innerHTML=`<tr class="emptyDataRow"><td colspan="13">조회 결과가 없습니다.</td></tr>`;return}dom.sheetBody.innerHTML=state.filteredRows.map(row=>{const rid=rowId(row);const cells=COLUMN_CONFIG.map(col=>buildDataCell(row,col)).join("");return `<tr data-row="${escapeHtml(rid)}">${cells}<td class="${row.__dirty?"dirty-cell":""}"><div class="cellDisplay center"><button class="rowActionBtn delete" type="button" data-delete-row="${escapeHtml(rid)}">✕</button></div></td></tr>`}).join("");focusActiveEditor()}
      function focusActiveEditor(){if(!state.editingCell)return;requestAnimationFrame(()=>{const editor=dom.sheetBody.querySelector(".edit-control");if(!editor)return;editor.focus();if(editor instanceof HTMLInputElement&&editor.type!=="date")editor.select();if(editor instanceof HTMLTextAreaElement){editor.selectionStart=editor.value.length;editor.selectionEnd=editor.value.length;autoGrowTextarea(editor)}})}function markRowDirty(row,key,value){if(!row)return;row[key]=value;row.__dirty=true;row.__dirtyFields=row.__dirtyFields||{};row.__dirtyFields[key]=true}function startEdit(rowIdValue,key){const row=findRowById(rowIdValue);if(!row)return;state.editingCell={rowId:String(rowIdValue),key:String(key)};renderTable()}function stopEdit(){state.editingCell=null;renderTable()}function commitEditor(target){if(!target||target.dataset.committed==="1")return;const rowIdValue=target.getAttribute("data-row-id");const key=target.getAttribute("data-key");if(!rowIdValue||!key){stopEdit();return}const row=findRowById(rowIdValue);if(!row){stopEdit();return}let nextValue=target.value??"";if(key==="wave")nextValue=normalizeWave(nextValue);if(key==="contract_date")nextValue=formatDateForInput(nextValue);if(NUMERIC_COLUMNS.has(key))nextValue=formatCurrencyForInput(nextValue);target.dataset.committed="1";markRowDirty(row,key,nextValue);state.editingCell=null;applyFilters()}function cancelEditor(target){if(target)target.dataset.committed="1";state.editingCell=null;renderTable()}function autoGrowTextarea(el){if(!(el instanceof HTMLTextAreaElement))return;el.style.height="auto";el.style.height=Math.max(96,el.scrollHeight)+"px"}function addRow(){state.rows.push(blankRow());applyFilters();const last=state.rows[state.rows.length-1];if(last)startEdit(rowId(last),"camp");setStatus("새 행이 추가되었습니다.","ok")}function deleteRow(rowIdValue){const row=findRowById(rowIdValue);if(!row)return;const label=[normalizeText(row.camp),normalizeText(row.route),normalizeWave(row.wave)].filter(Boolean).join(" / ")||String(rowIdValue);const ok=confirm(`삭제 대상으로 표시할까요?\n저장해야 실제 반영됩니다.\n\n대상: ${label}`);if(!ok)return;if(row.__isNew)state.rows=state.rows.filter(r=>String(rowId(r))!==String(rowIdValue));else if(row.seq){state.deletedIds.add(row.seq);row.__dirty=true}applyFilters();setStatus("삭제 대상으로 표시했습니다. 전체 저장 시 반영됩니다.","warn")}function cleanPayload(row,includeSeq,dirtyOnly=false){const obj={};if(includeSeq&&row.seq!=null)obj.seq=row.seq;const dirtyKeys=row.__dirtyFields?Object.keys(row.__dirtyFields).filter(key=>DATA_COLUMNS.includes(key)):[];const keys=dirtyOnly&&dirtyKeys.length?dirtyKeys:DATA_COLUMNS;for(const key of keys)obj[key]=valueForSave(key,row[key]);return obj}
      async function fetchRows(){try{setLoading(true,"데이터 불러오는 중...");state.deletedIds.clear();state.editingCell=null;const result=await routeApi("/route-price/list",{});const rows=Array.isArray(result.rows)?result.rows:[];state.rows=rows.map(normalizeLoadedRow);applyFilters()}catch(e){console.error(e);state.rows=[];state.filteredRows=[];renderTable();updatePills();setStatus("불러오기 실패: "+(e?.message||String(e)),"err");if(String(e?.message||"").includes("permission")||String(e?.message||"").includes("권한"))showAccessDenied(state.viewerEmail,e.message)}finally{setLoading(false)}}async function saveAll(){try{setLoading(true,"저장 중...");const deleteIds=Array.from(state.deletedIds).filter(Boolean);const dirtyRows=state.rows.filter(row=>row.__dirty&&!(row.seq&&state.deletedIds.has(row.seq)));const updateRows=dirtyRows.filter(row=>!row.__isNew&&row.seq!=null);const newRows=dirtyRows.filter(row=>row.__isNew&&hasAnyValue(row));if(!deleteIds.length&&!updateRows.length&&!newRows.length){setStatus("저장할 변경사항이 없습니다.","warn");return}await routeApi("/route-price/save",{deleteIds,updateRows:updateRows.map(row=>cleanPayload(row,true,true)),newRows:newRows.map(row=>cleanPayload(row,false,false))});await fetchRows();setStatus("저장 완료","ok")}catch(e){console.error(e);setStatus("저장 실패: "+(e?.message||String(e)),"err")}finally{setLoading(false)}}function clearFilters(){dom.filterInputs.forEach(el=>{el.value=""});dom.toggleOnlyChanged.checked=false;applyFilters()}function exportCsv(){const rows=state.filteredRows.filter(row=>!(row.seq&&state.deletedIds.has(row.seq)));if(!rows.length){alert("내보낼 데이터가 없습니다.");return}const headers=COLUMN_CONFIG.map(col=>col.label);const keys=COLUMN_CONFIG.map(col=>col.key);const csvRows=[headers,...rows.map(row=>keys.map(key=>String(key==="seq"?(row.seq??""):getRowValue(row,key))))];const csv=csvRows.map(row=>row.map(value=>/[",\n\r]/.test(value)?`"${value.replace(/"/g,'""')}"`:value).join(",")).join("\r\n");const blob=new Blob(["\ufeff"+csv],{type:"text/csv;charset=utf-8"});const url=URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;a.download="maroowell_route_"+new Date().toISOString().slice(0,10)+".csv";document.body.appendChild(a);a.click();a.remove();setTimeout(()=>URL.revokeObjectURL(url),1000)}
      dom.btnReload.addEventListener("click",fetchRows);dom.btnAddRow.addEventListener("click",addRow);dom.btnSaveAll.addEventListener("click",saveAll);dom.btnExportCsv.addEventListener("click",exportCsv);dom.btnClearFilters.addEventListener("click",clearFilters);dom.btnLogout.addEventListener("click",signOutAndMove);dom.btnDeniedHome.addEventListener("click",()=>location.replace(INDEX_PATH));dom.btnDeniedLogout.addEventListener("click",signOutAndMove);dom.toggleOnlyChanged.addEventListener("change",applyFilters);dom.filterInputs.forEach(input=>input.addEventListener("input",applyFilters));dom.sheetBody.addEventListener("dblclick",event=>{const td=event.target.closest("td[data-editable='1']");if(!td)return;startEdit(td.getAttribute("data-row-id"),td.getAttribute("data-key"))});dom.sheetBody.addEventListener("click",event=>{const deleteBtn=event.target.closest("[data-delete-row]");if(deleteBtn)deleteRow(deleteBtn.getAttribute("data-delete-row"))});dom.sheetBody.addEventListener("input",event=>{const target=event.target;if(target instanceof HTMLTextAreaElement)autoGrowTextarea(target)});dom.sheetBody.addEventListener("focusout",event=>{const target=event.target.closest(".edit-control");if(!target)return;commitEditor(target)});dom.sheetBody.addEventListener("keydown",event=>{const target=event.target.closest(".edit-control");if(!target)return;if(event.key==="Escape"){event.preventDefault();cancelEditor(target);return}if(event.key==="Enter"&&!(target instanceof HTMLTextAreaElement)){event.preventDefault();commitEditor(target)}});
      try{const ok=await requireAuth();if(!ok)return;await fetchRows()}catch(e){console.error(e);document.documentElement.style.visibility="visible";setStatus(e?.message||String(e),"err")}
    })();
