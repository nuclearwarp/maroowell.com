  function selectRouteById(id) {
    const row = routeRows.find(item => String(item.id) === String(id));
    if (!row) return;

    selectedRoute = row;
    selectedPoint = null;
    selectedPolygonId = null;
    cancelDrawModeSilently();
    setPointPickMode(false, false);
    clearAttachmentsState();
    fillPointForm(null);
    renderRouteList();
    renderRouteDetail();
    renderPointList();
    renderMapFeatures();
    fitAll();

    setStatus(`${routeCodeOf(row)} 선택`, "ok");
  }

  function selectPointById(id) {
    const row = pointRows.find(item => String(item.id) === String(id));
    if (!row) return;

    selectedPoint = row;
    selectedPolygonId = null;

    const matchedRoute = routeRows.find(route => {
      return String(row.route_info_id || "") === String(route.id || "") ||
        routeCodeForPoint(row) === routeCodeOf(route);
    });

    if (matchedRoute) selectedRoute = matchedRoute;

    fillPointForm(row);
    renderRouteList();
    renderRouteDetail();
    renderPointList();
    renderMapFeatures();
    loadAttachments(row.id);

    const lat = Number(row.lat);
    const lng = Number(row.lng);

    if (Number.isFinite(lat) && Number.isFinite(lng) && map) {
      map.panTo(new kakao.maps.LatLng(lat, lng));
      map.setLevel(Math.min(map.getLevel(), 3));
    }

    setPointStatus("포인트 선택 완료", "ok");
  }

  function extractRings(value) {
    if (!value) return [];

    let obj = value;

    if (typeof obj === "string") {
      try { obj = JSON.parse(obj); }
      catch { return []; }
    }

    const rings = [];

    if (obj?.type === "Polygon" && Array.isArray(obj.coordinates)) {
      for (const ring of obj.coordinates) {
        const latlngs = ring
          .map(pair => {
            const lng = Number(pair?.[0]);
            const lat = Number(pair?.[1]);

            if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;
            return new kakao.maps.LatLng(lat, lng);
          })
          .filter(Boolean);

        if (latlngs.length >= 3) rings.push(latlngs);
      }
    }

    if (Array.isArray(obj)) {
      const latlngs = obj
        .map(item => {
          if (Array.isArray(item)) {
            const lng = Number(item[0]);
            const lat = Number(item[1]);
            if (Number.isFinite(lat) && Number.isFinite(lng)) return new kakao.maps.LatLng(lat, lng);
          }

          const lat = Number(item?.lat);
          const lng = Number(item?.lng);
          if (Number.isFinite(lat) && Number.isFinite(lng)) return new kakao.maps.LatLng(lat, lng);

          return null;
        })
        .filter(Boolean);

      if (latlngs.length >= 3) rings.push(latlngs);
    }

    return rings;
  }

  function ringCenter(ring) {
    let lat = 0;
    let lng = 0;

    ring.forEach(item => {
      lat += item.getLat();
      lng += item.getLng();
    });

    return new kakao.maps.LatLng(lat / ring.length, lng / ring.length);
  }

  function renderMapFeatures() {
    if (!map) return;

    clearMapObjects();

    for (const poly of polygonRows) {
      if (poly.is_active === false) continue;

      const code = polygonCodeOf(poly);
      const colors = colorOfSubRoute(code);
      const isSelected = String(selectedPolygonId || "") === String(poly.id || "");
      const routeSelected = selectedRoute && (
        String(poly.route_info_id || "") === String(selectedRoute.id || "") ||
        code === routeCodeOf(selectedRoute)
      );

      const rings = extractRings(poly.polygon_wgs84 || poly.polygon || poly.geojson);

      for (const ring of rings) {
        const polygon = new kakao.maps.Polygon({
          path: ring,
          strokeWeight: isSelected || routeSelected ? 4 : 2,
          strokeColor: colors.stroke,
          strokeOpacity: isSelected || routeSelected ? 0.95 : 0.78,
          fillColor: colors.fill,
          fillOpacity: isSelected || routeSelected ? 0.34 : 0.18
        });

        polygon.setMap(map);
        polygonObjects.push(polygon);

        kakao.maps.event.addListener(polygon, "click", () => {
          markFeatureClick();
          selectedPolygonId = poly.id;
          const route = routeRows.find(row =>
            String(poly.route_info_id || "") === String(row.id || "") ||
            polygonCodeOf(poly) === routeCodeOf(row)
          );

          if (route) selectedRoute = route;
          selectedPoint = null;
          fillPointForm(null);
          clearAttachmentsState();
          renderRouteList();
          renderRouteDetail();
          renderPointList();
          renderMapFeatures();
          setDrawStatus("폴리곤 선택 완료. 수정하려면 폴리곤 그리기를 누르세요.", true);
        });

        const labelColor = colors.label || colors.stroke;
        const label = new kakao.maps.CustomOverlay({
          position: ringCenter(ring),
          content: `<div class="routeMapLabel" style="background:${esc(labelColor)};border-color:${esc(colors.stroke)}">${esc(code)}</div>`,
          yAnchor: 0.5
        });

        label.setMap(map);
        polygonLabels.push(label);
      }
    }

    for (const point of pointRows) {
      if (point.is_active === false) continue;

      const lat = Number(point.lat);
      const lng = Number(point.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) continue;

      const type = point.point_type || "etc";
      const title = point.title || pointTypeLabel(type);
      const active = selectedPoint?.id === point.id ? " active" : "";

      const overlay = new kakao.maps.CustomOverlay({
        position: new kakao.maps.LatLng(lat, lng),
        yAnchor: 1,
        content: `
          <div class="markerTip ${pointTypeClass(type)}${active}" data-point-id="${esc(point.id)}">
            <div class="markerBubble">${esc(pointTypeIcon(type))}</div>
            <div class="markerLabel">${esc(title)}</div>
          </div>
        `
      });

      overlay.setMap(map);
      pointOverlays.push(overlay);

      setTimeout(() => {
        document.querySelectorAll(`.markerTip[data-point-id="${CSS.escape(String(point.id))}"]`).forEach(el => {
          el.addEventListener("click", event => {
            event.stopPropagation();
            markFeatureClick();
            selectPointById(point.id);
          });
        });
      }, 0);
    }

    if (selectedPoint && !selectedPoint.id) {
      const lat = Number(selectedPoint.lat);
      const lng = Number(selectedPoint.lng);

      if (Number.isFinite(lat) && Number.isFinite(lng)) {
        const overlay = new kakao.maps.CustomOverlay({
          position: new kakao.maps.LatLng(lat, lng),
          yAnchor: 1,
          content: `
            <div class="markerTip ${pointTypeClass(selectedPoint.point_type || "tip")}">
              <div class="markerBubble">신</div>
              <div class="markerLabel">신규 위치</div>
            </div>
          `
        });

        overlay.setMap(map);
        pointOverlays.push(overlay);
      }
    }
  }

  function collectAllVisibleLatLngs() {
    const latlngs = [];

    for (const poly of polygonRows) {
      if (poly.is_active === false) continue;

      for (const ring of extractRings(poly.polygon_wgs84 || poly.polygon || poly.geojson)) {
        latlngs.push(...ring);
      }
    }

    for (const point of pointRows) {
      if (point.is_active === false) continue;

      const lat = Number(point.lat);
      const lng = Number(point.lng);

      if (Number.isFinite(lat) && Number.isFinite(lng)) {
        latlngs.push(new kakao.maps.LatLng(lat, lng));
      }
    }

    if (selectedPoint && !selectedPoint.id) {
      const lat = Number(selectedPoint.lat);
      const lng = Number(selectedPoint.lng);

      if (Number.isFinite(lat) && Number.isFinite(lng)) {
        latlngs.push(new kakao.maps.LatLng(lat, lng));
      }
    }

    return latlngs;
  }

  function setMapBoundsByLatLngs(latlngs) {
    if (!map || !latlngs?.length) return;

    const bounds = new kakao.maps.LatLngBounds();

    latlngs.forEach(latlng => bounds.extend(latlng));
    map.setBounds(bounds);

    setTimeout(() => {
      try { map.relayout(); } catch {}
    }, 40);
  }

  function fitAll() {
    if (!map) return;

    try { map.relayout(); } catch {}

    const latlngs = collectAllVisibleLatLngs();

    if (latlngs.length) {
      setMapBoundsByLatLngs(latlngs);
      return;
    }

    map.setCenter(new kakao.maps.LatLng(37.5665, 126.9780));
    map.setLevel(8);
  }

  function resetMapView() {
    cancelDrawModeSilently();
    setPointPickMode(false, false);

    selectedRoute = null;
    selectedPoint = null;
    selectedPolygonId = null;

    clearAttachmentsState();
    clearRouteDetail();
    fillPointForm(null);
    renderRouteList();
    renderPointList();

    isSatellite = false;
    isRoadviewOn = false;
    map.setMapTypeId(kakao.maps.MapTypeId.ROADMAP);
    $("toggleMapTypeBtn").textContent = "위성";
    $("toggleMapTypeBtn").classList.remove("active");

    if (roadviewOverlay) {
      roadviewOverlay.setMap(null);
    }
    $("toggleRoadviewBtn").classList.remove("active");

    renderMapFeatures();
    fitAll();
    setStatus("지도 초기화 완료", "ok");
  }

  function setMapType() {
    if (!map) return;

    isSatellite = !isSatellite;
    map.setMapTypeId(isSatellite ? kakao.maps.MapTypeId.HYBRID : kakao.maps.MapTypeId.ROADMAP);
    $("toggleMapTypeBtn").textContent = isSatellite ? "일반" : "위성";
    $("toggleMapTypeBtn").classList.toggle("active", isSatellite);
  }

  function toggleRoadviewOverlay() {
    if (!map || !roadviewOverlay) {
      setStatus("로드뷰 오버레이를 사용할 수 없습니다.", "bad");
      return;
    }

    isRoadviewOn = !isRoadviewOn;
    roadviewOverlay.setMap(isRoadviewOn ? map : null);
    $("toggleRoadviewBtn").classList.toggle("active", isRoadviewOn);
    setStatus(isRoadviewOn ? "로드뷰 도로 표시 ON" : "로드뷰 도로 표시 OFF", isRoadviewOn ? "ok" : "warn");
  }

  function searchAddressOrPlace() {
    if (!map) return;

    const keyword = clean($("addressSearchInput").value);

    if (!keyword) {
      setPointStatus("검색할 주소나 건물명을 입력하세요.", "bad");
      return;
    }

    setPointStatus("주소/건물명 검색 중...", "warn");

    const moveTo = (lat, lng, label) => {
      const position = new kakao.maps.LatLng(lat, lng);
      map.setLevel(3);
      map.panTo(position);

      setPointStatus(`${label || keyword} 위치로 지도를 이동했습니다.\n마커 찍기 ON 후 실제 배송 위치를 지도에서 클릭하세요.`, "ok");
    };

    const fallbackAddressSearch = () => {
      if (!kakaoGeocoder) {
        setPointStatus("주소 검색 객체를 사용할 수 없습니다.", "bad");
        return;
      }

      kakaoGeocoder.addressSearch(keyword, (result, status) => {
        if (status === kakao.maps.services.Status.OK && result && result.length) {
          moveTo(Number(result[0].y), Number(result[0].x), result[0].address_name);
          return;
        }

        setPointStatus("검색 결과가 없습니다. 건물명보다 도로명/지번 주소로 다시 검색해보세요.", "bad");
      });
    };

    if (kakaoPlaces) {
      kakaoPlaces.keywordSearch(keyword, (result, status) => {
        if (status === kakao.maps.services.Status.OK && result && result.length) {
          moveTo(Number(result[0].y), Number(result[0].x), result[0].place_name || result[0].address_name);
          return;
        }

        fallbackAddressSearch();
      });
      return;
    }

    fallbackAddressSearch();
  }

  function clearDrawObjects() {
    drawVertexMarkers.forEach(marker => marker.setMap(null));
    drawVertexMarkers = [];

    if (drawLine) {
      drawLine.setMap(null);
      drawLine = null;
    }

    if (drawPreviewPolygon) {
      drawPreviewPolygon.setMap(null);
      drawPreviewPolygon = null;
    }
  }

  function createDrawMarkerImage() {
    const svg = `
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18">
        <circle cx="9" cy="9" r="5.2" fill="#111827" stroke="#e5e7eb" stroke-width="2.4"/>
      </svg>
    `.trim();

    const url = "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg);
    return new kakao.maps.MarkerImage(
      url,
      new kakao.maps.Size(18, 18),
      { offset: new kakao.maps.Point(9, 9) }
    );
  }

  function redrawDrawing() {
    clearDrawObjects();

    if (!drawVertices.length) return;

    drawVertices.forEach(latlng => {
      const marker = new kakao.maps.Marker({
        map,
        position: latlng,
        image: createDrawMarkerImage(),
        draggable: false
      });

      drawVertexMarkers.push(marker);
    });

    if (drawVertices.length >= 2) {
      drawLine = new kakao.maps.Polyline({
        map,
        path: drawVertices,
        strokeWeight: 3,
        strokeColor: "#111827",
        strokeOpacity: 0.88
      });
    }

    if (drawVertices.length >= 3) {
      drawPreviewPolygon = new kakao.maps.Polygon({
        map,
        path: drawVertices,
        strokeWeight: 3,
        strokeColor: "#2563eb",
        strokeOpacity: 0.92,
        fillColor: "#93c5fd",
        fillOpacity: 0.22
      });
    }
  }

  function addDrawVertex(latLng) {
    drawVertices.push(latLng);
    redrawDrawing();

    setDrawStatus(
      `폴리곤 그리기 중: ${drawVertices.length}점\n좌클릭: 점 추가 / 우클릭: 가까운 점 삭제 / 완료: 저장 준비`,
      true
    );
  }

  function distanceSq(a, b) {
    const dx = a.getLat() - b.getLat();
    const dy = a.getLng() - b.getLng();
    return dx * dx + dy * dy;
  }

  function deleteNearestDrawVertex(latLng) {
    if (!drawVertices.length) return;

    let minIndex = 0;
    let minDistance = Infinity;

    drawVertices.forEach((point, index) => {
      const dist = distanceSq(point, latLng);

      if (dist < minDistance) {
        minDistance = dist;
        minIndex = index;
      }
    });

    drawVertices.splice(minIndex, 1);
    redrawDrawing();
    setDrawStatus(`가까운 점을 삭제했습니다. 현재 ${drawVertices.length}점`, true);
  }

  function startDrawMode() {
    if (!selectedRoute) {
      setStatus("먼저 좌측에서 라우트를 선택하세요.", "bad");
      return;
    }

    setPointPickMode(false, false);

    drawMode = true;
    drawEditingPolygonId = selectedPolygonId || null;
    drawVertices = [];

    if (drawEditingPolygonId) {
      const target = polygonRows.find(row => String(row.id) === String(drawEditingPolygonId));
      const firstRing = extractRings(target?.polygon_wgs84 || target?.polygon || target?.geojson)[0];

      if (firstRing?.length) {
        drawVertices = firstRing.slice();
      }
    }

    redrawDrawing();

    setDrawStatus(
      drawEditingPolygonId
        ? "기존 폴리곤 수정 모드입니다. 점을 추가/삭제한 뒤 완료를 누르세요."
        : "폴리곤 신규 그리기 모드입니다. 지도에서 점을 3개 이상 찍은 뒤 완료를 누르세요.",
      true
    );

    setStatus("폴리곤 그리기 모드", "warn");
  }

  function cancelDrawModeSilently() {
    drawMode = false;
    drawEditingPolygonId = null;
    drawVertices = [];
    clearDrawObjects();
    setDrawStatus("", false);
