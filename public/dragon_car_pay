      function setPill(kind, text){
        dom.pillState.className = "pill " + (kind || "ok");
        dom.pillState.textContent = text || "READY";
      }

      function setStatus(text){
        dom.statusText.textContent = text || "";
      }

      async function fetchAll(table){
        const size = 1000;
        let from = 0;
        const out = [];

        while(true){
          const { data, error } = await supabase
            .from(table)
            .select("*")
            .range(from, from + size - 1);

          if(error) throw error;

          out.push(...(data || []));

          if(!data || data.length < size) break;
          from += size;
        }

        return out;
      }

      async function loadData(){
        if(!supabase) throw new Error("Supabase 설정이 없습니다.");

        setPill("warn","LOAD");
        setStatus("용차 정산 데이터를 불러오는 중입니다.");
        dom.btnReload.disabled = true;

        const [rows, vendors, infos] = await Promise.all([
          fetchAll(DATA_TABLE),
          fetchAll(VENDORS_TABLE).catch(() => []),
          fetchAll(INFO_TABLE).catch(() => [])
        ]);

        state.allRows = rows || [];
        state.vendorRows = vendors || [];
        state.vendorById.clear();

        for(const v of state.vendorRows){
          const id = clean(first(v,["id","vendor_id","pk_id","seq"]));
          if(id) state.vendorById.set(String(id), v);
        }

        state.infoRows = infos || [];
        state.infoByName.clear();

        for(const r of state.infoRows){
          const name = infoName(r);
          if(name) state.infoByName.set(compact(name), r);
        }

        render();

        setPill("ok","READY");
        setStatus("불러오기 완료: 원본 " + fmt(state.allRows.length) + "행 / 기사정보 " + fmt(state.infoRows.length) + "행");
        dom.btnReload.disabled = false;
      }

      async function ensureAuth(){
        if(!supabase){
          document.documentElement.style.visibility = "visible";
          showDenied("Supabase 설정이 없어 페이지를 사용할 수 없습니다.","");
          return false;
        }

        const { data } = await supabase.auth.getSession();
        state.session = data?.session || null;

        if(!state.session){
          window.location.href = LOGIN_PATH;
          return false;
        }

        state.viewerEmail = state.session.user?.email || "";
        state.viewerUserId = state.session.user?.id || "";

        return true;
      }

      async function checkAccess(){
        let access = null;
        let profile = null;

        try{
          const { data } = await supabase
            .from(ACCESS_TABLE)
            .select("*")
            .or("email.eq." + state.viewerEmail + ",user_id.eq." + state.viewerUserId)
            .limit(1)
            .maybeSingle();

          access = data || null;
        } catch {}

        try{
          const { data } = await supabase
            .from(PROFILES_TABLE)
            .select("*")
            .eq("id", state.viewerUserId)
            .limit(1)
            .maybeSingle();

          profile = data || null;
        } catch {}

        const role = Number(access?.role_level || access?.roleLevel || 0);
        const ok = !!(
          access?.is_super_admin ||
          access?.is_admin ||
          role >= 60 ||
          profile?.is_dragon_car_admin ||
          access?.is_dragon_car_admin
        );

        if(!ok){
          showDenied("이 페이지는 최고관리자 또는 용차 관리자만 접근할 수 있습니다.", state.viewerEmail);
          return false;
        }

        return true;
      }

      function showDenied(message, email){
        dom.accessDeniedText.textContent = message;
        dom.accessDeniedEmail.textContent = email ? "로그인 계정: " + email : "";
        dom.accessDenied.classList.add("show");
      }

      async function logout(){
        try{
          await supabase?.auth.signOut();
        } catch {}

        window.location.href = LOGIN_PATH;
      }

      async function downloadPng(){
        const target = dom.statementCapture;

        if(!target || target.style.display === "none") return;

        if(!window.htmlToImage){
          alert("PNG 저장 라이브러리를 불러오지 못했습니다.");
          return;
        }

        const group = state.groups.find(x => x.key === state.selectedGroupKey);
        const safe = (group?.name || "정산서").replace(/[\\/:*?"<>|]/g,"_");
        const file = "마루웰_" + state.month + "_용차정산서_" + safe + ".png";

        setPill("warn","CAPTURE");
        dom.btnDownloadPng.disabled = true;

        const clone = target.cloneNode(true);
        clone.classList.add("capture-export");
        clone.style.display = "block";

        const host = document.createElement("div");
        host.className = "capture-host";
        host.appendChild(clone);
        document.body.appendChild(host);

        try{
          const dataUrl = await window.htmlToImage.toPng(clone, {
            cacheBust:true,
            pixelRatio:2,
            backgroundColor:"#ffffff",
            width:clone.scrollWidth,
            height:clone.scrollHeight,
            style:{
              transform:"none",
              transformOrigin:"top left"
            }
          });

          const a = document.createElement("a");
          a.href = dataUrl;
          a.download = file;
          document.body.appendChild(a);
          a.click();
          a.remove();

          setPill("ok","READY");
          setStatus("PNG 저장 완료: " + file);
        } catch(e){
          console.error(e);
          setPill("err","ERROR");
          alert("PNG 저장 실패: " + (e?.message || e));
        } finally {
          host.remove();
          dom.btnDownloadPng.disabled = false;
        }
      }

      function bind(){
        dom.monthInput.value = state.month;

        dom.btnReload.addEventListener("click", () => {
          loadData().catch(e => {
            console.error(e);
            setPill("err","ERROR");
            setStatus("불러오기 실패: " + (e?.message || e));
            dom.btnReload.disabled = false;
          });
        });

        dom.btnDownloadPng.addEventListener("click", downloadPng);
        dom.btnLogout.addEventListener("click", logout);
        dom.btnDeniedLogout.addEventListener("click", logout);
        dom.btnDeniedHome.addEventListener("click", () => {
          window.location.href = INDEX_PATH;
        });

        dom.btnClearSearch.addEventListener("click", () => {
          dom.searchInput.value = "";
          state.selectedGroupKey = "";
          render();
        });

        dom.monthInput.addEventListener("change", () => {
          state.month = parseMonth(dom.monthInput.value);
          dom.monthInput.value = state.month;
          state.selectedGroupKey = "";
          render();
        });

        dom.monthInput.addEventListener("keydown", e => {
          if(e.key === "Enter"){
            state.month = parseMonth(dom.monthInput.value);
            dom.monthInput.value = state.month;
            state.selectedGroupKey = "";
            render();
          }
        });

        dom.searchInput.addEventListener("input", () => {
          state.selectedGroupKey = "";
          render();
        });

        dom.btnModeVendor.addEventListener("click", () => {
          if(state.mode === "vendor") return;

          state.mode = "vendor";
          state.selectedGroupKey = "";

          dom.btnModeVendor.classList.add("active");
          dom.btnModeDriver.classList.remove("active");

          render();
        });

        dom.btnModeDriver.addEventListener("click", () => {
          if(state.mode === "driver") return;

          state.mode = "driver";
          state.selectedGroupKey = "";

          dom.btnModeDriver.classList.add("active");
          dom.btnModeVendor.classList.remove("active");

          render();
        });
      }

      async function boot(){
        bind();
        document.documentElement.style.visibility = "visible";

        if(!(await ensureAuth())) return;
        if(!(await checkAccess())) return;

        await loadData();
      }

      boot().catch(e => {
        console.error(e);
        document.documentElement.style.visibility = "visible";
        setPill("err","ERROR");
        setStatus("초기화 실패: " + (e?.message || e));
      });
    })();
  </script>

