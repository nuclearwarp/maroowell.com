        infoRows:[],
        infoByName:new Map(),
        monthlyTeam:null
      };

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth:{
              storage:window.sessionStorage,
              persistSession:true,
              autoRefreshToken:true,
              detectSessionInUrl:true
            }
          })
        : null;

      function clean(v){ return String(v ?? "").trim(); }
      function compact(v){ return clean(v).replace(/\s+/g,""); }

      function esc(v){
        return String(v ?? "")
          .replace(/&/g,"&amp;")
          .replace(/</g,"&lt;")
          .replace(/>/g,"&gt;")
          .replace(/"/g,"&quot;")
          .replace(/'/g,"&#39;");
      }

      function toNumber(v){
        if(typeof v === "number" && Number.isFinite(v)) return v;
        const n = Number(String(v ?? "").replace(/[₩원,%\s]/g,"").replace(/,/g,""));
        return Number.isFinite(n) ? n : 0;
      }

      function roundWon(v){ return Math.round(Number(v) || 0); }
      function money(v){ return "₩" + roundWon(v).toLocaleString("ko-KR"); }
      function fmt(v){ return roundWon(v).toLocaleString("ko-KR"); }

      function keyNorm(k){
        return String(k || "").replace(/[^a-zA-Z0-9가-힣]/g,"").toLowerCase();
      }

      function first(row, keys){
        if(!row) return "";

        for(const k of keys){
          if(Object.prototype.hasOwnProperty.call(row,k) && row[k] != null && clean(row[k]) !== ""){
            return row[k];
          }
        }

        const m = new Map();
        Object.keys(row).forEach(k => m.set(keyNorm(k), k));

        for(const k of keys){
          const real = m.get(keyNorm(k));
          if(real && row[real] != null && clean(row[real]) !== ""){
            return row[real];
          }
        }

        return "";
      }

      function defaultMonth(){
        const d = new Date();
        return d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2,"0");
      }

      function parseMonth(v){
        const raw = clean(v);

        let m = raw.match(/(20\d{2})\s*[-./년 ]\s*(\d{1,2})/);
        if(m) return m[1] + "-" + String(Number(m[2])).padStart(2,"0");

        m = raw.match(/(^|\D)(\d{2})\s*년\s*(\d{1,2})\s*월/);
        if(m) return "20" + m[2] + "-" + String(Number(m[3])).padStart(2,"0");

        m = raw.match(/^(20\d{2})(\d{2})$/);
        if(m) return m[1] + "-" + m[2];

        return raw;
      }

      function monthTitle(month){
        const m = String(month || "").match(/^(\d{4})-(\d{2})$/);
        return m ? m[1] + "년 " + Number(m[2]) + "월" : month || "-";
      }

      function monthShort(month){
        const m = String(month || "").match(/^(\d{4})-(\d{2})$/);
        return m ? m[1] + ". " + Number(m[2]) + "." : month || "-";
      }

      function excelDate(v){
        return typeof v === "number" && v > 20000 && v < 80000
          ? new Date(Math.round((v - 25569) * 86400 * 1000))
          : null;
      }

      function parseDate(v, month){
        if(v instanceof Date && !Number.isNaN(v.getTime())) return v;

        const ex = excelDate(v);
        if(ex) return ex;

        const raw = clean(v);
        if(!raw) return null;

        let m = raw.match(/(20\d{2})\D+(\d{1,2})\D+(\d{1,2})/);
        if(m) return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));

        m = raw.match(/^(\d{1,2})\s*[/.-]\s*(\d{1,2})/);
        if(m){
          const y = Number(String(month || state.month).slice(0,4)) || new Date().getFullYear();
          return new Date(y, Number(m[1]) - 1, Number(m[2]));
        }

        const d = new Date(raw);
        return Number.isNaN(d.getTime()) ? null : d;
      }

      function dateMonth(v, month){
        const d = parseDate(v, month);
        return d ? d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2,"0") : "";
      }

      function dateText(v, month){
        const d = parseDate(v, month);
        if(!d) return clean(v) || "-";
        return (d.getMonth() + 1) + "/" + d.getDate() + " " + ["일","월","화","수","목","금","토"][d.getDay()];
      }

      function isSun(v, month){
        const d = parseDate(v, month);
        return !!d && d.getDay() === 0;
      }

      function taxIssued(v){
        if(typeof v === "boolean") return v;
        if(typeof v === "number") return v !== 0;

        const s = compact(v).toLowerCase();
        if(!s) return false;
        if(["발행","발행완료","완료","o","y","yes","true","1","issued"].includes(s)) return true;
        if(["미발행","무","x","n","no","false","0","notissued","미완료"].includes(s)) return false;
        if(s.includes("미발행")) return false;

        return s.includes("발행");
      }

      function paid(v){
        if(typeof v === "boolean") return v;
        if(typeof v === "number") return v !== 0;

        const s = compact(v).toLowerCase();
        if(!s) return false;
        if(["입금","입금완료","완료","o","y","yes","true","1","paid"].includes(s)) return true;
        if(s.includes("미입금")) return false;

        return s.includes("입금");
      }

      function falseLike(v){
        const s = compact(v).toLowerCase();
        return ["x","n","no","false","0","미가입","없음","제외","미적용"].includes(s);
      }

      function parseRate(v, fallback){
        const raw = clean(v);
        if(!raw) return fallback;
        if(/^0+(\.0+)?%?$/.test(raw)) return 0;

        let n = toNumber(raw);
        if(!Number.isFinite(n)) return fallback;
        if(raw.includes("%") || n > 1) n = n / 100;

        return Math.max(0, n);
      }

      function taxBreakdown(issued){
        const supply = roundWon(issued / 1.1);
        return { supply, vat:roundWon(issued - supply) };
      }

      function getDate(row){
        return first(row,[
          "order_date","orderDate",
          "delivery_date","deliveryDate",
          "work_date","workDate",
          "service_date","settlement_date",
          "date","배송일자","배송 일자","일자"
        ]);
      }

      function getMonthFromRow(row){
        const mv = parseMonth(first(row,[
          "settlement_month","settlementMonth",
          "pay_month","target_month",
          "month","정산월"
        ]));

        if(/^\d{4}-\d{2}$/.test(mv)) return mv;
        return dateMonth(getDate(row), state.month);
      }

      function vendorNameById(id){
        if(!id) return "";
        const v = state.vendorById.get(String(id));
        return clean(first(v,["vendor_name","company_name","business_name","name","상호","업체명"]));
      }

      function rowInfo(row){
        const price = toNumber(first(row,[
          "price","unit_price","unitPrice","unit_cost","delivery_unit_price","단가"
        ]));

        const parcel = toNumber(first(row,[
          "parcel","parcel_count",
          "delivery_count","deliveryCount",
          "delivery_quantity","delivery_qty",
          "quantity","qty","count",
          "배송수량","배송 수량","수량"
        ]));

        let amount = toNumber(first(row,[
          "amount","settlement_amount","settlementAmount",
          "total_amount","totalAmount",
          "pay_amount","payment_amount",
          "정산금액","정산 금액","금액","총금액"
        ]));

        if(!amount && price && parcel) amount = price * parcel;

        const vendorId = clean(first(row,["vendor_id","vendorId","vendor","vendor_pk","거래처id","벤더id"]));
        const vendorName = clean(first(row,["vendor_name","vendorName","company_name","companyName","업체","업체명","거래처"]))
          || vendorNameById(vendorId)
          || "미지정 업체";

        const driver = clean(first(row,[
          "delivery_driver","deliveryDriver",
          "driver_name","driverName",
          "driver","투입 기사","기사","기사명","용차기사"
        ])) || "미지정 기사";

        return {
          raw:row,
          date:getDate(row),
          vendorId,
          vendorName,
          orderName:clean(first(row,["order_name","orderName","order","order_no","order_number","오더","오더명","Order"])),
          driver,
          camp:clean(first(row,["camp","camp_code","campCode","camp_name","캠프"])),
          wave:clean(first(row,["wave","work_wave","day_night","dayNight","shift","주야","주/야","주간/야간"])),
          route:clean(first(row,["route","route_name","routeName","route_code","라우트"])).replace(/\s+/g," "),
          price,
          parcel,
          returnQty:toNumber(first(row,["return_quantity","return_qty","return_count","returnCount","반품수량","반품 수량","반품"])),
          amount:roundWon(amount),
          taxIssued:taxIssued(first(row,[
            "tax_invoice","taxInvoice",
            "tax_invoice_status","tax_status",
            "invoice_status","tax_bill","tax_issued",
            "is_tax_invoice_issued","is_tax_issued",
            "세금계산서","세금계산서발행","세금계산서 발행"
          ])),
          paid:paid(first(row,["payment_status","paid_status","is_paid","deposit_status","입금여부"]))
        };
      }

      function infoName(row){
        return clean(first(row,["person_name","name","driver_name","기사명","이름"]));
      }

      function driverInfo(name){
        return state.infoByName.get(compact(name)) || {};
      }

      function infoVal(name, keys){
        return clean(first(driverInfo(name), keys));
      }

      function businessName(name){
        return infoVal(name,["business_name","businessName","사업자 상호","사업자상호","상호"]) || name || "-";
      }

      function businessNo(name){
        return infoVal(name,["business_registration_number","businessRegistrationNumber","business_no","사업자 번호","사업자번호"]) || "-";
      }

      function payrollBank(name){
        return infoVal(name,["payroll_bank_name","payrollBankName","bank_name","급여 은행","급여은행","은행"]) || "-";
      }

      function payrollAccount(name){
        return infoVal(name,["payroll_account_number","payrollAccountNumber","account_number","급여 계좌","급여계좌","계좌 번호","계좌번호"]) || "-";
      }

      function commissionRate(name){
        if(ZERO_COMMISSION_DRIVERS.has(compact(name))) return 0;

        return parseRate(
          infoVal(name,["dragon_car_commission","dragonCarCommission","용차 수수료","용차수수료"]),
          DEFAULT_COMMISSION_RATE
        );
      }

      function insuranceEnabled(name){
        const raw = infoVal(name,["employment_accident_insurance","employmentAccidentInsurance","고용산재"]);
        return raw ? !falseLike(raw) : true;
      }

      function vendorStats(infos){
        const total = infos.reduce((a,r) => a + r.amount, 0);
        const unpaid = infos.filter(r => !r.paid).reduce((a,r) => a + r.amount, 0);
        const paidAmount = total - unpaid;
        const parcel = infos.reduce((a,r) => a + r.parcel, 0);
        const ret = infos.reduce((a,r) => a + r.returnQty, 0);
        const days = new Set(infos.map(r => dateText(r.date, state.month))).size;

        return { total, unpaid, paidAmount, parcel, ret, days };
      }

      function driverBaseStats(infos, name){
        const total = infos.reduce((a,r) => a + r.amount, 0);
        const issued = infos.filter(r => r.taxIssued).reduce((a,r) => a + r.amount, 0);
        const unissued = total - issued;
        const tax = taxBreakdown(issued);
        const rate = commissionRate(name);
        const commission = roundWon(total * rate);
        const insurance = insuranceEnabled(name) ? roundWon(tax.supply * INSURANCE_RATE) : 0;

        return {
          total,
          issued,
          unissued,
          supply:tax.supply,
          vat:tax.vat,
          rate,
          commission,
          insurance,
          afterCommission:total - commission,
          afterInsurance:total - commission - insurance,
          teamBonus:0,
          finalPay:total - commission - insurance
        };
      }

      function monthlyTeamStats(driverGroups){
        let commission = 0;
        let insurance = 0;

        for(const g of driverGroups){
          const s = driverBaseStats(g.infos, g.name);
          commission += s.commission;
          insurance += s.insurance;
        }

        const insuranceHalf = roundWon(insurance * 0.5);
        const pool = Math.max(0, commission - insuranceHalf);
        const bonus = roundWon(pool * 0.5);

        return { commission, insurance, insuranceHalf, pool, bonus };
      }

      function rowSearch(info, q){
        if(!q) return true;

        return [
          info.vendorId,
          info.vendorName,
          info.orderName,
          info.driver,
          info.camp,
          info.wave,
          info.route
        ].join(" ").toLowerCase().includes(q.toLowerCase());
      }

      function buildGroups(){
        const q = clean(dom.searchInput.value);

        state.monthRows = state.allRows.filter(r => getMonthFromRow(r) === state.month);

        const rows = state.monthRows
          .map(rowInfo)
          .filter(i => rowSearch(i, q));

        const map = new Map();

        for(const info of rows){
          const key = state.mode === "driver"
            ? "driver:" + info.driver
            : "vendor:" + (info.vendorId || info.vendorName) + ":" + info.orderName;

          if(!map.has(key)){
            map.set(key, {
              key,
              mode:state.mode,
              name:state.mode === "driver" ? info.driver : info.vendorName,
              subtitle:state.mode === "driver" ? "" : (info.orderName || "Order 없음"),
              vendorName:info.vendorName,
              orderName:info.orderName,
              infos:[]
            });
          }

          map.get(key).infos.push(info);
        }

        let groups = Array.from(map.values());

        if(state.mode === "driver"){
          const monthly = monthlyTeamStats(groups);

          groups.forEach(g => {
            const s = driverBaseStats(g.infos, g.name);

            if(compact(g.name) === compact(TEAM_LEADER_NAME)){
              s.teamBonus = monthly.bonus;
              s.issued += monthly.bonus;
              s.total += monthly.bonus;

              const tb = taxBreakdown(s.issued);
              s.supply = tb.supply;
              s.vat = tb.vat;
              s.afterCommission += monthly.bonus;
              s.afterInsurance += monthly.bonus;
              s.finalPay += monthly.bonus;
            }

            g.stats = s;
          });

          state.monthlyTeam = monthly;
        } else {
          groups.forEach(g => g.stats = vendorStats(g.infos));
          state.monthlyTeam = null;
        }

        groups.sort((a,b) => b.stats.total - a.stats.total || String(a.name).localeCompare(String(b.name), "ko"));

        state.groups = groups;

        if(!groups.some(g => g.key === state.selectedGroupKey)){
          state.selectedGroupKey = groups[0]?.key || "";
        }
      }

      function renderSummary(){
        const totals = state.groups.reduce((a,g) => {
          a.total += g.stats.total || 0;
          a.issued += g.stats.issued || 0;
          a.unpaid += g.stats.unpaid || 0;
          a.comm += g.stats.commission || 0;
          a.ins += g.stats.insurance || 0;
          return a;
        }, { total:0, issued:0, unpaid:0, comm:0, ins:0 });

        if(state.mode === "driver"){
          dom.summaryGrid.innerHTML = `
            <div class="summaryCard"><div class="summaryLabel">정산월</div><div class="summaryValue">${esc(monthShort(state.month))}</div></div>
            <div class="summaryCard"><div class="summaryLabel">정산서 수</div><div class="summaryValue blue">${fmt(state.groups.length)}</div></div>
            <div class="summaryCard"><div class="summaryLabel">월 총금액</div><div class="summaryValue">${money(totals.total)}</div></div>
            <div class="summaryCard"><div class="summaryLabel">세금계산서 발행</div><div class="summaryValue green">${money(totals.issued)}</div></div>
            <div class="summaryCard"><div class="summaryLabel">수수료 공제</div><div class="summaryValue red">${money(totals.comm)}</div></div>
            <div class="summaryCard"><div class="summaryLabel">고용/산재</div><div class="summaryValue yellow">${money(totals.ins)}</div></div>
          `;
        } else {
          dom.summaryGrid.innerHTML = `
            <div class="summaryCard"><div class="summaryLabel">정산월</div><div class="summaryValue">${esc(monthShort(state.month))}</div></div>
            <div class="summaryCard"><div class="summaryLabel">정산서 수</div><div class="summaryValue blue">${fmt(state.groups.length)}</div></div>
            <div class="summaryCard"><div class="summaryLabel">월 총금액</div><div class="summaryValue">${money(totals.total)}</div></div>
            <div class="summaryCard"><div class="summaryLabel">미입금</div><div class="summaryValue red">${money(totals.unpaid)}</div></div>
          `;
        }

        dom.pillRows.textContent = "행 " + fmt(state.monthRows.length);
        dom.pillGroups.textContent = "정산서 " + fmt(state.groups.length);
      }

      function groupMeta(g){
        if(g.mode === "driver"){
          const s = g.stats;

          return `
            <span>총 금액 <b>${money(s.total)}</b></span>
            <span>수수료 <b>${money(s.commission)}</b></span>
            <span>공제 후 <b>${money(s.afterCommission)}</b></span>
            <span>고용/산재 <b>${money(s.insurance)}</b></span>
            <span class="wide">고용산재 공제 후 <b>${money(s.afterInsurance)}</b></span>
            <span>발행 <b>${money(s.issued)}</b></span>
            <span>미발행 <b>${money(s.unissued)}</b></span>
            ${s.teamBonus ? `<span class="wide">한팀장 수수료 <b>${money(s.teamBonus)}</b></span>` : ""}
            <span class="wide">실 지급액 <b>${money(s.finalPay)}</b></span>
          `;
        }

        const s = g.stats;

        return `
          <span>총금액 <b>${money(s.total)}</b></span>
          <span>미입금 <b>${money(s.unpaid)}</b></span>
          <span>입금 <b>${money(s.paidAmount)}</b></span>
          <span>배송 <b>${fmt(s.parcel)}</b></span>
        `;
      }

      function renderGroupList(){
        if(!state.groups.length){
          dom.groupList.innerHTML = `<div class="emptyState" style="padding:16px;">표시할 정산서가 없습니다.</div>`;
          return;
        }

        dom.groupList.innerHTML = state.groups.map(g => `
          <div class="groupItem ${g.key === state.selectedGroupKey ? "active" : ""}" data-key="${esc(g.key)}">
            <div class="groupName">${esc(g.name || "-")}${g.subtitle ? "\n" + esc(g.subtitle) : ""}</div>
            <div class="groupMeta">${groupMeta(g)}</div>
          </div>
        `).join("");

        dom.groupList.querySelectorAll(".groupItem").forEach(el => {
          el.addEventListener("click", () => {
            state.selectedGroupKey = el.dataset.key || "";
            render();
          });
        });
      }

      function renderStatement(){
        const g = state.groups.find(x => x.key === state.selectedGroupKey);

        if(!g){
          dom.statementCapture.style.display = "none";
          dom.emptyState.style.display = "block";
          dom.statementCapture.innerHTML = "";
