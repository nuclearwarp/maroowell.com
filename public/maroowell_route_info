<script>
(() => {
  "use strict";

  const cfg = window.MARUWELL_CONFIG || {};
  const $ = id => document.getElementById(id);

  const TABLE_ROUTE = "maroowell_route_info";
  const TABLE_POLYGON = "maroowell_sub_sub_route";
  const TABLE_POINT = "maroowell_route_delivery_points";
  const TABLE_ATTACHMENT = "maroowell_route_point_attachments";
  const ATTACHMENT_BUCKET = "maroowell-route-point-images";

  let supabaseClient = null;
  let currentUser = null;
  let access = null;
  let isSuperAdmin = false;

  let map = null;
  let isSatellite = false;

  let routeRows = [];
  let polygonRows = [];
  let pointRows = [];
  let attachmentRows = [];
  let attachmentSignedUrls = new Map();

  let selectedRoute = null;
  let selectedPoint = null;
  let selectedPolygonId = null;

  let addPointMode = false;

  let drawMode = false;
  let drawReplaceExisting = true;
  let drawEditingPolygonId = null;
  let drawVertices = [];

  let polygonObjects = [];
  let polygonLabels = [];
  let pointOverlays = [];

  let drawVertexMarkers = [];
  let drawLine = null;
  let drawPreviewPolygon = null;

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg || "";
    $("statusText").className = type ? "status " + type : "status";
  }

  function setPointStatus(msg, type = "") {
    $("pointStatusText").textContent = msg || "";
    $("pointStatusText").className = type ? "status " + type : "status";
  }

  function setAttachmentStatus(msg, type = "") {
    $("attachmentStatusText").textContent = msg || "";
    $("attachmentStatusText").className = type ? "status " + type : "status";
  }

  function setDrawStatus(msg, show = false) {
    $("drawStatus").textContent = msg || "";
    $("drawStatus").className = show ? "drawStatus show" : "drawStatus";
    $("drawInfoText").textContent = msg || "";
  }

  function setRouteBaseStatus(msg, type = "") {
    const el = $("routeBaseInfoText");
    if (!el) return;
    el.textContent = msg || "";
    el.className = type ? "status " + type : "status";
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function naturalCompare(a, b) {
    return String(a ?? "").localeCompare(String(b ?? ""), "ko-KR", {
      numeric: true,
      sensitivity: "base"
    });
  }

  function sortRouteRows(rows) {
    return [...(rows || [])].sort((a, b) => {
      return (
        naturalCompare(a.camp, b.camp) ||
        naturalCompare(a.route, b.route) ||
        naturalCompare(a.sub, b.sub) ||
        naturalCompare(a.sub_sub, b.sub_sub) ||
        naturalCompare(routeCodeOf(a), routeCodeOf(b))
      );
    });
  }

  function routeCodeOf(row) {
    return normalizeRoute(row?.route_code || `${row?.route || ""}${row?.sub || ""}${row?.sub_sub || ""}`);
  }

  function routeLabel(row) {
    return [row.route, clean(row.sub), clean(row.sub_sub)].filter(Boolean).join("-");
  }

  function polygonCodeOf(row) {
    return normalizeRoute(row?.route_code || row?.route_norm);
  }

  function pointTypeLabel(type) {
    return {
      tip: "배송팁",
      entrance: "입구",
      password: "비번",
      parking: "주차",
      caution: "주의",
      door: "문",
      gate: "게이트",
      etc: "기타"
    }[type] || "기타";
  }

  function pointTypeIcon(type) {
    return {
      tip: "팁",
      entrance: "입",
      password: "🔒",
      parking: "P",
      caution: "!",
      door: "문",
      gate: "G",
      etc: "·"
    }[type] || "·";
  }

  function pointTypeClass(type) {
    return "marker-" + (type || "etc");
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  async function checkAccess() {
    const { data: sessionData, error: sessionError } = await supabaseClient.auth.getSession();
    if (sessionError) throw sessionError;

    currentUser = sessionData?.session?.user;

    if (!currentUser) {
      location.href = (cfg.PATHS?.login || "/login.html") + "?next=" + encodeURIComponent(location.pathname);
      return false;
    }

    $("userPill").textContent = currentUser.email || currentUser.id;

    const { data, error } = await supabaseClient.rpc("mw_my_access").maybeSingle();

    if (error) {
      showDenied(error.message);
      return false;
    }

    access = data || {};
    isSuperAdmin =
      access?.is_maroowell === true &&
      access?.is_admin === true &&
      Number(access?.max_role_level || 0) >= 90;

    if (access?.is_maroowell !== true) {
      showDenied("마루웰 소속 권한이 필요합니다.\n조건: user_access.is_maroowell = true");
      return false;
    }

    if (!isSuperAdmin) {
      $("softDeletePointBtn").style.display = "none";
      $("deleteRouteBtn").style.display = "none";
    }

    document.documentElement.style.visibility = "visible";
    return true;
  }

  function showDenied(message) {
    $("accessDenied").classList.add("show");
    $("accessDeniedText").textContent = message || "접근 권한이 없습니다.";
    $("accessDeniedEmail").textContent = currentUser?.email
      ? `현재 로그인: ${currentUser.email}`
      : "현재 로그인 정보를 확인할 수 없습니다.";
    document.documentElement.style.visibility = "visible";
  }

  function initMap() {
    return new Promise(resolve => {
      kakao.maps.load(() => {
        map = new kakao.maps.Map($("map"), {
          center: new kakao.maps.LatLng(37.5665, 126.9780),
          level: 8
        });

        kakao.maps.event.addListener(map, "click", e => {
          if (drawMode) {
            addDrawVertex(e.latLng);
            return;
          }

          if (addPointMode) {
            if (!selectedRoute) {
              setStatus("먼저 좌측에서 라우트를 선택하세요.", "bad");
              return;
            }

            createNewPointFromMapClick(e.latLng);
          }
        });

        kakao.maps.event.addListener(map, "rightclick", e => {
          if (drawMode) {
            deleteNearestDrawVertex(e.latLng);
          }
        });

        resolve();
      });
    });
  }

  function createDrawMarkerImage() {
    const svg = `
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18">
        <circle cx="9" cy="9" r="5.2" fill="#111827" stroke="#e5e7eb" stroke-width="2.4"/>
      </svg>
    `.trim();

    const url = "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg);
    return new kakao.maps.MarkerImage(
      url,
      new kakao.maps.Size(18, 18),
      { offset: new kakao.maps.Point(9, 9) }
    );
  }

  function clearMapObjects() {
    polygonObjects.forEach(obj => obj.setMap(null));
    polygonLabels.forEach(obj => obj.setMap(null));
    pointOverlays.forEach(obj => obj.setMap(null));
    polygonObjects = [];
    polygonLabels = [];
    pointOverlays = [];
  }

  function clearDrawObjects() {
    drawVertexMarkers.forEach(marker => marker.setMap(null));
    drawVertexMarkers = [];

    if (drawLine) {
      drawLine.setMap(null);
      drawLine = null;
    }

    if (drawPreviewPolygon) {
      drawPreviewPolygon.setMap(null);
      drawPreviewPolygon = null;
    }
  }

  function setMapBoundsByLatLngs(latlngs) {
    if (!latlngs.length) return;

    const bounds = new kakao.maps.LatLngBounds();
    latlngs.forEach(latlng => bounds.extend(latlng));
    map.setBounds(bounds);
  }

  function safeParseJson(value) {
    if (!value) return null;
    if (typeof value === "object") return value;

    try {
      return JSON.parse(value);
    } catch {
      return null;
    }
  }

  function coordToLatLng(coord) {
    if (!coord) return null;

    if (Array.isArray(coord) && coord.length >= 2) {
      let a = Number(coord[0]);
      let b = Number(coord[1]);

      if (!Number.isFinite(a) || !Number.isFinite(b)) return null;

      let lng = a;
      let lat = b;

      if (a >= 30 && a <= 45 && b >= 120 && b <= 135) {
        lat = a;
        lng = b;
      }

      if (lat < 30 || lat > 45 || lng < 120 || lng > 135) return null;

      return new kakao.maps.LatLng(lat, lng);
    }

    if (typeof coord === "object") {
      const lat = Number(coord.lat ?? coord.latitude ?? coord.y);
      const lng = Number(coord.lng ?? coord.lon ?? coord.longitude ?? coord.x);

      if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;
      if (lat < 30 || lat > 45 || lng < 120 || lng > 135) return null;

      return new kakao.maps.LatLng(lat, lng);
    }

    return null;
  }

  function extractRings(raw) {
    const data = safeParseJson(raw);
    if (!data) return [];

    if (data.type === "Feature") return extractRings(data.geometry);

    if (data.type === "FeatureCollection") {
      return (data.features || []).flatMap(f => extractRings(f));
    }

    if (data.type === "Polygon") {
      return (data.coordinates || [])
        .map(ring => ring.map(coordToLatLng).filter(Boolean))
        .filter(ring => ring.length >= 3);
    }

    if (data.type === "MultiPolygon") {
      return (data.coordinates || []).flatMap(poly => {
        return (poly || [])
          .map(ring => ring.map(coordToLatLng).filter(Boolean))
          .filter(ring => ring.length >= 3);
      });
    }

    if (Array.isArray(data)) {
      if (!data.length) return [];

      if (Array.isArray(data[0]) && typeof data[0][0] === "number") {
        const ring = data.map(coordToLatLng).filter(Boolean);
        return ring.length >= 3 ? [ring] : [];
      }

      if (typeof data[0] === "object" && !Array.isArray(data[0])) {
        const ring = data.map(coordToLatLng).filter(Boolean);
        return ring.length >= 3 ? [ring] : [];
      }

      return data
        .map(item => {
          if (Array.isArray(item) && item.length && Array.isArray(item[0]) && typeof item[0][0] === "number") {
            return item.map(coordToLatLng).filter(Boolean);
          }

          if (Array.isArray(item) && item.length && typeof item[0] === "object") {
            return item.map(coordToLatLng).filter(Boolean);
          }

          return [];
        })
        .filter(ring => ring.length >= 3);
    }

    return [];
  }

  function ringCenter(ring) {
    if (!ring.length) return null;

    let lat = 0;
    let lng = 0;

    ring.forEach(item => {
      lat += item.getLat();
      lng += item.getLng();
    });

    return new kakao.maps.LatLng(lat / ring.length, lng / ring.length);
  }

  function renderMapFeatures() {
    if (!map) return;

    clearMapObjects();

    const selectedCode = selectedRoute ? routeCodeOf(selectedRoute) : "";
    const allLatLngs = [];

    for (const polyRow of polygonRows) {
      if (polyRow.is_active === false) continue;

      if (drawMode && drawEditingPolygonId && drawEditingPolygonId === polyRow.id) {
        continue;
      }

      const code = polygonCodeOf(polyRow);
      const selected = selectedCode && code === selectedCode;
      const selectedPolygon = selectedPolygonId && selectedPolygonId === polyRow.id;
      const rings = extractRings(polyRow.polygon_wgs84);

      for (const ring of rings) {
        allLatLngs.push(...ring);

        const polygon = new kakao.maps.Polygon({
          path: ring,
          strokeWeight: selectedPolygon ? 4 : selected ? 3 : 2,
          strokeColor: selectedPolygon ? "#facc15" : selected ? "#facc15" : "#38bdf8",
          strokeOpacity: selectedPolygon ? 0.95 : selected ? 0.85 : 0.65,
          fillColor: selectedPolygon ? "#fde047" : selected ? "#fde047" : "#38bdf8",
          fillOpacity: selectedPolygon ? 0.22 : selected ? 0.16 : 0.12
        });

        polygon.setMap(map);

        kakao.maps.event.addListener(polygon, "click", mouseEvent => {
          if (drawMode) {
            addDrawVertex(mouseEvent.latLng);
            return;
          }

          if (addPointMode) {
            if (!selectedRoute) {
              selectRouteByCode(polyRow.camp, code);
              setStatus("라우트를 선택했습니다. 다시 위치를 클릭하면 배송 포인트가 등록됩니다.", "warn");
              return;
            }

            createNewPointFromMapClick(mouseEvent.latLng);
            return;
          }

          selectedPolygonId = polyRow.id;
          selectRouteByCode(polyRow.camp, code);
        });

        kakao.maps.event.addListener(polygon, "rightclick", mouseEvent => {
          if (drawMode) {
            deleteNearestDrawVertex(mouseEvent.latLng);
          }
        });

        polygonObjects.push(polygon);

        const center = ringCenter(ring);

        if (center) {
          const label = document.createElement("div");
          label.style.cssText = [
            "padding:3px 7px",
            "border-radius:999px",
            "border:1px solid rgba(255,255,255,.55)",
            "background:rgba(0,0,0,.65)",
            "color:#fff",
            "font-size:11px",
            "font-weight:900",
            "white-space:nowrap"
          ].join(";");

          label.textContent = code;

          const overlay = new kakao.maps.CustomOverlay({
            position: center,
            content: label,
            yAnchor: 0.5,
            zIndex: selectedPolygon ? 16 : selected ? 15 : 8
          });

          overlay.setMap(map);
          polygonLabels.push(overlay);
        }
      }
    }

    for (const point of pointRows) {
      if (point.is_active === false) continue;

      const lat = Number(point.lat);
      const lng = Number(point.lng);

      if (!Number.isFinite(lat) || !Number.isFinite(lng)) continue;

      const position = new kakao.maps.LatLng(lat, lng);
      allLatLngs.push(position);

      const el = document.createElement("div");
      const active = selectedPoint && selectedPoint.id === point.id;

      el.className = `markerTip ${pointTypeClass(point.point_type)} ${active ? "active" : ""}`;
      el.innerHTML = `
        <div class="markerBubble">${esc(pointTypeIcon(point.point_type))}</div>
        <div class="markerLabel">${esc(point.title || pointTypeLabel(point.point_type))}</div>
      `;

      el.addEventListener("click", event => {
        event.stopPropagation();
        selectPoint(point.id);
      });

      const overlay = new kakao.maps.CustomOverlay({
        position,
        content: el,
        yAnchor: 1.2,
        zIndex: active ? 30 : 20
      });

      overlay.setMap(map);
      pointOverlays.push(overlay);
    }

    if (allLatLngs.length && !selectedRoute) {
      setMapBoundsByLatLngs(allLatLngs);
    }
  }

  function deleteDrawVertexAt(index) {
    if (!drawMode) return;
    if (index < 0 || index >= drawVertices.length) return;

    if (drawVertices.length <= 3) {
      setStatus("폴리곤은 최소 3개 점이 필요해서 더 지울 수 없습니다.", "bad");
      return;
    }

    drawVertices.splice(index, 1);
    renderDrawPreview();
  }

  function deleteNearestDrawVertex(latLng) {
    if (!drawMode || !latLng || !drawVertices.length) return;

    if (!map || !map.getProjection) {
      setStatus("지도 좌표 계산을 할 수 없습니다.", "bad");
      return;
    }

    const projection = map.getProjection();
    const clickPoint = projection.containerPointFromCoords(latLng);

    let nearestIndex = -1;
    let nearestDistance = Infinity;

    drawVertices.forEach((vertex, index) => {
      const vertexPoint = projection.containerPointFromCoords(vertex);
      const dx = Number(vertexPoint.x) - Number(clickPoint.x);
      const dy = Number(vertexPoint.y) - Number(clickPoint.y);
      const distance = Math.sqrt(dx * dx + dy * dy);

      if (distance < nearestDistance) {
        nearestDistance = distance;
        nearestIndex = index;
      }
    });

    if (nearestIndex < 0 || nearestDistance > 28) {
      setStatus("삭제할 점 가까이에서 우클릭하세요.", "warn");
      return;
    }

    deleteDrawVertexAt(nearestIndex);
  }

  function renderDrawPreview() {
    clearDrawObjects();

    if (!drawVertices.length) {
      setDrawStatus("그리기: 지도 클릭 첫추가 · Enter/그리기 저장 버튼 저장 · Backspace 마지막 점 취소 · ESC 취소", true);
      return;
    }

    const markerImage = createDrawMarkerImage();

    drawVertices.forEach((latLng, index) => {
      const marker = new kakao.maps.Marker({
        map,
        position: latLng,
        image: markerImage,
        draggable: true,
        zIndex: 100
      });

      kakao.maps.event.addListener(marker, "dragend", () => {
        drawVertices[index] = marker.getPosition();
        renderDrawPreview();
      });

      kakao.maps.event.addListener(marker, "rightclick", () => {
        deleteDrawVertexAt(index);
      });

      drawVertexMarkers.push(marker);
    });

    if (drawVertices.length >= 2) {
      drawLine = new kakao.maps.Polyline({
        path: drawVertices,
        strokeWeight: 2,
        strokeColor: "#0ea5e9",
        strokeOpacity: 0.95,
        strokeStyle: "dash"
      });

      drawLine.setMap(map);
    }

    if (drawVertices.length >= 3) {
      drawPreviewPolygon = new kakao.maps.Polygon({
        path: drawVertices,
        strokeWeight: 2,
        strokeColor: "#0ea5e9",
        strokeOpacity: 0.95,
        strokeStyle: "dash",
        fillColor: "#38bdf8",
        fillOpacity: 0.05
      });

      drawPreviewPolygon.setMap(map);

      kakao.maps.event.addListener(drawPreviewPolygon, "click", mouseEvent => {
        if (drawMode) addDrawVertex(mouseEvent.latLng);
      });

      kakao.maps.event.addListener(drawPreviewPolygon, "rightclick", mouseEvent => {
        if (drawMode) deleteNearestDrawVertex(mouseEvent.latLng);
      });
    }

    const modeText = drawEditingPolygonId
      ? "수정"
      : drawReplaceExisting
        ? "새로 그리기"
        : "구역 추가";

    setDrawStatus(
      `${modeText}: 지도 클릭 점추가 · 점 드래그 이동 · 점 우클릭 삭제 · Enter/그리기 저장 버튼 저장 · Backspace 마지막 점 취소 · ESC 취소`,
      true
    );
  }

  function addDrawVertex(latLng) {
    if (!selectedRoute) {
      setStatus("먼저 라우트를 선택하세요.", "bad");
      return;
    }

    drawVertices.push(latLng);
    renderDrawPreview();
  }

  function getSelectedActivePolygons() {
    if (!selectedRoute) return [];

    const code = routeCodeOf(selectedRoute);

    return polygonRows.filter(row => {
      return row.is_active !== false
        && row.camp === selectedRoute.camp
        && polygonCodeOf(row) === code;
    });
  }

  function startDrawMode(replaceExisting) {
    if (!selectedRoute) {
      setStatus("먼저 좌측에서 라우트를 선택하세요.", "bad");
      return;
    }

    if (addPointMode) {
      addPointMode = false;
      $("addPointModeBtn").textContent = "점 추가 OFF";
      $("addPointModeBtn").className = "warn";
    }

    drawMode = true;
    drawReplaceExisting = replaceExisting;
    drawEditingPolygonId = null;
    drawVertices = [];
    clearDrawObjects();

    const modeText = drawReplaceExisting ? "새로 그리기" : "구역 추가";
    setStatus(`${modeText} 모드입니다. 지도 또는 기존 폴리곤 위에서 꼭짓점을 순서대로 클릭하세요.`, "warn");
    setDrawStatus(`${modeText}: 지도 클릭 첫추가 · Enter/그리기 저장 버튼 저장 · Backspace 마지막 점 취소 · ESC 취소`, true);
  }

  function startEditPolygonMode() {
    if (!selectedRoute) {
      setStatus("먼저 좌측에서 라우트를 선택하세요.", "bad");
      return;
    }

    const polygons = getSelectedActivePolygons();

    if (!polygons.length) {
      setStatus("수정할 기존 폴리곤이 없습니다. 새로 그리기를 사용하세요.", "bad");
      return;
    }

    const target = polygons.find(row => row.id === selectedPolygonId) || polygons[0];
    const rings = extractRings(target.polygon_wgs84);

    if (!rings.length || rings[0].length < 3) {
      setStatus("기존 폴리곤 좌표를 읽을 수 없습니다. 새로 그리기를 사용하세요.", "bad");
      return;
    }

    if (addPointMode) {
      addPointMode = false;
      $("addPointModeBtn").textContent = "점 추가 OFF";
      $("addPointModeBtn").className = "warn";
    }

    drawMode = true;
    drawReplaceExisting = true;
    drawEditingPolygonId = target.id;
    selectedPolygonId = target.id;
    drawVertices = rings[0].slice();

    const first = drawVertices[0];
    const last = drawVertices[drawVertices.length - 1];

    if (
      first &&
      last &&
      first.getLat() === last.getLat() &&
      first.getLng() === last.getLng()
    ) {
      drawVertices.pop();
    }

    renderMapFeatures();
    renderDrawPreview();

    setStatus("수정 모드입니다. 점을 드래그해서 위치를 바꾸고 저장하세요.", "warn");
  }

  function undoDrawVertex() {
    if (!drawMode) {
      setStatus("폴리곤 편집 모드가 아닙니다.", "bad");
      return;
    }

    if (!drawVertices.length) return;

    drawVertices.pop();
    renderDrawPreview();
  }

  function cancelDrawMode() {
    drawMode = false;
    drawReplaceExisting = true;
    drawEditingPolygonId = null;
    drawVertices = [];
    clearDrawObjects();
    setDrawStatus("", false);
    setStatus("폴리곤 편집을 취소했습니다.", "ok");
    renderMapFeatures();
  }

  function cancelDrawModeSilently() {
    drawMode = false;
    drawReplaceExisting = true;
    drawEditingPolygonId = null;
    drawVertices = [];
    clearDrawObjects();
    setDrawStatus("", false);
  }

  function buildGeoJsonPolygon(vertices) {
    const ring = vertices.map(latLng => [
      Number(latLng.getLng().toFixed(8)),
      Number(latLng.getLat().toFixed(8))
    ]);

    const first = ring[0];
    const last = ring[ring.length - 1];

    if (first[0] !== last[0] || first[1] !== last[1]) {
      ring.push([...first]);
    }

    return {
      type: "Polygon",
      coordinates: [ring]
    };
  }

  async function deactivatePolygonsForSave(code) {
    if (drawEditingPolygonId) {
      const { error } = await supabaseClient
        .from(TABLE_POLYGON)
        .update({ is_active:false })
        .eq("id", drawEditingPolygonId);

      if (error) throw error;

      polygonRows = polygonRows.map(row => {
        return row.id === drawEditingPolygonId ? { ...row, is_active:false } : row;
      });

      return;
    }

    if (drawReplaceExisting) {
      const activeTargets = polygonRows.filter(row => {
        return row.is_active !== false
          && row.camp === selectedRoute.camp
          && polygonCodeOf(row) === code;
      });

      for (const target of activeTargets) {
        const { error } = await supabaseClient
          .from(TABLE_POLYGON)
          .update({ is_active:false })
          .eq("id", target.id);

        if (error) throw error;
      }

      polygonRows = polygonRows.map(row => {
        const shouldDeactivate = row.is_active !== false
          && row.camp === selectedRoute.camp
          && polygonCodeOf(row) === code;

        return shouldDeactivate ? { ...row, is_active:false } : row;
      });
    }
  }

  async function saveDrawPolygon() {
    if (!drawMode) {
      setStatus("폴리곤 편집 모드가 아닙니다.", "bad");
      return;
    }

    if (!selectedRoute) {
      setStatus("선택된 라우트가 없습니다.", "bad");
      return;
    }

    if (drawVertices.length < 3) {
      setStatus("폴리곤은 최소 3개 점이 필요합니다.", "bad");
      return;
    }

    const code = routeCodeOf(selectedRoute);
    const geo = buildGeoJsonPolygon(drawVertices);

    const modeText = drawEditingPolygonId
      ? "기존 폴리곤을 비활성화하고 수정본 저장"
      : drawReplaceExisting
        ? "기존 활성 폴리곤 전체 비활성화 후 새 폴리곤 저장"
        : "기존 폴리곤 유지 후 구역 추가";

    const ok = confirm(`${selectedRoute.camp} / ${code}\n\n${modeText}할까요?`);
    if (!ok) return;

    setStatus("폴리곤 저장 중...", "warn");

    await deactivatePolygonsForSave(code);

    const payload = {
      camp: selectedRoute.camp,
      route_code: code,
      polygon_wgs84: geo,
      camps_code: selectedRoute.coordinate || null,
      is_active: true
    };

    const { data, error } = await supabaseClient
      .from(TABLE_POLYGON)
      .insert(payload)
      .select(`
        id,
        camp,
        route_code,
        route_norm,
        polygon_wgs84,
        camps_code,
        is_active,
        created_at,
        updated_at
      `)
      .single();

    if (error) throw error;

    polygonRows.push(data);
    selectedPolygonId = data.id;

    drawMode = false;
    drawReplaceExisting = true;
    drawEditingPolygonId = null;
    drawVertices = [];
    clearDrawObjects();
    setDrawStatus("", false);

    renderMapFeatures();
    renderRouteList();
    renderCounts();
    focusSelectedRoute();

    setStatus("폴리곤 저장 완료", "ok");
  }

  async function loadData() {
    setStatus("데이터를 불러오는 중...", "warn");

    const camp = clean($("campInput").value);
    const routeFilter = normalizeRoute($("routeInput").value);

    let routeQuery = supabaseClient
      .from(TABLE_ROUTE)
      .select(`
        id,
        camp,
        route,
        sub,
        sub_sub,
        sub_package,
        description,
        memo,
        coordinate,
        sort_order,
        is_active,
        route_code,
        route_norm,
        created_at,
        updated_at
      `)
      .eq("is_active", true)
      .order("camp", { ascending:true })
      .order("route", { ascending:true })
      .order("sub", { ascending:true })
      .order("sub_sub", { ascending:true })
      .order("sort_order", { ascending:true })
      .limit(5000);

    if (camp) routeQuery = routeQuery.ilike("camp", `%${camp}%`);

    const { data: routes, error: routeError } = await routeQuery;
    if (routeError) throw routeError;

    routeRows = sortRouteRows((routes || []).filter(row => {
      if (!routeFilter) return true;

      const code = routeCodeOf(row);
      const routeNorm = normalizeRoute(row.route);

      return code.includes(routeFilter) || routeNorm.includes(routeFilter);
    }));

    let polygonQuery = supabaseClient
      .from(TABLE_POLYGON)
      .select(`
        id,
        camp,
        route_code,
        route_norm,
        polygon_wgs84,
        camps_code,
        is_active,
        created_at,
        updated_at
      `)
      .eq("is_active", true)
      .limit(5000);

    if (camp) polygonQuery = polygonQuery.ilike("camp", `%${camp}%`);

    const { data: polygons, error: polygonError } = await polygonQuery;
    if (polygonError) throw polygonError;

    polygonRows = (polygons || []).filter(row => {
      if (!routeFilter) return true;
      return polygonCodeOf(row).includes(routeFilter);
    });

    let pointQuery = supabaseClient
      .from(TABLE_POINT)
      .select(`
        id,
        camp,
        route_code,
        route_norm,
        route_info_id,
        polygon_id,
        lat,
        lng,
        point_type,
        title,
        delivery_tip,
        password_note,
        entrance_note,
        parking_note,
        caution_note,
        memo,
        marker_shape,
        marker_color,
        marker_json,
        is_active,
        created_at,
        updated_at
      `)
      .eq("is_active", true)
      .limit(10000);

    if (camp) pointQuery = pointQuery.ilike("camp", `%${camp}%`);

    const { data: points, error: pointError } = await pointQuery;
    if (pointError) throw pointError;

    pointRows = (points || []).filter(row => {
      if (!routeFilter) return true;
      return normalizeRoute(row.route_code || row.route_norm).includes(routeFilter);
    });

    selectedRoute = null;
    selectedPoint = null;
    selectedPolygonId = null;

    cancelDrawModeSilently();
    clearAttachmentsState();
    renderRouteList();
    renderPointList();
    clearRouteDetail();
    fillPointForm(null);
    renderMapFeatures();
    renderCounts();

    setStatus("조회 완료", "ok");
  }

  function renderCounts() {
    $("routeCount").textContent = routeRows.length.toLocaleString();
    $("polygonCount").textContent = polygonRows.filter(row => row.is_active !== false).length.toLocaleString();
    $("pointCount").textContent = pointRows.filter(row => row.is_active !== false).length.toLocaleString();
  }

  function renderRouteList() {
    const wrap = $("routeList");

    if (!routeRows.length) {
      wrap.innerHTML = `<div class="detailEmpty">라우트 데이터가 없습니다.</div>`;
      return;
    }

    const pointCountByRoute = new Map();
    const polygonCountByRoute = new Map();

    for (const point of pointRows) {
      const key = `${point.camp}||${normalizeRoute(point.route_code || point.route_norm)}`;
      pointCountByRoute.set(key, (pointCountByRoute.get(key) || 0) + 1);
    }

    for (const poly of polygonRows) {
      if (poly.is_active === false) continue;
      const key = `${poly.camp}||${polygonCodeOf(poly)}`;
      polygonCountByRoute.set(key, (polygonCountByRoute.get(key) || 0) + 1);
    }

    wrap.innerHTML = routeRows.map(row => {
      const code = routeCodeOf(row);
      const key = `${row.camp}||${code}`;
      const active = selectedRoute && selectedRoute.id === row.id;

      return `
        <div class="routeCard ${active ? "active" : ""}" data-route-id="${esc(row.id)}">
          <div class="routeMain">
            <div class="routeCode">${esc(code)}</div>
            <div class="routeMeta">${esc(row.camp)} · ${esc(routeLabel(row))}</div>
          </div>
          <div class="routeDesc">${esc(row.description || row.memo || "설명 없음")}</div>
          <div class="routeBadges">
            <span class="miniBadge">폴리곤 ${polygonCountByRoute.get(key) || 0}</span>
            <span class="miniBadge">포인트 ${pointCountByRoute.get(key) || 0}</span>
            ${row.sub_package ? `<span class="miniBadge">${esc(row.sub_package)}</span>` : ""}
          </div>
        </div>
      `;
    }).join("");
  }

  function renderPointList() {
    const wrap = $("pointList");

    const list = selectedRoute
      ? pointRows.filter(p => p.camp === selectedRoute.camp && normalizeRoute(p.route_code || p.route_norm) === routeCodeOf(selectedRoute))
      : pointRows;

    $("pointListCount").textContent = `${list.length.toLocaleString()}개`;

    if (!list.length) {
      wrap.innerHTML = `<div class="detailEmpty">배송 포인트가 없습니다.</div>`;
      return;
    }

    wrap.innerHTML = list.map(point => {
      const active = selectedPoint && selectedPoint.id === point.id;
      const desc = point.delivery_tip || point.entrance_note || point.password_note || point.parking_note || point.caution_note || point.memo || "";

      return `
        <div class="pointCard ${active ? "active" : ""}" data-point-id="${esc(point.id)}">
          <div class="pointTitle">[${esc(pointTypeLabel(point.point_type))}] ${esc(point.title || point.route_code)}</div>
          <div class="pointSub">${esc(desc || `${point.lat}, ${point.lng}`)}</div>
        </div>
      `;
    }).join("");
  }

  function selectRouteById(id) {
    const row = routeRows.find(item => item.id === id);
    if (!row) return;

    selectedRoute = row;
    selectedPoint = null;

    const activePolygons = getSelectedActivePolygons();

    if (!activePolygons.some(poly => poly.id === selectedPolygonId)) {
      selectedPolygonId = activePolygons[0]?.id || null;
    }

    cancelDrawModeSilently();
    clearAttachmentsState();
    renderRouteList();
    renderRouteDetail(row);
    renderPointList();
    fillPointForm(null);
    renderMapFeatures();
    focusSelectedRoute();
  }

  function selectRouteByCode(camp, code) {
    const norm = normalizeRoute(code);

    const row = routeRows.find(item => {
      return item.camp === camp && routeCodeOf(item) === norm;
    }) || routeRows.find(item => routeCodeOf(item) === norm);

    if (row) {
      selectRouteById(row.id);
    }
  }

  function renderRouteDetail(row) {
    $("routeDetailEmpty").style.display = "none";
    $("routeDetailForm").style.display = "";
    $("selectedRouteCode").textContent = `${row.camp} / ${routeCodeOf(row)}`;

    $("routeCampInput").value = row.camp || "";
    $("routeRouteInput").value = row.route || "";
    $("routeSubInput").value = row.sub || "";
    $("routeSubSubInput").value = row.sub_sub || "";

    $("routeDescriptionInput").value = row.description || "";
    $("routeMemoInput").value = row.memo || "";
    $("routeSubPackageInput").value = row.sub_package || "";
    $("routeCoordinateInput").value = row.coordinate || "";

    setRouteBaseStatus("Camp / Route / Sub / Sub-sub 수정 시 연결된 폴리곤·포인트의 route_code도 같이 맞춰집니다.");
  }

  function clearRouteDetail() {
    $("routeDetailEmpty").style.display = "";
    $("routeDetailForm").style.display = "none";
    $("selectedRouteCode").textContent = "선택 없음";

    $("routeCampInput").value = "";
    $("routeRouteInput").value = "";
    $("routeSubInput").value = "";
    $("routeSubSubInput").value = "";

    $("routeDescriptionInput").value = "";
    $("routeMemoInput").value = "";
    $("routeSubPackageInput").value = "";
    $("routeCoordinateInput").value = "";

    setRouteBaseStatus("");
  }

  function focusSelectedRoute() {
    if (!selectedRoute) return;

    const code = routeCodeOf(selectedRoute);
    const latlngs = [];

    for (const poly of polygonRows) {
      if (poly.camp === selectedRoute.camp && polygonCodeOf(poly) === code && poly.is_active !== false) {
        for (const ring of extractRings(poly.polygon_wgs84)) {
          latlngs.push(...ring);
        }
      }
    }

    for (const point of pointRows) {
      if (point.camp === selectedRoute.camp && normalizeRoute(point.route_code || point.route_norm) === code) {
        const lat = Number(point.lat);
        const lng = Number(point.lng);

        if (Number.isFinite(lat) && Number.isFinite(lng)) {
          latlngs.push(new kakao.maps.LatLng(lat, lng));
        }
      }
    }

    if (latlngs.length) setMapBoundsByLatLngs(latlngs);
  }

  async function saveRouteBase() {
    if (!selectedRoute) {
      setRouteBaseStatus("선택된 라우트가 없습니다.", "bad");
      return;
    }

    const oldCamp = selectedRoute.camp;
    const oldCode = routeCodeOf(selectedRoute);

    const nextCamp = clean($("routeCampInput").value);
    const nextRoute = clean($("routeRouteInput").value);
    const nextSub = clean($("routeSubInput").value);
    const nextSubSub = clean($("routeSubSubInput").value);
    const nextCode = normalizeRoute(`${nextRoute}${nextSub}${nextSubSub}`);

    if (!nextCamp || !nextRoute) {
      setRouteBaseStatus("Camp와 Route는 필수입니다.", "bad");
      return;
    }

    const ok = confirm(
      [
        "라우트 기본정보를 수정할까요?",
        "",
        `기존: ${oldCamp} / ${oldCode}`,
        `변경: ${nextCamp} / ${nextCode}`,
        "",
        "연결된 폴리곤·포인트의 camp / route_code도 함께 변경됩니다."
      ].join("\n")
    );

    if (!ok) return;

    setRouteBaseStatus("라우트 기본정보 수정 중...", "warn");

    const routePayload = {
      camp: nextCamp,
      route: nextRoute,
      sub: nextSub || null,
      sub_sub: nextSubSub || null
    };

    const { data, error } = await supabaseClient
      .from(TABLE_ROUTE)
      .update(routePayload)
      .eq("id", selectedRoute.id)
      .select(`
        id,
        camp,
        route,
        sub,
        sub_sub,
        sub_package,
        description,
        memo,
        coordinate,
        sort_order,
        is_active,
        route_code,
        route_norm,
        created_at,
        updated_at
      `)
      .single();

    if (error) throw error;

    const activePolygonsToMove = polygonRows.filter(row => {
      return row.is_active !== false
        && row.camp === oldCamp
        && polygonCodeOf(row) === oldCode;
    });

    for (const poly of activePolygonsToMove) {
      const { error: polyError } = await supabaseClient
        .from(TABLE_POLYGON)
        .update({
          camp: nextCamp,
          route_code: nextCode
        })
        .eq("id", poly.id);

      if (polyError) throw polyError;
    }

    const activePointsToMove = pointRows.filter(row => {
      return row.is_active !== false
        && (
          row.route_info_id === selectedRoute.id ||
          (row.camp === oldCamp && normalizeRoute(row.route_code || row.route_norm) === oldCode)
        );
    });

    for (const point of activePointsToMove) {
      const { error: pointError } = await supabaseClient
        .from(TABLE_POINT)
        .update({
          camp: nextCamp,
          route_code: nextCode,
          route_info_id: selectedRoute.id
        })
        .eq("id", point.id);

      if (pointError) throw pointError;
    }

    selectedRoute = { ...selectedRoute, ...data };
    routeRows = sortRouteRows(routeRows.map(row => row.id === selectedRoute.id ? selectedRoute : row));

    polygonRows = polygonRows.map(row => {
      const shouldMove = row.is_active !== false && row.camp === oldCamp && polygonCodeOf(row) === oldCode;
      return shouldMove ? { ...row, camp: nextCamp, route_code: nextCode, route_norm: nextCode } : row;
    });

    pointRows = pointRows.map(row => {
      const shouldMove = row.is_active !== false
        && (
          row.route_info_id === selectedRoute.id ||
          (row.camp === oldCamp && normalizeRoute(row.route_code || row.route_norm) === oldCode)
        );

      return shouldMove ? { ...row, camp: nextCamp, route_code: nextCode, route_norm: nextCode, route_info_id: selectedRoute.id } : row;
    });

    renderRouteList();
    renderRouteDetail(selectedRoute);
    renderPointList();
    renderMapFeatures();
    renderCounts();
    focusSelectedRoute();

