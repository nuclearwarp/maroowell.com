<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>클렌징 히스토리</title>
  <link rel="icon" href="/favicon.ico?v=2">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    :root {
      --bg:#081120;
      --panel:#0d1728;
      --panel2:#0e1728;
      --head:#111c30;
      --th:#27364d;
      --line:rgba(255,255,255,.14);
      --txt:#eaf2ff;
      --muted:#9fb0d0;
      --blue:#2563eb;
      --green:#16a34a;
      --purple:#7e22ce;
      --red:#ef4444;
      --yellow:#f59e0b;
    }

    * { box-sizing:border-box; }

    body {
      margin:0;
      background:var(--bg);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    .top {
      display:flex;
      gap:10px;
      align-items:center;
      padding:12px 14px;
      background:#07101d;
      border-bottom:1px solid var(--line);
    }

    .logo {
      width:34px;
      height:34px;
      border-radius:12px;
      display:flex;
      align-items:center;
      justify-content:center;
      background:rgba(255,255,255,.05);
      text-decoration:none;
      flex:0 0 auto;
    }

    .logo img {
      width:28px;
      height:28px;
      display:block;
    }

    .title h1 {
      margin:0;
      font-size:22px;
      line-height:1.1;
      letter-spacing:-.04em;
    }

    .title p {
      margin:4px 0 0;
      color:var(--muted);
      font-size:12px;
      font-weight:800;
    }

    .spacer { flex:1; }

    .pill {
      border:1px solid var(--line);
      border-radius:999px;
      padding:7px 11px;
      background:rgba(255,255,255,.05);
      font-size:12px;
      font-weight:900;
      color:#bfdbfe;
      white-space:nowrap;
    }

    .bar {
      display:grid;
      grid-template-columns:130px 150px 115px 150px 180px 160px 115px 110px minmax(160px,1fr) 76px 76px 76px;
      gap:8px;
      padding:12px;
      background:var(--panel);
      border-bottom:1px solid var(--line);
      align-items:end;
    }

    label {
      display:block;
      color:#bfdbfe;
      font-size:12px;
      font-weight:900;
      margin:0 0 5px 2px;
    }

    input,
    select {
      width:100%;
      height:40px;
      border-radius:11px;
      border:1px solid var(--line);
      background:#0b1220;
      color:var(--txt);
      padding:0 10px;
      font-weight:800;
      outline:none;
    }

    input:focus,
    select:focus {
      border-color:rgba(96,165,250,.65);
      box-shadow:0 0 0 2px rgba(96,165,250,.14);
    }

    select option {
      background:#111827;
      color:#fff;
    }

    .btn {
      height:40px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.07);
      color:var(--txt);
      font-weight:900;
      padding:0 13px;
      cursor:pointer;
      align-self:end;
      white-space:nowrap;
    }

    .btn:hover { background:rgba(255,255,255,.11); }
    .btn.primary { background:rgba(37,99,235,.75); }
    .btn.ok { background:rgba(22,163,74,.55); }
    .btn.purple { background:rgba(126,34,206,.5); }

    .main {
      padding:14px;
      overflow:auto;
    }

    .board {
      min-width:1180px;
      border:1px solid var(--line);
      border-radius:18px;
      overflow:hidden;
      background:var(--panel2);
    }

    .head {
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:flex-end;
      padding:14px 16px;
      background:var(--head);
      border-bottom:1px solid var(--line);
    }

    .head h2 {
      margin:0;
      font-size:22px;
      letter-spacing:-.04em;
    }

    .head p {
      margin:5px 0 0;
      color:#bfdbfe;
      font-size:13px;
      font-weight:900;
    }

    .actions {
      display:flex;
      gap:8px;
      align-items:center;
      flex:0 0 auto;
    }

    table {
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
    }

    th,
    td {
      border-right:1px solid rgba(255,255,255,.1);
      border-bottom:1px solid rgba(255,255,255,.1);
      padding:8px 7px;
      text-align:center;
      font-size:12px;
      line-height:1.35;
    }

    th:last-child,
    td:last-child {
      border-right:none;
    }

    th {
      background:var(--th);
      font-weight:1000;
      white-space:nowrap;
    }

    td {
      font-weight:800;
      word-break:break-word;
    }

    tbody tr:hover td {
      background:rgba(96,165,250,.07);
    }

    .left { text-align:left; }
    .num { text-align:right; font-variant-numeric:tabular-nums; }
    .green { color:#bbf7d0; }
    .yellow { color:#fde68a; }
    .red { color:#fca5a5; }
    tbody tr.rowClean td,
    tbody tr.rowClean .green,
    tbody tr.rowClean .yellow,
    tbody tr.rowClean .red {
      color:#f87171;
      font-weight:1000;
    }
    tbody tr.rowWarn td,
    tbody tr.rowWarn .green,
    tbody tr.rowWarn .yellow,
    tbody tr.rowWarn .red {
      color:#fde68a;
      font-weight:1000;
    }

    .cellInput {
      height:30px;
      min-width:0;
      border-radius:8px;
      padding:0 7px;
      font-size:12px;
      font-weight:800;
    }

    .empty,
    .denied {
      margin:40px auto;
      max-width:720px;
      padding:26px;
      border:1px dashed var(--line);
      border-radius:18px;
      text-align:center;
      color:#cbd5e1;
      font-weight:900;
    }

    .denied {
      border-color:rgba(239,68,68,.35);
      background:rgba(127,29,29,.18);
      text-align:left;
      color:#fecaca;
    }

    .denied h2 {
      margin:0 0 12px;
      color:#fecaca;
    }

    .denied p {
      margin:0;
      line-height:1.65;
    }

    .hide { display:none!important; }

    @media(max-width:1100px) {
      .bar {
        grid-template-columns:1fr 1fr;
      }

      .main {
        padding:8px;
      }

      .title p {
        display:none;
      }

      .btn {
        width:100%;
      }
    }
  </style>
</head>

<body>
  <div class="top">
    <a href="#" id="mwBoardMenuToggle" class="logo">
      <img src="/favicon.ico" alt="MarooWell">
    </a>

    <div class="title">
      <h1>클렌징 히스토리</h1>
      <p>마지막 주차 기본 조회 / 주간·야간 필터 / 백엔드 API 분리</p>
    </div>

    <div class="spacer"></div>
    <span id="user" class="pill">세션 확인</span>
  </div>

  <div id="bar" class="bar">
    <div>
      <label>Week</label>
      <input id="week" placeholder="자동: 마지막 주차">
    </div>

    <div>
      <label>Camp</label>
      <input id="camp">
    </div>

    <div>
      <label>Wave</label>
      <select id="wave">
        <option value="">전체</option>
        <option value="2W">주간</option>
        <option value="1W">야간</option>
      </select>
    </div>

    <div>
      <label>Route</label>
      <input id="route">
    </div>

    <div>
      <label>Vendor</label>
      <input id="vendor">
    </div>

    <div>
      <label>사업자번호</label>
      <input id="biz">
    </div>

    <div>
      <label>Reason</label>
      <select id="reason">
        <option value="">전체</option>
        <option>수행률</option>
        <option>반품</option>
      </select>
    </div>

    <div>
      <label>Limit</label>
      <select id="limit">
        <option>100</option>
        <option selected>300</option>
        <option>500</option>
        <option>1000</option>
      </select>
    </div>

    <div>
      <label>통합 검색</label>
      <input id="q">
    </div>

    <button class="btn primary" id="search">조회</button>
    <button class="btn" id="reset">초기화</button>
    <button class="btn ok" id="add">신규</button>
  </div>

  <main class="main" id="main">
    <div class="board" id="board">
      <div class="head">
        <div>
          <h2>클렌징 히스토리</h2>
          <p id="summary">조회 전</p>
        </div>

        <div class="actions">
          <button class="btn" id="refresh">새로고침</button>
          <button class="btn purple" id="copyImage">이미지 복사</button>
        </div>
      </div>

      <div id="table"></div>
    </div>
  </main>

<script>
(() => {
  "use strict";

  const $ = id => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};
  const API = (cfg.CLEANSING_HISTORY_API_BASE || "https://cleansinghistory.maroowell.com").replace(/\/$/, "");
  const TABLE_HISTORY = "cleansing_history";
  const TABLE_CLHI_ACCESS = "cleansing_history_access";

  let supabaseClient = null;
  let me = {};
  let rows = [];
  let editingId = "";

  const esc = v => String(v ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");

  const val = id => $(id).value.trim();

  const fmtNum = v => {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    return Number.isFinite(n) ? n.toLocaleString("ko-KR") : String(v);
  };

  const fmtPct = v => {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    return Number.isFinite(n) ? n.toFixed(2).replace(/\.00$/, "") + "%" : String(v);
  };

  const fmtWon = v => {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    return Number.isFinite(n) ? "₩" + n.toLocaleString("ko-KR") : String(v);
  };

  const isSuper = () => {
    return me?.is_super_admin === true || Number(me?.max_role_level || 0) >= 90;
  };

  const isBackendSessionError = err => {
    const msg = String(err?.message || err || "");
    return /invalid_session|JWT|refresh token|Auth session missing/i.test(msg);
  };

  const isBackendSaveError = err => {
    const msg = String(err?.message || err || "");
    return isBackendSessionError(err) || /supabase_(patch|insert|upsert)_failed:cleansing_history/i.test(msg);
  };

  function stringifyDetail(detail) {
    if (!detail) return "";
    if (typeof detail === "string") return detail;

    try {
      return JSON.stringify(detail);
    } catch {
      return String(detail);
    }
  }

  function parseWeek(week) {
    const raw = String(week || "").trim().toUpperCase();
    const yearMatch = raw.match(/^\s*(20\d{2})/);
    const weekMatch = raw.match(/(\d{1,2})\s*W\b/);
    const year = yearMatch ? Number(yearMatch[1]) : 0;
    const weekNo = weekMatch ? Number(weekMatch[1]) : 0;

    return { year, weekNo };
  }

  function compareWeekDesc(a, b) {
    const aw = parseWeek(a?.week ?? a);
    const bw = parseWeek(b?.week ?? b);
    const diff = (bw.year - aw.year) || (bw.weekNo - aw.weekNo);

    if (diff) return diff;

    return String(b?.week ?? b ?? "").localeCompare(String(a?.week ?? a ?? ""), "ko", {
      numeric: true,
      sensitivity: "base"
    });
  }

  function compareWeekAsc(a, b) {
    const aw = parseWeek(a?.week ?? a);
    const bw = parseWeek(b?.week ?? b);
    const diff = (aw.year - bw.year) || (aw.weekNo - bw.weekNo);

    if (diff) return diff;

    return String(a?.week ?? a ?? "").localeCompare(String(b?.week ?? b ?? ""), "ko", {
      numeric: true,
      sensitivity: "base"
    });
  }

  function waveSortValue(wave) {
    const raw = String(wave || "").trim().toUpperCase();

    if (raw === "2W" || raw === "W2" || raw === "WAVE2" || raw === "주간") return 0;
    if (raw === "1W" || raw === "W1" || raw === "WAVE1" || raw === "야간") return 1;

    return 2;
  }

  function compareRows(a, b) {
    return compareWeekAsc(a, b) ||
      String(a.camp || "").localeCompare(String(b.camp || ""), "ko", { numeric:true, sensitivity:"base" }) ||
      (waveSortValue(a.wave) - waveSortValue(b.wave)) ||
      String(a.route || "").localeCompare(String(b.route || ""), "ko", { numeric:true, sensitivity:"base" });
  }

  function noSpace(v) {
    return String(v ?? "").replace(/\s+/g, "");
  }

  function weekKey(v) {
    const parts = parseWeek(v);
    return parts.year && parts.weekNo ? `${parts.year}-${parts.weekNo}W` : noSpace(v);
  }

  function previousWeekKey(year, weekNo, back) {
    if (!year || !weekNo) return "";

    if (weekNo > back) {
      return `${year}-${weekNo - back}W`;
    }

    return `${year - 1}-${52 - (back - weekNo)}W`;
  }

  function routeKey(value) {
    const raw = noSpace(value);

    if (!raw) return "";

    return Array.from(new Set(raw.split(",").map(v => v.trim()).filter(Boolean)))
      .sort((a, b) => a.localeCompare(b, "ko", { numeric:true, sensitivity:"base" }))
      .join(",");
  }

  function statusKeys(row, weekOverride = "") {
    const week = weekOverride || weekKey(row.week);
    const camp = noSpace(row.camp);
    const wave = noSpace(row.wave);
    const route = routeKey(row.route);
    const reason = noSpace(row.reason);

    return {
      full: `${week}||${camp}||${wave}||${route}||${reason}`,
      route: `${week}||${camp}||${wave}||${route}`
    };
  }

  function buildStatusIndex(sourceRows) {
    const full = new Map();
    const route = new Map();

    for (const row of sourceRows || []) {
      const baseOk = weekKey(row.week) && noSpace(row.camp) && noSpace(row.wave) && routeKey(row.route);

      if (!baseOk) continue;

      const keys = statusKeys(row);

      if (noSpace(row.reason)) {
        full.set(keys.full, (full.get(keys.full) || 0) + 1);
      }

      route.set(keys.route, (route.get(keys.route) || 0) + 1);
    }

    return { full, route };
  }

  function cleansingStatus(row, index) {
    const parts = parseWeek(row.week);
    const prevOne = previousWeekKey(parts.year, parts.weekNo, 1);
    const prevTwo = previousWeekKey(parts.year, parts.weekNo, 2);

    if (!prevOne || !prevTwo) return "pass";

    const prevOneKeys = statusKeys(row, prevOne);
    const prevTwoKeys = statusKeys(row, prevTwo);
    const cleanCnt = index.full.get(prevTwoKeys.full) || 0;

    if (cleanCnt > 0) return "클렌징";

    const warnCnt =
      (index.full.get(prevOneKeys.full) || 0) +
      (index.full.get(prevTwoKeys.full) || 0) +
      (index.route.get(prevOneKeys.route) || 0) +
      (index.route.get(prevTwoKeys.route) || 0);

    return warnCnt > 0 ? "경고" : "pass";
  }

  function decorateRows(targetRows, sourceRows) {
    const index = buildStatusIndex(sourceRows);

    return (targetRows || []).map(row => ({
      ...row,
      cleansing_status: cleansingStatus(row, index)
    }));
  }

  function reasonClass(value) {
    return noSpace(value) === "반품" ? "red" : "";
  }

  function rowClass(row) {
    if (row?.cleansing_status === "클렌징") return "rowClean";
    if (row?.cleansing_status === "경고") return "rowWarn";
    return "";
  }

  function rowId(row) {
    return String(row?.id ?? "");
  }

  function isEditing(row) {
    return editingId && rowId(row) === editingId;
  }

  function inputCell(row, field, className = "") {
    return `<input class="cellInput ${className}" data-field="${esc(field)}" value="${esc(row?.[field] ?? "")}">`;
  }

  function waveCell(row) {
    const value = String(row?.wave || "");

    return `
      <select class="cellInput" data-field="wave">
        <option value="2W" ${value === "2W" ? "selected" : ""}>주간</option>
        <option value="1W" ${value === "1W" ? "selected" : ""}>야간</option>
      </select>
    `;
  }

  function displayWave(row) {
    return row.wave === "2W" ? "주간" : row.wave === "1W" ? "야간" : esc(row.wave || "");
  }

  function actionButton(row) {
    const id = rowId(row);
    const attr = isEditing(row) ? "data-save" : "data-edit";
    const text = isEditing(row) ? "저장" : "수정";

    return `<td><button class="btn" style="height:28px;padding:0 9px" ${attr}="${esc(id)}">${text}</button></td>`;
  }

  function numericPatchValue(value) {
    const text = String(value || "").replace(/[,%₩,\s]/g, "");

    if (!text) return null;

    const n = Number(text);
    return Number.isFinite(n) ? n : null;
  }

  function readPatchFromRow(tr) {
    const patch = {};

    tr.querySelectorAll("[data-field]").forEach(input => {
      const field = input.dataset.field;
      const value = input.value.trim();

      if (["demand", "complete", "execution_rate", "price"].includes(field)) {
        patch[field] = numericPatchValue(value);
      } else {
        patch[field] = value || null;
      }
    });

    return patch;
  }

  function showErrorBox(title, message) {
    document.documentElement.style.visibility = "visible";
    $("bar").classList.add("hide");
    $("board").classList.add("hide");
    $("main").innerHTML = `
      <div class="denied">
        <h2>${esc(title)}</h2>
        <p>${esc(message)}</p>
      </div>
    `;
  }

  function showDenied() {
    showErrorBox(
      "클렌징 히스토리 권한 없음",
      "클히 권한이 있는 사용자만 조회할 수 있습니다."
    );
  }

  function initSupabase() {
    const { SUPABASE_URL, SUPABASE_ANON_KEY } = cfg;

    if (!SUPABASE_URL || !SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try {
        return window.sessionStorage;
      } catch {
        return undefined;
      }
    })();

    supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  async function getSession() {
    if (!supabaseClient) initSupabase();

    const { data, error } = await supabaseClient.auth.getSession();

    if (error) throw error;

    const session = data?.session || null;

    if (!session) {
      throw new Error("로그인이 필요합니다. 먼저 로그인하세요.");
    }

    return session;
  }

  async function getToken(forceRefresh = false) {
    if (!supabaseClient) initSupabase();

    if (forceRefresh) {
      const { data, error } = await supabaseClient.auth.refreshSession();

      if (error) throw error;

      const refreshedToken = data?.session?.access_token;

      if (refreshedToken) return refreshedToken;
    }

    const { data, error } = await supabaseClient.auth.getSession();

    if (error) throw error;

    const token = data?.session?.access_token;

    if (!token) {
      throw new Error("로그인이 필요합니다. 먼저 로그인하세요.");
    }

    return token;
  }

  async function directMe() {
    const session = await getSession();
    const user = session.user || {};
    const uid = String(user.id || "").trim();
    const email = String(user.email || "").trim();

    if (!uid) {
      throw new Error("유효하지 않은 로그인 세션입니다.");
    }

    const out = {
      user: { id: uid, email },
      email,
      is_maroowell: false,
      is_admin: false,
      is_super_admin: false,
      is_dragon_car_admin: false,
      max_role_level: 0,
      can_select: false
    };

    try {
      const { data, error } = await supabaseClient.rpc("mw_my_access").maybeSingle();

      if (!error && data) {
        out.is_maroowell = data.is_maroowell === true;
        out.is_admin = data.is_admin === true;
        out.is_dragon_car_admin = data.is_dragon_car_admin === true;
        out.max_role_level = Number(data.max_role_level || data.role_level || 0);
        out.is_super_admin = out.max_role_level >= 90 || data.is_super_admin === true;
      }
    } catch {}

    if (out.is_super_admin) {
      out.can_select = true;
      return out;
    }

    const checks = [
      () => supabaseClient.from(TABLE_CLHI_ACCESS).select("can_select").eq("user_id", uid).eq("can_select", true).maybeSingle(),
      () => supabaseClient.from(TABLE_CLHI_ACCESS).select("can_select").eq("email", email).eq("can_select", true).maybeSingle()
    ];

    for (const run of checks) {
      try {
        const { data, error } = await run();

        if (!error && data?.can_select === true) {
          out.can_select = true;
          break;
        }
      } catch {}
    }

    return out;
  }

  async function directMeta() {
    if (!supabaseClient) initSupabase();

    const data = [];
    const pageSize = 1000;

    for (let from = 0; from < 10000; from += pageSize) {
      const { data: page, error } = await supabaseClient
        .from(TABLE_HISTORY)
        .select("week")
        .not("week", "is", null)
        .range(from, from + pageSize - 1);

      if (error) throw error;

      const rows = Array.isArray(page) ? page : [];
      data.push(...rows);

      if (rows.length < pageSize) break;
    }

    const latest = data
      .filter(row => String(row?.week || "").trim())
      .sort(compareWeekDesc)[0];

    return {
      ok: true,
      latest_week: latest?.week || ""
    };
  }

  function applyEq(query, field, value) {
    const v = String(value || "").trim();
    return v ? query.eq(field, v) : query;
  }

  function applyIlike(query, field, value) {
    const v = String(value || "").trim();
    return v ? query.ilike(field, `%${v.replaceAll("%", "\\%").replaceAll("_", "\\_")}%`) : query;
  }

  function safeOrSearch(value) {
    return String(value || "")
      .trim()
      .replace(/[,%]/g, " ")
      .replace(/\s+/g, " ");
  }

  function directRowsQuery({ count = false } = {}) {
    let query = supabaseClient
      .from(TABLE_HISTORY)
      .select("*", count ? { count:"exact" } : {});

    query = applyEq(query, "week", val("week"));
    query = applyEq(query, "camp", val("camp"));
    query = applyEq(query, "wave", val("wave"));
    query = applyIlike(query, "route", val("route"));
    query = applyIlike(query, "vendor_name", val("vendor"));
    query = applyIlike(query, "business_number", val("biz"));
    query = applyEq(query, "reason", val("reason"));

    const q = safeOrSearch(val("q"));

    if (q) {
      const like = `%${q}%`;
      query = query.or([
        `week.ilike.${like}`,
        `camp.ilike.${like}`,
        `wave.ilike.${like}`,
        `route.ilike.${like}`,
        `zip.ilike.${like}`,
        `execution_rate_grade.ilike.${like}`,
        `reason.ilike.${like}`,
        `vendor_name.ilike.${like}`,
        `business_number.ilike.${like}`
      ].join(","));
    }

    return query.order("id", { ascending:true });
  }

  async function directStatusContextRows() {
    const pageSize = 1000;
    const out = [];

    for (let from = 0; from < 10000; from += pageSize) {
      const { data, error } = await supabaseClient
        .from(TABLE_HISTORY)
        .select("week,camp,wave,route,reason")
        .range(from, from + pageSize - 1);

      if (error) throw error;

      const pageRows = Array.isArray(data) ? data : [];
      out.push(...pageRows);

      if (pageRows.length < pageSize) break;
    }

    return out;
  }

  async function directRows() {
    if (!supabaseClient) initSupabase();

    const limit = Math.max(1, Math.min(1000, Number(val("limit")) || 300));
    const pageSize = 1000;
    const fetched = [];
    let totalCount = null;

    for (let from = 0; from < 10000; from += pageSize) {
      const { data, error, count } = await directRowsQuery({ count: from === 0 })
        .range(from, from + pageSize - 1);

      if (error) throw error;

      if (from === 0 && typeof count === "number") {
        totalCount = count;
      }

      const pageRows = Array.isArray(data) ? data : [];
      fetched.push(...pageRows);

      if (pageRows.length < pageSize) break;
    }

    const contextRows = await directStatusContextRows();
    const sorted = decorateRows(fetched, contextRows).sort(compareRows);
    const out = sorted.slice(0, limit);

    return {
      ok: true,
      rows: out,
      count: totalCount ?? sorted.length,
      effective_week: val("week") || out[0]?.week || ""
    };
  }

  async function directSave(path, options) {
    if (!supabaseClient) initSupabase();

    const body = JSON.parse(options?.body || "{}");
    const id = path.match(/\/api\/cleansing-history\/([^/]+)$/)?.[1];
    const query = supabaseClient.from(TABLE_HISTORY);

    if (id) {
      const { data, error } = await query.update(body).eq("id", id).select("*").maybeSingle();

      if (error) throw error;

      return {
        ok: true,
        row: data
      };
    }

    const { data, error } = await query.insert(body).select("*").maybeSingle();

    if (error) throw error;

    return {
      ok: true,
      row: data
    };
  }

  async function api(path, options = {}, retrying = false) {
    const token = await getToken(retrying);

    const headers = new Headers(options.headers || {});
    headers.set("Authorization", "Bearer " + token);

    if (options.body && !headers.has("Content-Type")) {
      headers.set("Content-Type", "application/json");
    }

    const res = await fetch(API + path, {
      ...options,
      headers
    });

    const text = await res.text();

    let data = null;
    try {
      data = text ? JSON.parse(text) : null;
    } catch {
      data = {
        ok: false,
        error: text
      };
    }

    if (!res.ok || data?.ok === false) {
      if (!retrying && res.status === 401 && data?.error === "invalid_session") {
        return api(path, options, true);
      }

      const detail = stringifyDetail(data?.detail);
      throw new Error([
        data?.error || data?.message || text || "요청 실패",
        detail
      ].filter(Boolean).join("\n"));
    }

    return data;
  }

  async function initMe() {
    try {
      me = await directMe();
      if (!me.can_select) {
        try {
          me = await api("/api/cleansing-history/me");
        } catch {}
      }
    } catch {
      me = await api("/api/cleansing-history/me");
    }

    $("user").textContent = me.email || me.user?.email || "권한 확인됨";
    $("add").classList.toggle("hide", !isSuper());

    document.documentElement.style.visibility = "visible";

    if (!me.can_select) {
      showDenied();
      return false;
    }

    return true;
  }

  async function initWeek() {
    let meta = null;

    try {
      meta = await api("/api/cleansing-history/meta");
    } catch (e) {
      if (!isBackendSessionError(e)) throw e;
      meta = await directMeta();
    }

    if (meta.latest_week && !val("week")) {
      $("week").value = meta.latest_week;
    }
  }

  async function load() {
    if (!me.can_select) return;

    const p = new URLSearchParams();

    [
      "week",
      "camp",
      "wave",
      "route",
      "vendor",
      "biz",
      "reason",
      "limit",
      "q"
    ].forEach(id => {
      const v = val(id);
      if (v) p.set(id, v);
    });

    let data = null;

    try {
      data = await api("/api/cleansing-history?" + p.toString());
    } catch (e) {
      if (!isBackendSessionError(e)) throw e;
      data = await directRows();
    }

    rows = data.rows || [];

    render();

    $("summary").textContent =
      `표시 ${rows.length.toLocaleString("ko-KR")}건 / 조건 ${Number(data.count || 0).toLocaleString("ko-KR")}건` +
      `${data.effective_week ? " / " + data.effective_week : ""}`;
  }

  function render() {
    if (!rows.length) {
      $("table").innerHTML = '<div class="empty">조회 결과가 없습니다.</div>';
      return;
    }

    const edit = isSuper();

    $("table").innerHTML = `
      <table>
        <thead>
          <tr>
            ${edit ? '<th style="width:70px">관리</th>' : ""}
            <th style="width:100px">Week</th>
            <th style="width:90px">Camp</th>
            <th style="width:70px">Wave</th>
            <th style="width:130px">Route</th>
            <th style="width:230px">Zip</th>
            <th style="width:90px">Demand</th>
            <th style="width:90px">Complete</th>
            <th style="width:90px">수행률</th>
            <th style="width:80px">등급</th>
            <th style="width:80px">Reason</th>
            <th style="width:90px">Price</th>
            <th style="width:230px">Vendor</th>
            <th style="width:130px">사업자번호</th>
          </tr>
        </thead>
        <tbody>
          ${rows.map(r => `
            <tr class="${rowClass(r)}" data-row-id="${esc(rowId(r))}">
              ${edit ? actionButton(r) : ""}
              <td>${isEditing(r) ? inputCell(r, "week") : esc(r.week)}</td>
              <td>${isEditing(r) ? inputCell(r, "camp") : esc(r.camp)}</td>
              <td>${isEditing(r) ? waveCell(r) : displayWave(r)}</td>
              <td>${isEditing(r) ? inputCell(r, "route") : esc(r.route)}</td>
              <td class="left">${isEditing(r) ? inputCell(r, "zip") : esc(r.zip || "")}</td>
              <td class="num">${isEditing(r) ? inputCell(r, "demand", "num") : fmtNum(r.demand)}</td>
              <td class="num">${isEditing(r) ? inputCell(r, "complete", "num") : fmtNum(r.complete)}</td>
              <td class="num green">${isEditing(r) ? inputCell(r, "execution_rate", "num") : fmtPct(r.execution_rate)}</td>
              <td>${isEditing(r) ? inputCell(r, "execution_rate_grade") : esc(r.execution_rate_grade || "")}</td>
              <td class="${reasonClass(r.reason)}">${isEditing(r) ? inputCell(r, "reason") : esc(r.reason || "")}</td>
              <td class="num yellow">${isEditing(r) ? inputCell(r, "price", "num") : fmtWon(r.price)}</td>
              <td class="left">${isEditing(r) ? inputCell(r, "vendor_name") : esc(r.vendor_name || "")}</td>
              <td>${isEditing(r) ? inputCell(r, "business_number") : esc(r.business_number || "")}</td>
            </tr>
          `).join("")}
        </tbody>
      </table>
    `;
  }

  async function save(row) {
    if (!isSuper()) return;

    const patch = {
      week: prompt("week", row?.week || val("week") || "") || null,
      camp: prompt("camp", row?.camp || "") || null,
      wave: prompt("wave 1W/2W", row?.wave || val("wave") || "") || null,
      route: prompt("route", row?.route || "") || null,
      zip: prompt("zip", row?.zip || "") || null,
      demand: Number(prompt("demand", row?.demand || "") || 0) || null,
      complete: Number(prompt("complete", row?.complete || "") || 0) || null,
      execution_rate: Number(prompt("execution_rate", row?.execution_rate || "") || 0) || null,
      execution_rate_grade: prompt("grade", row?.execution_rate_grade || "") || null,
      reason: prompt("reason", row?.reason || "") || null,
      price: Number(prompt("price", row?.price || "") || 0) || null,
      vendor_name: prompt("vendor_name", row?.vendor_name || "") || null,
      business_number: prompt("business_number", row?.business_number || "") || null
    };

    if (!patch.week || !patch.camp || !patch.route) {
      alert("week/camp/route 필수");
      return;
    }

    await persistPatch(row, patch);
    editingId = "";
    await load();
  }

  async function persistPatch(row, patch) {
    const path = row
      ? "/api/cleansing-history/" + encodeURIComponent(row.id)
      : "/api/cleansing-history";

    const options = {
      method: row ? "PATCH" : "POST",
      body: JSON.stringify(patch)
    };

    try {
      await api(path, options);
    } catch (e) {
      if (!isBackendSaveError(e)) throw e;
      await directSave(path, options);
    }
  }

  async function saveInline(row, tr) {
    const patch = readPatchFromRow(tr);

    if (!patch.week || !patch.camp || !patch.route) {
      alert("week/camp/route 필수");
      return;
    }

    await persistPatch(row, patch);
    editingId = "";

    await load();
  }

  function drawText(ctx, text, x, y, maxWidth) {
    const raw = String(text ?? "");

    if (!maxWidth || ctx.measureText(raw).width <= maxWidth) {
      ctx.fillText(raw, x, y);
      return;
    }

    let out = raw;

    while (out.length > 1 && ctx.measureText(out + "...").width > maxWidth) {
      out = out.slice(0, -1);
    }

    ctx.fillText(out + "...", x, y);
  }

  function canvasBlob(canvas) {
    return new Promise(resolve => canvas.toBlob(resolve, "image/png"));
  }

  async function copyImage() {
    if (!rows.length) {
      alert("복사할 조회 결과가 없습니다.");
      return;
    }

    const columns = [
      ["Week", 120, r => r.week],
      ["Camp", 100, r => r.camp],
      ["Wave", 76, r => r.wave === "2W" ? "주간" : r.wave === "1W" ? "야간" : r.wave],
      ["Route", 150, r => r.route],
      ["Zip", 260, r => r.zip],
      ["Demand", 105, r => fmtNum(r.demand)],
      ["Complete", 105, r => fmtNum(r.complete)],
      ["수행률", 92, r => fmtPct(r.execution_rate)],
      ["등급", 78, r => r.execution_rate_grade],
      ["Reason", 88, r => r.reason],
      ["Price", 96, r => fmtWon(r.price)],
      ["Vendor", 220, r => r.vendor_name],
      ["사업자번호", 140, r => r.business_number]
    ];
    const rowHeight = 32;
    const headerHeight = 58;
    const width = columns.reduce((sum, col) => sum + col[1], 0) + 24;
    const height = headerHeight + rowHeight * (rows.length + 1) + 18;
    const canvas = document.createElement("canvas");
    const scale = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
    canvas.width = width * scale;
    canvas.height = height * scale;
    canvas.style.width = width + "px";
    canvas.style.height = height + "px";

    const ctx = canvas.getContext("2d");
    ctx.scale(scale, scale);
    ctx.fillStyle = "#081120";
    ctx.fillRect(0, 0, width, height);
    ctx.fillStyle = "#eaf2ff";
    ctx.font = "800 24px system-ui, -apple-system, Segoe UI, sans-serif";
    ctx.fillText("클렌징 히스토리", 12, 34);

    let x = 12;
    let y = headerHeight;
    ctx.fillStyle = "#27364d";
    ctx.fillRect(12, y - rowHeight, width - 24, rowHeight);
    ctx.strokeStyle = "rgba(255,255,255,.16)";
    ctx.lineWidth = 1;
    ctx.font = "800 12px system-ui, -apple-system, Segoe UI, sans-serif";

    for (const [label, colWidth] of columns) {
      ctx.strokeRect(x, y - rowHeight, colWidth, rowHeight);
      ctx.fillStyle = "#eaf2ff";
      drawText(ctx, label, x + 8, y - 11, colWidth - 16);
      x += colWidth;
    }

    rows.forEach((row, idx) => {
      x = 12;
      const top = y + idx * rowHeight;
      ctx.fillStyle = idx % 2 ? "#0b1424" : "#0d1728";
      ctx.fillRect(12, top, width - 24, rowHeight);
      ctx.font = "700 12px system-ui, -apple-system, Segoe UI, sans-serif";

      for (const [label, colWidth, getter] of columns) {
        ctx.strokeStyle = "rgba(255,255,255,.10)";
        ctx.strokeRect(x, top, colWidth, rowHeight);
        ctx.fillStyle =
          row.cleansing_status === "클렌징" ? "#f87171" :
            row.cleansing_status === "경고" ? "#fde68a" :
              label === "Reason" && noSpace(row.reason) === "반품" ? "#fca5a5" :
                "#dbeafe";
        drawText(ctx, getter(row), x + 8, top + 21, colWidth - 16);
        x += colWidth;
      }
    });

    const blob = await canvasBlob(canvas);

    if (!blob) {
      throw new Error("이미지 생성 실패");
    }

    if (navigator.clipboard && window.ClipboardItem) {
      await navigator.clipboard.write([
        new ClipboardItem({ "image/png": blob })
      ]);
      alert("이미지를 클립보드에 복사했습니다.");
      return;
    }

    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "cleansing_history.png";
    a.click();
    URL.revokeObjectURL(a.href);
  }

  function bind() {
    $("search").onclick = () => load().catch(e => alert(e.message));
    $("refresh").onclick = $("search").onclick;

    $("reset").onclick = async () => {
      ["week", "camp", "route", "vendor", "biz", "q"].forEach(id => {
        $(id).value = "";
      });

      $("wave").value = "";
      $("reason").value = "";

      try {
        await initWeek();
        await load();
      } catch (e) {
        alert(e.message);
      }
    };

    $("copyImage").onclick = () => copyImage().catch(e => alert(e.message));

    $("add").onclick = () => {
      save(null).catch(e => alert(e.message));
    };

    $("table").onclick = e => {
      const saveBtn = e.target.closest("[data-save]");

      if (saveBtn) {
        const id = saveBtn.dataset.save;
        const row = rows.find(r => rowId(r) === id);
        const tr = saveBtn.closest("tr");

        if (row && tr) {
          saveInline(row, tr).catch(err => alert(err.message));
        }

        return;
      }

      const btn = e.target.closest("[data-edit]");

      if (!btn) return;

      const row = rows.find(r => rowId(r) === btn.dataset.edit);

      if (row) {
        editingId = rowId(row);
        render();
      }
    };

    ["week", "camp", "route", "vendor", "biz", "q"].forEach(id => {
      $(id).addEventListener("keydown", e => {
        if (e.key === "Enter") {
          load().catch(err => alert(err.message));
        }
      });
    });

    $("wave").onchange = $("reason").onchange = () => {
      load().catch(e => alert(e.message));
    };
  }

  async function init() {
    try {
      initSupabase();
      bind();

      if (await initMe()) {
        await initWeek();
        await load();
      }
    } catch (e) {
      document.documentElement.style.visibility = "visible";
      showErrorBox("세션/조회 오류", e.message);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once:true });
  } else {
    init();
  }
})();
</script>
