<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰 정보</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

  <style>
    html{visibility:hidden}

    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --panel:#ffffff;
      --line:#d8e0ee;
      --line2:#cbd5e1;
      --txt:#0f172a;
      --muted:#64748b;
      --sheetBg:#eef3f8;
      --headBg:#dbeafe;
      --filterBg:#eff6ff;
      --cellBg:#ffffff;
      --cellAlt:#f8fafc;
      --cellTxt:#0f172a;
      --resignBg:#ffe3e0;
      --resignAlt:#ffd9d6;
      --resignBorder:#f1b7b0;
      --vehicleWarn:#fff7cc;
      --vehicleWarnBorder:#e9d15e;
      --dirtyBg:#e0eeff;
      --dirtyBorder:#60a5fa;
      --topbarH:64px;
      --toolbarH:58px;
      --statusH:44px;
      --shadow:0 12px 30px rgba(15,23,42,.07);
      --font:"문경감홍사과체","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      height:100%;
      font-family:var(--font);
      background:
        radial-gradient(circle at 12% 0%,rgba(37,99,235,.07),transparent 32%),
        radial-gradient(circle at 86% 0%,rgba(14,165,233,.07),transparent 30%),
        linear-gradient(180deg,#ffffff 0%,#f6f8fc 100%);
      color:var(--txt);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
    }

    body{overflow:hidden}

    button,input,select{
      font-family:var(--font);
      font-weight:400;
    }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--topbarH) var(--toolbarH) auto 1fr var(--statusH);
      gap:0;
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      margin:8px 12px 0;
      padding:0 14px;
      border:1px solid var(--line);
      border-radius:20px;
      background:rgba(255,255,255,.96);
      min-width:0;
      overflow:auto hidden;
      box-shadow:var(--shadow);
      backdrop-filter:blur(12px);
    }

    .topbar a{
      display:flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      color:inherit;
      flex:0 0 auto;
      width:32px;
      height:32px;
      background:transparent;
      border:0;
      box-shadow:none;
      padding:0;
    }

    .topbar img{
      width:30px;
      height:30px;
      display:block;
      object-fit:contain;
      filter:drop-shadow(0 2px 4px rgba(15,23,42,.10));
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
      flex:0 0 auto;
    }

    .titleBox b{
      font-size:22px;
      line-height:1.1;
      letter-spacing:-.04em;
      white-space:nowrap;
      font-weight:540;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:12px;
      font-weight:400;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .spacer{flex:1 0 24px}

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:#ffffff;
      color:var(--txt);
      cursor:pointer;
      font-weight:500;
      font-size:13px;
      white-space:nowrap;
      flex:0 0 auto;
      box-shadow:0 1px 0 rgba(255,255,255,.8),0 5px 14px rgba(15,23,42,.05);
    }

    .btn:hover{
      background:#f8fbff;
      border-color:#93c5fd;
    }

    .btn.ok{
      background:linear-gradient(180deg,#22c55e,#16a34a);
      border-color:#16a34a;
      color:#ffffff;
      box-shadow:0 8px 18px rgba(22,163,74,.16);
    }

    .btn.warn{
      background:linear-gradient(180deg,#f59e0b,#d97706);
      border-color:#d97706;
      color:#ffffff;
      box-shadow:0 8px 18px rgba(217,119,6,.14);
    }

    .btn.danger{
      background:#fff5f5;
      border-color:#fecaca;
      color:#dc2626;
      box-shadow:none;
    }

    .btn:disabled{opacity:.6;cursor:not-allowed}

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      margin:8px 12px 0;
      padding:8px 12px;
      background:rgba(255,255,255,.96);
      border:1px solid var(--line);
      border-radius:18px;
      overflow:auto hidden;
      min-width:0;
      box-shadow:0 8px 22px rgba(15,23,42,.05);
    }

    .group{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .group:last-child{
      border-right:none;
      padding-right:0;
    }

    .toggle{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:#f8fafc;
      font-size:12px;
      font-weight:500;
      color:#334155;
      white-space:nowrap;
    }

    .toggle input{
      margin:0;
      width:16px;
      height:16px;
      accent-color:#2563eb;
      cursor:pointer;
    }

    .helper{
      color:#475569;
      font-size:12px;
      white-space:nowrap;
      font-weight:400;
    }

    .hiddenColumnBar{
      min-height:0;
      display:flex;
      align-items:center;
      gap:8px;
      margin:8px 12px 0;
      padding:8px 12px;
      background:rgba(255,255,255,.96);
      border:1px solid var(--line);
      border-radius:16px;
      overflow:auto hidden;
      box-shadow:0 7px 18px rgba(15,23,42,.04);
    }

    .hiddenColumnBar.empty{
      display:none;
    }

    .hiddenLabel{
      color:#1d4ed8;
      font-size:12px;
      font-weight:600;
      flex:0 0 auto;
    }

    .hiddenChip{
      height:30px;
      padding:0 11px;
      border-radius:999px;
      border:1px solid #bfdbfe;
      background:#eff6ff;
      color:#1d4ed8;
      font-size:12px;
      font-weight:500;
      cursor:pointer;
      white-space:nowrap;
      flex:0 0 auto;
    }

    .hiddenChip:hover{
      background:#dbeafe;
    }

    .hiddenChip.all{
      border-color:#bbf7d0;
      background:#f0fdf4;
      color:#15803d;
    }

    .sheetWrap{
      overflow:auto;
      margin:8px 12px 0;
      border:1px solid var(--line);
      border-radius:16px;
      background:var(--sheetBg);
      box-shadow:var(--shadow);
    }

    .sheetInner{
      min-width:max-content;
    }

    table{
      width:max-content;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
      font-size:13px;
    }

    col.hiddenCol{
      display:none;
    }

    th,td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child,td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:4;
      background:var(--headBg);
      padding:8px 7px;
      text-align:center;
      font-size:13px;
      font-weight:540;
      white-space:nowrap;
    }

    thead tr.filterRow th{
      top:40px;
      z-index:3;
      background:var(--filterBg);
      padding:6px;
    }

    .thInner{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:5px;
      min-width:0;
      padding:0 2px;
    }

    .thLabel{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .hideColBtn{
      height:22px;
      min-width:36px;
      padding:0 8px;
      border-radius:999px;
      border:1px solid #f0a6bd;
      background:#fde2ec;
      color:#a21caf;
      font-size:11px;
      line-height:20px;
      font-weight:500;
      cursor:pointer;
      flex:0 0 auto;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      white-space:nowrap;
    }

    .hideColBtn:hover{
      background:#fbcfe8;
      color:#86198f;
      border-color:#ec4899;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    tbody tr.resigned-row td{
      background:var(--resignBg) !important;
      border-bottom-color:var(--resignBorder);
    }

    tbody tr.resigned-row:nth-child(even) td{
      background:var(--resignAlt) !important;
    }

    td.vehicle-warn{
      background:var(--vehicleWarn) !important;
      box-shadow:inset 0 0 0 1px var(--vehicleWarnBorder);
    }

    td.dirty-cell{
      box-shadow:inset 0 0 0 2px var(--dirtyBorder);
      background:var(--dirtyBg) !important;
    }

    .cellView{
      min-height:44px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:0 10px;
      font-size:13px;
      line-height:1.35;
      word-break:break-word;
      overflow-wrap:anywhere;
      font-weight:400;
    }

    .cellView.center{justify-content:center;text-align:center}
    .cellView.right{justify-content:flex-end;text-align:right;font-variant-numeric:tabular-nums}
    .cellView.code{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px}

    .cellInput,
    .cellSelect{
      width:100%;
      min-height:44px;
      border:none;
      outline:none;
      background:transparent;
      color:var(--cellTxt);
      padding:10px 10px;
      font:inherit;
      font-weight:400;
      border-radius:0;
    }

    .cellInput{
      font-size:13px;
      line-height:1.35;
    }

    .cellInput.code{
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:12px;
    }

    .cellInput.center,
    .cellSelect.center{
      text-align:center;
    }

    .cellInput.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .cellInput::placeholder{
      color:#94a3b8;
    }

    .cellSelect{
      cursor:pointer;
      text-align:center;
    }

    .filterInput{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      outline:none;
      font-weight:400;
    }

    .filterInput:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
    }

    .rowActionBtn{
      width:34px;
      height:34px;
      border-radius:10px;
      border:1px solid #fecaca;
      background:#fff5f5;
      color:#dc2626;
      cursor:pointer;
      font-weight:600;
    }

    .rowActionBtn:hover{
      background:#fee2e2;
    }

    .emptyDataRow td{
      height:88px;
      text-align:center;
      color:#64748b;
      font-weight:500;
      background:#eef3f8;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:8px;
      padding:6px 12px;
      border-top:1px solid var(--line);
      background:rgba(255,255,255,.96);
      min-width:0;
      overflow:auto hidden;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      height:28px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid #d8e0ee;
      background:#f8fafc;
      color:#334155;
      font-size:12px;
      font-weight:500;
      white-space:nowrap;
      flex:0 0 auto;
    }

    .pill.ok{
      border-color:#bbf7d0;
      background:#f0fdf4;
      color:#15803d;
    }

    .pill.warn{
      border-color:#fde68a;
      background:#fffbeb;
      color:#a16207;
    }

    .pill.err{
      border-color:#fecaca;
      background:#fff5f5;
      color:#dc2626;
    }

    .statusText{
      color:#475569;
      font-size:12px;
      min-width:max-content;
      font-weight:400;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      z-index:1000;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:rgba(248,250,252,.96);
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(520px,100%);
      border:1px solid var(--line);
      border-radius:22px;
      background:#ffffff;
      box-shadow:0 24px 70px rgba(15,23,42,.14);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 10px;
      color:#0f172a;
      font-size:24px;
      font-weight:560;
      letter-spacing:-.04em;
    }

    .accessCard p{
      margin:0;
      color:#475569;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
      font-weight:400;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid #d8e0ee;
      background:#f8fafc;
      color:#0f172a;
      font-size:13px;
      font-weight:400;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width:980px){
      :root{--topbarH:60px;--toolbarH:56px}
      .topbar{margin:0;border-radius:0;border-left:0;border-right:0;border-top:0}
      .toolbar{margin:0;border-radius:0;border-left:0;border-right:0}
      .sheetWrap{margin:8px 0 0;border-left:0;border-right:0;border-radius:0}
      .hiddenColumnBar{margin:8px 0 0;border-left:0;border-right:0;border-radius:0}
      .btn{padding:0 10px;font-size:12px}
      .titleBox b{font-size:18px}
      .titleBox small{font-size:11px}
      .topbar img{width:28px;height:28px}
      table{font-size:12px}
      .cellView,.cellInput,.cellSelect{font-size:12px}
    }
  
    /* ===== MAROOWELL INFO FONT SIZE/WEIGHT FINAL FIX - 2026-06-07 ===== */
    /*
      요청사항:
      - 페이지 전체 폰트를 문경감홍사과체로 강제 통일
      - 테이블/필터/셀 글씨 크기 10px
      - 이름 컬럼만 11px
      - 전체 굵기 대폭 완화
      - 기존 기능 로직 변경 없음
    */

    html,
    body,
    button,
    input,
    select,
    textarea,
    table,
    thead,
    tbody,
    tr,
    th,
    td,
    div,
    span,
    small,
    b,
    label,
    .cellView,
    .cellInput,
    .cellInput.code,
    .cellView.code,
    .cellSelect,
    .filterInput,
    .btn,
    .pill,
    .helper,
    .hiddenChip,
    .hideColBtn,
    .rowActionBtn,
    .statusText,
    .toggle,
    .accessCard,
    .accessCard *{
      font-family:var(--font)!important;
      text-shadow:none!important;
      -webkit-text-stroke:0 transparent!important;
    }

    body,
    button,
    input,
    select,
    textarea,
    table,
    th,
    td,
    div,
    span,
    small,
    b,
    label,
    .btn,
    .pill,
    .toggle,
    .helper,
    .statusText{
      font-weight:300!important;
    }

    .titleBox b{
      font-size:18px!important;
      font-weight:420!important;
      letter-spacing:-.035em!important;
    }

    .titleBox small{
      font-size:10px!important;
      font-weight:300!important;
    }

    .topbar{
      --topbar-local-font:var(--font);
    }

    .btn{
      height:34px!important;
      padding:0 12px!important;
      font-size:11px!important;
      font-weight:400!important;
    }

    .toolbar{
      padding:7px 10px!important;
      gap:10px!important;
    }

    .toggle,
    .helper,
    .hiddenLabel,
    .hiddenChip,
    .statusText,
    .pill{
      font-size:10px!important;
      font-weight:300!important;
    }

    .toggle{
      padding:7px 10px!important;
    }

    table,
    thead th,
    tbody td,
    .cellView,
    .cellInput,
    .cellInput.code,
    .cellView.code,
    .cellSelect,
    .filterInput{
      font-size:10px!important;
      font-weight:300!important;
      letter-spacing:-.01em!important;
    }

    thead th{
      padding:6px 5px!important;
      font-weight:360!important;
    }

    thead tr.filterRow th{
      top:32px!important;
      padding:5px!important;
    }

    .cellView{
      min-height:34px!important;
      padding:0 7px!important;
      line-height:1.25!important;
    }

    .cellInput,
    .cellSelect{
      min-height:34px!important;
      padding:7px 7px!important;
      line-height:1.25!important;
    }

    .filterInput{
      height:28px!important;
      padding:0 8px!important;
      border-radius:9px!important;
    }

    td[data-col="person_name"] .cellView,
    td[data-col="person_name"] .cellInput{
      font-size:11px!important;
      font-weight:360!important;
    }

    td[data-col="position_title"] .cellView,
    td[data-col="position_title"] .cellInput,
    td[data-col="position_title"] .cellSelect,
    td[data-col="camp_code"] .cellView,
    td[data-col="camp_code"] .cellInput,
    td[data-col="camp_code"] .cellSelect,
    td[data-col="wave"] .cellView,
    td[data-col="wave"] .cellInput,
    td[data-col="wave"] .cellSelect,
    td[data-col="vehicle_plate_number"] .cellView,
    td[data-col="vehicle_plate_number"] .cellInput{
      font-weight:320!important;
    }

    .hideColBtn{
      height:19px!important;
      min-width:30px!important;
      padding:0 6px!important;
      font-size:9px!important;
      font-weight:300!important;
      line-height:17px!important;
    }

    .rowActionBtn{
      width:28px!important;
      height:28px!important;
      border-radius:9px!important;
      font-size:10px!important;
      font-weight:400!important;
    }

    .accessCard h2{
      font-size:20px!important;
      font-weight:420!important;
    }

    .accessCard p,
    .accessMeta{
      font-size:12px!important;
      font-weight:300!important;
    }

    @media (max-width:980px){
      .titleBox b{
        font-size:16px!important;
      }

      .titleBox small{
        font-size:9px!important;
      }

      .btn{
        font-size:10px!important;
      }

      table,
      thead th,
      tbody td,
      .cellView,
      .cellInput,
      .cellInput.code,
      .cellView.code,
      .cellSelect,
      .filterInput{
        font-size:10px!important;
      }

      td[data-col="person_name"] .cellView,
      td[data-col="person_name"] .cellInput{
        font-size:11px!important;
      }
    }
    /* ===== MAROOWELL INFO FONT SIZE/WEIGHT FINAL FIX END ===== */

  </style>
</head>

<body>
  <div class="app">
    <div class="topbar">
      <a id="mwBoardMenuToggle" href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>마루웰 정보</b>
        <small>직원 / 정산 베이스 정보 관리</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnAddRow" class="btn warn" type="button">행 추가</button>
      <button id="btnSaveAll" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportExcel" class="btn" type="button">엑셀 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="group">
        <label class="toggle" for="toggleIncludeResigned">
          <input id="toggleIncludeResigned" type="checkbox" />
          <span>퇴사 포함</span>
        </label>
      </div>

      <div class="group">
        <label class="toggle" for="toggleOnlyChanged">
          <input id="toggleOnlyChanged" type="checkbox" />
          <span>변경 행만 보기</span>
        </label>
      </div>

      <div class="group">
        <button id="btnClearFilters" class="btn" type="button">필터 초기화</button>
      </div>

      <div class="group">
        <span class="helper">열 제목의 <b>접기</b>를 누르면 숨겨지고, 아래 숨김 열 메뉴에서 다시 활성화합니다. 엑셀 다운로드는 현재 보이는 열만 내려갑니다.</span>
      </div>
    </div>

    <div id="hiddenColumnBar" class="hiddenColumnBar empty"></div>

    <div class="sheetWrap">
      <div class="sheetInner">
        <table id="infoTable">
          <colgroup id="tableColgroup"></colgroup>
          <thead id="tableHead"></thead>
          <tbody id="sheetBody"></tbody>
        </table>
      </div>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillDirty" class="pill warn">변경 0</span>
      <span id="statusText" class="statusText">기본값은 퇴사 숨김입니다.</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const cfg = window.MARUWELL_CONFIG || {};
      const INDEX_PATH = PATHS?.index || "/index.html";
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INFO_API_BASE = String(
        cfg.BACKENDS?.maroowellInfo ||
        cfg.BACKENDS?.maroowellinfo ||
        cfg.MAROOWELL_INFO_API ||
        "https://maroowellinfo.brain-0f6.workers.dev"
      ).replace(/\/+$/, "");

      const HIDDEN_COLUMNS_KEY = "mw_info_hidden_columns_v1";

      const DATA_COLUMNS = [
        "person_name",
        "contact_phone",
        "position_title",
        "camp_code",
        "wave",
        "coupang_id",
        "vehicle_plate_number",
        "resident_registration_number",
        "transport_qualification_number",
        "sub_account_info",
        "payroll_bank_name",
        "payroll_account_number",
        "business_name",
        "business_registration_number",
        "hire_date",
        "emergency_contact_phone",
        "emergency_contact_relationship",
        "fixed_commission_amount",
        "fixed_unit_price",
        "dragon_car_commission",
        "employment_accident_insurance"
      ];

      const COLUMN_CONFIG = [
        { key: "pk_id", label: "순번", type: "readonly", className: "right code center", width: 80 },
        { key: "person_name", label: "이름", width: 120 },
        { key: "contact_phone", label: "연락처", className: "code", width: 130 },
        { key: "position_title", label: "직책", className: "center", width: 110 },
        { key: "camp_code", label: "camp", className: "center", width: 100 },
        { key: "wave", label: "wave", type: "select", options: ["", "주간", "야간", "주/야"], className: "center", width: 90 },
        { key: "coupang_id", label: "coupang_id", className: "code", width: 120 },
        { key: "vehicle_plate_number", label: "차량 번호", className: "center", width: 130 },
        { key: "resident_registration_number", label: "주민번호", className: "code", width: 150 },
        { key: "transport_qualification_number", label: "운송자격증번호", className: "code", width: 150 },
        { key: "sub_account_info", label: "서브 계정", width: 170 },
        { key: "payroll_bank_name", label: "급여 은행", className: "center", width: 120 },
        { key: "payroll_account_number", label: "급여 계좌", className: "code", width: 170 },
        { key: "business_name", label: "사업자 상호", width: 150 },
        { key: "business_registration_number", label: "사업자 번호", className: "code", width: 150 },
        { key: "hire_date", label: "입사일", type: "date", className: "center code", width: 130 },
        { key: "emergency_contact_phone", label: "비상 연락처", className: "code", width: 150 },
        { key: "emergency_contact_relationship", label: "관계", className: "center", width: 110 },
        { key: "fixed_commission_amount", label: "고정 수수료", className: "right code", width: 120 },
        { key: "fixed_unit_price", label: "고정 단가", className: "right code", width: 120 },
        { key: "dragon_car_commission", label: "용차 수수료", className: "right code", width: 120 },
        { key: "employment_accident_insurance", label: "고용산재", type: "select", options: ["", "O", "X"], className: "center", width: 90 }
      ];

      const FILTER_PLACEHOLDERS = {
        person_name: "이름 / !이우람",
        contact_phone: "연락처",
        position_title: "직책 / !퇴사",
        camp_code: "camp",
        wave: "주간 / 야간 / !주간",
        coupang_id: "ID",
        vehicle_plate_number: "차량 번호 / !배",
        resident_registration_number: "주민번호",
        transport_qualification_number: "자격증번호",
        sub_account_info: "서브 계정",
        payroll_bank_name: "은행",
        payroll_account_number: "계좌",
        business_name: "사업자 상호",
        business_registration_number: "사업자 번호",
        hire_date: "2025 / !2024",
        emergency_contact_phone: "비상 연락처",
        emergency_contact_relationship: "관계",
        fixed_commission_amount: "고정 수수료",
        fixed_unit_price: "고정 단가",
        dragon_car_commission: "용차 수수료 / !8%",
        employment_accident_insurance: "O / X / !X"
      };

      const $ = (sel) => document.querySelector(sel);

      const dom = {
        table: $("#infoTable"),
        tableColgroup: $("#tableColgroup"),
        tableHead: $("#tableHead"),
        sheetBody: $("#sheetBody"),
        hiddenColumnBar: $("#hiddenColumnBar"),
        btnReload: $("#btnReload"),
        btnAddRow: $("#btnAddRow"),
        btnSaveAll: $("#btnSaveAll"),
        btnExportExcel: $("#btnExportExcel"),
        btnClearFilters: $("#btnClearFilters"),
        btnLogout: $("#btnLogout"),
        toggleIncludeResigned: $("#toggleIncludeResigned"),
        toggleOnlyChanged: $("#toggleOnlyChanged"),
        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillDirty: $("#pillDirty"),
        statusText: $("#statusText"),
        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout")
      };

      const state = {
        rows: [],
        filteredRows: [],
        loading: false,
        viewerEmail: "",
        viewerUserId: "",
        session: null,
        accessRow: null,
        deletedIds: new Set(),
        tempSeq: 0,
        filters: {},
        hiddenColumns: new Set()
      };

      function loadHiddenColumns() {
        try {
          const arr = JSON.parse(localStorage.getItem(HIDDEN_COLUMNS_KEY) || "[]");
          state.hiddenColumns = new Set(Array.isArray(arr) ? arr.filter(key => COLUMN_CONFIG.some(col => col.key === key)) : []);
        } catch {
          state.hiddenColumns = new Set();
        }
      }

      function saveHiddenColumns() {
        try {
          localStorage.setItem(HIDDEN_COLUMNS_KEY, JSON.stringify(Array.from(state.hiddenColumns)));
        } catch {}
      }

      loadHiddenColumns();

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";
        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnAddRow.disabled = !!on;
        dom.btnSaveAll.disabled = !!on;
        dom.btnExportExcel.disabled = !!on;
        dom.btnClearFilters.disabled = !!on;
        if (on) setStatus(text || "처리 중...", "warn");
      }

      function visibleColumns() {
        return COLUMN_CONFIG.filter(col => !state.hiddenColumns.has(col.key));
      }

      function formatDateForInput(v) {
        const s = normalizeText(v);
        if (!s) return "";
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
        if (/^\d{4}\.\d{1,2}\.\d{1,2}$/.test(s)) {
          const [y, m, d] = s.split(".");
          return `${y.padStart(4, "0")}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
        }
        return s;
      }

      function normalizeLoadedRow(row) {
        const out = { ...(row || {}) };
        for (const key of DATA_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }
        out.hire_date = formatDateForInput(out.hire_date);
        out.__dirty = false;
        out.__isNew = false;
        out.__dirtyFields = {};
        return out;
      }

      function rowId(row) {
        return row.pk_id ?? row.__temp_id;
      }

      function isResigned(row) {
        return normalizeText(row.position_title).includes("퇴사");
      }

      function isVehicleWarn(row) {
        return /[배아바사자]/.test(normalizeText(row.vehicle_plate_number));
      }

      function blankRow() {
        const row = {
          __temp_id: "new_" + (++state.tempSeq),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {}
        };
        for (const key of DATA_COLUMNS) row[key] = "";
        return row;
      }

      function hasAnyValue(row) {
        return DATA_COLUMNS.some(key => normalizeText(row[key]));
      }

      function valueForSave(key, value) {
        const v = normalizeText(value);
        if (!v) return null;
        if (key === "hire_date") return v;
        return v;
      }

      function updatePills() {
        const visibleCount = state.filteredRows.length;
        const dirtyCount = state.rows.filter(row => row.__dirty).length + state.deletedIds.size;
        dom.pillRows.textContent = "행 " + visibleCount;
        dom.pillDirty.textContent = "변경 " + dirtyCount;
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";
        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function infoApi(path, body = {}) {
        const token = state.session?.access_token || "";
        if (!token) throw new Error("로그인이 필요합니다.");

        const res = await fetch(INFO_API_BASE + path, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
          },
          body: JSON.stringify(body),
          cache: "no-store"
        });

        const text = await res.text();
        let data = null;

        if (text) {
          try {
            data = JSON.parse(text);
          } catch {
            data = text;
          }
        }

        if (!res.ok || data?.ok === false) {
          const msg =
            (data && typeof data === "object" && (data.error || data.message || data.detail)) ||
            (typeof data === "string" ? data : "") ||
            `HTTP ${res.status}`;
          throw new Error(String(msg));
        }

        return data;
      }

      async function requireAuthAndAccess() {
        if (!supabase || !supabase.auth) {
          alert("Supabase 설정을 확인하세요.");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();

          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          state.session = session;
          state.viewerEmail = normalizeText(session.user?.email || "");
          state.viewerUserId = normalizeText(session.user?.id || "");

          supabase.auth.onAuthStateChange((evt, s) => {
            if (evt === "SIGNED_OUT" || !s) {
              const next = safeNextPath(location.pathname + location.search + location.hash);
              location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
              return;
            }
            state.session = s;
          });

          if (!state.viewerUserId) {
            showAccessDenied(state.viewerEmail, "로그인 사용자 ID를 확인할 수 없습니다.");
            return false;
          }

          const accessRes = await fetch(INFO_API_BASE + "/access", {
            method: "GET",
            headers: {
              "Authorization": "Bearer " + session.access_token
            },
            cache: "no-store"
          });

          const accessData = await accessRes.json().catch(() => null);

          if (!accessRes.ok || accessData?.ok === false) {
            showAccessDenied(state.viewerEmail, "권한 확인 실패: " + (accessData?.error || accessData?.detail || accessRes.status));
            return false;
          }

          state.accessRow = accessData?.access || null;

          if (!accessData?.canAccess) {
            showAccessDenied(state.viewerEmail, "이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.");
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          console.error(e);
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      function parseFilterExpression(raw) {
        const text = normalizeText(raw);
        if (!text) return { include: [], exclude: [] };

        const tokens = text.split(/\s+/).filter(Boolean);
        const include = [];
        const exclude = [];

        for (const token of tokens) {
          if (token.startsWith("!") || token.startsWith("-")) {
            const x = normalizeLower(token.slice(1));
            if (x) exclude.push(x);
          } else {
            include.push(normalizeLower(token));
          }
        }

        return { include, exclude };
      }

      function matchFilter(value, expr) {
        const actual = normalizeLower(value);
        const parsed = parseFilterExpression(expr);

        for (const token of parsed.include) {
          if (!actual.includes(token)) return false;
        }
        for (const token of parsed.exclude) {
          if (actual.includes(token)) return false;
        }
        return true;
      }

      function getRowValue(row, key) {
        if (key === "hire_date") return formatDateForInput(row.hire_date);
        return normalizeText(row[key]);
      }

      function findRowById(id) {
        return state.rows.find(row => String(rowId(row)) === String(id)) || null;
      }

      function renderHiddenColumnBar() {
        const hidden = COLUMN_CONFIG.filter(col => state.hiddenColumns.has(col.key));

        if (!hidden.length) {
          dom.hiddenColumnBar.className = "hiddenColumnBar empty";
          dom.hiddenColumnBar.innerHTML = "";
          return;
        }

        dom.hiddenColumnBar.className = "hiddenColumnBar";
        dom.hiddenColumnBar.innerHTML = `
          <span class="hiddenLabel">숨김 열</span>
          <button class="hiddenChip all" type="button" data-show-all-cols="1">전체 열 보기</button>
          ${hidden.map(col => `<button class="hiddenChip" type="button" data-show-col="${escapeHtml(col.key)}">${escapeHtml(col.label)} 다시 보기</button>`).join("")}
        `;
      }

      function renderTableStructure() {
        const cols = visibleColumns();

        dom.tableColgroup.innerHTML = [
          ...cols.map(col => `<col style="width:${Number(col.width || 120)}px" />`),
          `<col style="width:72px" />`
        ].join("");

        dom.tableHead.innerHTML = `
          <tr>
            ${cols.map(col => `
              <th data-head-col="${escapeHtml(col.key)}">
                <div class="thInner">
                  <span class="thLabel">${escapeHtml(col.label)}</span>
                  <button class="hideColBtn" type="button" data-hide-col="${escapeHtml(col.key)}" title="${escapeHtml(col.label)} 열 접기">접기</button>
                </div>
              </th>
            `).join("")}
            <th>
              <div class="thInner">
                <span class="thLabel">삭제</span>
              </div>
            </th>
          </tr>
          <tr class="filterRow">
            ${cols.map(col => {
              if (col.key === "pk_id") return `<th></th>`;
              const value = state.filters[col.key] || "";
              return `<th><input class="filterInput" data-filter="${escapeHtml(col.key)}" value="${escapeHtml(value)}" placeholder="${escapeHtml(FILTER_PLACEHOLDERS[col.key] || col.label)}" /></th>`;
            }).join("")}
            <th></th>
          </tr>
        `;

        renderHiddenColumnBar();
      }

      function applyFilters(options = {}) {
        const renderStructure = options?.renderStructure !== false;

        state.filteredRows = state.rows.filter(row => {
          if (row.pk_id && state.deletedIds.has(row.pk_id)) return false;
          if (!dom.toggleIncludeResigned.checked && isResigned(row)) return false;
          if (dom.toggleOnlyChanged.checked && !row.__dirty) return false;

          for (const [key, expr] of Object.entries(state.filters)) {
            if (!normalizeText(expr)) continue;
            if (!matchFilter(getRowValue(row, key), expr)) return false;
          }

          return true;
        });

        if (renderStructure) renderTableStructure();
        renderTable();
        updatePills();

        if (!state.rows.length) {
          setStatus("데이터가 없습니다.", "warn");
        } else if (state.filteredRows.length !== state.rows.length) {
          setStatus(`필터 결과 ${state.filteredRows.length}건`, "ok");
        } else {
          setStatus(`전체 ${state.rows.length}건 로드 완료`, "ok");
        }
      }

      function buildDataCell(row, col) {
        const rid = rowId(row);
        const value = getRowValue(row, col.key);
        const classes = [];
        if (row.__dirtyFields?.[col.key]) classes.push("dirty-cell");
        if (col.key === "vehicle_plate_number" && isVehicleWarn(row)) classes.push("vehicle-warn");

        if (col.type === "readonly") {
          const displayValue = row.pk_id ?? "NEW";
          return `
            <td data-col="${escapeHtml(col.key)}" class="${classes.join(" ")}">
              <div class="cellView ${col.className || ""}">${escapeHtml(displayValue)}</div>
            </td>
          `;
        }

        if (col.type === "select") {
          const options = (col.options || []).map(opt => {
            const selected = String(opt) === String(value) ? "selected" : "";
            const label = opt || "-";
            return `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(label)}</option>`;
          }).join("");

          return `
            <td data-col="${escapeHtml(col.key)}" class="${classes.join(" ")}">
              <select
                class="cellSelect ${col.className || ""}"
                data-row-id="${escapeHtml(rid)}"
                data-key="${escapeHtml(col.key)}"
              >${options}</select>
            </td>
          `;
        }

        const inputType = col.type === "date" ? "date" : "text";

        return `
          <td data-col="${escapeHtml(col.key)}" class="${classes.join(" ")}">
            <input
              class="cellInput ${col.className || ""}"
              type="${inputType}"
              value="${escapeHtml(value)}"
              data-row-id="${escapeHtml(rid)}"
              data-key="${escapeHtml(col.key)}"
              autocomplete="off"
            />
          </td>
        `;
      }

      function renderTable() {
        const cols = visibleColumns();
        if (!state.filteredRows.length) {
          dom.sheetBody.innerHTML = `
            <tr class="emptyDataRow">
              <td colspan="${cols.length + 1}">조회 결과가 없습니다.</td>
            </tr>
          `;
          return;
        }

        dom.sheetBody.innerHTML = state.filteredRows.map(row => {
          const rid = rowId(row);
          const trClass = isResigned(row) ? "resigned-row" : "";
          const cells = cols.map(col => buildDataCell(row, col)).join("");

          return `
            <tr data-row="${escapeHtml(rid)}" class="${trClass}">
              ${cells}
              <td class="${row.__dirty ? "dirty-cell" : ""}">
                <div class="cellView center">
                  <button class="rowActionBtn delete" type="button" data-delete-row="${escapeHtml(rid)}">✕</button>
                </div>
              </td>
            </tr>
          `;
        }).join("");
      }

      function updateRowDom(row) {
        const rid = rowId(row);
        const tr = dom.sheetBody.querySelector(`tr[data-row="${CSS.escape(String(rid))}"]`);
        if (!tr) return;

        tr.classList.toggle("resigned-row", isResigned(row));

        for (const col of visibleColumns()) {
          const td = tr.querySelector(`td[data-col="${col.key}"]`);
          if (!td) continue;
          td.classList.toggle("dirty-cell", !!row.__dirtyFields?.[col.key]);
          if (col.key === "vehicle_plate_number") {
            td.classList.toggle("vehicle-warn", isVehicleWarn(row));
          }
        }

        const deleteTd = tr.lastElementChild;
        if (deleteTd) deleteTd.classList.toggle("dirty-cell", !!row.__dirty);
        updatePills();
      }

      function markRowDirty(row, key, value) {
        if (!row) return;
        row[key] = value;
        row.__dirty = true;
        row.__dirtyFields = row.__dirtyFields || {};
        row.__dirtyFields[key] = true;
      }

      function addRow() {
        state.rows.push(blankRow());
        applyFilters();
        setStatus("새 행이 추가되었습니다.", "ok");
      }

      function deleteRow(rowIdValue) {
        const row = findRowById(rowIdValue);
        if (!row) return;

        const label = normalizeText(row.person_name) || normalizeText(row.contact_phone) || String(rowIdValue);
        const ok = confirm(`삭제 대상으로 표시할까요?\n저장해야 실제 반영됩니다.\n\n대상: ${label}`);
        if (!ok) return;

        if (row.__isNew) {
          state.rows = state.rows.filter(r => String(rowId(r)) !== String(rowIdValue));
        } else if (row.pk_id) {
          state.deletedIds.add(row.pk_id);
          row.__dirty = true;
        }

        applyFilters();
        setStatus("삭제 대상으로 표시했습니다. 전체 저장 시 반영됩니다.", "warn");
      }

      function cleanPayload(row, includePk) {
        const obj = {};
        if (includePk && row.pk_id != null) obj.pk_id = row.pk_id;
        for (const key of DATA_COLUMNS) {
          obj[key] = valueForSave(key, row[key]);
        }
        return obj;
      }

      async function fetchRows() {
        try {
          setLoading(true, "데이터 불러오는 중...");
          state.deletedIds.clear();

          const result = await infoApi("/info/list", {});
          const data = Array.isArray(result?.rows) ? result.rows : [];

          state.rows = data.map(normalizeLoadedRow);
          applyFilters();
        } catch (e) {
          console.error(e);
          state.rows = [];
          state.filteredRows = [];
          renderTableStructure();
          renderTable();
          updatePills();
          setStatus("불러오기 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      async function saveAll() {
        try {
          setLoading(true, "저장 중...");

          const deleteIds = Array.from(state.deletedIds).filter(Boolean);
          const dirtyRows = state.rows.filter(row => row.__dirty && !(row.pk_id && state.deletedIds.has(row.pk_id)));
          const updateRows = dirtyRows.filter(row => !row.__isNew && row.pk_id != null);
          const newRows = dirtyRows.filter(row => row.__isNew && hasAnyValue(row));

          if (!deleteIds.length && !updateRows.length && !newRows.length) {
            setStatus("저장할 변경사항이 없습니다.", "warn");
            return;
          }

          const result = await infoApi("/info/save", {
            deleteIds,
            updateRows: updateRows.map(row => cleanPayload(row, true)),
            newRows: newRows.map(row => cleanPayload(row, false))
          });

          await fetchRows();
          setStatus(`저장 완료: 삭제 ${result.deleted || 0} / 수정 ${result.updated || 0} / 신규 ${result.inserted || 0}`, "ok");
        } catch (e) {
          console.error(e);
          setStatus("저장 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      function clearFilters() {
        state.filters = {};
        dom.toggleOnlyChanged.checked = false;
        applyFilters();
      }

      function exportExcel() {
        const rows = state.filteredRows.filter(row => !(row.pk_id && state.deletedIds.has(row.pk_id)));
        if (!rows.length) {
          alert("내보낼 데이터가 없습니다.");
          return;
        }

        const cols = visibleColumns();
        const header = cols.map(col => col.label);
        const aoa = [
          header,
          ...rows.map(row => cols.map(col => col.key === "pk_id" ? (row.pk_id ?? "") : getRowValue(row, col.key)))
        ];

        const now = new Date();
        const stamp = [
          now.getFullYear(),
          String(now.getMonth() + 1).padStart(2, "0"),
          String(now.getDate()).padStart(2, "0"),
          "_",
          String(now.getHours()).padStart(2, "0"),
          String(now.getMinutes()).padStart(2, "0")
        ].join("");

        if (window.XLSX?.utils?.aoa_to_sheet) {
          const ws = XLSX.utils.aoa_to_sheet(aoa);
          ws["!cols"] = cols.map(col => ({ wch: Math.max(10, Math.min(28, Math.round((col.width || 120) / 7))) }));
          const wb = XLSX.utils.book_new();
          XLSX.utils.book_append_sheet(wb, ws, "maroowell_info");
          XLSX.writeFile(wb, `maroowell_info_${stamp}.xlsx`);
          return;
        }

        const csv = "\uFEFF" + aoa.map(line => line.map(v => `"${String(v ?? "").replaceAll('"', '""')}"`).join(",")).join("\n");
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `maroowell_info_${stamp}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      function hideColumn(key) {
        if (!COLUMN_CONFIG.some(col => col.key === key)) return;
        state.hiddenColumns.add(key);
        saveHiddenColumns();
        applyFilters();
      }

      function showColumn(key) {
        state.hiddenColumns.delete(key);
        saveHiddenColumns();
        applyFilters();
      }

      function showAllColumns() {
        state.hiddenColumns.clear();
        saveHiddenColumns();
        applyFilters();
      }

      function bindTableEvents() {
        dom.sheetBody.addEventListener("input", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!rowIdValue || !key) return;

          const row = findRowById(rowIdValue);
          if (!row) return;

          markRowDirty(row, key, target.value);

          if (key === "position_title" && !dom.toggleIncludeResigned.checked && isResigned(row)) {
            applyFilters();
            return;
          }

          updateRowDom(row);
        });

        dom.sheetBody.addEventListener("change", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const rowIdValue = target.getAttribute("data-row-id");
          const key = target.getAttribute("data-key");
          if (!rowIdValue || !key) return;

          const row = findRowById(rowIdValue);
          if (!row) return;

          markRowDirty(row, key, target.value);

          if (key === "position_title" && !dom.toggleIncludeResigned.checked && isResigned(row)) {
            applyFilters();
            return;
          }

          updateRowDom(row);
        });

        dom.sheetBody.addEventListener("click", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const deleteId = target.getAttribute("data-delete-row");
          if (deleteId) deleteRow(deleteId);
        });
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", fetchRows);
        dom.btnAddRow.addEventListener("click", addRow);
        dom.btnSaveAll.addEventListener("click", saveAll);
        dom.btnExportExcel.addEventListener("click", exportExcel);
        dom.btnClearFilters.addEventListener("click", clearFilters);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.toggleIncludeResigned.addEventListener("change", applyFilters);
        dom.toggleOnlyChanged.addEventListener("change", applyFilters);

        dom.tableHead.addEventListener("compositionstart", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLInputElement)) return;
          if (!target.dataset.filter) return;
          target.dataset.composing = "1";
        });

        dom.tableHead.addEventListener("compositionend", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLInputElement)) return;
          const key = target.dataset.filter;
          if (!key) return;

          target.dataset.composing = "";
          state.filters[key] = target.value;
          applyFilters({ renderStructure:false });
        });

        dom.tableHead.addEventListener("input", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLInputElement)) return;
          const key = target.dataset.filter;
          if (!key) return;

          if (e.isComposing || target.dataset.composing === "1") return;

          state.filters[key] = target.value;
          applyFilters({ renderStructure:false });
        });

        dom.tableHead.addEventListener("click", (e) => {
          const btn = e.target.closest("[data-hide-col]");
          if (!btn) return;
          hideColumn(btn.getAttribute("data-hide-col"));
        });

        dom.hiddenColumnBar.addEventListener("click", (e) => {
          const btn = e.target.closest("button");
          if (!btn) return;

          if (btn.hasAttribute("data-show-all-cols")) {
            showAllColumns();
            return;
          }

          const key = btn.getAttribute("data-show-col");
          if (key) showColumn(key);
        });

        dom.btnDeniedHome.addEventListener("click", () => {
          location.replace(INDEX_PATH);
        });

        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        bindTableEvents();
      }

      bindEvents();
      renderTableStructure();
      renderTable();

      if (!(await requireAuthAndAccess())) return;
      await fetchRows();
    })();
  </script>

  <script>
    window.MW_BOARD_MENU_MODE = "admin";
  </script>
  <script src="/board-menu.js"></script>
</body>
