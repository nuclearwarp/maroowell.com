      function cloneDeductionItem(item = {}) {
        return {
          id: item.id ?? null,
          dragon_car_id: item.dragon_car_id ?? null,
          name: item.name || "",
          subtraction_price: item.subtraction_price ?? "",
          subtraction_item: item.subtraction_item || "",
