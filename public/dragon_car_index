      function markDirty(row) {
        row.__dirty = true;
        refreshStatus();
      }

      function buildPayload(row) {
        const linkedVendorName = row.vendor_id
          ? (vendorNameById(row.vendor_id) || row.order_vendor || "")
          : (row.order_vendor || "");

        return {
          vendor_id: row.vendor_id || null,
          order_date: toDateInput(row.order_date) || null,
          order_name: nullIfBlank(row.order_name),
          order_vendor: nullIfBlank(linkedVendorName),
          camp: nullIfBlank(row.camp),
          wave: nullIfBlank(row.wave),
          route: nullIfBlank(row.route),
          price: toNum(row.price),
          settlement_day: nullIfBlank(row.settlement_day),
          delivery_driver: nullIfBlank(row.delivery_driver),
          parcel: toInt(row.parcel),
          return_count: toInt(row.return_count),
          amount: hasManualAmount(row) ? toNum(row.amount) : null,
          settlement_month: nullIfBlank(row.settlement_month),
          dragon_car_id: nullIfBlank(row.dragon_car_id),
          dragon_car_pw: nullIfBlank(row.dragon_car_pw),
          tax_invoice: !!row.tax_invoice,
          payment_confirm: !!row.payment_confirm,
          dragon_car_note: nullIfBlank(row.dragon_car_note)
        };
      }

      async function saveRowByObject(row) {
        const payload = buildPayload(row);

        if (row.id) {
          const { data, error } = await supabase
            .from(TABLE)
            .update(payload)
            .eq("id", row.id)
            .select("*")
            .single();
          if (error) throw error;
          Object.assign(row, data, { __dirty: false, __new: false });
        } else {
          const { data, error } = await supabase
            .from(TABLE)
            .insert(payload)
            .select("*")
            .single();
          if (error) throw error;
          Object.assign(row, data, { __dirty: false, __new: false });
        }
      }

      async function saveRow(rowIndex) {
        const row = state.rows[rowIndex];
        if (!row) return;
        try {
          setStatus("저장 중...", "warn");
          await saveRowByObject(row);
          render();
          setStatus("저장 완료 · ID " + (row.id || "-"), "ok");
        } catch (e) {
          console.error(e);
          setStatus("저장 실패: " + formatDbError(e), "err");
        }
      }

      async function deleteRow(rowIndex) {
        const row = state.rows[rowIndex];
        if (!row) return;
        if (!confirm("이 행을 삭제할까요?")) return;

        try {
          if (row.id) {
            const { error } = await supabase.from(TABLE).delete().eq("id", row.id);
            if (error) throw error;
          }
          state.rows.splice(rowIndex, 1);
          render();
          setStatus("삭제 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("삭제 실패: " + formatDbError(e), "err");
        }
      }

      async function saveAll() {
        const dirtyRows = state.rows.filter(r => r.__dirty);
        if (!dirtyRows.length) {
          setStatus("저장할 변경이 없습니다.", "ok");
          return;
        }
        try {
          setStatus("변경분 저장 중...", "warn");
          for (const row of dirtyRows) {
            await saveRowByObject(row);
          }
          render();
          setStatus("전체 저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("전체 저장 실패: " + formatDbError(e), "err");
        }
      }

      async function loadVendors() {
        try {
          const { data, error } = await supabase
            .from(VENDORS_TABLE)
            .select("id,name,vendor_code,business_number")
            .order("name", { ascending: true });

          if (error) throw error;

          state.vendors = sortVendors(Array.isArray(data) ? data : []);
          setVendorFilterOptions();

          if (!state.vendors.length) {
            setStatus("벤더 목록이 0건입니다. 권한(RLS) 또는 vendor_members 연결을 확인하세요.", "warn");
          }
        } catch (e) {
          console.error(e);
          state.vendors = [];
          setVendorFilterOptions();
          setStatus("벤더 불러오기 실패: " + formatDbError(e), "err");
        }
      }


      async function loadSubtractionsForRows(rows) {
        const targetRows = Array.isArray(rows) ? rows : [];
        targetRows.forEach(row => {
          row.__subtractions = [];
        });

        const ids = targetRows
          .map(row => Number(row.id))
          .filter(id => Number.isFinite(id) && id > 0);

        if (!ids.length) return;

        try {
          const { data, error } = await supabase
            .from(SUBTRACTION_TABLE)
            .select("*")
            .in("dragon_car_id", ids)
            .order("created_at", { ascending: true });

          if (error) throw error;

          const grouped = new Map();
          for (const item of Array.isArray(data) ? data : []) {
            const key = Number(item.dragon_car_id);
            if (!grouped.has(key)) grouped.set(key, []);
            grouped.get(key).push(item);
          }

          targetRows.forEach(row => {
            row.__subtractions = grouped.get(Number(row.id)) || [];
          });
        } catch (e) {
          console.error(e);
          setStatus("용차 차감 불러오기 실패: " + formatDbError(e), "warn");
        }
      }

      async function loadAllSubtractions() {
        try {
          const { data, error } = await supabase
            .from(SUBTRACTION_TABLE)
            .select("*")
            .order("created_at", { ascending: false });

          if (error) throw error;

          const rows = Array.isArray(data) ? data : [];
          state.subtractionRows = rows;

          const ids = Array.from(new Set(
            rows.map(item => Number(item.dragon_car_id)).filter(id => Number.isFinite(id) && id > 0)
          ));

          state.subtractionParents = new Map();

          if (ids.length) {
            const { data: parentData, error: parentError } = await supabase
              .from(TABLE)
              .select("*")
              .in("id", ids);

            if (parentError) throw parentError;

            const grouped = new Map();
            for (const item of rows) {
              const key = Number(item.dragon_car_id);
              if (!grouped.has(key)) grouped.set(key, []);
              grouped.get(key).push(item);
            }

            for (const parent of Array.isArray(parentData) ? parentData : []) {
              const id = Number(parent.id);
              state.subtractionParents.set(id, {
                ...parent,
                order_vendor: parent.vendor_id ? (vendorNameById(parent.vendor_id) || parent.order_vendor || "") : (parent.order_vendor || ""),
                amount: parent.amount ?? "",
                __subtractions: grouped.get(id) || [],
                __amountManual: parent.amount != null && String(parent.amount).trim() !== "",
                __dirty: false,
                __new: false,
                __subtractionOnly: true
              });
            }
          }

          if (state.activeSheet === "subtraction") {
            renderSubtractionSheet();
          }
        } catch (e) {
          console.error(e);
          state.subtractionRows = [];
          state.subtractionParents = new Map();
          setStatus("용차 차감 DB 불러오기 실패: " + formatDbError(e), "warn");
        }
      }

      function rowForSubtractionDragonId(dragonCarId) {
        const id = Number(dragonCarId);
        if (!Number.isFinite(id) || id <= 0) return { row:null, rowIndex:-1 };

        let rowIndex = state.rows.findIndex(row => Number(row.id) === id);
        if (rowIndex >= 0) return { row:state.rows[rowIndex], rowIndex };

        const parent = state.subtractionParents.get(id);

        if (!parent) return { row:null, rowIndex:-1 };

        state.rows.push({
          ...parent,
          __subtractionOnly:true,
          __dirty:false,
          __new:false
        });

        rowIndex = state.rows.length - 1;

        return {
          row:state.rows[rowIndex],
          rowIndex
        };
      }

      function openDeductionByDragonId(dragonCarId) {
        const found = rowForSubtractionDragonId(dragonCarId);

        if (!found.row || found.rowIndex < 0) {
          setStatus("연결된 용차 행을 찾지 못했습니다. dragon_car_id: " + dragonCarId, "err");
          return;
        }

        openDeductionModal(found.rowIndex);
      }

      async function loadRows() {
        const monthInfo = getSelectedSettlementMonthInfo();
        try {
          let query = supabase
            .from(TABLE)
            .select("*");

          if (monthInfo) {
            setStatus(`${monthInfo.label} 불러오는 중...`, "warn");
            query = query
              .gte("order_date", monthInfo.cycleStartIso)
              .lte("order_date", monthInfo.cycleEndIso);
          } else {
            setStatus("전체 기간 불러오는 중...", "warn");
          }

          const { data, error } = await query
            .order("order_date", { ascending: false, nullsFirst: false })
            .order("id", { ascending: false });

          if (error) throw error;

          state.rows = (Array.isArray(data) ? data : []).map(row => ({
            ...row,
            order_vendor: row.vendor_id ? (vendorNameById(row.vendor_id) || row.order_vendor || "") : (row.order_vendor || ""),
            amount: row.amount ?? "",
            __subtractions: [],
            __amountManual: row.amount != null && String(row.amount).trim() !== "",
            __dirty: false,
            __new: false
          }));

          await loadSubtractionsForRows(state.rows);
          await loadAllSubtractions();

          render();
          if (monthInfo) {
            setStatus(`${monthInfo.label} 불러오기 완료 (${monthInfo.cycleStartIso} ~ ${monthInfo.cycleEndIso})`, "ok");
          } else {
            setStatus(`전체 기간 불러오기 완료 (${state.rows.length}건)`, "ok");
          }
        } catch (e) {
          console.error(e);
          if (monthInfo) {
            setStatus(`${monthInfo.label} 불러오기 실패: ` + formatDbError(e), "err");
          } else {
            setStatus(`전체 기간 불러오기 실패: ` + formatDbError(e), "err");
          }
        }
      }

      function excelCell(value, options = {}) {
        const text = String(value ?? "");
        const escaped = text
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");

        const style = options.text
          ? "mso-number-format:'\\@';white-space:normal;"
          : "white-space:normal;";

        return `<td style="${style}">${escaped.replace(/\n/g, "<br>")}</td>`;
      }

      function exportCsv() {
        const rows = getFilteredRows();

        if (!rows.length) {
          alert("다운로드할 데이터가 없습니다.");
          return;
        }

        // 엑셀 다운로드는 화면에 보이는 용차 시트 th 제목 기준으로만 구성한다.
        // 차감 관련 컬럼은 다운로드에서 완전히 제외한다.
        const headers = [
          "Date",
          "연결 벤더",
          "Order",
          "캠프",
          "주간/야간",
          "라우트",
          "단가",
          "세금계산서",
          "입금여부",
          "정산일자",
          "투입 기사",
          "배송 수량",
          "반품 수량",
          "합계",
          "금액",
          "정산월",
          "ID",
          "PW",
          "비고"
        ];

        const excelRows = rows.map(row => [
          toDateInput(row.order_date),
          vendorNameById(row.vendor_id),
          row.order_name || "",
          row.camp || "",
          row.wave || "",
          row.route || "",
          row.price ?? "",
          row.tax_invoice ? "발행" : "미발행",
          row.payment_confirm ? "입금" : "미입금",
          row.settlement_day || "",
          row.delivery_driver || "",
          toInt(row.parcel),
          toInt(row.return_count),
          totalCount(row),
          amountValue(row) ?? "",
          row.settlement_month || "",
          row.dragon_car_id || "",
          row.dragon_car_pw || "",
          row.dragon_car_note || ""
        ]);

        const headerHtml = headers.map(title => `<th>${title}</th>`).join("");
        const bodyHtml = excelRows.map(values => {
          return "<tr>" + values.map((value, index) => {
            // ID/PW/비고는 엑셀에서 자동 숫자 변환하지 않도록 텍스트 형식으로 둔다.
            return excelCell(value, { text:index >= 16 });
          }).join("") + "</tr>";
        }).join("");

        const html = `
          <!doctype html>
          <html>
          <head>
            <meta charset="utf-8">
            <style>
              table{border-collapse:collapse;font-family:"Malgun Gothic","Noto Sans KR",Arial,sans-serif;font-size:11pt;}
              th{background:#dbeafe;font-weight:700;text-align:center;}
              th,td{border:1px solid #cbd5e1;padding:6px 8px;vertical-align:middle;}
            </style>
          </head>
          <body>
            <table>
              <thead><tr>${headerHtml}</tr></thead>
              <tbody>${bodyHtml}</tbody>
            </table>
          </body>
          </html>
        `;

        const blob = new Blob(["\uFEFF" + html], { type:"application/vnd.ms-excel;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "dragon_car_" + new Date().toISOString().slice(0, 10) + ".xls";
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      async function clearFilters() {
        quickSearch.value = "";
        toolbarVendorFilter.value = "";
        toolbarMonthFilter.value = "";
        toolbarDateFrom.value = "";
        toolbarDateTo.value = "";
        document.querySelectorAll(".filterInput, .filterSelect").forEach(el => {
          el.value = "";
        });
        syncExternalDateDisplays();
        syncVendorDisplays();
        setVendorFilterOptions();
        render();
        await loadRows();
      }

      sheetBody.addEventListener("input", (e) => {
        const el = e.target;
        const rowIndex = Number(el.dataset.row);
        const field = el.dataset.field;
        if (!Number.isInteger(rowIndex) || !field || !state.rows[rowIndex]) return;

        const row = state.rows[rowIndex];
        const tr = el.closest("tr");

        if (field === "amount") {
          row.amount = el.value;
          row.__amountManual = String(el.value ?? "").trim() !== "";
          syncAmountInputState(el, row);
          markDirty(row);
          return;
        }

        row[field] = el.value;

        if (el.classList.contains("autoGrow")) {
          resizeAutoTextarea(el);
        }

        if (field === "price" || field === "parcel" || field === "return_count") {
          syncRowCalculatedCells(tr, row);
        }

        markDirty(row);
      });

      sheetBody.addEventListener("change", (e) => {
        const el = e.target;
        const rowIndex = Number(el.dataset.row);
        const field = el.dataset.field;
        if (!Number.isInteger(rowIndex) || !field || !state.rows[rowIndex]) return;

        const row = state.rows[rowIndex];

        if (field === "order_date") {
          row.order_date = el.value || "";
          markDirty(row);
          render();
          return;
        }


        if (field === "tax_invoice" || field === "payment_confirm") {
          row[field] = String(el.value) === "true";
          markDirty(row);
          render();
        }
      });

      sheetBody.addEventListener("blur", (e) => {
        const el = e.target;
        const rowIndex = Number(el.dataset?.row);
        const field = el.dataset?.field;
        if (!Number.isInteger(rowIndex) || !field || !state.rows[rowIndex]) return;

        const row = state.rows[rowIndex];

        if (field === "amount") {
          if (hasManualAmount(row)) {
            const manual = toNum(row.amount);
            row.amount = manual == null ? "" : String(manual);
          } else {
            row.amount = "";
          }
          el.value = amountDisplayValue(row);
          syncAmountInputState(el, row);
          return;
        }

        if (field === "price") {
          const price = toNum(row.price);
          row.price = price == null ? "" : String(price);
          el.value = formatNumber(price);
          syncRowCalculatedCells(el.closest("tr"), row);
          return;
        }

        if (field === "parcel" || field === "return_count") {
          row[field] = String(toInt(row[field]));
          el.value = row[field];
          syncRowCalculatedCells(el.closest("tr"), row);
          return;
        }

        if (el.classList.contains("autoGrow")) {
          resizeAutoTextarea(el);
        }
      }, true);

      subtractionSheetBody.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-sub-action]");
        if (!btn) return;

        const action = btn.dataset.subAction;

        if (action === "deduction") {
          openDeductionByDragonId(btn.dataset.dragonCarId);
        }
      });

      sheetBody.addEventListener("click", async (e) => {
        const btn = e.target.closest("[data-action]");
        if (!btn) return;

        const action = btn.dataset.action;
        const rowIndex = Number(btn.dataset.row);

        if (action === "open-date") {
          const row = state.rows[rowIndex];
          if (!row) return;

          openCalendar({
            anchorEl: btn.closest(".dateCell") || btn,
            value: row.order_date,
            onSelect: (iso) => {
              row.order_date = iso || "";
              markDirty(row);
              render();
            },
            onClear: () => {
              row.order_date = "";
              markDirty(row);
              render();
            }
          });
          return;
        }

        if (action === "deduction") {
          openDeductionModal(rowIndex);
          return;
        }

        if (action === "save") {
          await saveRow(rowIndex);
          return;
        }

        if (action === "copy") {
          const row = state.rows[rowIndex];
          if (!row) return;
          state.newRowSeq += 1;
          state.rows.unshift({
            ...row,
            id: null,
            __newSeq: state.newRowSeq,
            __dirty: true,
            __new: true
          });
          render();
          setStatus("행 복제 완료", "ok");
          return;
        }

        if (action === "delete") {
          await deleteRow(rowIndex);
        }
      });

      document.addEventListener("click", (e) => {
        const btn = e.target.closest('[data-action="open-external-date"]');
        if (!btn) return;

        const targetId = btn.dataset.target;
        const input = document.getElementById(targetId);
        if (!input) return;

        openCalendar({
          anchorEl: btn.closest(".toolbarDateField, .filterDateField") || btn,
          value: input.value,
          onSelect: (iso) => setExternalDateValue(targetId, iso),
          onClear: () => setExternalDateValue(targetId, "")
        });
      });

      document.addEventListener("click", (e) => {
        const btn = e.target.closest('[data-action="open-vendor-lookup"]');
        if (!btn) return;
        const targetId = btn.dataset.target;
        const input = document.getElementById(targetId);
        if (!input) return;
        const display = document.getElementById(targetId + "Display");
        openVendorLookup({
          anchorEl: btn.closest('.toolbarVendorField, .filterVendorField') || btn,
          value: input.value,
          emptyLabel: display?.dataset.emptyLabel || '전체',
          onSelect: (vendorId) => setExternalVendorValue(targetId, vendorId)
        });
      });

      document.addEventListener("click", (e) => {
        const btn = e.target.closest('[data-action="open-row-vendor-lookup"]');
        if (!btn) return;
        const rowIndex = Number(btn.dataset.row);
        const row = state.rows[rowIndex];
        if (!row) return;
        openVendorLookup({
          anchorEl: btn.closest('.vendorLookupField') || btn,
          value: row.vendor_id,
          emptyLabel: '미연결',
          onSelect: (vendorId) => {
            row.vendor_id = vendorId || "";
            row.order_vendor = row.vendor_id ? (vendorNameById(row.vendor_id) || "") : "";
            markDirty(row);
            render();
          }
        });
      });

      quickSearch.addEventListener("input", render);
      toolbarVendorFilter.addEventListener("change", render);
      toolbarMonthFilter.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          loadRows();
        }
      });
      toolbarMonthFilter.addEventListener("change", () => {
        const raw = String(toolbarMonthFilter.value ?? "").trim();
        if (!raw) {
          toolbarMonthFilter.value = "";
          loadRows();
          return;
        }
        const parsed = parseSettlementMonthInput(raw);
        if (parsed) {
          toolbarMonthFilter.value = parsed.monthKey;
          loadRows();
          return;
        }
        setStatus("정산월은 YYYY-MM 형식으로 입력하세요. 예: 2026-04", "warn");
      });
      toolbarDateFrom.addEventListener("change", render);
      toolbarDateTo.addEventListener("change", render);

      document.addEventListener("input", (e) => {
        if (e.target.classList.contains("filterInput")) render();
      });

      document.addEventListener("change", (e) => {
        if (e.target.classList.contains("filterSelect")) render();
      });

      btnReload.addEventListener("click", loadRows);

      btnSubtractionSheet.addEventListener("click", () => {
        setActiveSheet(state.activeSheet === "subtraction" ? "dragon" : "subtraction");
      });

      btnAddSubtraction.addEventListener("click", openSubtractionTargetPicker);

      btnBackDragonSheet.addEventListener("click", () => {
        setActiveSheet("dragon");
      });

      btnAdd.addEventListener("click", () => {
        state.rows.unshift(emptyRow());
        render();
        setStatus("새 행 추가 완료", "ok");
      });
      btnSaveAll.addEventListener("click", saveAll);
      btnClearFilters.addEventListener("click", () => { clearFilters(); });
      btnExportCsv.addEventListener("click", exportCsv);

      btnLogout.addEventListener("click", async () => {
        if (!confirm("로그아웃할까요?")) return;
        try { await supabase.auth.signOut(); } catch {}
        location.replace(LOGIN_PATH);
      });

      syncExternalDateDisplays();
      syncVendorDisplays();
      applyDefaultSettlementMonth();

      if (!(await requireAuth())) return;
      await loadVendors();
      render();
      await loadRows();
    })();
  </script>
  <script>
    window.MW_BOARD_MENU_MODE = "admin";
  </script>
  <script src="/board-menu.js"></script>
</body>
</html>
