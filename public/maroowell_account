<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />
  <title>정산 데이터 조회</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    :root{
      --bg:#081120;--panel:#101b2f;--panel2:#0d1728;--line:rgba(255,255,255,.11);--line2:rgba(255,255,255,.18);
      --txt:#eaf2ff;--muted:#9fb0d0;--blue:#2563eb;--green:#16a34a;--red:#b91c1c;--yellow:#f59e0b;--cyan:#0891b2;
      --shadow:0 16px 42px rgba(0,0,0,.28)
    }
    *{box-sizing:border-box}
    html,body{margin:0;min-height:100%;background:var(--bg);color:var(--txt);font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif}
    body{overflow:auto}button,input,select{font-family:inherit}
    .app{min-height:100vh;min-height:100dvh;background:linear-gradient(180deg,var(--bg),#060b13)}
    .topbar{position:sticky;top:0;z-index:40;display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid var(--line);background:linear-gradient(180deg,#0b1424,#07101d)}
    .brand{display:flex;align-items:center;gap:10px;min-width:0}.logoButton{width:34px;height:34px;border:1px solid transparent;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;flex:0 0 auto;cursor:pointer;background:rgba(255,255,255,.03)}.logoButton:hover{background:rgba(255,255,255,.10);border-color:rgba(255,255,255,.18)}.logoButton img{width:28px;height:28px;display:block}.brandText{min-width:0}.brandText h1{margin:0;font-size:22px;line-height:1.05;letter-spacing:-.04em}.brandText p{margin:4px 0 0;color:var(--muted);font-size:12px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topSpacer{flex:1}
    .userBadge{display:inline-flex;align-items:center;min-height:34px;max-width:260px;padding:0 12px;border-radius:999px;border:1px solid var(--line2);background:rgba(255,255,255,.05);color:#bfdbfe;font-size:12px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .btn{height:38px;padding:0 13px;border-radius:999px;border:1px solid var(--line2);background:rgba(255,255,255,.07);color:var(--txt);font-size:13px;font-weight:900;cursor:pointer;white-space:nowrap;touch-action:manipulation}.btn:hover{background:rgba(255,255,255,.11)}.btn.primary{background:rgba(37,99,235,.75);border-color:rgba(147,197,253,.45)}.btn.ok{background:rgba(22,163,74,.55);border-color:rgba(134,239,172,.35)}.btn.warn{background:rgba(245,158,11,.34);border-color:rgba(253,230,138,.35)}.btn.copy{background:rgba(14,116,144,.55);border-color:rgba(103,232,249,.35)}.btn.danger{background:rgba(185,28,28,.42);border-color:rgba(252,165,165,.35);color:#fecaca}.btn:disabled{opacity:.55;cursor:not-allowed}
    .wrap{max-width:1680px;margin:0 auto;padding:16px 14px 44px}.card{border:1px solid var(--line2);border-radius:18px;background:rgba(16,27,47,.88);box-shadow:var(--shadow);overflow:hidden;margin-bottom:14px}.cardHead{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:14px 16px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.04)}.cardHead h2{margin:0;font-size:17px;letter-spacing:-.03em}.cardBody{padding:16px}
    .toolbar{display:grid;grid-template-columns:150px 120px minmax(220px,1fr) auto auto auto;gap:10px;align-items:end}.field{display:flex;flex-direction:column;gap:6px;min-width:0}.field label{color:#bfdbfe;font-size:12px;font-weight:900}.input,.select{width:100%;height:42px;border-radius:12px;border:1px solid var(--line2);background:#0b1220;color:var(--txt);padding:0 12px;font-size:14px;font-weight:800;outline:none}.input:focus,.select:focus{border-color:rgba(96,165,250,.75);box-shadow:0 0 0 3px rgba(96,165,250,.12)}.select option{background:#0b1220;color:#fff}
    .pillGrid{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));gap:8px;margin-top:12px}.pill{display:flex;flex-direction:column;gap:5px;min-height:58px;border:1px solid var(--line2);border-radius:14px;background:rgba(255,255,255,.045);padding:9px 10px}.pill span{color:var(--muted);font-size:11px;font-weight:900}.pill b{font-size:18px;line-height:1.1}.status{font-size:13px;font-weight:800;line-height:1.55;color:#b7c7e6;white-space:pre-wrap;margin-top:10px}.status.ok{color:#bbf7d0}.status.warn{color:#fde68a}.status.err{color:#fecaca}.muted{color:var(--muted);font-size:13px;font-weight:800;line-height:1.55}.money{color:#bbf7d0;font-weight:950}.warn{color:#fde68a;font-weight:950}.left{text-align:left!important}
    .tableWrap{overflow:auto;max-height:calc(100dvh - 315px);border-top:1px solid var(--line);background:rgba(0,0,0,.16)}table{width:100%;min-width:1420px;border-collapse:separate;border-spacing:0;font-size:12px}th,td{border-right:1px solid rgba(255,255,255,.11);border-bottom:1px solid rgba(255,255,255,.11);padding:7px 8px;text-align:center;vertical-align:middle;white-space:nowrap}th{position:sticky;top:0;z-index:2;background:#27364d;color:#fff;font-size:12px;font-weight:1000}td{background:rgba(255,255,255,.025)}tr:hover td{background:rgba(96,165,250,.08)}.emptyBox{padding:44px 12px;text-align:center;color:#cbd5e1;font-size:14px;font-weight:900}
    .accessDenied{position:fixed;inset:0;display:none;align-items:center;justify-content:center;padding:20px;background:linear-gradient(180deg,rgba(11,18,32,.96),rgba(11,18,32,.98));z-index:9999}.accessDenied.show{display:flex}.accessCard{width:min(520px,calc(100vw - 24px));border:1px solid rgba(255,255,255,.10);border-radius:22px;background:#101827;box-shadow:0 24px 60px rgba(0,0,0,.35);padding:24px}.accessCard h2{margin:0 0 8px;font-size:24px}.accessCard p{margin:0;color:#b8c3d9;line-height:1.6;font-size:14px;white-space:pre-wrap}.accessMeta{margin-top:14px;padding:12px 14px;border-radius:14px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.04);color:#e6eefc;font-size:13px;font-weight:800;word-break:break-word;line-height:1.6}.accessActions{margin-top:18px;display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap}
    @media(max-width:980px){.brandText h1{font-size:18px}.brandText p,.userBadge{display:none}.topbar{padding:10px}.topbar .btn{height:34px;padding:0 10px;font-size:12px}.toolbar{grid-template-columns:1fr}.toolbar .btn{width:100%}.pillGrid{grid-template-columns:repeat(2,minmax(0,1fr))}.tableWrap{max-height:none}.wrap{padding:10px 8px 36px}}
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기"><img src="/favicon.ico" alt="Maroowell" /></a>
        <div class="brandText"><h1>정산 데이터 조회</h1><p>maroowell_account 월별 정산 데이터 조회</p></div>
      </div>
      <div class="topSpacer"></div><div id="userBadge" class="userBadge">-</div><button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <main class="wrap">
      <section class="card">
        <div class="cardHead"><h2>조회 조건</h2><span id="stateText" class="muted">대기 중</span></div>
        <div class="cardBody">
          <div class="toolbar">
            <div class="field"><label for="yearSelect">정산 연도</label><select id="yearSelect" class="select"></select></div>
            <div class="field"><label for="monthSelect">정산 월</label><select id="monthSelect" class="select"></select></div>
            <div class="field"><label for="searchInput">검색</label><input id="searchInput" class="input" type="text" placeholder="구분 / ID / Route / 캠프 / 배송유형" autocomplete="off" /></div>
            <button id="btnLoad" class="btn primary" type="button">조회</button>
            <button id="btnExcel" class="btn ok" type="button">엑셀 다운로드</button>
            <button id="btnReset" class="btn" type="button">초기화</button>
          </div>
          <div id="statusText" class="status">정산 연도와 월을 선택하고 조회를 누르세요.</div>
          <div class="pillGrid">
            <div class="pill"><span>정산월</span><b id="summaryPeriod">-</b></div>
            <div class="pill"><span>조회 행</span><b id="summaryRows">0</b></div>
            <div class="pill"><span>배송 행</span><b id="summaryDelivery">0</b></div>
            <div class="pill"><span>프백 행</span><b id="summaryFreshbag">0</b></div>
            <div class="pill"><span>배송금액</span><b id="summaryDefault">0</b></div>
            <div class="pill"><span>프백금액</span><b id="summaryFreshbagPrice">0</b></div>
            <div class="pill"><span>총금액</span><b id="summaryTotal">0</b></div>
          </div>
        </div>
      </section>

      <section class="card">
        <div class="cardHead"><h2>정산 데이터</h2><span id="tableNote" class="muted">-</span></div>
        <div class="tableWrap">
          <table id="dataTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 데이터가 없습니다.</div></td></tr></tbody></table>
        </div>
      </section>
    </main>
  </div>

  <div id="accessDenied" class="accessDenied"><div class="accessCard"><h2>접근 권한 없음</h2><p id="accessDeniedText">최고관리자 권한이 필요합니다.</p><div id="accessDeniedEmail" class="accessMeta"></div><div class="accessActions"><button id="deniedHomeBtn" class="btn" type="button">홈으로</button><button id="deniedLogoutBtn" class="btn danger" type="button">로그아웃</button></div></div></div>

  <script>
    (async function(){
      "use strict";
      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY;
      const LOGIN_PATH = CONFIG.PATHS?.login || "/login.html";
      const HOME_PATH = CONFIG.PATHS?.index || "/zipcode_search";
      const TABLE_NAME = "maroowell_account";

      const els = {
        userBadge:document.getElementById("userBadge"), btnLogout:document.getElementById("btnLogout"), yearSelect:document.getElementById("yearSelect"), monthSelect:document.getElementById("monthSelect"), searchInput:document.getElementById("searchInput"), btnLoad:document.getElementById("btnLoad"), btnExcel:document.getElementById("btnExcel"), btnReset:document.getElementById("btnReset"), stateText:document.getElementById("stateText"), statusText:document.getElementById("statusText"), dataTable:document.getElementById("dataTable"), tableNote:document.getElementById("tableNote"), summaryPeriod:document.getElementById("summaryPeriod"), summaryRows:document.getElementById("summaryRows"), summaryDelivery:document.getElementById("summaryDelivery"), summaryFreshbag:document.getElementById("summaryFreshbag"), summaryDefault:document.getElementById("summaryDefault"), summaryFreshbagPrice:document.getElementById("summaryFreshbagPrice"), summaryTotal:document.getElementById("summaryTotal"), accessDenied:document.getElementById("accessDenied"), accessDeniedText:document.getElementById("accessDeniedText"), accessDeniedEmail:document.getElementById("accessDeniedEmail"), deniedHomeBtn:document.getElementById("deniedHomeBtn"), deniedLogoutBtn:document.getElementById("deniedLogoutBtn")
      };

      const state = { session:null, user:null, access:null, rows:[], filtered:[] };
      const supabaseClient = SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {auth:{storage:window.sessionStorage,persistSession:true,autoRefreshToken:true,detectSessionInUrl:true}}) : null;

      function clean(v){return String(v ?? "").trim()}
      function esc(v){return String(v ?? "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#39;")}
      function money(v){const n=Number(v||0);return Number.isFinite(n)?n.toLocaleString("ko-KR"):"0"}
      function isFreshbagClassify(v){const s=clean(v).replace(/\s+/g,"");return /프레|프레쉬|프레시|fresh/i.test(s)}
      function setStatus(text,type){els.statusText.textContent=text||"";els.statusText.className=type?`status ${type}`:"status"}
      function setBusy(busy){els.btnLoad.disabled=busy;els.btnExcel.disabled=busy;els.stateText.textContent=busy?"처리 중":"READY"}

      function initPeriodSelects(){
        const now=new Date();const currentYear=now.getFullYear();const currentMonth=now.getMonth()+1;const years=[];
        for(let y=currentYear+1;y>=currentYear-8;y--) years.push(y);
        els.yearSelect.innerHTML=years.map(y=>`<option value="${y}">${y}년</option>`).join("");
        els.monthSelect.innerHTML=Array.from({length:12},(_,i)=>`<option value="${i+1}">${i+1}월</option>`).join("");
        els.yearSelect.value=String(currentYear);els.monthSelect.value=String(currentMonth);
      }

      function getSelectedPeriod(){
        const dateYear=Number(els.yearSelect.value);const dateMonth=Number(els.monthSelect.value);
        if(!Number.isInteger(dateYear)||dateYear<2000||dateYear>2100) throw new Error("정산 연도를 선택하세요.");
        if(!Number.isInteger(dateMonth)||dateMonth<1||dateMonth>12) throw new Error("정산 월을 선택하세요.");
        return {date_year:dateYear,date_month:dateMonth};
      }

      function showAccessDenied(message){els.accessDeniedText.textContent=message||"최고관리자 권한이 필요합니다.";els.accessDeniedEmail.textContent=state.user?.email?`현재 계정: ${state.user.email}`:"로그인 계정을 확인할 수 없습니다.";els.accessDenied.classList.add("show");document.documentElement.style.visibility="visible"}
      async function logout(){try{if(supabaseClient) await supabaseClient.auth.signOut()}catch{}location.href=LOGIN_PATH}

      async function checkAccess(){
        if(!supabaseClient){showAccessDenied("Supabase 설정을 찾지 못했습니다. config.js를 확인하세요.");return false}
        const {data:sessionData,error:sessionError}=await supabaseClient.auth.getSession();if(sessionError) throw sessionError;
        state.session=sessionData?.session||null;state.user=state.session?.user||null;
        if(!state.user){location.href=`${LOGIN_PATH}?next=${encodeURIComponent(location.pathname)}`;return false}
        els.userBadge.textContent=state.user.email||state.user.id||"로그인";
        const {data,error}=await supabaseClient.rpc("mw_my_access").maybeSingle();if(error) throw error;state.access=data||null;
        const isSuperAdmin=data?.is_maroowell===true&&data?.is_admin===true&&Number(data?.max_role_level||0)>=90;
        if(!isSuperAdmin){showAccessDenied("최고관리자 권한이 필요합니다.\n조건: 마루웰 권한 + 관리자 권한 + role_level 90 이상");return false}
        document.documentElement.style.visibility="visible";return true;
      }

      async function loadRows(){
        const period=getSelectedPeriod();setBusy(true);setStatus(`${period.date_year}년 ${period.date_month}월 정산 데이터를 조회하는 중입니다...`,"");
        try{
          const {data,error}=await supabaseClient.from(TABLE_NAME).select("*").eq("date_year",period.date_year).eq("date_month",period.date_month).order("delivery_date",{ascending:true}).order("route",{ascending:true}).order("row_id",{ascending:true});
          if(error) throw error;
          state.rows=Array.isArray(data)?data:[];applyFilter();setStatus(`조회 완료: ${state.rows.length.toLocaleString("ko-KR")}행`,"ok");
        }catch(err){console.error(err);setStatus(`조회 실패: ${err.message||err}`,"err")}
        finally{setBusy(false)}
      }

      function applyFilter(){
        const q=clean(els.searchInput.value).toLowerCase();
        state.filtered=!q?state.rows:state.rows.filter(row=>[row.classify,row.id,row.route,row.delivery_date,row.camp,row.wave].some(v=>clean(v).toLowerCase().includes(q)));
        renderSummary();renderTable();
      }

      function renderSummary(){
        const period=getSelectedPeriod();const rows=state.filtered;const delivery=rows.filter(r=>!isFreshbagClassify(r.classify)).length;const freshbag=rows.filter(r=>isFreshbagClassify(r.classify)).length;
        const defaultSum=rows.reduce((s,r)=>s+Number(r.default_price||0),0);const freshbagSum=rows.reduce((s,r)=>s+Number(r.freshbag_incentive_price||0),0);const totalSum=rows.reduce((s,r)=>s+Number(r.total_price||0),0);
        els.summaryPeriod.textContent=`${period.date_year}.${String(period.date_month).padStart(2,"0")}`;els.summaryRows.textContent=rows.length.toLocaleString("ko-KR");els.summaryDelivery.textContent=delivery.toLocaleString("ko-KR");els.summaryFreshbag.textContent=freshbag.toLocaleString("ko-KR");els.summaryDefault.textContent=money(defaultSum);els.summaryFreshbagPrice.textContent=money(freshbagSum);els.summaryTotal.textContent=money(totalSum);
      }

      function renderTable(){
        const headers=["No","구분","ID","Route","배송일자","캠프","배송유형","배송건수","반품","단가","프백인센","기본금액","프백금액","총금액","프백회수"];
        els.dataTable.querySelector("thead").innerHTML=`<tr>${headers.map(h=>`<th>${esc(h)}</th>`).join("")}</tr>`;
        if(!state.filtered.length){els.dataTable.querySelector("tbody").innerHTML=`<tr><td colspan="${headers.length}"><div class="emptyBox">조회된 데이터가 없습니다.</div></td></tr>`;els.tableNote.textContent="0행";return}
        els.dataTable.querySelector("tbody").innerHTML=state.filtered.map((row,idx)=>`<tr><td>${idx+1}</td><td class="${isFreshbagClassify(row.classify)?"warn":""}">${esc(row.classify)}</td><td class="left">${esc(row.id)}</td><td>${esc(row.route)}</td><td>${esc(row.delivery_date)}</td><td>${esc(row.camp)}</td><td>${esc(row.wave)}</td><td>${money(row.parcel)}</td><td>${money(row["return"])}</td><td>${money(row.price)}</td><td class="warn">${money(row.freshbag_incentive)}</td><td class="money">${money(row.default_price)}</td><td class="warn">${money(row.freshbag_incentive_price)}</td><td class="money">${money(row.total_price)}</td><td>${money(row.freshbag_return)}</td></tr>`).join("");
        els.tableNote.textContent=`${state.filtered.length.toLocaleString("ko-KR")}행 표시`;
      }

      function exportExcel(){
        if(!state.filtered.length){setStatus("다운로드할 데이터가 없습니다.","warn");return}
        const period=getSelectedPeriod();
        const rows=state.filtered.map((r,idx)=>({No:idx+1,정산연도:r.date_year,정산월:r.date_month,구분:r.classify,ID:r.id,Route:r.route,배송일자:r.delivery_date,캠프:r.camp,배송유형:r.wave,배송건수:r.parcel,반품:r["return"],단가:r.price,프백인센:r.freshbag_incentive,기본금액:r.default_price,프백금액:r.freshbag_incentive_price,총금액:r.total_price,프백회수:r.freshbag_return}));
        const ws=XLSX.utils.json_to_sheet(rows);const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,"정산데이터");
        XLSX.writeFile(wb,`maroowell_account_${period.date_year}_${String(period.date_month).padStart(2,"0")}.xlsx`);
      }

      function resetPage(){state.rows=[];state.filtered=[];els.searchInput.value="";setStatus("정산 연도와 월을 선택하고 조회를 누르세요.","");renderSummary();renderTable()}
      function bind(){els.btnLogout.addEventListener("click",logout);els.deniedLogoutBtn.addEventListener("click",logout);els.deniedHomeBtn.addEventListener("click",()=>{location.href=HOME_PATH});els.btnLoad.addEventListener("click",loadRows);els.btnExcel.addEventListener("click",exportExcel);els.btnReset.addEventListener("click",resetPage);els.searchInput.addEventListener("input",applyFilter);els.yearSelect.addEventListener("change",resetPage);els.monthSelect.addEventListener("change",resetPage)}
      async function boot(){initPeriodSelects();bind();renderSummary();renderTable();try{await checkAccess()}catch(err){console.error(err);showAccessDenied(err.message||String(err))}}
      boot();
    })();
  </script>
</body>
</html>
