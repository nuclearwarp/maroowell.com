      async function downloadPng() {
        const target = dom.statementCapture;
        if (!target || target.style.display === "none") return;
        if (!window.htmlToImage) {
          alert("PNG 저장 라이브러리를 불러오지 못했습니다.");
          return;
        }

        const group = state.groups.find(item => item.key === state.selectedGroupKey);
        const safeName = (group?.name || "정산서").replace(/[\\/:*?"<>|]/g, "_");
        const fileName = "마루웰_" + state.month + "_용차정산서_" + safeName + ".png";

        setStatePill("warn", "CAPTURE");
        setStatus("PNG 저장용 이미지를 생성하는 중입니다.");
        dom.btnDownloadPng.disabled = true;

        const clone = target.cloneNode(true);
        clone.classList.add("capture-export");
        clone.style.display = "block";
        const host = document.createElement("div");
        host.className = "capture-host";
        host.appendChild(clone);
        document.body.appendChild(host);

        try {
          const dataUrl = await window.htmlToImage.toPng(clone, {
            cacheBust: true,
            pixelRatio: 2,
            backgroundColor: "#ffffff",
            width: clone.scrollWidth,
            height: clone.scrollHeight,
            style: {
              transform: "none",
              transformOrigin: "top left"
            }
          });
          const a = document.createElement("a");
          a.href = dataUrl;
          a.download = fileName;
          document.body.appendChild(a);
          a.click();
          a.remove();
          setStatePill("ok", "READY");
          setStatus("PNG 저장 완료: " + fileName);
        } catch (err) {
          console.error(err);
          setStatePill("err", "ERROR");
          setStatus("PNG 저장 실패: " + (err?.message || err));
          alert("PNG 저장 실패: " + (err?.message || err));
        } finally {
          host.remove();
          dom.btnDownloadPng.disabled = false;
        }
      }

      function bindEvents() {
        dom.monthInput.value = state.month;

        dom.btnReload.addEventListener("click", () => loadRows().catch(err => {
          console.error(err);
          setStatePill("err", "ERROR");
          setStatus("불러오기 실패: " + (err?.message || err));
          dom.btnReload.disabled = false;
        }));

        dom.btnDownloadPng.addEventListener("click", () => downloadPng());
        dom.btnLogout.addEventListener("click", () => logout());
        dom.btnDeniedLogout.addEventListener("click", () => logout());
        dom.btnDeniedHome.addEventListener("click", () => { window.location.href = INDEX_PATH; });

        dom.btnClearSearch.addEventListener("click", () => {
          dom.searchInput.value = "";
          render();
        });

        dom.monthInput.addEventListener("change", () => {
          state.month = parseMonthInput(dom.monthInput.value);
          dom.monthInput.value = state.month;
          state.selectedGroupKey = "";
          render();
        });

        dom.monthInput.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            state.month = parseMonthInput(dom.monthInput.value);
            dom.monthInput.value = state.month;
            state.selectedGroupKey = "";
            render();
          }
        });

        dom.searchInput.addEventListener("input", () => {
          state.selectedGroupKey = "";
          render();
        });

        dom.btnModeVendor.addEventListener("click", () => {
          if (state.mode === "vendor") return;
          state.mode = "vendor";
          state.selectedGroupKey = "";
          dom.btnModeVendor.classList.add("active");
          dom.btnModeDriver.classList.remove("active");
          render();
        });

        dom.btnModeDriver.addEventListener("click", () => {
          if (state.mode === "driver") return;
          state.mode = "driver";
          state.selectedGroupKey = "";
          dom.btnModeDriver.classList.add("active");
          dom.btnModeVendor.classList.remove("active");
          render();
        });
      }

      async function boot() {
        bindEvents();
        document.documentElement.style.visibility = "visible";
        if (!(await ensureAuthenticated())) return;
        if (!(await checkAccess())) return;
        await loadRows();
      }

      boot().catch(err => {
        console.error(err);
        document.documentElement.style.visibility = "visible";
        setStatePill("err", "ERROR");
        setStatus("초기화 실패: " + (err?.message || err));
      });
    })();
  </script>
  <script src="/board-menu.js"></script>
</body>
</html>
