    @media(max-width:1280px){.toolbar{grid-template-columns:repeat(3,minmax(0,1fr))}.toolbar .btn{width:100%}.pillGrid{grid-template-columns:repeat(4,minmax(0,1fr))}.grid2{grid-template-columns:1fr}.aliasBox{grid-template-columns:1fr}}@media(max-width:720px){.brandText h1{font-size:18px}.brandText p,.userBadge{display:none}.topbar{padding:10px}.topbar .btn{height:34px;padding:0 10px;font-size:12px}.toolbar{grid-template-columns:1fr}.pillGrid{grid-template-columns:repeat(2,minmax(0,1fr))}.wrap{padding:10px 8px 36px}.cardBody{padding:12px}.tableWrap{max-height:none}}
