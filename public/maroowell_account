        ctx.fillStyle="#111827";
        ctx.font=`700 24px ${graphFont}`;
        ctx.textAlign="left";
        ctx.textBaseline="middle";
        ctx.fillText(data.title,24,34);

        const statsBottom = drawGraphStats(ctx,data,graphFont,24,66,width-24);

        if(!rows.length){
