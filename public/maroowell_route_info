  function parsePasteText(text) {
    const lines = String(text || "")
      .split(/\r?\n/g)
      .map(line => line.trimEnd())
      .filter(line => line.trim());

    if (!lines.length) return [];

    const first = lines[0].split("\t").map(clean);

    const hasHeader = first.some(cell => {
      const key = String(cell || "").replace(/\s+/g, "").toLowerCase();

      return [
        "캠프",
        "camp",
        "라우트",
        "route",
        "서브",
        "서서브",
        "설명",
        "정보",
        "memo",
        "coordinate",
        "sub_package",
        "subpackage"
      ].includes(key);
    }) || first.some(cell => ["캠프","라우트","서브","서서브","설명","정보"].includes(cell));

    const header = hasHeader ? first : ["캠프","라우트","서브","서서브","설명","정보"];
    const bodyLines = hasHeader ? lines.slice(1) : lines;

    const keyOf = label => {
      const k = String(label || "").replace(/\s+/g, "").toLowerCase();

      if (k === "캠프" || k === "camp") return "camp";
      if (k === "라우트" || k === "route") return "route";
      if (k === "서브" || k === "sub") return "sub";
      if (k === "서서브" || k === "subsub" || k === "sub_sub" || k === "sub-sub") return "sub_sub";
      if (k === "설명" || k === "description") return "description";
      if (k === "정보" || k === "memo" || k === "메모") return "memo";
      if (k === "좌표" || k === "coordinate") return "coordinate";
      if (k === "subpackage" || k === "sub_package" || k === "패키지") return "sub_package";
      return "";
    };

    const keys = header.map(keyOf);

    return bodyLines.map((line, idx) => {
      const cols = line.split("\t");
      const row = {
        camp: "",
        route: "",
        sub: "",
        sub_sub: "",
        description: "",
        memo: "",
        coordinate: "",
        sub_package: "",
        sort_order: idx
      };

      cols.forEach((value, i) => {
        const key = keys[i];
        if (key) row[key] = clean(value);
      });

      return row;
    }).filter(row => row.camp && row.route);
  }

  async function importPasteRows() {
    const rows = parsePasteText($("pasteTextInput").value);

    if (!rows.length) {
      $("pasteStatusText").textContent = "가져올 행이 없습니다.";
      $("pasteStatusText").className = "status bad";
      return;
    }

    $("pasteStatusText").textContent = `${rows.length}건 저장 중...`;
    $("pasteStatusText").className = "status warn";

    let inserted = 0;
    let updated = 0;

    for (const row of rows) {
      const code = normalizeRoute(`${row.route}${row.sub}${row.sub_sub}`);

      const { data: existing, error: findError } = await supabaseClient
        .from(TABLE_ROUTE)
        .select("id")
        .eq("camp", row.camp)
        .eq("route_code", code)
        .maybeSingle();

      if (findError) throw findError;

      const payload = {
        camp: row.camp,
        route: row.route,
        sub: row.sub || null,
        sub_sub: row.sub_sub || null,
        description: row.description || null,
        memo: row.memo || null,
        coordinate: row.coordinate || null,
        sub_package: row.sub_package || null,
        sort_order: row.sort_order || 0,
        is_active: true
      };

      if (existing?.id) {
        const { error } = await supabaseClient
          .from(TABLE_ROUTE)
          .update(payload)
          .eq("id", existing.id);

        if (error) throw error;
        updated++;
      } else {
        const { error } = await supabaseClient
          .from(TABLE_ROUTE)
          .insert(payload);

        if (error) throw error;
        inserted++;
      }
    }

    $("pasteStatusText").textContent = `저장 완료: 신규 ${inserted}건 / 수정 ${updated}건`;
    $("pasteStatusText").className = "status ok";

    await loadData();
  }

  async function signOut() {
    try {
      await supabaseClient?.auth?.signOut();
    } catch {}

    location.href = cfg.PATHS?.login || "/login.html";
  }

  function bindEvents() {
    $("loadBtn").addEventListener("click", () => run(loadData));

    $("campInput").addEventListener("keydown", e => {
      if (e.key === "Enter") run(loadData);
    });

    $("routeInput").addEventListener("keydown", e => {
      if (e.key === "Enter") run(loadData);
    });

    $("routeList").addEventListener("click", e => {
      const card = e.target.closest("[data-route-id]");
      if (!card) return;
      selectRouteById(card.dataset.routeId);
    });

    $("pointList").addEventListener("click", e => {
      const card = e.target.closest("[data-point-id]");
      if (!card) return;
      selectPoint(card.dataset.pointId);
    });

    $("saveRouteBaseBtn").addEventListener("click", () => run(saveRouteBase));
    $("deleteRouteBtn").addEventListener("click", () => run(deleteSelectedRoute));

    $("saveRouteInfoBtn").addEventListener("click", () => run(saveRouteInfo));
    $("focusRouteBtn").addEventListener("click", focusSelectedRoute);

    $("drawReplaceBtn").addEventListener("click", () => startDrawMode(true));
    $("drawEditBtn").addEventListener("click", startEditPolygonMode);
    $("drawAppendBtn").addEventListener("click", () => startDrawMode(false));
    $("drawUndoBtn").addEventListener("click", undoDrawVertex);
    $("drawSaveBtn").addEventListener("click", () => run(saveDrawPolygon));
    $("drawCancelBtn").addEventListener("click", cancelDrawMode);

    $("savePointBtn").addEventListener("click", () => run(savePoint));
    $("newPointBtn").addEventListener("click", resetPointForm);
    $("softDeletePointBtn").addEventListener("click", () => run(softDeletePoint));

    $("uploadAttachmentBtn").addEventListener("click", () => run(uploadAttachments));

    $("clearAttachmentBtn").addEventListener("click", () => {
      $("attachmentFileInput").value = "";
      $("attachmentCaptionInput").value = "";
      setAttachmentStatus("선택 해제 완료", "ok");
    });

    $("attachmentList").addEventListener("click", e => {
      const openBtn = e.target.closest("[data-action='open-attachment']");
      if (openBtn) {
        openImagePreview(openBtn.dataset.url, openBtn.dataset.caption);
        return;
      }

      const deleteBtn = e.target.closest("[data-action='delete-attachment']");
      if (deleteBtn) {
        run(() => deleteAttachment(deleteBtn.dataset.id));
      }
    });

    $("addPointModeBtn").addEventListener("click", toggleAddPointMode);
    $("toggleMapTypeBtn").addEventListener("click", setMapType);
    $("fitAllBtn").addEventListener("click", fitAll);
    $("resetMapBtn").addEventListener("click", fitAll);

    $("pasteOpenBtn").addEventListener("click", openPasteModal);
    $("pasteCloseBtn").addEventListener("click", closePasteModal);

    $("pasteClearBtn").addEventListener("click", () => {
      $("pasteTextInput").value = "";
      $("pasteStatusText").textContent = "";
    });

    $("pasteImportBtn").addEventListener("click", () => run(importPasteRows));

    $("imageModalCloseBtn").addEventListener("click", closeImagePreview);

    $("imageModal").addEventListener("click", e => {
      if (e.target.id === "imageModal") closeImagePreview();
    });

    $("deniedHomeBtn").addEventListener("click", () => {
      location.href = cfg.PATHS?.index || "/index.html";
    });

    $("deniedLogoutBtn").addEventListener("click", signOut);

    document.addEventListener("keydown", e => {
      if (e.key === "Escape") {
        closePasteModal();
        closeImagePreview();

        if (drawMode) cancelDrawMode();
      }

      if (drawMode && e.key === "Enter") {
        e.preventDefault();
        run(saveDrawPolygon);
      }

      if (drawMode && e.key === "Backspace") {
        e.preventDefault();
        undoDrawVertex();
      }
    });
  }

  function handleError(e) {
    console.error(e);
    setStatus(e.message || String(e), "bad");
    setPointStatus(e.message || String(e), "bad");
    setAttachmentStatus(e.message || String(e), "bad");
    setRouteBaseStatus(e.message || String(e), "bad");

    if (drawMode) {
      setDrawStatus(e.message || String(e), true);
    }
  }

  function run(fn) {
    Promise.resolve().then(fn).catch(handleError);
  }

  initSupabase();
  bindEvents();

  run(async () => {
    const ok = await checkAccess();
    if (!ok) return;

    await initMap();
    await loadData();

    document.documentElement.style.visibility = "visible";
  });
})();
</script>

<script src="/board-menu.js"></script>
</body>
</html>
