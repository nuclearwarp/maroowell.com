  function polygonGeoJsonFromVertices() {
    if (drawVertices.length < 3) throw new Error("폴리곤은 최소 3개 점이 필요합니다.");

    const coords = drawVertices.map(latlng => [latlng.getLng(), latlng.getLat()]);
    const first = coords[0];
    const last = coords[coords.length - 1];

    if (first[0] !== last[0] || first[1] !== last[1]) {
      coords.push(first);
    }

    return {
      type: "Polygon",
      coordinates: [coords]
    };
  }

  async function finishDrawMode() {
    if (!drawMode) {
      setStatus("폴리곤 그리기 모드가 아닙니다.", "bad");
      return;
    }

    if (!selectedRoute) {
      setStatus("선택된 라우트가 없습니다.", "bad");
      return;
    }

    if (drawVertices.length < 3) {
      setStatus("폴리곤은 최소 3개 점이 필요합니다.", "bad");
      return;
    }

    await saveCurrentPolygon();
