<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --line:rgba(255,255,255,.10);
      --txt:#e6eefc;
      --muted:#93a4c7;
      --sheetBg:#eef3f8;
      --headBg:#dde7f3;
      --cellBg:#ffffff;
      --cellAlt:#f9fbfe;
      --cellTxt:#0f172a;
      --line2:#d4dbe5;
      --greenBg:#d9f0c7;
      --greenTxt:#46691c;
      --redBg:#ffd6d0;
      --redTxt:#a33d2c;
      --blueBg:#d8e8ff;
      --blueTxt:#245ecb;
      --grayBg:#e5e7eb;
      --grayTxt:#6b7280;
      --headerH:56px;
      --toolbarH:58px;
      --statusH:46px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      height: 100%;
      font-family: system-ui, -apple-system, "Noto Sans KR", Segoe UI, Roboto, Arial, sans-serif;
      background: var(--bg);
      color: var(--txt);
    }

    body { overflow: hidden; }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--headerH) var(--toolbarH) auto 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:#0c1422;
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
    }

    .spacer{ flex:1; }

    .btn{
      height:38px;
      padding:0 14px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      cursor:pointer;
      font-weight:800;
      font-size:13px;
      color:#fff;
      background:rgba(255,255,255,.06);
      white-space:nowrap;
    }

    .btn:hover{ background:rgba(255,255,255,.11); }
    .btn.primary{ background:rgba(29,78,216,.88); }
    .btn.primary:hover{ background:rgba(29,78,216,.98); }
    .btn.danger{
      background:rgba(185,28,28,.22);
      color:#fecaca;
      border-color:rgba(248,113,113,.24);
    }
    .btn.danger:hover{ background:rgba(185,28,28,.34); }

    .toolbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:10px 12px;
      background:#0b1422;
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .toolGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolGroup label{
      font-size:12px;
      color:var(--muted);
      font-weight:800;
      white-space:nowrap;
    }

    .toolbar input,
    .toolbar select{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbar input:focus,
    .toolbar select:focus{
      border-color:rgba(96,165,250,.55);
    }

    .sheetWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .sheetInner{
      min-width:2210px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
    }

    th, td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child, td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:3;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:13px;
      font-weight:900;
      white-space:nowrap;
    }

    thead tr.filterRow th{
      top:43px;
      z-index:2;
      background:#edf3fb;
      padding:6px;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    tbody tr.paidRow td{
      background:rgba(219,234,254,.72);
    }

    tbody tr.paidRow:nth-child(even) td{
      background:rgba(210,228,250,.82);
    }

    .cellInput,
    .cellSelect,
    .cellTextarea{
      width:100%;
      border:none;
      background:transparent;
      color:var(--cellTxt);
      outline:none;
      font:inherit;
    }

    .cellInput,
    .cellSelect{
      height:44px;
      padding:0 10px;
      font-size:14px;
    }

    .cellTextarea{
      min-height:44px;
      resize:vertical;
      padding:10px;
      line-height:1.4;
      font-size:14px;
    }

    .cellInput:focus,
    .cellSelect:focus,
    .cellTextarea:focus{
      background:rgba(59,130,246,.08);
      box-shadow:inset 0 0 0 2px rgba(59,130,246,.18);
    }

    .readonlyCell{
      height:44px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:900;
      background:rgba(15,23,42,.04);
    }

    .totalCell{
      justify-content:center;
      font-variant-numeric:tabular-nums;
    }

    .amountCell{
      justify-content:flex-end;
      padding:0 12px;
      font-variant-numeric:tabular-nums;
    }

    .emptyDataRow td{
      padding:18px 14px;
      text-align:center;
      color:#64748b;
      font-weight:800;
      background:#f8fbff !important;
    }

    .filterInput,
    .filterSelect{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      outline:none;
    }

    .filterInput:focus,
    .filterSelect:focus{
      border-color:#60a5fa;
    }

    .centerSelectWrap{
      display:grid;
      place-items:center;
      min-height:56px;
      padding:4px 0;
    }

    .chipSelect{
      width:86px;
      margin:0 auto;
      height:32px;
      border-radius:999px;
      font-weight:900;
      text-align:center;
      text-align-last:center;
      appearance:none;
      -webkit-appearance:none;
      padding:0 28px 0 10px;
      border:1px solid rgba(0,0,0,.06);
      background-position:right 10px center;
      background-repeat:no-repeat;
      background-size:10px 10px;
      background-image:url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="%236b7280"><path d="M5.5 7.5 10 12l4.5-4.5" stroke="%236b7280" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>');
    }

    .routeTextarea{
      min-height:56px;
      white-space:pre-wrap;
      word-break:break-word;
      overflow-wrap:anywhere;
      line-height:1.35;
    }

    .currencyField{
      position:relative;
      display:flex;
      align-items:center;
      min-height:44px;
      padding:0 8px;
    }

    .currencyPrefix{
      position:absolute;
      left:10px;
      color:#64748b;
      font-size:13px;
      font-weight:900;
      pointer-events:none;
    }

    .currencyInput{
      padding-left:28px;
      text-align:right;
      font-variant-numeric:tabular-nums;
      font-weight:900;
    }

    .currencyReadonly{
      justify-content:flex-end;
      padding:0 10px;
      font-variant-numeric:tabular-nums;
      font-weight:900;
    }

    .summaryBar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:8px 12px;
      background:#0d1626;
      border-bottom:1px solid var(--line);
    }

    .summaryTitle{
      font-size:12px;
      font-weight:900;
      color:var(--muted);
      white-space:nowrap;
    }

    .summaryCards{
      display:flex;
      gap:10px;
      min-width:0;
      overflow:auto hidden;
    }

    .summaryCard{
      min-width:140px;
      padding:8px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      display:flex;
      flex-direction:column;
      gap:4px;
    }

    .summaryLabel{
      color:var(--muted);
      font-size:11px;
      font-weight:800;
    }

    .summaryValue{
      color:#f8fafc;
      font-size:18px;
      font-weight:900;
      line-height:1.1;
      font-variant-numeric:tabular-nums;
    }

    .summaryValue.money{
      color:#bfdbfe;
    }

    .vendorCell{
      padding:4px 6px;
      align-items:stretch;
    }

    .vendorCell .vendorLookupDisplay{
      min-height:44px;
      height:auto;
      padding:6px 10px;
      display:flex;
      align-items:center;
      justify-content:flex-start;
      white-space:normal;
      overflow:visible;
      text-overflow:clip;
      line-height:1.28;
      word-break:break-all;
      overflow-wrap:anywhere;
    }

    .vendorCell .dateIconBtn{
      min-height:44px;
      height:auto;
      align-self:stretch;
    }

    .vendorLookupField,
    .toolbarVendorField,
    .filterVendorField{
      display:flex;
      align-items:center;
      gap:4px;
      min-width:0;
    }

    .vendorLookupField{
      min-height:44px;
    }

    .vendorLookupDisplay{
      flex:1;
      min-width:0;
      height:32px;
      border:1px solid #c7d2e2;
      border-radius:10px;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:13px;
      text-align:left;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      cursor:pointer;
    }

    .vendorLookupDisplay.empty{
      color:#94a3b8;
      font-weight:700;
    }

    .toolbarVendorField .vendorLookupDisplay{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
      font-size:13px;
    }

    .toolbarVendorField .vendorLookupDisplay.empty{
      color:var(--txt);
      opacity:.72;
    }

    .filterVendorField .vendorLookupDisplay{
      height:34px;
      font-size:12px;
    }

    .vendorPopover{
      position:fixed;
      z-index:10000;
      width:360px;
      max-height:420px;
      border:1px solid #d5deeb;
      border-radius:16px;
      background:#fff;
      box-shadow:0 20px 50px rgba(15,23,42,.22);
      overflow:hidden;
    }

    .vendorPopover.hidden{
      display:none;
    }

    .vendorPopoverHead{
      display:flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      border-bottom:1px solid #e2e8f0;
      background:#f8fafc;
    }

    .vendorSearchInput{
      flex:1;
      height:36px;
      border:1px solid #cbd5e1;
      border-radius:10px;
      padding:0 12px;
      font-size:14px;
      outline:none;
    }

    .vendorSearchInput:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(59,130,246,.12);
    }

    .vendorPopoverBody{
      max-height:320px;
      overflow:auto;
      padding:8px;
    }

    .vendorResultBtn{
      width:100%;
      border:1px solid #e2e8f0;
      border-radius:12px;
      background:#fff;
      padding:10px 12px;
      text-align:left;
      cursor:pointer;
      display:flex;
      flex-direction:column;
      gap:3px;
      margin-bottom:8px;
    }

    .vendorResultBtn:hover{
      background:#f8fbff;
      border-color:#bfdbfe;
    }

    .vendorResultBtn .name{
      color:#0f172a;
      font-size:14px;
      font-weight:900;
    }

    .vendorResultBtn .meta{
      color:#64748b;
      font-size:12px;
      font-weight:700;
    }

    .vendorPopoverFoot{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      padding:10px 12px;
      border-top:1px solid #e2e8f0;
      background:#f8fafc;
    }

    .vendorHint{
      color:#64748b;
      font-size:12px;
      font-weight:700;
    }

    .vendorEmpty{
      padding:18px 12px;
      text-align:center;
      color:#64748b;
      font-weight:800;
    }

    .vendorEmptyActions{
      padding:0 8px 10px;
    }

    .vendorAddInlineBtn{
      width:100%;
      height:40px;
      border:1px solid #bfdbfe;
      border-radius:12px;
      background:#eff6ff;
      color:#1d4ed8;
      font-weight:900;
      cursor:pointer;
    }

    .vendorCreateOverlay{
      position:fixed;
      inset:0;
      z-index:10020;
      background:rgba(15,23,42,.34);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:20px;
    }

    .vendorCreateOverlay.hidden{
      display:none;
    }

    .vendorCreateModal{
      width:min(420px, calc(100vw - 24px));
      border:1px solid #d5deeb;
      border-radius:18px;
      background:#fff;
      box-shadow:0 24px 60px rgba(15,23,42,.24);
      overflow:hidden;
    }

    .vendorCreateHead{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      padding:14px 16px;
      border-bottom:1px solid #e2e8f0;
      background:#f8fafc;
    }

    .vendorCreateTitle{
      color:#0f172a;
      font-size:16px;
      font-weight:900;
    }

    .vendorCreateBody{
      padding:16px;
      display:grid;
      gap:12px;
    }

    .vendorCreateField{
      display:grid;
      gap:6px;
    }

    .vendorCreateField label{
      color:#334155;
      font-size:12px;
      font-weight:900;
    }

    .vendorCreateField input{
      width:100%;
      height:40px;
      border:1px solid #cbd5e1;
      border-radius:12px;
      padding:0 12px;
      font-size:14px;
      outline:none;
    }

    .vendorCreateField input:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(59,130,246,.12);
    }

    .vendorCreateHelp{
      color:#64748b;
      font-size:12px;
      font-weight:700;
      line-height:1.45;
    }

    .vendorCreateFoot{
      display:flex;
      align-items:center;
      justify-content:flex-end;
      gap:8px;
      padding:14px 16px;
      border-top:1px solid #e2e8f0;
      background:#f8fafc;
    }

    .amountInput{
      text-align:right;
      font-variant-numeric:tabular-nums;
      font-weight:900;
    }

    .amountInput.autoAmount{
      color:#475569;
    }

    .amountInput.manualAmount{
      color:#0f172a;
      background:rgba(59,130,246,.06);
    }

    .taxTrue{ background:var(--greenBg); color:var(--greenTxt); }
    .taxFalse{ background:var(--redBg); color:var(--redTxt); }
    .payTrue{ background:var(--blueBg); color:var(--blueTxt); }
    .payFalse{ background:var(--grayBg); color:var(--grayTxt); }

    .rowActions{
      display:flex;
      gap:6px;
      justify-content:center;
      align-items:center;
      padding:6px;
      min-height:44px;
    }

    .miniBtn{
      height:30px;
      min-width:30px;
      padding:0 8px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      cursor:pointer;
      font-size:12px;
      font-weight:800;
    }

    .miniBtn:hover{ background:#f5f7fb; }
    .miniBtn.save{ background:#effcf3; color:#166534; border-color:#b8e3c5; }
    .miniBtn.copy{ background:#eff6ff; color:#1d4ed8; border-color:#c7dcff; }
    .miniBtn.del{ background:#fff1f2; color:#b91c1c; border-color:#fecdd3; }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:6px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{ color:#bbf7d0; }
    .pill.warn{ color:#fde68a; }
    .pill.err{ color:#fecaca; }

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .dateCell{
      position:relative;
      height:44px;
      display:flex;
      align-items:center;
      gap:3px;
      padding:0 4px 0 6px;
    }

    .dateDisplay{
      flex:1;
      height:32px;
      border:1px solid #c7d2e2;
      border-radius:10px;
      background:#fff;
      color:#0f172a;
      padding:0 6px 0 8px;
      font-size:13px;
      text-align:left;
      cursor:pointer;
    }

    .dateDisplay:focus{
      outline:none;
      border-color:#60a5fa;
    }

    .dateNative{
      position:absolute;
      inset:0;
      opacity:0;
      pointer-events:none;
    }

    .dateIconBtn{
      height:28px;
      min-width:28px;
      border:1px solid #c7d2e2;
      background:#fff;
      border-radius:10px;
      cursor:pointer;
      font-size:14px;
    }


    .dateDisplay,
    .toolbarDateDisplay,
    .filterDateDisplay{
      appearance:none;
      -webkit-appearance:none;
      display:flex;
      align-items:center;
      width:100%;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      text-align:left;
      justify-content:flex-start;
    }

    .dateDisplay{
      font-weight:700;
    }

    .dateDisplay.empty,
    .toolbarDateDisplay.empty,
    .filterDateDisplay.empty{
      color:#94a3b8;
      font-weight:700;
    }

    .redDateText{
      color:#dc2626 !important;
      font-weight:700 !important;
      font-size:13px !important;
    }

    .toolbarDateField,
    .filterDateField{
      display:flex;
      align-items:center;
      gap:6px;
      min-width:0;
    }

    .toolbarDateField{
      width:146px;
    }

    .toolbarDateDisplay{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbarDateDisplay:focus{
      border-color:rgba(96,165,250,.55);
    }

    .toolbarDateSep{
      color:var(--muted);
      font-size:12px;
      font-weight:900;
    }

    .filterDateDisplay{
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      outline:none;
    }

    .filterDateDisplay:focus{
      border-color:#60a5fa;
    }

    .toolbarMini,
    .filterMini{
      flex:0 0 auto;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .toolbarMini{
      height:38px;
      min-width:38px;
      border-color:rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
    }

    .filterMini{
      height:34px;
      min-width:34px;
    }

    .calendarPopover{
      position:fixed;
      z-index:9999;
      width:320px;
      padding:12px;
      border:1px solid #d5deeb;
      border-radius:16px;
      background:#fff;
      color:#0f172a;
      box-shadow:0 20px 50px rgba(15,23,42,.22);
    }

    .calendarPopover.hidden{
      display:none;
    }

    .calendarHeader{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      margin-bottom:10px;
    }

    .calendarHeaderLeft{
      display:flex;
      align-items:center;
      gap:8px;
      min-width:0;
    }

    .calendarMonthLabel{
      font-size:16px;
      font-weight:900;
      min-width:88px;
      text-align:center;
    }

    .calendarNavBtn,
    .calendarCloseBtn,
    .calendarActionBtn{
      height:32px;
      min-width:32px;
      border-radius:10px;
      border:1px solid #d7dee9;
      background:#fff;
      color:#0f172a;
      font-size:14px;
      font-weight:900;
      cursor:pointer;
    }

    .calendarNavBtn:hover,
    .calendarCloseBtn:hover,
    .calendarActionBtn:hover{
      background:#f8fafc;
    }

    .calendarActionBtn{
      padding:0 10px;
      min-width:auto;
      font-size:12px;
    }

    .calendarActionBtn.danger{
      color:#b91c1c;
      border-color:#fecdd3;
      background:#fff1f2;
    }

    .calendarWeekHead,
    .calendarGrid{
      display:grid;
      grid-template-columns:repeat(7, 1fr);
      gap:6px;
    }

    .calendarWeekHead{
      margin-bottom:6px;
    }

    .calendarWeekHead div{
      text-align:center;
      font-size:12px;
      font-weight:900;
      color:#64748b;
      padding:4px 0;
    }

