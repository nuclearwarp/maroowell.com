<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />
  <title>마루웰 스케줄</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    html { visibility:hidden; }

    :root{
      --bg:#081120;
      --panel:#101b2f;
      --panel2:#0d1728;
      --line:rgba(255,255,255,.11);
      --line2:rgba(255,255,255,.18);
      --txt:#eaf2ff;
      --muted:#9fb0d0;
      --blue:#60a5fa;
      --green:#16a34a;
      --red:#dc2626;
      --yellow:#f59e0b;
      --cell:#111827;
      --head:#27364d;
      --camp:#bcd0ef;
      --route:#d8ead2;
      --week:#ffdf6a;
      --shadow:0 16px 42px rgba(0,0,0,.28);
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      min-height:100%;
      background:var(--bg);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    body{overflow:hidden}

    button,input,select,textarea{font-family:inherit}

    .app{
      height:100vh;
      height:100dvh;
      display:grid;
      grid-template-rows:auto auto 1fr;
      background:linear-gradient(180deg,var(--bg),#060b13);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:12px 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,#0b1424,#07101d);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
    }

    .logoButton{
      width:34px;
      height:34px;
      border:1px solid transparent;
      border-radius:12px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      flex:0 0 auto;
      cursor:pointer;
      background:rgba(255,255,255,.03);
      transition:background .15s ease,border-color .15s ease,transform .15s ease;
    }

    .logoButton:hover{
      background:rgba(255,255,255,.10);
      border-color:rgba(255,255,255,.18);
      transform:translateY(-1px);
    }

    .logoButton img{
      width:28px;
      height:28px;
      display:block;
    }

    .brandText{min-width:0}

    .brandText h1{
      margin:0;
      font-size:22px;
      line-height:1.05;
      letter-spacing:-.04em;
    }

    .brandText p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .topSpacer{flex:1}

    .userBadge{
      display:inline-flex;
      align-items:center;
      min-height:34px;
      max-width:220px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.05);
      color:#bfdbfe;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .btn{
      height:38px;
      padding:0 13px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.07);
      color:var(--txt);
      font-size:13px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
      touch-action:manipulation;
    }

    .btn:hover{background:rgba(255,255,255,.11)}
    .btn.primary{background:rgba(37,99,235,.75);border-color:rgba(147,197,253,.45)}
    .btn.ok{background:rgba(22,163,74,.55);border-color:rgba(134,239,172,.35)}
    .btn.warn{background:rgba(245,158,11,.34);border-color:rgba(253,230,138,.35)}
    .btn.excel{background:rgba(20,120,70,.7);border-color:rgba(134,239,172,.35)}
    .btn.danger{background:rgba(185,28,28,.42);border-color:rgba(252,165,165,.35);color:#fecaca}
    .btn:disabled{opacity:.55;cursor:not-allowed}

    .toolbar{
      display:grid;
      grid-template-columns:160px 150px 180px minmax(240px,1fr) auto auto auto auto auto auto;
      gap:10px;
      align-items:end;
      padding:12px 14px;
      border-bottom:1px solid var(--line);
      background:var(--panel2);
      position:relative;
      z-index:10;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:5px;
      min-width:0;
    }

    .field label{
      color:#bfdbfe;
      font-size:12px;
      font-weight:900;
    }

    .input,
    .select,
    .weekButton{
      width:100%;
      height:42px;
      border-radius:12px;
      border:1px solid var(--line2);
      background:#0b1220;
      color:var(--txt);
      padding:0 12px;
      font-size:14px;
      font-weight:800;
      outline:none;
    }

    .input:focus,
    .select:focus,
    .weekButton:focus{
      border-color:rgba(96,165,250,.75);
      box-shadow:0 0 0 3px rgba(96,165,250,.12);
    }

    .weekButton{
      display:flex;
      align-items:center;
      justify-content:space-between;
      cursor:pointer;
    }

    .weekButton span:first-child{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .weekButton .chev{
      color:#bfdbfe;
      font-size:12px;
      margin-left:8px;
    }

    .weekPickerWrap{position:relative}

    .weekPopup{
      position:absolute;
      top:calc(100% + 8px);
      left:0;
      width:316px;
      max-width:calc(100vw - 24px);
      border:1px solid rgba(148,163,184,.38);
      border-radius:16px;
      background:#f8fafc;
      color:#0f172a;
      box-shadow:0 24px 70px rgba(0,0,0,.38);
      padding:12px;
      display:none;
      z-index:100;
    }

    .weekPopup.open{display:block}

    .weekPopupHeader{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
    }

    .weekMonthTitle{
      font-weight:1000;
      font-size:15px;
      color:#0f172a;
    }

    .weekNav{display:flex;gap:6px}

    .weekNav button{
      width:34px;
      height:32px;
      border-radius:10px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      font-weight:1000;
      cursor:pointer;
    }

    .weekGrid{
      display:grid;
      grid-template-columns:repeat(7,1fr);
      gap:3px;
    }

    .weekDow{
      height:24px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:12px;
      font-weight:1000;
      color:#475569;
    }

    .weekDay{
      height:32px;
      border:0;
      background:transparent;
      border-radius:8px;
      color:#0f172a;
      font-size:13px;
      font-weight:800;
      cursor:pointer;
    }

    .weekDay.other{color:#94a3b8}
    .weekDay.today{box-shadow:inset 0 0 0 2px rgba(37,99,235,.35)}
    .weekDay.selected{background:#2563eb;color:#fff}
    .weekRowHighlight{background:#dbeafe!important}
    .weekDay.selected.weekRowHighlight{background:#2563eb!important;color:#fff!important}

    .weekPopupFooter{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-top:10px;
      gap:8px;
      font-size:12px;
      color:#475569;
      font-weight:900;
    }

    .weekPopupFooter button{
      height:30px;
      padding:0 10px;
      border-radius:10px;
      border:1px solid #cbd5e1;
      background:#fff;
      color:#0f172a;
      font-weight:1000;
      cursor:pointer;
    }

    .weekBtns{
      display:flex;
      gap:6px;
      align-items:center;
    }

    .metaLine{
      grid-column:1 / -1;
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
      min-height:24px;
      color:#b7c7e6;
      font-size:12px;
      font-weight:800;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:4px;
      padding:5px 10px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.06);
      color:#dbeafe;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{color:#bbf7d0}
    .pill.warn{color:#fde68a}
    .pill.err{color:#fecaca}

    .main{
      min-height:0;
      display:block;
      overflow:hidden;
    }

    .boardWrap{
      min-width:0;
      min-height:0;
      height:100%;
      overflow:auto;
      padding:14px;
      background:#08101d;
    }

    .scheduleBoard{
      min-width:980px;
      border:1px solid var(--line2);
      border-radius:18px;
      overflow:hidden;
      background:#0e1728;
      box-shadow:var(--shadow);
    }

    .boardHeader{
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:12px;
      padding:14px 16px;
      background:linear-gradient(180deg,#17233a,#111c30);
      border-bottom:1px solid var(--line);
    }

    .boardTitle{min-width:0}

    .boardTitle h2{
      margin:0;
      font-size:22px;
      line-height:1.15;
      letter-spacing:-.04em;
    }

    .boardTitle p{
      margin:6px 0 0;
      color:#bfdbfe;
      font-size:13px;
      font-weight:900;
    }

    .boardActions{
      display:flex;
      gap:8px;
      align-items:center;
      flex:0 0 auto;
    }

    table.scheduleTable{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      background:#0f1728;
    }

    .scheduleTable th,
    .scheduleTable td{
      border-right:1px solid rgba(255,255,255,.12);
      border-bottom:1px solid rgba(255,255,255,.12);
      text-align:center;
      vertical-align:middle;
    }

    .scheduleTable th:last-child,
    .scheduleTable td:last-child{border-right:none}
    .scheduleTable tr:last-child td{border-bottom:none}

    .scheduleTable th{
      height:42px;
      padding:7px 6px;
      background:var(--head);
      color:#fff;
      font-size:13px;
      font-weight:1000;
      line-height:1.15;
      white-space:nowrap;
    }

    .scheduleTable th.sun{color:#ff4444}

    .weekCell{
      width:120px;
      background:var(--week)!important;
      color:#111827!important;
      font-size:16px!important;
      font-weight:1000!important;
    }

    .campCell{
      width:110px;
      background:var(--camp)!important;
      color:#0f172a!important;
      font-size:17px!important;
      font-weight:1000!important;
    }

    .routeHead{width:160px}

    .routeCell{
      width:160px;
      padding:0;
      background:var(--route);
      color:#111827;
      font-weight:1000;
    }

    .routeInner{
      display:flex;
      align-items:center;
      gap:6px;
      min-height:42px;
      padding:6px 8px;
    }

    .routeLabel{
      flex:1;
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      text-align:left;
      font-size:14px;
    }

    .expander{
      width:25px;
      height:25px;
      border-radius:999px;
      border:1px solid rgba(15,23,42,.25);
      background:rgba(255,255,255,.72);
      color:#111827;
      font-weight:1000;
      cursor:pointer;
      flex:0 0 auto;
      line-height:1;
    }

    .expander.empty{
      visibility:hidden;
      pointer-events:none;
    }

    .childRoute .routeCell{background:#eef7e9}

    .childRoute .routeLabel{
      padding-left:18px;
      font-size:13px;
      color:#334155;
    }

    .childBadge{
      display:inline-flex;
      align-items:center;
      height:20px;
      padding:0 7px;
      border-radius:999px;
      background:#334155;
      color:white;
      font-size:11px;
      font-weight:900;
      margin-left:4px;
    }

    .cellEdit{
      min-width:0;
      width:100%;
      height:42px;
      border:0;
      border-radius:0;
      padding:5px 7px;
      background:var(--cell);
      color:#f8fafc;
      font-size:13px;
      font-weight:900;
      text-align:center;
      outline:none;
    }

    .cellEdit:focus{
      box-shadow:inset 0 0 0 3px rgba(96,165,250,.65);
      background:#0b1220!important;
      color:#fff!important;
    }

    .cellEdit.dirty{box-shadow:inset 0 -3px 0 rgba(245,158,11,.85)}
    .cellEdit.hasValue{color:#0f172a}
    .cellEdit::placeholder{color:rgba(148,163,184,.8);font-weight:800}

    .emptyBoard{
      padding:48px 16px;
      text-align:center;
      color:#cbd5e1;
      font-weight:900;
      border:1px dashed var(--line2);
      border-radius:18px;
      background:rgba(255,255,255,.035);
    }

    .suggestBox{
      position:fixed;
      display:none;
      z-index:2147482000;
      width:320px;
      max-height:290px;
      overflow:auto;
      border:1px solid rgba(148,163,184,.42);
      border-radius:14px;
      background:#0f172a;
      box-shadow:0 20px 60px rgba(0,0,0,.45);
      padding:6px;
    }

    .suggestBox.open{display:block}

    .suggestItem{
      width:100%;
      display:block;
      text-align:left;
      border:1px solid transparent;
      border-radius:11px;
      background:transparent;
      color:#eaf2ff;
      padding:9px 10px;
      cursor:pointer;
    }

    .suggestItem:hover,
    .suggestItem.active{
      background:rgba(96,165,250,.18);
      border-color:rgba(96,165,250,.35);
    }

    .suggestTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      font-size:13px;
      font-weight:1000;
    }

    .suggestType{
      flex:0 0 auto;
      border-radius:999px;
      padding:2px 8px;
      border:1px solid rgba(255,255,255,.16);
      background:rgba(255,255,255,.08);
      color:#bfdbfe;
      font-size:11px;
      font-weight:1000;
    }

    .suggestMeta{
      margin-top:4px;
      color:#b6c4dc;
      font-size:11px;
      font-weight:800;
      line-height:1.45;
    }

    .captureArea{background:#0e1728}

    .captureArea.export{
      width:1280px!important;
      max-width:none!important;
      min-width:1280px!important;
      border-radius:0!important;
      box-shadow:none!important;
    }

    .captureHost{
      position:fixed;
      left:-200000px;
      top:0;
      width:auto;
      height:auto;
      overflow:visible;
      background:#0e1728;
      padding:24px;
      z-index:-1;
    }

    @media(max-width:1080px){
      body{overflow:auto}

      .app{
        min-height:100dvh;
        height:auto;
        display:block;
      }

      .topbar{
        position:sticky;
        top:0;
        z-index:20;
      }

      .brandText h1{font-size:19px}
      .brandText p{display:none}
      .userBadge{display:none}

      .toolbar{
        position:sticky;
        top:57px;
        z-index:19;
        grid-template-columns:1fr 1fr;
        align-items:end;
      }

      .toolbar > .btn,
      .toolbar > .weekBtns{width:100%}

      .toolbar .btn{width:100%}

      .weekBtns{
        display:grid;
        grid-template-columns:1fr 1fr;
      }

      .metaLine{grid-column:1 / -1}

      .main{display:block;overflow:visible}

      .boardWrap{
        padding:10px;
        overflow:auto;
        height:auto;
      }

      .scheduleBoard{min-width:920px}

      .weekPopup{
        position:fixed;
        left:12px;
        right:12px;
        top:150px;
        width:auto;
      }
    }

    @media(max-width:560px){
      .topbar{padding:10px}

      .logoButton{width:32px;height:32px}
      .logoButton img{width:24px;height:24px}
      .brandText h1{font-size:18px}

      .btn{
        height:36px;
        padding:0 10px;
        font-size:12px;
      }

      .toolbar{
        top:49px;
        grid-template-columns:1fr;
        gap:8px;
        padding:10px;
      }

      .field label{font-size:11px}

      .input,
      .select,
      .weekButton{
        height:40px;
        font-size:13px;
      }

      .metaLine{font-size:11px}
      .boardWrap{padding:8px}

      .boardHeader{
        align-items:flex-start;
        flex-direction:column;
      }

      .boardActions{
        width:100%;
        display:grid;
        grid-template-columns:1fr 1fr;
      }

      .boardActions .btn{width:100%}
      .suggestBox{width:calc(100vw - 20px)}
    }
  </style>
</head>

<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기">
          <img src="/favicon.ico" alt="Maroowell" />
        </a>
        <div class="brandText">
          <h1>마루웰 스케줄</h1>
          <p>캠프 / 주야 / 주차별 입차 스케줄 등록</p>
        </div>
      </div>

      <div class="topSpacer"></div>

      <div id="userBadge" class="userBadge">-</div>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <section class="toolbar">
      <div class="field">
        <label for="campInput">Camp</label>
        <input id="campInput" class="input" type="text" placeholder="예: M익산1, 대구3" autocomplete="off" />
      </div>

      <div class="field">
        <label for="waveSelect">주/야</label>
        <select id="waveSelect" class="select">
          <option value="WAVE2">주간</option>
          <option value="WAVE1">야간</option>
        </select>
      </div>

      <div class="field weekPickerWrap">
        <label>주차</label>
        <button id="weekButton" class="weekButton" type="button">
          <span id="weekButtonText">-</span>
          <span class="chev">▼</span>
        </button>

        <div id="weekPopup" class="weekPopup">
          <div class="weekPopupHeader">
            <div id="weekMonthTitle" class="weekMonthTitle">-</div>
            <div class="weekNav">
              <button id="btnPickerPrev" type="button">‹</button>
              <button id="btnPickerNext" type="button">›</button>
            </div>
          </div>

          <div id="weekGrid" class="weekGrid"></div>

          <div class="weekPopupFooter">
            <button id="btnPickerToday" type="button">오늘</button>
            <span>주 행을 클릭하면 일~토 주차가 선택됩니다.</span>
          </div>
        </div>
      </div>

      <div class="field">
        <label for="searchInput">검색</label>
        <input id="searchInput" class="input" type="text" placeholder="라우트 / 기사 / ID" autocomplete="off" />
      </div>

      <div class="weekBtns">
        <button id="btnPrevWeek" class="btn" type="button">이전주</button>
        <button id="btnNextWeek" class="btn" type="button">다음주</button>
      </div>

      <button id="btnLoad" class="btn primary" type="button">불러오기</button>
      <button id="btnSave" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportMeta" class="btn excel" type="button">엑셀 생성</button>
      <button id="btnCopyImage" class="btn warn" type="button">이미지 복사</button>
      <button id="btnReset" class="btn" type="button">초기화</button>

      <div class="metaLine">
        <span id="statePill" class="pill ok">READY</span>
        <span id="weekPill" class="pill">-</span>
        <span id="rowPill" class="pill">라우트 0</span>
        <span id="dirtyPill" class="pill">미저장 0</span>
        <span id="apiPill" class="pill ok">Worker API</span>
        <span id="statusText">캠프와 주/야를 선택하고 불러오기를 누르세요.</span>
      </div>
    </section>

    <main class="main">
      <section id="boardWrap" class="boardWrap">
        <div id="boardRoot" class="scheduleBoard captureArea">
          <div class="boardHeader">
            <div class="boardTitle">
              <h2 id="boardTitle">스케줄</h2>
              <p id="boardSubTitle">-</p>
            </div>

            <div class="boardActions">
              <button id="btnCollapseAll" class="btn" type="button">전체 접기</button>
              <button id="btnExpandAll" class="btn" type="button">전체 펼치기</button>
            </div>
          </div>

          <div id="tableHost">
            <div class="emptyBoard">
              캠프를 입력하고 불러오기를 누르면 라우트 스케줄 표가 표시됩니다.
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div id="suggestBox" class="suggestBox"></div>

  <script>
    (async function(){
      "use strict";

      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
