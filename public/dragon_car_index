      async function searchVendorLookup(query) {
        const q = String(query || "").trim();
        const seq = ++vendorLookupState.searchSeq;
        vendorLookupState.loading = !!q;
        if (!q) {
          vendorLookupState.results = [];
          vendorLookupState.loading = false;
          renderVendorLookupList();
          return;
        }
        renderVendorLookupList();
        try {
          const rows = await fetchRouteVendors(q);
          if (seq !== vendorLookupState.searchSeq) return;
          vendorLookupState.results = rows;
          rows.forEach(upsertVendorInState);
        } catch (err) {
          if (seq !== vendorLookupState.searchSeq) return;
          vendorLookupState.results = [];
          setStatus('벤더 검색 실패: ' + formatDbError(err), 'err');
        } finally {
          if (seq === vendorLookupState.searchSeq) {
            vendorLookupState.loading = false;
            renderVendorLookupList();
          }
        }
      }

      function renderVendorLookupList() {
        if (!vendorLookupState.root || !vendorLookupState.body) return;
        const ctx = vendorLookupState.ctx || {};
        const vendors = filteredVendors(vendorLookupState.query);
        const emptyLabel = ctx.emptyLabel || "미선택";
        const q = String(vendorLookupState.query || "").trim();
        const items = [];
        if (ctx.allowEmpty !== false) {
          items.push(`
            <button class="vendorResultBtn" type="button" data-vendor-action="pick-empty">
              <span class="name">${esc(emptyLabel)}</span>
              <span class="meta">선택 해제</span>
            </button>
          `);
        }
        if (vendorLookupState.loading) {
          items.push('<div class="vendorEmpty">검색 중...</div>');
        } else {
          for (const vendor of vendors) {
            items.push(`
              <button class="vendorResultBtn" type="button" data-vendor-action="pick" data-vendor-id="${esc(vendor.id)}">
                <span class="name">${esc(vendor.name || "-")}</span>
                <span class="meta">${esc(vendorMeta(vendor) || "벤더")}</span>
              </button>
            `);
          }
          if (!vendors.length) {
            items.push(`<div class="vendorEmpty">${q ? `검색 결과 없음 : &quot;${esc(q)}&quot;` : '검색어를 입력하세요.'}</div>`);
            if (ctx.allowCreate !== false && q) {
              items.push(`
                <div class="vendorEmptyActions">
                  <button class="vendorAddInlineBtn" type="button" data-vendor-action="open-create">"${esc(q)}" 신규 등록</button>
                </div>
              `);
            }
          }
        }
        vendorLookupState.body.innerHTML = items.join("");
        positionVendorLookup();
      }

      function ensureVendorLookup() {
        if (vendorLookupState.root) return;
        const root = document.createElement("div");
        root.className = "vendorPopover hidden";
        root.innerHTML = `
          <div class="vendorPopoverHead">
            <input class="vendorSearchInput" type="text" placeholder="벤더명 / 사업자번호 검색" />
            <button class="calendarCloseBtn" type="button" data-vendor-action="close">✕</button>
          </div>
          <div class="vendorPopoverBody"></div>
          <div class="vendorPopoverFoot">
            <span class="vendorHint">가나다순으로 표시됩니다. 없으면 신규 등록할 수 있습니다.</span>
            <button class="calendarActionBtn danger" type="button" data-vendor-action="clear">선택 해제</button>
          </div>
        `;
        document.body.appendChild(root);
        vendorLookupState.root = root;
        vendorLookupState.body = root.querySelector('.vendorPopoverBody');
        vendorLookupState.searchInput = root.querySelector('.vendorSearchInput');

        vendorLookupState.searchInput.addEventListener('input', () => {
          vendorLookupState.query = vendorLookupState.searchInput.value || "";
          searchVendorLookup(vendorLookupState.query);
        });

        root.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-vendor-action]');
          if (!btn) return;
          const action = btn.dataset.vendorAction;
          const ctx = vendorLookupState.ctx;
          if (action === 'close') {
            closeVendorLookup();
            return;
          }
          if (action === 'clear' || action === 'pick-empty') {
            ctx?.onSelect?.("");
            closeVendorLookup();
            return;
          }
          if (action === 'open-create') {
            openVendorCreateModal({
              initialName: vendorLookupState.query,
              onCreated: (vendor) => {
                ctx?.onSelect?.(vendor?.id || "");
                closeVendorLookup();
              }
            });
            return;
          }
          if (action === 'pick') {
            ctx?.onSelect?.(btn.dataset.vendorId || "");
            closeVendorLookup();
          }
        });

        document.addEventListener('mousedown', (e) => {
          if (!vendorLookupState.root || vendorLookupState.root.classList.contains('hidden')) return;
          const target = e.target;
          if (vendorLookupState.root.contains(target)) return;
          if (vendorLookupState.anchorEl && vendorLookupState.anchorEl.contains && vendorLookupState.anchorEl.contains(target)) return;
          closeVendorLookup();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            closeVendorLookup();
            closeVendorCreateModal();
          }
        });

        window.addEventListener('resize', positionVendorLookup);
        document.addEventListener('scroll', () => {
          if (!vendorLookupState.root || vendorLookupState.root.classList.contains('hidden')) return;
          positionVendorLookup();
        }, true);
      }

      function openVendorLookup(options) {
        ensureVendorLookup();
        vendorLookupState.ctx = options || {};
        vendorLookupState.anchorEl = options?.anchorEl || null;
        vendorLookupState.query = "";
        vendorLookupState.loading = false;
        vendorLookupState.results = [];
        vendorLookupState.searchInput.value = "";
        vendorLookupState.root.classList.remove('hidden');
        renderVendorLookupList();
        vendorLookupState.searchInput.focus();
      }

