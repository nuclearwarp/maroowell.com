  async function loadAttachments(pointId, showErrors = true) {
    attachmentRows = [];
    attachmentSignedUrls = new Map();

    if (!pointId) {
      renderAttachments();
      return;
    }

    try {
      const result = await routeInfoApi("/route-info/attachments/list", {
        point_id: pointId
      });

      attachmentRows = result.attachments || [];
      attachmentSignedUrls = new Map();

      for (const row of attachmentRows) {
        if (row.signed_url) attachmentSignedUrls.set(row.id, row.signed_url);
        else if (row.public_url) attachmentSignedUrls.set(row.id, row.public_url);
      }

      renderAttachments();
    } catch (e) {
      if (showErrors) {
        setAttachmentStatus(e.message || String(e), "bad");
      }
      renderAttachments();
    }
