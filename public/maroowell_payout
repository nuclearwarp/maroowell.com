      function buildSettlementModels(agg) {
        const master = agg.master || {};
        const gross = agg.amountSum;
        const loss = agg.lossSum;
        const deliveryCount = agg.deliveryCount;
        const returnCount = agg.returnCount;
        const { supply, vat } = calcVatSplit(gross);

        const fixedCommission = parseFixedAmount(master.fixed_commission_amount);
        const fixedUnit = parseFixedAmount(master.fixed_unit_price);
        const dragonDeduction = calcDragonDeduction(master.dragon_car_commission, gross);
        const insuranceDeduction = calcInsuranceDeduction(master.employment_accident_insurance, gross);

        const typeMap = buildTypeSummaryMap(agg.rawRows);
        const deliveryAmt =
          (typeMap["배송"]?.amountSum || 0) +
          (typeMap["배송(전월소급)"]?.amountSum || 0);

        const returnAmt =
          (typeMap["반품"]?.amountSum || 0) +
          (typeMap["반품(전월소급)"]?.amountSum || 0);

        const manualAmt = typeMap["수기반영"]?.amountSum || 0;
        const uncontractedAmt = typeMap["미계약 라우트"]?.amountSum || 0;
        const freshbackAmt =
          (typeMap["프레시백 회수 인센티브"]?.amountSum || 0) +
          (typeMap["프레쉬백 회수 인센티브"]?.amountSum || 0);

        const basePayout = gross - loss;
        const newPayout = gross - loss - fixedCommission - dragonDeduction - insuranceDeduction;
        const oldPayout = gross - loss - dragonDeduction - insuranceDeduction;

        return {
          common: { gross, loss, supply, vat, deliveryCount, returnCount },
          main: [
            ["총금액", gross, "정산Raw 총금액 합계"],
            ["분실차감", -loss, "분실파손List 차감금액 합계"],
            ["예상지급액", basePayout, "총금액 - 분실차감"]
          ],
          newer: [
            ["배송 정산금", deliveryAmt, "구분=배송 합계"],
            ["반품 정산금", returnAmt, "반품 포함 구분 합계"],
            ["수기반영", manualAmt, "구분=수기반영"],
            ["미계약 라우트", uncontractedAmt, "구분=미계약 라우트"],
            ["프레시백 인센", freshbackAmt, "프레시백 관련 구분 합계"],
            ["공급가액", supply, "총금액 기준 부가세 제외"],
            ["부가세", vat, "총금액 - 공급가액"],
            ["고정 수수료", -fixedCommission, "기사정보 fixed_commission_amount"],
            ["용차 수수료", -dragonDeduction, "기사정보 dragon_car_commission"],
            ["고용산재", -insuranceDeduction, "기사정보 employment_accident_insurance"],
            ["분실차감", -loss, "분실파손List 차감금액"],
            ["신형 예상지급", newPayout, "총금액 - 각종 공제"]
          ],
          older: [
            ["총 배송건수", deliveryCount, "정산Raw 배송건수 합계"],
            ["총 반품건수", returnCount, "정산Raw 반품건수 합계"],
            ["총금액", gross, "정산Raw 총금액 합계"],
            ["고정 단가", fixedUnit, "기사정보 fixed_unit_price"],
            ["용차 수수료", -dragonDeduction, "기사정보 dragon_car_commission"],
            ["고용산재", -insuranceDeduction, "기사정보 employment_accident_insurance"],
            ["분실차감", -loss, "분실파손List 차감금액"],
            ["구형 예상지급", oldPayout, "총금액 - 주요 공제"]
          ]
        };
      }

