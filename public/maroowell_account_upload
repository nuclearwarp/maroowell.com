<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />
  <title>정산 업로드</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    :root{
      --bg:#081120;
      --panel:#101b2f;
      --panel2:#0d1728;
      --line:rgba(255,255,255,.12);
      --line2:rgba(255,255,255,.18);
      --txt:#eaf2ff;
      --muted:#9fb0d0;
      --blue:#2563eb;
      --green:#16a34a;
      --red:#dc2626;
      --yellow:#f59e0b;
      --cyan:#0891b2;
      --shadow:0 16px 42px rgba(0,0,0,.28);
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      min-height:100%;
      background:var(--bg);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    body{overflow:auto}
    button,input,select,textarea{font-family:inherit}

    .app{
      min-height:100dvh;
      background:linear-gradient(180deg,var(--bg),#060b13);
    }

    .topbar{
      position:sticky;
      top:0;
      z-index:30;
      display:flex;
      align-items:center;
      gap:10px;
      padding:12px 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,#0b1424,#07101d);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
    }

    .logoButton{
      width:34px;
      height:34px;
      border:1px solid transparent;
      border-radius:12px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      flex:0 0 auto;
      cursor:pointer;
      background:rgba(255,255,255,.03);
    }

    .logoButton:hover{
      background:rgba(255,255,255,.10);
      border-color:rgba(255,255,255,.18);
    }

    .logoButton img{
      width:28px;
      height:28px;
      display:block;
    }

    .brandText{min-width:0}

    .brandText h1{
      margin:0;
      font-size:22px;
      line-height:1.05;
      letter-spacing:-.04em;
    }

    .brandText p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .topSpacer{flex:1}

    .userBadge{
      display:inline-flex;
      align-items:center;
      min-height:34px;
      max-width:260px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.05);
      color:#bfdbfe;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .btn{
      min-height:38px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.07);
      color:var(--txt);
      font-size:13px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
      touch-action:manipulation;
    }

    .btn:hover{background:rgba(255,255,255,.11)}
    .btn.primary{background:rgba(37,99,235,.75);border-color:rgba(147,197,253,.45)}
    .btn.ok{background:rgba(22,163,74,.55);border-color:rgba(134,239,172,.35)}
    .btn.warn{background:rgba(245,158,11,.34);border-color:rgba(253,230,138,.35)}
    .btn.copy{background:rgba(14,116,144,.55);border-color:rgba(103,232,249,.35)}
    .btn.danger{background:rgba(185,28,28,.42);border-color:rgba(252,165,165,.35);color:#fecaca}
    .btn:disabled{opacity:.55;cursor:not-allowed}

    .main{
      max-width:1680px;
      margin:0 auto;
      padding:16px;
    }

    .layout{
      display:grid;
      grid-template-columns:420px minmax(0,1fr);
      gap:14px;
      align-items:start;
    }

    .card{
      border:1px solid var(--line2);
      border-radius:18px;
      background:rgba(16,27,47,.92);
      box-shadow:var(--shadow);
      overflow:hidden;
      margin-bottom:14px;
    }

    .cardHead{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:13px 14px;
      border-bottom:1px solid var(--line);
      background:rgba(255,255,255,.04);
    }

    .cardHead h2{
      margin:0;
      font-size:16px;
      letter-spacing:-.03em;
    }

    .cardBody{padding:14px}

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
      margin-bottom:11px;
    }

    .field label{
      color:#bfdbfe;
      font-size:12px;
      font-weight:900;
    }

    .input,.select{
      width:100%;
      min-height:42px;
      border-radius:12px;
      border:1px solid var(--line2);
      background:#0b1220;
      color:var(--txt);
      padding:0 12px;
      font-size:14px;
      font-weight:800;
      outline:none;
    }

    .input[type=file]{
      height:auto;
      padding:10px 12px;
      line-height:1.5;
    }

    .select option{
      background:#111827;
      color:#fff;
    }

    .input:focus,.select:focus{
      border-color:rgba(96,165,250,.75);
      box-shadow:0 0 0 3px rgba(96,165,250,.12);
    }

    .twoCols{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .row{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      align-items:center;
    }

    .checkLine{
      display:grid;
      grid-template-columns:auto 1fr;
      gap:9px;
      align-items:start;
      padding:10px 11px;
      border:1px solid rgba(255,255,255,.10);
      border-radius:14px;
      background:rgba(255,255,255,.035);
      color:#cbd5e1;
      font-size:12px;
      font-weight:800;
      line-height:1.45;
      margin-bottom:10px;
    }

    .checkLine input{
      width:16px;
      height:16px;
      margin-top:2px;
      accent-color:#2563eb;
    }

    .status{
      margin-top:10px;
      color:#b7c7e6;
      font-size:13px;
      font-weight:800;
      line-height:1.55;
      white-space:pre-wrap;
    }

    .status.ok{color:#bbf7d0}
    .status.warn{color:#fde68a}
    .status.err{color:#fecaca}

    .muted{
      color:#9fb0d0;
      font-size:12px;
      font-weight:800;
      line-height:1.55;
    }

    .pillGrid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:8px;
      margin-top:12px;
    }

    .pill{
      min-width:0;
      padding:9px 10px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.11);
      background:rgba(255,255,255,.045);
    }

    .pill span{
      display:block;
      color:#9fb0d0;
      font-size:11px;
      font-weight:900;
    }

    .pill b{
      display:block;
      margin-top:4px;
      font-size:18px;
      line-height:1;
      font-weight:1000;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .errorBox{
      display:none;
      border:1px solid rgba(248,113,113,.35);
      border-radius:16px;
      background:rgba(127,29,29,.26);
      padding:12px;
      margin-bottom:14px;
    }

    .errorBox.show{display:block}

    .errorBox h3{
      margin:0 0 8px;
      color:#fecaca;
      font-size:15px;
    }

    .errorList{
      display:grid;
      gap:7px;
      max-height:260px;
      overflow:auto;
    }

    .errorItem{
      border:1px solid rgba(248,113,113,.28);
      border-radius:12px;
      background:rgba(0,0,0,.18);
      padding:9px 10px;
      color:#fee2e2;
      font-size:12px;
      font-weight:800;
      line-height:1.45;
    }

    .errorItem b{color:#fff}
    .errorItem small{display:block;color:#fecaca;margin-top:3px}

    .tableWrap{
      width:100%;
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:rgba(0,0,0,.18);
      max-height:720px;
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:100%;
      min-width:1540px;
      font-size:12px;
    }

    th,td{
      border-right:1px solid rgba(255,255,255,.10);
      border-bottom:1px solid rgba(255,255,255,.10);
      padding:7px 8px;
      text-align:center;
      white-space:nowrap;
      vertical-align:middle;
    }

    th{
      position:sticky;
      top:0;
      z-index:2;
      background:#27364d;
      color:#fff;
      font-weight:1000;
    }

    td{
      background:rgba(255,255,255,.025);
      color:#e5edff;
    }

    tr.invalid td{
      background:rgba(127,29,29,.35)!important;
      color:#fecaca;
    }

    tr.exempt td{
      background:rgba(245,158,11,.10);
    }

    .left{text-align:left}
    .money{font-variant-numeric:tabular-nums;text-align:right}
    .okText{color:#bbf7d0;font-weight:1000}
    .warnText{color:#fde68a;font-weight:1000}
    .badText{color:#fecaca;font-weight:1000}
    .infoText{color:#bae6fd;font-weight:1000}
    .emptyBox{padding:30px 12px;text-align:center;color:#94a3b8;font-weight:900}

    .logBox{
      white-space:pre-wrap;
      word-break:break-word;
      margin:0;
      max-height:320px;
      overflow:auto;
      padding:12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(0,0,0,.22);
      color:#dbeafe;
      font:12px/1.5 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(7,11,19,.98));
      z-index:2147483000;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(540px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.12);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 70px rgba(0,0,0,.46);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 10px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.65;
      white-space:pre-wrap;
      font-size:14px;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      line-height:1.6;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media(max-width:1080px){
      .layout{grid-template-columns:1fr}
      .topbar{padding:9px 10px}
      .brandText h1{font-size:18px}
      .brandText p{display:none}
      .userBadge{display:none}
    }

    @media(max-width:560px){
      .main{padding:10px}
      .twoCols{grid-template-columns:1fr}
      .row .btn{width:100%}
      .pillGrid{grid-template-columns:1fr}
      .topbar .btn{height:32px;padding:0 8px;font-size:11px}
    }
  </style>
</head>

<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기">
          <img src="/favicon.ico" alt="Maroowell" />
        </a>
        <div class="brandText">
          <h1>정산 업로드1</h1>
          <p>정산Raw 시트 추출 / 월별 등록 / 금액 교차검증</p>
        </div>
      </div>
      <div class="topSpacer"></div>
      <div id="userBadge" class="userBadge">세션 확인 중</div>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <main class="main">
      <div class="layout">
        <section>
          <div class="card">
            <div class="cardHead">
              <h2>정산서 파일</h2>
            </div>
            <div class="cardBody">
              <div class="twoCols">
                <div class="field">
                  <label for="yearSelect">정산 연도</label>
                  <select id="yearSelect" class="select"></select>
                </div>
                <div class="field">
                  <label for="monthSelect">정산 월</label>
                  <select id="monthSelect" class="select"></select>
                </div>
              </div>

              <div class="field">
                <label for="fileInput">정산서 파일</label>
                <input id="fileInput" class="input" type="file" accept=".xlsx,.xls" />
              </div>

              <div class="checkLine">
                <input id="maroowellOnlyCheck" type="checkbox" checked />
                <div>
                  업체명이 <b>마루웰</b>인 행만 업로드합니다.<br>
                  업체명 컬럼이 비어 있으면 행은 유지합니다.
                </div>
              </div>

              <div class="checkLine">
                <input id="replaceMonthCheck" type="checkbox" checked />
                <div>
                  업로드 전 <b>선택 연도/월 데이터만 삭제 후 재등록</b><br>
                  프백 회수율 업로드 방식과 동일하게 월별로 관리합니다.
                </div>
              </div>

              <div class="row">
                <button id="btnParse" class="btn primary" type="button">정산Raw 읽기</button>
                <button id="btnUpload" class="btn ok" type="button" disabled>DB 업로드</button>
                <button id="btnReset" class="btn" type="button">초기화</button>
              </div>

              <div id="statusText" class="status">정산서 파일을 선택하고 정산Raw 읽기를 누르세요.</div>

              <div class="pillGrid">
                <div class="pill"><span>추출 행</span><b id="countRows">0</b></div>
                <div class="pill"><span>검증 오류</span><b id="countErrors">0</b></div>
                <div class="pill"><span>예외 행</span><b id="countExempt">0</b></div>
                <div class="pill"><span>스킵 행</span><b id="countSkipped">0</b></div>
                <div class="pill"><span>기본금액</span><b id="sumDefault">0</b></div>
                <div class="pill"><span>프백 인센티브</span><b id="sumFreshbag">0</b></div>
                <div class="pill"><span>총금액</span><b id="sumTotal">0</b></div>
                <div class="pill"><span>날짜 수</span><b id="countDates">0</b></div>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="cardHead">
              <h2>매핑 / 검증 기준</h2>
            </div>
            <div class="cardBody muted">
              읽는 시트: <b>정산Raw</b><br><br>
              구분 → classify<br>
              ID → id<br>
              Route → route<br>
              배송일자 → delivery_date<br>
              캠프명 → camp<br>
              배송유형 → wave<br>
              배송건수 → parcel<br>
              반품 → return<br>
              단가 → price<br>
              기본배송단가 금액 / 기본금액 → default_price<br>
              추가인센티브 / 프레시백 인센티브 / 프레시백 회수 인센티브 → freshbag_incentive<br>
              추가 인센티브 가중요인 금액 / 프백 인센티브 단가 → freshbag_incentive_price<br>
              총금액 → total_price<br><br>
              검증식:<br>
              1) <b>(배송 + 반품) × 단가 = 기본금액</b><br>
              2) <b>(배송 + 반품) × (단가 + 프백 인센티브 단가) = 총금액</b><br><br>
              <b>미계약 라우트</b>만 계약 단가 기준이 없어 오류 예외로 처리합니다.<br>프백 인센티브 단독 행은 배송/반품 수량 검증 대상이 아니므로 오류 행으로 올리지 않습니다.
            </div>
          </div>

          <div class="card">
            <div class="cardHead">
              <h2>로그</h2>
            </div>
            <div class="cardBody">
              <pre id="logOutput" class="logBox">대기 중</pre>
            </div>
          </div>
        </section>

        <section>
          <div id="validationBox" class="errorBox">
            <h3>금액 검증 오류</h3>
            <div id="validationList" class="errorList"></div>
          </div>

          <div class="card">
            <div class="cardHead">
              <h2>미리보기</h2>
              <span class="muted" id="previewNote">최대 500행 표시 / 오류 행 상단 정렬</span>
            </div>
            <div class="tableWrap">
              <table id="previewTable">
                <thead></thead>
                <tbody>
                  <tr><td><div class="emptyBox">아직 추출된 데이터가 없습니다.</div></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">최고관리자 권한이 필요합니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="deniedHomeBtn" class="btn" type="button">홈으로</button>
        <button id="deniedLogoutBtn" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function(){
      "use strict";

      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY;
      const LOGIN_PATH = CONFIG.PATHS?.login || "/login.html";
      const HOME_PATH = CONFIG.PATHS?.index || "/zipcode_search";
      const TABLE_NAME = "maroowell_account";
      const REQUIRED_SHEET_NAME = "정산Raw";
      const INSERT_CHUNK_SIZE = 500;
      const MONEY_TOLERANCE = 1;

      const els = {
        userBadge: document.getElementById("userBadge"),
        btnLogout: document.getElementById("btnLogout"),
        yearSelect: document.getElementById("yearSelect"),
        monthSelect: document.getElementById("monthSelect"),
        fileInput: document.getElementById("fileInput"),
        maroowellOnlyCheck: document.getElementById("maroowellOnlyCheck"),
        replaceMonthCheck: document.getElementById("replaceMonthCheck"),
        btnParse: document.getElementById("btnParse"),
        btnUpload: document.getElementById("btnUpload"),
        btnReset: document.getElementById("btnReset"),
        statusText: document.getElementById("statusText"),
        logOutput: document.getElementById("logOutput"),
        previewTable: document.getElementById("previewTable"),
        previewNote: document.getElementById("previewNote"),
        validationBox: document.getElementById("validationBox"),
        validationList: document.getElementById("validationList"),
        countRows: document.getElementById("countRows"),
        countErrors: document.getElementById("countErrors"),
        countExempt: document.getElementById("countExempt"),
        countSkipped: document.getElementById("countSkipped"),
        countDates: document.getElementById("countDates"),
        sumDefault: document.getElementById("sumDefault"),
        sumFreshbag: document.getElementById("sumFreshbag"),
        sumTotal: document.getElementById("sumTotal"),
        accessDenied: document.getElementById("accessDenied"),
        accessDeniedText: document.getElementById("accessDeniedText"),
        accessDeniedEmail: document.getElementById("accessDeniedEmail"),
        deniedHomeBtn: document.getElementById("deniedHomeBtn"),
        deniedLogoutBtn: document.getElementById("deniedLogoutBtn")
      };

      const state = {
        user:null,
        access:null,
        rows:[],
        skipped:[],
        fileName:"",
        canUpload:false
      };

      const supabaseClient = SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth:{
              storage:window.sessionStorage,
              persistSession:true,
              autoRefreshToken:true,
              detectSessionInUrl:true
            }
          })
        : null;

      function clean(v){
        return String(v ?? "").trim();
      }

      function compact(v){
        return clean(v).replace(/\s+/g, "").replace(/_/g, "").toLowerCase();
      }

      function esc(v){
        return String(v ?? "")
          .replaceAll("&","&amp;")
          .replaceAll("<","&lt;")
          .replaceAll(">","&gt;")
          .replaceAll('"',"&quot;")
          .replaceAll("'","&#39;");
      }

      function setStatus(message, type = ""){
        els.statusText.textContent = message;
        els.statusText.className = type ? "status " + type : "status";
      }

      function log(value){
        els.logOutput.textContent = typeof value === "string"
          ? value
          : JSON.stringify(value, null, 2);
      }

      function money(v){
        const n = Number(v || 0);
        if(!Number.isFinite(n)) return "0";
        return Math.round(n).toLocaleString("ko-KR");
      }

      function parseNumber(v){
        if(v === null || v === undefined || v === "") return 0;
        if(typeof v === "number"){
          if(!Number.isFinite(v)) return 0;
          return v;
        }

        const s = clean(v)
          .replace(/,/g,"")
          .replace(/원/g,"")
          .replace(/₩/g,"")
          .replace(/\s+/g,"");

        if(!s || s === "-" || s === ".") return 0;

        const n = Number(s.replace(/[^\d.-]/g,""));
        return Number.isFinite(n) ? n : 0;
      }

      function parseIntCount(v){
        return Math.round(parseNumber(v));
      }

      function hasValue(v){
        return !(v === null || v === undefined || clean(v) === "");
      }

      function roundMoney(v){
        const n = Number(v || 0);
        if(!Number.isFinite(n)) return 0;
        return Math.round(n);
      }

      function normalizeRoute(v){
        return clean(v).toUpperCase().replace(/[^0-9A-Z가-힣]/g, "");
      }

      function pad2(v){
        return String(Number(v)).padStart(2, "0");
      }

      function excelSerialToIso(serial){
        const n = Number(serial);
        if(!Number.isFinite(n)) return null;

        const utcDays = Math.floor(n - 25569);
        const dateInfo = new Date(utcDays * 86400 * 1000);

        if(Number.isNaN(dateInfo.getTime())) return null;

        return `${dateInfo.getUTCFullYear()}-${pad2(dateInfo.getUTCMonth() + 1)}-${pad2(dateInfo.getUTCDate())}`;
      }

      function parseDateValue(v){
        if(v instanceof Date && !Number.isNaN(v.getTime())){
          return `${v.getFullYear()}-${pad2(v.getMonth() + 1)}-${pad2(v.getDate())}`;
        }

        if(typeof v === "number") return excelSerialToIso(v);

        const s = clean(v);
        if(!s) return null;

        if(/^\d{5}(\.\d+)?$/.test(s)) return excelSerialToIso(Number(s));

        let m = s.match(/(20\d{2})[.\-/년\s]+(\d{1,2})[.\-/월\s]+(\d{1,2})/);
        if(m) return `${m[1]}-${pad2(m[2])}-${pad2(m[3])}`;

        m = s.match(/^(\d{1,2})[.\-/월]\s*(\d{1,2})/);
        if(m){
          const year = Number(els.yearSelect.value || new Date().getFullYear());
          return `${year}-${pad2(m[1])}-${pad2(m[2])}`;
        }

        return null;
      }

      function isBlankDataRow(row){
        return !row || row.every(v => !hasValue(v));
      }

      function isUncontractedRoute(classify){
        const key = compact(classify);
        return key.includes("미계약") || key.includes("미계약라우트");
      }

      function isFreshbagIncentiveRow(classify){
        const key = compact(classify);
        return (
          key.includes("프레시백") ||
          key.includes("프레쉬백") ||
          key.includes("freshbag") ||
          key.includes("인센티브")
        );
      }

      function isFormulaExempt(classify){
        return isUncontractedRoute(classify);
      }

      function findColumn(headers, names, fallback = -1){
        const keys = headers.map(compact);
        const candidates = names.map(compact);

        for(const c of candidates){
          const exact = keys.findIndex(k => k === c);
          if(exact >= 0) return exact;
        }

        for(const c of candidates){
          const partial = keys.findIndex(k => k.includes(c) || c.includes(k));
          if(partial >= 0) return partial;
        }

        return fallback;
      }

      function findHeaderRow(rows){
        for(let r = 0; r < Math.min(rows.length, 50); r++){
          const keys = (rows[r] || []).map(compact);
          const hasClassify = keys.some(k => k === "구분" || k.includes("구분"));
          const hasId = keys.some(k => k === "id" || k.includes("아이디"));
          const hasRoute = keys.some(k => k === "route" || k.includes("라우트"));
          const hasTotal = keys.some(k => k.includes("총금액") || k.includes("total"));
          if(hasClassify && hasId && hasRoute && hasTotal) return r;
        }

        return 0;
      }

      function detectYearMonthFromFileName(name){
        const s = clean(name);
        const m = s.match(/(20\d{2})\s*년\s*(\d{1,2})\s*월/);
        if(!m) return;

        const year = Number(m[1]);
        const month = Number(m[2]);

        if(year && month >= 1 && month <= 12){
          els.yearSelect.value = String(year);
          els.monthSelect.value = String(month);
        }
      }

      function findColumnExact(headers, names, fallback = -1){
        const keys = headers.map(compact);
        const candidates = names.map(compact);

        for(const c of candidates){
          const exact = keys.findIndex(k => k === c);
          if(exact >= 0) return exact;
        }

        return fallback;
      }

      function findColumnContains(headers, names, fallback = -1, forbidden = []){
        const keys = headers.map(compact);
        const candidates = names.map(compact);
        const forbiddenKeys = forbidden.map(compact);

        for(const c of candidates){
          const exact = keys.findIndex(k => k === c && !forbiddenKeys.some(f => k.includes(f)));
          if(exact >= 0) return exact;
        }

        for(const c of candidates){
          const partial = keys.findIndex(k => {
            if(!k) return false;
            if(forbiddenKeys.some(f => k.includes(f))) return false;
            return k.includes(c) || c.includes(k);
          });
          if(partial >= 0) return partial;
        }

        return fallback;
      }

      function buildColumnMap(headers){
        return {
          classify: findColumnContains(headers, ["구분"], 0),
          id: findColumnContains(headers, ["ID", "아이디"], 1),
          route: findColumnContains(headers, ["Route", "라우트"], 2),
          deliveryDate: findColumnContains(headers, ["배송일자", "배송일", "일자"], 3),
          camp: findColumnContains(headers, ["캠프명", "캠프", "Camp"], 4),
          wave: findColumnContains(headers, ["배송유형", "주간심야", "주야", "Wave"], 5),
          vendor: findColumnContains(headers, ["업체명", "업체", "Vendor"], 6),
          parcel: findColumnContains(headers, ["배송건수", "파슬", "parcel"], 7),
          returnCount: findColumnContains(headers, ["반품", "운송장", "return"], 8),
          price: findColumnContains(headers, ["단가", "반품동일", "price"], 9),

          // 기본 배송단가 금액은 명시 컬럼이 있을 때만 매핑한다. 없으면 (배송+반품)*단가로 계산한다.
          defaultPrice: findColumnContains(headers, ["기본배송단가금액", "기본금액", "기본배송금액", "defaultprice", "baseprice"], -1),

          // 정산Raw의 총금액 컬럼.
          totalPrice: findColumnContains(headers, ["총금액", "총액", "totalprice", "total"], 10),

          // 프백 인센티브는 총 인센티브 금액이다. 검증식의 단가로 쓰지 않는다.
          freshbagIncentive: findColumnContains(headers, [
            "추가인센티브",
            "프레시백인센티브",
            "프레쉬백인센티브",
            "프레시백회수인센티브",
            "프레쉬백회수인센티브",
            "프백인센",
            "freshbagincentive"
          ], -1, ["가중요인", "단가", "unit", "price"]),

          // 프백 인센티브 단가는 추가 인센티브 가중요인 금액 계열 컬럼만 허용한다.
          // 절대 '프레시백 회수 인센티브' 총액 컬럼을 여기에 매핑하지 않는다.
          freshbagPrice: findColumnContains(headers, [
            "추가인센티브가중요인금액",
            "추가인센티브가중요인",
            "프백단가",
            "프레시백단가",
            "프레쉬백단가",
            "freshbagunit",
            "freshbagunitprice"
          ], -1),

          // 회수 수량은 명확한 수량/건수/개수 컬럼만 허용한다. 인센티브 금액 컬럼과 혼동 금지.
          freshbagReturn: findColumnContains(headers, [
            "프레시백회수수량",
            "프레쉬백회수수량",
            "프레시백회수건수",
            "프레쉬백회수건수",
            "프레시백회수개수",
            "프레쉬백회수개수",
            "freshbagreturncount"
          ], -1, ["인센티브", "금액", "price", "단가"])
        };
      }

      function validateAmounts(data, raw, meta){
        const classify = data.classify || "";
        const errors = [];
        const notes = [];

        const qty = Number(data.parcel || 0) + Number(data["return"] || 0);
        const price = Number(data.price || 0);
        const freshbagUnit = Number(data.freshbag_incentive_price || 0);

        if(isUncontractedRoute(classify)){
          notes.push("미계약 라우트: 계약 단가 기준이 없어 금액 검증식 예외 처리");
          return {
            hasError:false,
            exempt:true,
            errors,
            notes,
            expectedDefault:null,
            expectedTotal:null,
            defaultDiff:0,
            totalDiff:0
          };
        }

        if(isFreshbagIncentiveRow(classify) && qty === 0 && price === 0){
          notes.push("프백 인센티브 단독 행: 배송/반품 수량 검증 대상 아님");
          return {
            hasError:false,
            exempt:false,
            errors,
            notes,
            expectedDefault:null,
            expectedTotal:null,
            defaultDiff:0,
            totalDiff:0
          };
        }

        const expectedDefault = roundMoney(qty * price);
        const expectedTotal = roundMoney(qty * (price + freshbagUnit));

        const defaultCompareValue = meta.hasExplicitDefaultPrice ? roundMoney(meta.sourceDefault) : roundMoney(meta.sourceTotal);
        const totalCompareValue = roundMoney(meta.sourceTotal);

        const defaultDiff = roundMoney(defaultCompareValue - expectedDefault);
        const totalDiff = roundMoney(totalCompareValue - expectedTotal);

        if(Math.abs(defaultDiff) > MONEY_TOLERANCE){
          const label = meta.hasExplicitDefaultPrice ? "기본금액" : "총금액 기준 기본금액";
          errors.push(`${label} 불일치: 실제 ${money(defaultCompareValue)} / 예상 ${money(expectedDefault)} / 차이 ${money(defaultDiff)}`);
        }

        if(Math.abs(totalDiff) > MONEY_TOLERANCE){
          errors.push(`총금액 불일치: 실제 ${money(totalCompareValue)} / 예상 ${money(expectedTotal)} / 차이 ${money(totalDiff)}`);
        }

        if(!meta.hasExplicitDefaultPrice){
          notes.push("기본금액 명시 컬럼 없음: default_price는 (배송+반품)×단가 계산값으로 저장");
        }

        if(!meta.hasExplicitFreshbagUnit){
          notes.push("프백 인센티브 단가 컬럼 없음: 총금액 검증은 기본금액 기준으로 수행");
        }

        if(meta.rawFreshbagPriceValue && Math.abs(meta.rawFreshbagPriceValue) > 23){
          notes.push(`프백 인센티브 단가 후보값 ${money(meta.rawFreshbagPriceValue)}은 23원 초과라 단가로 사용하지 않음`);
        }

        return {
          hasError:errors.length > 0,
          exempt:false,
          errors,
          notes,
          expectedDefault,
          expectedTotal,
          defaultDiff,
          totalDiff
        };
      }

      function convertRow(row, col, rowNo){
        const classify = clean(row[col.classify]);
        const driverId = clean(row[col.id]);
        const rawRoute = col.route >= 0 ? row[col.route] : null;
        const route = normalizeRoute(rawRoute);
        const deliveryDate = parseDateValue(col.deliveryDate >= 0 ? row[col.deliveryDate] : null);
        const camp = clean(col.camp >= 0 ? row[col.camp] : "");
        const wave = clean(col.wave >= 0 ? row[col.wave] : "");
        const vendor = clean(col.vendor >= 0 ? row[col.vendor] : "");

        if(els.maroowellOnlyCheck.checked && vendor && vendor !== "마루웰"){
          return {
            skip:true,
            reason:"업체명 필터",
            rowNo,
            vendor,
            classify,
            id:driverId,
            route
          };
        }

        if(!classify && !driverId && !route && !deliveryDate){
          return {
            skip:true,
            reason:"빈 데이터 행",
            rowNo
          };
        }

        const parcel = parseIntCount(col.parcel >= 0 ? row[col.parcel] : 0);
        const returnCount = parseIntCount(col.returnCount >= 0 ? row[col.returnCount] : 0);
        const price = parseNumber(col.price >= 0 ? row[col.price] : 0);

        const rawTotal = parseNumber(col.totalPrice >= 0 ? row[col.totalPrice] : 0);
        const rawDefault = parseNumber(col.defaultPrice >= 0 ? row[col.defaultPrice] : null);
        const rawFreshbagIncentive = parseNumber(col.freshbagIncentive >= 0 ? row[col.freshbagIncentive] : 0);
        const rawFreshbagPriceValue = parseNumber(col.freshbagPrice >= 0 ? row[col.freshbagPrice] : 0);
        const hasExplicitFreshbagUnit = col.freshbagPrice >= 0 && hasValue(row[col.freshbagPrice]) && Math.abs(rawFreshbagPriceValue) <= 23;
        const freshbagUnit = hasExplicitFreshbagUnit ? rawFreshbagPriceValue : 0;
        const freshbagReturn = parseIntCount(col.freshbagReturn >= 0 ? row[col.freshbagReturn] : 0);

        const qty = parcel + returnCount;
        const hasExplicitDefaultPrice = col.defaultPrice >= 0 && hasValue(row[col.defaultPrice]);
        const isFreshbag = isFreshbagIncentiveRow(classify);
        const isUncontracted = isUncontractedRoute(classify);

        let defaultPrice = hasExplicitDefaultPrice
          ? rawDefault
          : roundMoney(qty * price);

        let totalPrice = hasValue(row[col.totalPrice])
          ? rawTotal
          : roundMoney(qty * (price + freshbagUnit));

        let freshbagIncentive = rawFreshbagIncentive;
        let freshbagIncentivePrice = freshbagUnit;

        if(isFreshbag){
          defaultPrice = 0;
          totalPrice = rawFreshbagIncentive || rawTotal || 0;
          freshbagIncentive = rawFreshbagIncentive || rawTotal || 0;
          freshbagIncentivePrice = 0;
        }

        if(isUncontracted){
          defaultPrice = rawDefault || rawTotal || 0;
          totalPrice = rawTotal || rawDefault || 0;
          freshbagIncentive = rawFreshbagIncentive || 0;
          freshbagIncentivePrice = 0;
        }

        const data = {
          date_year:Number(els.yearSelect.value),
          date_month:Number(els.monthSelect.value),
          classify: classify || null,
          id: driverId || null,
          route: route || null,
          delivery_date: deliveryDate,
          camp: camp || null,
          wave: wave || null,
          parcel,
          "return": returnCount,
          price,
          freshbag_incentive: freshbagIncentive,
          default_price: defaultPrice,
          freshbag_incentive_price: freshbagIncentivePrice,
          total_price: totalPrice,
          freshbag_return: freshbagReturn
        };

        const validation = validateAmounts(data, row, {
          rowNo,
          hasExplicitDefaultPrice,
          hasExplicitFreshbagUnit,
          sourceDefault:rawDefault,
          sourceTotal:rawTotal,
          rawFreshbagPriceValue
        });

        return {
          skip:false,
          data,
          validation,
          meta:{
            rowNo,
            vendor,
            sourceDefault:rawDefault,
            sourceTotal:rawTotal,
            sourceFreshbagIncentive:rawFreshbagIncentive,
            sourceFreshbagPrice:rawFreshbagPriceValue,
            normalizedFreshbagPrice:freshbagUnit,
            exempt:isUncontracted
          }
        };
      }

      function initSelectors(){
        const now = new Date();
        const thisYear = now.getFullYear();

        const years = [];
        for(let y = thisYear + 1; y >= thisYear - 8; y--){
          years.push(y);
        }

        els.yearSelect.innerHTML = years
          .map(y => `<option value="${y}">${y}년</option>`)
          .join("");

        els.monthSelect.innerHTML = Array.from({length:12}, (_, i) => i + 1)
          .map(m => `<option value="${m}">${m}월</option>`)
          .join("");

        els.yearSelect.value = String(thisYear);
        els.monthSelect.value = String(now.getMonth() + 1);
      }

      async function parseFile(){
        const file = els.fileInput.files?.[0];

        if(!file){
          setStatus("정산서 파일을 먼저 선택하세요.", "warn");
          return;
        }

        state.rows = [];
        state.skipped = [];
        state.fileName = file.name;
        detectYearMonthFromFileName(file.name);
        els.btnUpload.disabled = true;

        setStatus("파일을 읽는 중입니다...", "");

        const buffer = await file.arrayBuffer();
        const workbook = XLSX.read(buffer, {
          type:"array",
          cellDates:false,
          raw:true
        });

        const sheetName = workbook.SheetNames.find(name => clean(name) === REQUIRED_SHEET_NAME)
          || workbook.SheetNames.find(name => clean(name).replace(/\s+/g, "") === REQUIRED_SHEET_NAME);

        if(!sheetName){
          throw new Error(`'${REQUIRED_SHEET_NAME}' 시트를 찾지 못했습니다. 현재 시트: ${workbook.SheetNames.join(", ")}`);
        }

        const sheet = workbook.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(sheet, {
          header:1,
          raw:true,
          defval:null,
          blankrows:false
        });

        if(!rows.length){
          throw new Error("정산Raw 시트에 데이터가 없습니다.");
        }

        const headerRowIndex = findHeaderRow(rows);
        const headers = rows[headerRowIndex] || [];
        const col = buildColumnMap(headers);

        for(let r = headerRowIndex + 1; r < rows.length; r++){
          const row = rows[r] || [];
          if(isBlankDataRow(row)) continue;

          const converted = convertRow(row, col, r + 1);

          if(converted.skip){
            state.skipped.push(converted);
          }else{
            state.rows.push(converted);
          }
        }

        state.rows.sort((a,b) => {
          const ae = a.validation?.hasError ? 1 : 0;
          const be = b.validation?.hasError ? 1 : 0;
          if(ae !== be) return be - ae;

          const ax = a.validation?.exempt ? 1 : 0;
          const bx = b.validation?.exempt ? 1 : 0;
          if(ax !== bx) return bx - ax;

          return Number(a.meta?.rowNo || 0) - Number(b.meta?.rowNo || 0);
        });

        renderSummary();
        renderValidationBox();
        renderPreview();

        const errorCount = state.rows.filter(item => item.validation?.hasError).length;
        const exemptCount = state.rows.filter(item => item.validation?.exempt).length;

        if(!state.rows.length){
          setStatus("업로드 가능한 정산Raw 데이터가 없습니다.", "warn");
          els.btnUpload.disabled = true;
        }else if(errorCount > 0){
          setStatus(`${state.rows.length.toLocaleString("ko-KR")}행 추출 완료. 금액 검증 오류 ${errorCount.toLocaleString("ko-KR")}건이 있습니다. 오류 행을 확인하세요.`, "err");
          els.btnUpload.disabled = false;
        }else{
          setStatus(`${state.rows.length.toLocaleString("ko-KR")}행 추출 완료. 검증 오류 없음. 예외 ${exemptCount.toLocaleString("ko-KR")}행.`, "ok");
          els.btnUpload.disabled = false;
        }

        log({
          file:file.name,
          sheet:sheetName,
          date_year:Number(els.yearSelect.value),
          date_month:Number(els.monthSelect.value),
          header_row:headerRowIndex + 1,
          total_excel_rows:rows.length,
          parsed_rows:state.rows.length,
          skipped_rows:state.skipped.length,
          validation_errors:errorCount,
          validation_exempt_rows:exemptCount,
          skipped_sample:state.skipped.slice(0, 20),
          columns:col,
          headers
        });
      }

      function renderSummary(){
        const dataRows = state.rows.map(item => item.data);
        const errorCount = state.rows.filter(item => item.validation?.hasError).length;
        const exemptCount = state.rows.filter(item => item.validation?.exempt).length;
        const dateCount = new Set(dataRows.map(row => row.delivery_date).filter(Boolean)).size;

        const defaultSum = dataRows.reduce((sum, row) => sum + Number(row.default_price || 0), 0);
        const freshbagSum = dataRows.reduce((sum, row) => sum + Number(row.freshbag_incentive || 0), 0);
        const totalSum = dataRows.reduce((sum, row) => sum + Number(row.total_price || 0), 0);

        els.countRows.textContent = state.rows.length.toLocaleString("ko-KR");
        els.countErrors.textContent = errorCount.toLocaleString("ko-KR");
        els.countExempt.textContent = exemptCount.toLocaleString("ko-KR");
        els.countSkipped.textContent = state.skipped.length.toLocaleString("ko-KR");
        els.countDates.textContent = dateCount.toLocaleString("ko-KR");
        els.sumDefault.textContent = money(defaultSum);
        els.sumFreshbag.textContent = money(freshbagSum);
        els.sumTotal.textContent = money(totalSum);
      }

      function renderValidationBox(){
        const errors = state.rows.filter(item => item.validation?.hasError);

        if(!errors.length){
          els.validationBox.classList.remove("show");
          els.validationList.innerHTML = "";
          return;
        }

        els.validationBox.classList.add("show");

        els.validationList.innerHTML = errors.slice(0, 80).map(item => {
          const row = item.data;
          const v = item.validation;

          return `
            <div class="errorItem">
              <b>Excel ${item.meta.rowNo}행</b>
              / ${esc(row.classify)}
              / ${esc(row.id)}
              / ${esc(row.route)}
              / ${esc(row.delivery_date)}
              <small>${esc(v.errors.join(" / "))}</small>
            </div>
          `;
        }).join("");

        if(errors.length > 80){
          els.validationList.innerHTML += `
            <div class="errorItem">
              그 외 ${errors.length - 80}건의 오류가 더 있습니다. 미리보기 표 상단에서 확인하세요.
            </div>
          `;
        }
      }

      function renderPreview(){
        const headers = [
          "검증", "Excel행", "구분", "ID", "Route", "배송일자", "캠프", "배송유형",
          "배송", "반품", "단가", "프백 인센티브", "프백 인센티브 단가", "기본금액", "총금액",
          "예상기본", "기본차이", "예상총액", "총액차이", "메모"
        ];

        els.previewTable.querySelector("thead").innerHTML = `<tr>${headers.map(h => `<th>${esc(h)}</th>`).join("")}</tr>`;

        const shown = state.rows.slice(0, 500);

        if(!shown.length){
          els.previewTable.querySelector("tbody").innerHTML = `<tr><td colspan="${headers.length}"><div class="emptyBox">아직 추출된 데이터가 없습니다.</div></td></tr>`;
          els.previewNote.textContent = "최대 500행 표시 / 오류 행 상단 정렬";
          return;
        }

        els.previewTable.querySelector("tbody").innerHTML = shown.map((item) => {
          const row = item.data;
          const validation = item.validation || {};
          const invalid = validation.hasError;
          const exempt = validation.exempt;

          const statusText = invalid ? "오류" : (exempt ? "예외" : "정상");
          const statusClass = invalid ? "badText" : (exempt ? "warnText" : "okText");
          const trClass = invalid ? "invalid" : (exempt ? "exempt" : "");

          const memo = [
            ...(validation.errors || []),
            ...(validation.notes || [])
          ].join(" / ");

          return `
            <tr class="${trClass}">
              <td class="${statusClass}">${esc(statusText)}</td>
              <td>${esc(item.meta.rowNo)}</td>
              <td>${esc(row.classify)}</td>
              <td class="left">${esc(row.id)}</td>
              <td>${esc(row.route)}</td>
              <td>${esc(row.delivery_date)}</td>
              <td>${esc(row.camp)}</td>
              <td>${esc(row.wave)}</td>
              <td class="money">${money(row.parcel)}</td>
              <td class="money">${money(row["return"])}</td>
              <td class="money">${money(row.price)}</td>
              <td class="money">${money(row.freshbag_incentive)}</td>
              <td class="money">${money(row.freshbag_incentive_price)}</td>
              <td class="money">${money(row.default_price)}</td>
              <td class="money">${money(row.total_price)}</td>
              <td class="money">${validation.expectedDefault === null || validation.expectedDefault === undefined ? "-" : money(validation.expectedDefault)}</td>
              <td class="money ${Math.abs(validation.defaultDiff || 0) > MONEY_TOLERANCE ? "badText" : ""}">${validation.exempt ? "-" : money(validation.defaultDiff || 0)}</td>
              <td class="money">${validation.expectedTotal === null || validation.expectedTotal === undefined ? "-" : money(validation.expectedTotal)}</td>
              <td class="money ${Math.abs(validation.totalDiff || 0) > MONEY_TOLERANCE ? "badText" : ""}">${validation.exempt ? "-" : money(validation.totalDiff || 0)}</td>
              <td class="left">${esc(memo)}</td>
            </tr>
          `;
        }).join("");

        const errorCount = state.rows.filter(item => item.validation?.hasError).length;
        els.previewNote.textContent = `최대 500행 표시 / 전체 ${state.rows.length.toLocaleString("ko-KR")}행 / 오류 ${errorCount.toLocaleString("ko-KR")}건`;
      }

      async function deleteSelectedMonthRows(){
        const year = Number(els.yearSelect.value);
        const month = Number(els.monthSelect.value);

        const { error } = await supabaseClient
          .from(TABLE_NAME)
          .delete()
          .eq("date_year", year)
          .eq("date_month", month);

        if(error) throw error;
      }

      async function uploadRows(){
        if(!state.rows.length){
          setStatus("업로드할 데이터가 없습니다.", "warn");
          return;
        }

        const errorCount = state.rows.filter(item => item.validation?.hasError).length;
        const year = Number(els.yearSelect.value);
        const month = Number(els.monthSelect.value);

        if(errorCount > 0){
          const ok = confirm(`금액 검증 오류가 ${errorCount.toLocaleString("ko-KR")}건 있습니다.\n오류 행까지 포함해서 업로드할까요?`);
          if(!ok) return;
        }

        if(!confirm(`${year}년 ${month}월 정산 데이터 ${state.rows.length.toLocaleString("ko-KR")}행을 DB에 업로드할까요?`)) return;

        els.btnUpload.disabled = true;
        els.btnParse.disabled = true;
        setStatus("DB 업로드 중입니다...", "");

        try{
          if(els.replaceMonthCheck.checked){
            const ok = confirm(`${year}년 ${month}월 기존 정산 데이터를 먼저 삭제하고 재등록합니다. 계속할까요?`);
            if(!ok) return;

            setStatus(`${year}년 ${month}월 기존 데이터를 삭제하는 중입니다...`, "warn");
            await deleteSelectedMonthRows();
          }

          const records = state.rows.map(item => item.data);
          let inserted = 0;

          for(let i = 0; i < records.length; i += INSERT_CHUNK_SIZE){
            const chunk = records.slice(i, i + INSERT_CHUNK_SIZE);
            const { error } = await supabaseClient
              .from(TABLE_NAME)
              .insert(chunk);

            if(error) throw error;

            inserted += chunk.length;
            setStatus(`DB 업로드 중... ${inserted.toLocaleString("ko-KR")} / ${records.length.toLocaleString("ko-KR")}행`, "");
          }

          setStatus(`업로드 완료: ${year}년 ${month}월 / ${inserted.toLocaleString("ko-KR")}행`, "ok");
          log({
            result:"success",
            file:state.fileName,
            date_year:year,
            date_month:month,
            inserted_rows:inserted,
            replaced_selected_month:els.replaceMonthCheck.checked,
            validation_errors:errorCount
          });
        }catch(err){
          console.error(err);
          setStatus(`업로드 실패: ${err.message || err}`, "err");
          log({ result:"error", message:err.message || String(err), details:err });
        }finally{
          els.btnUpload.disabled = !state.rows.length;
          els.btnParse.disabled = false;
        }
      }

      function resetPage(){
        state.rows = [];
        state.skipped = [];
        state.fileName = "";
        els.fileInput.value = "";
        els.btnUpload.disabled = true;
        setStatus("정산서 파일을 선택하고 정산Raw 읽기를 누르세요.", "");
        log("대기 중");
        renderSummary();
        renderValidationBox();
        renderPreview();
      }

      function showAccessDenied(message){
        els.accessDeniedText.textContent = message || "최고관리자 권한이 필요합니다.";
        els.accessDeniedEmail.textContent = state.user?.email
          ? `현재 계정: ${state.user.email}`
          : "로그인 계정을 확인할 수 없습니다.";
        els.accessDenied.classList.add("show");
        document.documentElement.style.visibility = "visible";
      }

      async function logout(){
        try{
          if(supabaseClient) await supabaseClient.auth.signOut();
        }catch{}
        location.href = LOGIN_PATH;
      }

      async function checkAccess(){
        if(!supabaseClient){
          showAccessDenied("Supabase 설정을 찾지 못했습니다. config.js를 확인하세요.");
          return false;
        }

        const { data:sessionData, error:sessionError } = await supabaseClient.auth.getSession();

        if(sessionError){
          showAccessDenied(sessionError.message);
          return false;
        }

        const session = sessionData?.session;

        if(!session?.user){
          location.href = LOGIN_PATH + "?next=" + encodeURIComponent(location.pathname);
          return false;
        }

        state.user = session.user;
        els.userBadge.textContent = session.user.email || session.user.id;

        const { data:access, error:accessError } = await supabaseClient
          .rpc("mw_my_access")
          .maybeSingle();

        if(accessError){
          showAccessDenied(accessError.message);
          return false;
        }

        state.access = access;

        state.canUpload =
          access?.is_maroowell === true &&
          access?.is_admin === true &&
          Number(access?.max_role_level || 0) >= 90;

        if(!state.canUpload){
          showAccessDenied("최고관리자 권한이 필요합니다.\n조건: 마루웰 권한 + 관리자 권한 + role_level 90 이상");
          return false;
        }

        document.documentElement.style.visibility = "visible";
        return true;
      }

      function bind(){
        els.btnLogout.addEventListener("click", logout);
        els.deniedLogoutBtn.addEventListener("click", logout);
        els.deniedHomeBtn.addEventListener("click", () => { location.href = HOME_PATH; });

        els.fileInput.addEventListener("change", () => {
          const file = els.fileInput.files?.[0];
          if(file) detectYearMonthFromFileName(file.name);
        });

        els.btnParse.addEventListener("click", async () => {
          try{
            await parseFile();
          }catch(err){
            console.error(err);
            setStatus(`분석 실패: ${err.message || err}`, "err");
            log({ result:"error", message:err.message || String(err), details:err });
          }
        });

        els.btnUpload.addEventListener("click", uploadRows);
        els.btnReset.addEventListener("click", resetPage);

        els.yearSelect.addEventListener("change", () => {
          state.rows.forEach(item => { item.data.date_year = Number(els.yearSelect.value); });
        });

        els.monthSelect.addEventListener("change", () => {
          state.rows.forEach(item => { item.data.date_month = Number(els.monthSelect.value); });
        });
      }

      async function boot(){
        initSelectors();
        bind();
        renderSummary();
        renderValidationBox();
        renderPreview();

        const allowed = await checkAccess();
        if(!allowed) return;

        setStatus("정산서 파일을 선택하고 정산Raw 읽기를 누르세요.", "");
      }

      boot();
    })();
  </script>
</body>
</html>
