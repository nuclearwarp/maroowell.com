        return Number.isFinite(n) ? Math.trunc(n) : 0;
      }

      function toNum(v) {
        if (v === "" || v == null) return null;
        const cleaned = String(v).replace(/[^\d.-]/g, "");
        if (!cleaned) return null;
        const n = Number(cleaned);
        return Number.isFinite(n) ? n : null;
      }

