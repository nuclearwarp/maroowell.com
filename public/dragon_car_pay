              <td class="blank">&nbsp;</td><td class="blank">&nbsp;</td><td class="blank">&nbsp;</td>
            </tr>
          `;
        }

        return html;
      }

      function renderVendorStatement(g){
        const s = g.stats;

        return `
          <div id="invoiceTitleBox" class="invoiceTitleBox">마루웰 백업지원 대금 청구서</div>

          <div class="invoiceMeta">
            <div class="label">정산월</div>
            <div class="value">${esc(monthTitle(state.month))}</div>

            <div class="label">구분</div>
