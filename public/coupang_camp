<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>쿠팡 캠프 조회</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --bg2:#08111f;
      --panel:#0c1524;
      --line:rgba(255,255,255,.08);
      --line2:#d4dbe5;
      --txt:#e6eefc;
      --muted:#93a4c7;

      --btn:#162744;
      --btn2:#1a2f55;
      --ok:#1a5a3a;
      --warn:#6a4b13;
      --danger:#6b1b1b;

      --sheetBg:#eef3f8;
      --headBg:#dde7f3;
      --filterBg:#edf3fb;
      --cellBg:#ffffff;
      --cellAlt:#f8fbff;
      --cellTxt:#0f172a;

      --dirtyBg:#e0eeff;
      --dirtyBorder:#60a5fa;

      --topbarH:56px;
      --toolbarH:58px;
      --statusH:44px;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      height:100%;
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
      background:#0a0f1a;
      color:var(--txt);
    }

    body{overflow:hidden}

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--topbarH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,var(--bg),var(--bg2));
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
      letter-spacing:.1px;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:900;
    }

    .spacer{flex:1}

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:var(--btn);
      color:var(--txt);
      cursor:pointer;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
    }

    .btn:hover{background:var(--btn2)}
    .btn.ok{background:rgba(26,90,58,.35);border-color:rgba(0,255,140,.18)}
    .btn.warn{background:rgba(106,75,19,.35);border-color:rgba(255,180,0,.18)}
    .btn.danger{background:rgba(107,27,27,.35);border-color:rgba(255,60,60,.22);color:#ffccd3}
    .btn:disabled{opacity:.6;cursor:not-allowed}

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:var(--panel);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .group{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .group:last-child{
      border-right:none;
      padding-right:0;
    }

    .toggle{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      font-size:12px;
      font-weight:900;
      color:#d9e5ff;
      white-space:nowrap;
    }

    .toggle input{
      margin:0;
      width:16px;
      height:16px;
      accent-color:#2563eb;
      cursor:pointer;
    }

    .helper{
      color:#c7d3ea;
      font-size:12px;
      white-space:nowrap;
    }

    .sheetWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .sheetInner{
      min-width:1480px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
    }

    th,td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child,td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:4;
      background:var(--headBg);
      padding:9px 6px;
      text-align:center;
      font-size:13px;
      font-weight:900;
      white-space:nowrap;
    }

    thead tr.filterRow th{
      top:41px;
      z-index:3;
      background:var(--filterBg);
      padding:6px;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    td.dirty-cell{
      box-shadow:inset 0 0 0 2px var(--dirtyBorder);
      background:var(--dirtyBg) !important;
    }

    .cellDisplay{
      min-height:42px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:8px;
      font-size:13px;
      line-height:1.45;
      word-break:break-word;
      overflow-wrap:anywhere;
      white-space:pre-wrap;
      cursor:default;
    }

    td[data-editable="1"] .cellDisplay{
      cursor:text;
    }

    .cellDisplay.center{text-align:center;justify-content:center}
    .cellDisplay.right{text-align:right;justify-content:flex-end;font-variant-numeric:tabular-nums}
    .cellDisplay.left{text-align:left;justify-content:flex-start}
    .cellDisplay.multiline{
      align-items:flex-start;
      min-height:72px;
    }

    .editInput,
    .editTextarea{
      width:100%;
      border:none;
      outline:none;
      background:transparent;
      color:var(--cellTxt);
      padding:8px;
      font-size:13px;
      line-height:1.45;
      font-family:inherit;
      border-radius:0;
    }

    .editInput{
      min-height:42px;
    }

    .editTextarea{
      min-height:96px;
      resize:vertical;
      white-space:pre-wrap;
      overflow-wrap:anywhere;
    }

    .editInput.center{
      text-align:center;
    }

    .editInput.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .filterInput{
      width:100%;
      height:32px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 9px;
      font-size:12px;
      outline:none;
    }

    .filterInput:focus{
      border-color:#60a5fa;
    }

    .rowActionBtn{
      width:32px;
      height:32px;
      border-radius:10px;
      border:1px solid #d4dbe5;
      background:#fff;
      color:#64748b;
      cursor:pointer;
      font-size:15px;
      font-weight:900;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }

    .rowActionBtn:hover{
      background:#f8fafc;
      border-color:#cbd5e1;
    }

    .rowActionBtn.delete{
      color:#b91c1c;
      border-color:#fecaca;
      background:#fff5f5;
    }

    .emptyDataRow td{
      padding:20px 14px;
      text-align:center;
      color:#64748b;
      font-weight:800;
      background:#f8fbff !important;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:5px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{color:#bbf7d0}
    .pill.warn{color:#fde68a}
    .pill.err{color:#fecaca}

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a id="mwBoardMenuToggle" href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>쿠팡 캠프 조회</b>
        <small>더블클릭으로 수정 / 캠프 주소 및 좌표 관리</small>
      </div>

      <div class="spacer"></div>

      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnAddRow" class="btn warn" type="button">행 추가</button>
      <button id="btnSaveAll" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="group">
        <label class="toggle" for="toggleOnlyChanged">
          <input id="toggleOnlyChanged" type="checkbox" />
          <span>변경 행만 보기</span>
        </label>
      </div>

      <div class="group">
        <button id="btnClearFilters" class="btn" type="button">필터 초기화</button>
      </div>

      <div class="group">
        <span class="helper">필터칸에서 <b>!키워드</b> 또는 <b>-키워드</b> 입력 시 제외 검색</span>
      </div>
    </div>

    <div class="sheetWrap">
      <div class="sheetInner">
        <table>
          <colgroup>
            <col style="width:72px" />
            <col style="width:160px" />
            <col style="width:120px" />
            <col style="width:430px" />
            <col style="width:150px" />
            <col style="width:150px" />
            <col style="width:170px" />
            <col style="width:72px" />
          </colgroup>

          <thead>
            <tr>
              <th>순번</th>
              <th>캠프명</th>
              <th>코드</th>
              <th>주소</th>
              <th>위도</th>
              <th>경도</th>
              <th>MB 캠프</th>
              <th>삭제</th>
            </tr>
            <tr class="filterRow">
              <th></th>
              <th><input class="filterInput" data-filter="camp" placeholder="캠프명 / !일산2" /></th>
              <th><input class="filterInput" data-filter="code" placeholder="코드 / !WC03" /></th>
              <th><input class="filterInput" data-filter="address" placeholder="주소 / !군산" /></th>
              <th><input class="filterInput" data-filter="latitude" placeholder="위도" /></th>
              <th><input class="filterInput" data-filter="longitude" placeholder="경도" /></th>
              <th><input class="filterInput" data-filter="mb_camp" placeholder="MB 캠프 / !M_익산1" /></th>
              <th></th>
            </tr>
          </thead>

          <tbody id="sheetBody"></tbody>
        </table>
      </div>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillDirty" class="pill warn">변경 0</span>
      <span id="statusText" class="statusText">쿠팡 캠프 테이블 준비 완료</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const INDEX_PATH = PATHS?.index || "/index.html";
      const LOGIN_PATH = PATHS?.login || "/login.html";

      const ACCESS_TABLE = "user_access";
      const DATA_TABLE = "camps";

      const DATA_COLUMNS = [
        "camp",
        "code",
        "address",
        "latitude",
        "longitude",
        "mb_camp"
      ];

      const NUMERIC_COLUMNS = new Set(["latitude", "longitude"]);

      const COLUMN_CONFIG = [
        { key: "id", label: "순번", type: "readonly", className: "right center" },
        { key: "camp", label: "캠프명", className: "left" },
        { key: "code", label: "코드", className: "center" },
        { key: "address", label: "주소", type: "textarea", className: "left multiline" },
        { key: "latitude", label: "위도", className: "right" },
        { key: "longitude", label: "경도", className: "right" },
        { key: "mb_camp", label: "MB 캠프", className: "center" }
      ];

      const $ = (sel) => document.querySelector(sel);

      const dom = {
        sheetBody: $("#sheetBody"),
        btnReload: $("#btnReload"),
        btnAddRow: $("#btnAddRow"),
        btnSaveAll: $("#btnSaveAll"),
        btnExportCsv: $("#btnExportCsv"),
        btnClearFilters: $("#btnClearFilters"),
        btnLogout: $("#btnLogout"),
        toggleOnlyChanged: $("#toggleOnlyChanged"),
        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillDirty: $("#pillDirty"),
        statusText: $("#statusText"),
        filterInputs: Array.from(document.querySelectorAll(".filterInput")),
        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout")
      };

      const state = {
        rows: [],
        filteredRows: [],
        loading: false,
        viewerEmail: "",
        viewerUserId: "",
        session: null,
        accessRow: null,
        deletedIds: new Set(),
        tempId: 0,
        editingCell: null
      };

      function getSupabaseProjectRef(url) {
        try {
          const host = new URL(url).hostname || "";
          return host.split(".")[0] || "";
        } catch {
          return "";
        }
      }

      function createSupabaseSessionBridge(url) {
        const projectRef = getSupabaseProjectRef(url);
        const prefixes = projectRef ? [
          "sb-" + projectRef + "-auth-token",
          "sb-" + projectRef + "-auth-token-code-verifier"
        ] : [];
        const origin = window.location.origin;
        const channelName = projectRef ? ("mw-auth-bridge:" + projectRef) : "";
        const tabId = (Date.now().toString(36) + Math.random().toString(36).slice(2));
        const pending = new Map();
        let channel = null;
        let started = false;

        function matchesKey(key) {
          return !!key && prefixes.some(prefix => key === prefix || key.startsWith(prefix));
        }

        function readEntries(storage) {
          const target = storage || window.sessionStorage;
          const rows = [];
          try {
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (!matchesKey(key)) continue;
              rows.push({ key, value: target.getItem(key) });
            }
          } catch {}
          return rows;
        }

        function hasSession(storage) {
          return readEntries(storage).some(row =>
            row.key.includes("-auth-token") &&
            !row.key.includes("code-verifier") &&
            !!row.value
          );
        }

        function writeEntries(entries, storage) {
          const target = storage || window.sessionStorage;
          try {
            for (const row of entries || []) {
              if (!row || !matchesKey(row.key)) continue;
              if (row.value == null) target.removeItem(row.key);
              else target.setItem(row.key, row.value);
            }
          } catch {}
        }

        function clearSession(storage) {
          const target = storage || window.sessionStorage;
          try {
            const keys = [];
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (matchesKey(key)) keys.push(key);
            }
            keys.forEach(key => target.removeItem(key));
          } catch {}
        }

        function resolvePending(requestId, entries) {
          const item = pending.get(requestId);
          if (!item) return;
          pending.delete(requestId);
          clearTimeout(item.timer);
          if (Array.isArray(entries) && entries.length) writeEntries(entries, window.sessionStorage);
          item.resolve(hasSession(window.sessionStorage));
        }

        function handleSyncState(syncState) {
          if (syncState === "SIGNED_OUT") {
            clearSession(window.sessionStorage);
            return;
          }
          if (syncState === "SESSION_UPDATED" && !hasSession(window.sessionStorage)) {
            requestSessionCopy(1200).catch(() => {});
          }
        }

        function onWindowMessage(event) {
          if (event.origin !== origin) return;
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              event.source?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              }, origin);
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function onChannelMessage(event) {
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              channel?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              });
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function start() {
          if (started || !projectRef) return;
          started = true;
          window.addEventListener("message", onWindowMessage);
          try {
            if ("BroadcastChannel" in window) {
              channel = new BroadcastChannel(channelName);
              channel.addEventListener("message", onChannelMessage);
            }
          } catch {}
        }

        function requestSessionCopy(timeoutMs) {
          start();
          if (!projectRef) return Promise.resolve(false);
          if (hasSession(window.sessionStorage)) return Promise.resolve(true);

          const requestId = tabId + ":" + Date.now().toString(36) + Math.random().toString(36).slice(2);
          const payload = {
            type: "MW_SESSION_REQUEST",
            projectRef,
            requestId,
            fromTabId: tabId
          };

          return new Promise(resolve => {
            const timer = window.setTimeout(() => {
              pending.delete(requestId);
              resolve(hasSession(window.sessionStorage));
            }, Math.max(300, Number(timeoutMs) || 900));

            pending.set(requestId, { resolve, timer });

            try { channel?.postMessage(payload); } catch {}
            try {
              if (window.opener && window.opener !== window) {
                window.opener.postMessage(payload, origin);
              }
            } catch {}
          });
        }

        function broadcastAuthState(syncState) {
          start();
          const payload = {
            type: "MW_AUTH_SYNC",
            projectRef,
            state: syncState,
            fromTabId: tabId
          };
          try { channel?.postMessage(payload); } catch {}
          try {
            if (window.opener && window.opener !== window) {
              window.opener.postMessage(payload, origin);
            }
          } catch {}
        }

        return {
          start,
          requestSessionCopy,
          broadcastAuthState
        };
      }

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();

      const sessionBridge = createSupabaseSessionBridge(SUPABASE_URL);
      sessionBridge.start();
      await sessionBridge.requestSessionCopy(1200);

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function escapeHtmlWithBreaks(v) {
        return escapeHtml(v).replace(/\n/g, "<br>");
      }

      function formatCoordForInput(v) {
        const s = String(v ?? "").trim();
        if (!s) return "";
        const n = Number(s);
        if (!Number.isFinite(n)) return s;
        return String(n);
      }

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";
        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnAddRow.disabled = !!on;
        dom.btnSaveAll.disabled = !!on;
        dom.btnExportCsv.disabled = !!on;
        dom.btnClearFilters.disabled = !!on;
        if (on) setStatus(text || "처리 중...", "warn");
      }

      function normalizeLoadedRow(row) {
        const out = { ...(row || {}) };
        for (const key of DATA_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }
        out.latitude = formatCoordForInput(out.latitude);
        out.longitude = formatCoordForInput(out.longitude);
        out.__dirty = false;
        out.__isNew = false;
        out.__dirtyFields = {};
        return out;
      }

      function rowId(row) {
        return row.id ?? row.__temp_id;
      }

      function blankRow() {
        const row = {
          __temp_id: "new_" + (++state.tempId),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {}
        };
        for (const key of DATA_COLUMNS) row[key] = "";
        return row;
      }

      function hasAnyValue(row) {
        return DATA_COLUMNS.some(key => normalizeText(row[key]));
      }

      function parseNumericOrNull(value, key) {
        const s = String(value ?? "").trim();
        if (!s) return null;
        const n = Number(s);
        if (!Number.isFinite(n)) {
          throw new Error(`${key} 값이 숫자가 아닙니다: ${value}`);
        }
        return n;
      }

      function valueForSave(key, value) {
        const v = normalizeText(value);
        if (!v) return null;
        if (NUMERIC_COLUMNS.has(key)) return parseNumericOrNull(v, key);
        return v;
      }

      function updatePills() {
        const visibleCount = state.filteredRows.length;
        const dirtyCount = state.rows.filter(row => row.__dirty).length + state.deletedIds.size;
        dom.pillRows.textContent = "행 " + visibleCount;
        dom.pillDirty.textContent = "변경 " + dirtyCount;
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "이 페이지는 마루웰 소속 사용자만 접근할 수 있습니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";
        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
          sessionBridge.broadcastAuthState("SIGNED_OUT");
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function requireAuthAndAccess() {
        if (!supabase || !supabase.auth) {
          alert("Supabase 설정을 확인하세요.");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();

          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          state.session = session;
          state.viewerEmail = normalizeText(session.user?.email || "");
          state.viewerUserId = normalizeText(session.user?.id || "");

          supabase.auth.onAuthStateChange((evt, s) => {
            if (evt === "SIGNED_OUT" || !s) {
              sessionBridge.broadcastAuthState("SIGNED_OUT");
              const next = safeNextPath(location.pathname + location.search + location.hash);
              location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
              return;
            }
            if (evt === "SIGNED_IN" || evt === "TOKEN_REFRESHED" || evt === "USER_UPDATED") {
              sessionBridge.broadcastAuthState("SESSION_UPDATED");
            }
          });

          if (!state.viewerUserId) {
            showAccessDenied(state.viewerEmail, "로그인 사용자 ID를 확인할 수 없습니다.");
            return false;
          }

          const { data: accessRow, error: accessError } = await supabase
            .from(ACCESS_TABLE)
            .select("user_id, email, is_maroowell, is_admin")
            .eq("user_id", state.viewerUserId)
            .maybeSingle();

          if (accessError) {
            console.error(accessError);
            showAccessDenied(state.viewerEmail, "권한 테이블 조회 실패: " + accessError.message);
            return false;
          }

          state.accessRow = accessRow || null;

          if (!accessRow?.is_maroowell || !accessRow?.is_admin) {
            showAccessDenied(
              state.viewerEmail,
              "이 페이지는 마루웰 소속 최고관리자만 접근할 수 있습니다."
            );
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          console.error(e);
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      function parseFilterExpression(raw) {
        const text = normalizeText(raw);
        if (!text) return { include: [], exclude: [] };

        const tokens = text.split(/\s+/).filter(Boolean);
        const include = [];
        const exclude = [];

        for (const token of tokens) {
          if (token.startsWith("!") || token.startsWith("-")) {
            const x = normalizeLower(token.slice(1));
            if (x) exclude.push(x);
          } else {
            include.push(normalizeLower(token));
          }
        }

        return { include, exclude };
      }

      function matchFilter(value, expr) {
        const actual = normalizeLower(value);
        const parsed = parseFilterExpression(expr);

        for (const token of parsed.include) {
          if (!actual.includes(token)) return false;
        }
        for (const token of parsed.exclude) {
          if (actual.includes(token)) return false;
        }
        return true;
      }

      function getRowValue(row, key) {
        if (NUMERIC_COLUMNS.has(key)) return formatCoordForInput(row[key]);
        return normalizeText(row[key]);
      }

      function getDisplayValue(row, key) {
        return getRowValue(row, key) || "-";
      }

      function getEditableValue(row, key) {
        if (NUMERIC_COLUMNS.has(key)) return formatCoordForInput(row[key]);
        return String(row[key] ?? "");
      }

      function findRowById(id) {
        return state.rows.find(row => String(rowId(row)) === String(id)) || null;
      }

      function applyFilters() {
        state.filteredRows = state.rows.filter(row => {
          if (row.id && state.deletedIds.has(row.id)) return false;
          if (dom.toggleOnlyChanged.checked && !row.__dirty) return false;

          for (const input of dom.filterInputs) {
            const key = input.dataset.filter;
            const expr = input.value || "";
            if (!normalizeText(expr)) continue;
            if (!matchFilter(getRowValue(row, key), expr)) return false;
          }

          return true;
        });

        renderTable();
        updatePills();

        if (!state.rows.length) {
          setStatus("데이터가 없습니다.", "warn");
        } else if (state.filteredRows.length !== state.rows.length) {
          setStatus(`필터 결과 ${state.filteredRows.length}건`, "ok");
        } else {
          setStatus(`전체 ${state.rows.length}건 로드 완료`, "ok");
        }
      }

      function isEditing(row, colKey) {
        return !!state.editingCell &&
          String(state.editingCell.rowId) === String(rowId(row)) &&
          state.editingCell.key === colKey;
      }

      function buildDisplayCell(row, col) {
        const rid = rowId(row);
        const value = getDisplayValue(row, col.key);
        const tdClasses = [];
        if (row.__dirtyFields?.[col.key]) tdClasses.push("dirty-cell");

        const displayClasses = ["cellDisplay"];
        if (col.className) displayClasses.push(...col.className.split(" ").filter(Boolean));

        return `
          <td
            data-col="${escapeHtml(col.key)}"
            data-row-id="${escapeHtml(rid)}"
            data-key="${escapeHtml(col.key)}"
            data-editable="1"
            class="${tdClasses.join(" ")}"
            title="더블클릭하여 수정"
          >
            <div class="${displayClasses.join(" ")}">${escapeHtmlWithBreaks(value)}</div>
          </td>
        `;
      }

      function buildEditorCell(row, col) {
        const rid = rowId(row);
        const value = getEditableValue(row, col.key);
        const tdClasses = ["dirty-cell"];
        const commonAttrs = `
          data-row-id="${escapeHtml(rid)}"
          data-key="${escapeHtml(col.key)}"
          class="edit-control"
        `;

        if (col.type === "textarea") {
          return `
            <td data-col="${escapeHtml(col.key)}" class="${tdClasses.join(" ")}">
              <textarea ${commonAttrs} class="editTextarea ${col.className || ""} edit-control">${escapeHtml(value)}</textarea>
            </td>
          `;
        }

        return `
          <td data-col="${escapeHtml(col.key)}" class="${tdClasses.join(" ")}">
            <input
              ${commonAttrs}
              class="editInput ${col.className || ""} edit-control"
              type="text"
              value="${escapeHtml(value)}"
              autocomplete="off"
            />
          </td>
        `;
      }

      function buildDataCell(row, col) {
        if (col.type === "readonly") {
          const displayValue = row.id ?? "NEW";
          return `
            <td data-col="${escapeHtml(col.key)}" class="${row.__dirtyFields?.[col.key] ? "dirty-cell" : ""}">
              <div class="cellDisplay ${col.className || ""}">${escapeHtml(displayValue)}</div>
            </td>
          `;
        }

        return isEditing(row, col.key)
          ? buildEditorCell(row, col)
          : buildDisplayCell(row, col);
      }

      function renderTable() {
        if (!state.filteredRows.length) {
          dom.sheetBody.innerHTML = `
            <tr class="emptyDataRow">
              <td colspan="8">조회 결과가 없습니다.</td>
            </tr>
          `;
          return;
        }

        dom.sheetBody.innerHTML = state.filteredRows.map(row => {
          const rid = rowId(row);
          const cells = COLUMN_CONFIG.map(col => buildDataCell(row, col)).join("");

          return `
            <tr data-row="${escapeHtml(rid)}">
              ${cells}
              <td class="${row.__dirty ? "dirty-cell" : ""}">
                <div class="cellDisplay center">
                  <button class="rowActionBtn delete" type="button" data-delete-row="${escapeHtml(rid)}">✕</button>
                </div>
              </td>
            </tr>
          `;
        }).join("");

        focusActiveEditor();
      }

      function focusActiveEditor() {
        if (!state.editingCell) return;
        requestAnimationFrame(() => {
          const editor = dom.sheetBody.querySelector(".edit-control");
          if (!editor) return;
          editor.focus();
          if (editor instanceof HTMLInputElement) {
            editor.select();
          }
          if (editor instanceof HTMLTextAreaElement) {
            editor.selectionStart = editor.value.length;
            editor.selectionEnd = editor.value.length;
            autoGrowTextarea(editor);
          }
        });
      }

      function updateRowDom(row) {
        const rid = rowId(row);
        const tr = dom.sheetBody.querySelector(`tr[data-row="${CSS.escape(String(rid))}"]`);
        if (!tr) return;

        for (const col of COLUMN_CONFIG) {
          const td = tr.querySelector(`td[data-col="${col.key}"]`);
          if (!td) continue;
          td.classList.toggle("dirty-cell", !!row.__dirtyFields?.[col.key]);
        }

        const deleteTd = tr.lastElementChild;
        if (deleteTd) deleteTd.classList.toggle("dirty-cell", !!row.__dirty);
        updatePills();
      }

      function markRowDirty(row, key, value) {
        if (!row) return;
        row[key] = value;
        row.__dirty = true;
        row.__dirtyFields = row.__dirtyFields || {};
        row.__dirtyFields[key] = true;
      }

      function startEdit(rowIdValue, key) {
        const row = findRowById(rowIdValue);
        if (!row) return;
        state.editingCell = { rowId: String(rowIdValue), key: String(key) };
        renderTable();
      }

      function stopEdit() {
        state.editingCell = null;
        renderTable();
      }

      function commitEditor(target) {
        if (!target || target.dataset.committed === "1") return;
        const rowIdValue = target.getAttribute("data-row-id");
        const key = target.getAttribute("data-key");
        if (!rowIdValue || !key) {
          stopEdit();
          return;
        }

        const row = findRowById(rowIdValue);
        if (!row) {
          stopEdit();
          return;
        }

        let nextValue = target.value ?? "";
        if (NUMERIC_COLUMNS.has(key)) nextValue = formatCoordForInput(nextValue);

        target.dataset.committed = "1";
        markRowDirty(row, key, nextValue);
        state.editingCell = null;
        applyFilters();
      }

      function cancelEditor(target) {
        if (target) target.dataset.committed = "1";
        state.editingCell = null;
        renderTable();
      }

      function autoGrowTextarea(el) {
        if (!(el instanceof HTMLTextAreaElement)) return;
        el.style.height = "auto";
        el.style.height = Math.max(96, el.scrollHeight) + "px";
      }

      function addRow() {
        state.rows.push(blankRow());
        applyFilters();
        const last = state.rows[state.rows.length - 1];
        if (last) startEdit(rowId(last), "camp");
        setStatus("새 행이 추가되었습니다.", "ok");
      }

      function deleteRow(rowIdValue) {
        const row = findRowById(rowIdValue);
        if (!row) return;

        const label = [
          normalizeText(row.camp),
          normalizeText(row.code)
        ].filter(Boolean).join(" / ") || String(rowIdValue);

        const ok = confirm(`삭제 대상으로 표시할까요?\n저장해야 실제 반영됩니다.\n\n대상: ${label}`);
        if (!ok) return;

        if (row.__isNew) {
          state.rows = state.rows.filter(r => String(rowId(r)) !== String(rowIdValue));
        } else if (row.id) {
          state.deletedIds.add(row.id);
          row.__dirty = true;
        }

        applyFilters();
        setStatus("삭제 대상으로 표시했습니다. 전체 저장 시 반영됩니다.", "warn");
      }

      function cleanPayload(row, includeId) {
        const obj = {};
        if (includeId && row.id != null) obj.id = row.id;
        for (const key of DATA_COLUMNS) {
          obj[key] = valueForSave(key, row[key]);
        }
        return obj;
      }

      async function fetchRows() {
        try {
          setLoading(true, "데이터 불러오는 중...");
          state.deletedIds.clear();
          state.editingCell = null;

          const { data, error } = await supabase
            .from(DATA_TABLE)
            .select("*")
            .order("id", { ascending: true });

          if (error) throw error;

          state.rows = Array.isArray(data) ? data.map(normalizeLoadedRow) : [];
          applyFilters();
        } catch (e) {
          console.error(e);
          state.rows = [];
          state.filteredRows = [];
          renderTable();
          updatePills();
          setStatus("불러오기 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      async function saveAll() {
        try {
          setLoading(true, "저장 중...");

          const deleteIds = Array.from(state.deletedIds).filter(Boolean);
          const dirtyRows = state.rows.filter(row => row.__dirty && !(row.id && state.deletedIds.has(row.id)));
          const updateRows = dirtyRows.filter(row => !row.__isNew && row.id != null);
          const newRows = dirtyRows.filter(row => row.__isNew && hasAnyValue(row));

          if (!deleteIds.length && !updateRows.length && !newRows.length) {
            setStatus("저장할 변경사항이 없습니다.", "warn");
            return;
          }

          if (deleteIds.length) {
            const { error } = await supabase
              .from(DATA_TABLE)
              .delete()
              .in("id", deleteIds);
            if (error) throw error;
          }

          if (updateRows.length) {
            const payload = updateRows.map(row => cleanPayload(row, true));
            const { error } = await supabase
              .from(DATA_TABLE)
              .upsert(payload, { onConflict: "id" });
            if (error) throw error;
          }

          if (newRows.length) {
            const payload = newRows.map(row => cleanPayload(row, false));
            const { error } = await supabase
              .from(DATA_TABLE)
              .insert(payload);
            if (error) throw error;
          }

          await fetchRows();
          setStatus("저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("저장 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      function clearFilters() {
        dom.filterInputs.forEach(el => { el.value = ""; });
        dom.toggleOnlyChanged.checked = false;
        applyFilters();
      }

      function exportCsv() {
        const rows = state.filteredRows.filter(row => !(row.id && state.deletedIds.has(row.id)));
        if (!rows.length) {
          alert("내보낼 데이터가 없습니다.");
          return;
        }

        const headers = ["id", ...DATA_COLUMNS];
        const lines = [
          headers.join(","),
          ...rows.map(row => {
            return headers.map(key => {
              const raw = key === "id" ? (row.id ?? "") : getRowValue(row, key);
              const escaped = String(raw ?? "").replaceAll('"', '""');
              return `"${escaped}"`;
            }).join(",");
          })
        ];

        const csv = "\uFEFF" + lines.join("\n");
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        const now = new Date();
        const stamp = [
          now.getFullYear(),
          String(now.getMonth() + 1).padStart(2, "0"),
          String(now.getDate()).padStart(2, "0"),
          "_",
          String(now.getHours()).padStart(2, "0"),
          String(now.getMinutes()).padStart(2, "0")
        ].join("");

        a.href = url;
        a.download = `coupang_camps_${stamp}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      function bindTableEvents() {
        dom.sheetBody.addEventListener("dblclick", (e) => {
          const cell = e.target.closest('td[data-editable="1"]');
          if (!cell) return;
          const rowIdValue = cell.getAttribute("data-row-id");
          const key = cell.getAttribute("data-key");
          if (!rowIdValue || !key) return;
          startEdit(rowIdValue, key);
        });

        dom.sheetBody.addEventListener("click", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;

          const deleteId = target.getAttribute("data-delete-row");
          if (deleteId) deleteRow(deleteId);
        });

        dom.sheetBody.addEventListener("input", (e) => {
          const target = e.target;
          if (target instanceof HTMLTextAreaElement && target.classList.contains("edit-control")) {
            autoGrowTextarea(target);
          }
        });

        dom.sheetBody.addEventListener("keydown", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;
          if (!target.classList.contains("edit-control")) return;

          if (target instanceof HTMLTextAreaElement) {
            if (e.key === "Escape") {
              e.preventDefault();
              cancelEditor(target);
              return;
            }
            if (e.key === "Enter" && (e.ctrlKey || e.metaKey)) {
              e.preventDefault();
              commitEditor(target);
              return;
            }
            return;
          }

          if (e.key === "Escape") {
            e.preventDefault();
            cancelEditor(target);
            return;
          }

          if (e.key === "Enter") {
            e.preventDefault();
            commitEditor(target);
          }
        });

        dom.sheetBody.addEventListener("focusout", (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;
          if (!target.classList.contains("edit-control")) return;

          setTimeout(() => {
            if (target.dataset.committed === "1") return;
            if (document.activeElement === target) return;
            commitEditor(target);
          }, 0);
        });
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", fetchRows);
        dom.btnAddRow.addEventListener("click", addRow);
        dom.btnSaveAll.addEventListener("click", saveAll);
        dom.btnExportCsv.addEventListener("click", exportCsv);
        dom.btnClearFilters.addEventListener("click", clearFilters);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.toggleOnlyChanged.addEventListener("change", applyFilters);

        dom.filterInputs.forEach(el => {
          el.addEventListener("input", applyFilters);
        });

        dom.btnDeniedHome.addEventListener("click", () => {
          location.replace(INDEX_PATH);
        });

        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        bindTableEvents();
      }

      bindEvents();

      if (!(await requireAuthAndAccess())) return;
      await fetchRows();
    })();
  </script>

  <script>
    window.MW_BOARD_MENU_MODE = "admin";
  </script>
  <script src="/board-menu.js"></script>
