<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>쿠팡 캠프 조회</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.4/build/qrcode.min.js"></script>

  <style>
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --bg:#f6f8fc;
      --surface:#ffffff;
      --surface2:#f8fafc;
      --line:#d8e0ee;
      --line2:#d4dbe5;
      --txt:#0f172a;
      --muted:#64748b;
      --blue:#2563eb;
      --green:#16a34a;
      --yellow:#b77900;
      --red:#dc2626;
      --sheetBg:#eef3f8;
      --headBg:#dce8f5;
      --filterBg:#edf3fb;
      --cellBg:#ffffff;
      --cellAlt:#f8fbff;
      --dirtyBg:#e0eeff;
      --dirtyBorder:#60a5fa;
      --topbarH:56px;
      --toolbarH:58px;
      --statusH:44px;
      --font-mw:"문경감홍사과체","문경사과감홍체","Mungyeong Apple Gamhong","MungyeongGamhong","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,body{
      margin:0;
      height:100%;
      font-family:var(--font-mw);
      background:
        radial-gradient(circle at 16% 0%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 86% 0%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,var(--bg) 100%);
      color:var(--txt);
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
      font-weight:400;
    }

    body{overflow:hidden}

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--topbarH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:rgba(255,255,255,.94);
      backdrop-filter:blur(12px);
      box-shadow:0 1px 0 rgba(255,255,255,.8);
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .logoMenuToggle{
      width:32px;
      height:32px;
      display:inline-flex !important;
      align-items:center;
      justify-content:center;
      flex:0 0 auto;
      border:0;
      border-radius:0;
      background:transparent;
      box-shadow:none;
      padding:0;
      cursor:pointer;
    }

    .topbar img{
      width:30px;
      height:30px;
      display:block;
      object-fit:contain;
      filter:drop-shadow(0 2px 4px rgba(15,23,42,.10));
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
      letter-spacing:-.02em;
      font-weight:700;
      color:#0f172a;
      white-space:nowrap;
    }

    .titleBox small{
      margin-top:3px;
      color:var(--muted);
      font-size:11px;
      font-weight:500;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .spacer{flex:1}

    .btn{
      height:40px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#ffffff;
      color:#0f172a;
      cursor:pointer;
      font-weight:650;
      font-size:13px;
      white-space:nowrap;
      font-family:var(--font-mw);
      box-shadow:0 1px 0 rgba(255,255,255,.85), 0 4px 12px rgba(15,23,42,.04);
    }

    .btn:hover{
      background:#f8fbff;
      border-color:#93c5fd;
    }

    .btn.ok{
      background:linear-gradient(180deg,#22c55e,#16a34a);
      border-color:#16a34a;
      color:#ffffff;
      box-shadow:0 8px 18px rgba(22,163,74,.18);
    }

    .btn.warn{
      background:#fffbeb;
      border-color:#fde68a;
      color:#9a5c00;
    }

    .btn.danger{
      background:#fff5f5;
      border-color:#fecaca;
      color:#dc2626;
    }

    .btn.primary{
      background:linear-gradient(180deg,#3b82f6,#2563eb);
      border-color:#2563eb;
      color:#fff;
      box-shadow:0 8px 18px rgba(37,99,235,.18);
    }

    .btn:disabled{
      opacity:.6;
      cursor:not-allowed;
    }

    #btnAddRow:disabled,
    #btnSaveAll:disabled{
      display:inline-block;
      opacity:.42;
      filter:grayscale(.18);
    }

    .toolbar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:9px 12px;
      background:rgba(255,255,255,.92);
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .group{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .group:last-child{
      border-right:none;
      padding-right:0;
    }

    .toggle{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#fff;
      font-size:12px;
      font-weight:500;
      color:#334155;
      white-space:nowrap;
    }

    .toggle input{
      margin:0;
      width:16px;
      height:16px;
      accent-color:#2563eb;
      cursor:pointer;
    }

    .helper{
      color:#64748b;
      font-size:12px;
      white-space:nowrap;
      font-weight:500;
    }

    .sheetWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .sheetInner{
      min-width:1490px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--txt);
    }

    th,td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child,td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:4;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:13px;
      font-weight:650;
      white-space:nowrap;
      color:#0f172a;
    }

    thead tr.filterRow th{
      top:43px;
      z-index:3;
      background:var(--filterBg);
      padding:6px;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    tbody tr.newRow td{
      background:#ecfdf5 !important;
      box-shadow:inset 0 1px 0 rgba(22,163,74,.18), inset 0 -1px 0 rgba(22,163,74,.18);
    }

    td.dirty-cell{
      box-shadow:inset 0 0 0 2px var(--dirtyBorder);
      background:var(--dirtyBg) !important;
    }

    .cellInput,
    .cellSelect,
    .cellTextarea{
      width:100%;
      min-height:44px;
      border:none;
      outline:none;
      background:transparent;
      color:var(--txt);
      padding:10px 8px;
      font:inherit;
      font-size:13px;
      font-weight:500;
      line-height:1.35;
      border-radius:0;
    }

    .cellInput.center,
    .cellSelect.center,
    .cellTextarea.center{
      text-align:center;
    }

    .cellInput.left,
    .cellSelect.left,
    .cellTextarea.left{
      text-align:left;
    }

    .cellInput.right,
    .cellTextarea.right{
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .cellInput::placeholder,
    .cellTextarea::placeholder{
      color:#94a3b8;
    }

    .cellSelect{
      cursor:pointer;
      text-align:center;
    }

    .cellTextarea{
      display:block;
      resize:none;
      overflow:hidden;
      white-space:pre-wrap;
      word-break:keep-all;
      overflow-wrap:anywhere;
      line-height:1.42;
    }

    .cellTextarea.addressCell{
      min-height:44px;
      height:44px;
    }

    tbody td.addressTd{
      vertical-align:top;
    }

    .cellInput:disabled,
    .cellSelect:disabled,
    .cellTextarea:disabled{
      color:#0f172a;
      opacity:1;
      cursor:default;
    }

    .filterInput,
    .filterSelect{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      font-family:var(--font-mw);
      font-weight:500;
      outline:none;
    }

    .filterInput:focus,
    .filterSelect:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 2px rgba(96,165,250,.16);
    }

    .rowActionCell{
      padding:7px 6px;
      text-align:center;
      white-space:nowrap;
    }

    .rowActionBtn{
      height:30px;
      padding:0 10px;
      border-radius:999px;
      border:1px solid #fecaca;
      background:#fff5f5;
      color:#dc2626;
      cursor:pointer;
      font-size:12px;
      font-weight:750;
      font-family:var(--font-mw);
      box-shadow:0 3px 10px rgba(220,38,38,.08);
    }

    .rowActionBtn:hover{
      border-color:#ef4444;
      color:#ffffff;
      background:#dc2626;
      box-shadow:0 6px 14px rgba(220,38,38,.16);
    }

    .campCellWrap{
      display:grid;
      grid-template-columns:minmax(0,1fr) 42px;
      align-items:stretch;
      min-height:44px;
    }

    .campCellWrap .cellInput{
      min-width:0;
    }

    .campQrBtn{
      border:none;
      border-left:1px solid var(--line2);
      background:#f8fafc;
      color:#2563eb;
      font-family:var(--font-mw);
      font-weight:700;
      font-size:12px;
      cursor:pointer;
    }

    .campQrBtn:hover{
      background:#eff6ff;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:rgba(255,255,255,.96);
      overflow:hidden;
    }

    .pill{
      flex:0 0 auto;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      height:30px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#f8fafc;
      color:#475569;
      font-size:12px;
      font-weight:500;
      white-space:nowrap;
    }

    .pill.ok{
      background:#ecfdf5;
      border-color:#bbf7d0;
      color:#15803d;
    }

    .pill.warn{
      background:#fffbeb;
      border-color:#fde68a;
      color:#a16207;
    }

    .statusText{
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      color:#64748b;
      font-size:12px;
      font-weight:500;
    }

    .statusText.ok{color:#15803d}
    .statusText.warn{color:#a16207}
    .statusText.err{color:#dc2626}

    .emptyDataRow td{
      height:180px;
      text-align:center;
      color:#64748b;
      font-size:14px;
      font-weight:500;
      background:#fff !important;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:24px;
      background:rgba(248,250,252,.94);
      z-index:9999;
    }

    .accessDenied.show{
      display:flex;
    }

    .accessCard{
      width:min(520px,100%);
      padding:28px;
      border-radius:22px;
      border:1px solid #d8e0ee;
      background:#fff;
      box-shadow:0 24px 80px rgba(15,23,42,.15);
    }

    .accessCard h2{
      margin:0 0 10px;
      font-size:22px;
      font-weight:700;
      color:#0f172a;
    }

    .accessCard p{
      margin:0 0 18px;
      color:#475569;
      line-height:1.55;
      font-size:14px;
      font-weight:500;
    }

    .accessMeta{
      padding:12px 14px;
      border-radius:14px;
      background:#f8fafc;
      border:1px solid #e2e8f0;
      color:#64748b;
      font-size:12px;
      font-weight:500;
      word-break:break-all;
      margin-bottom:16px;
    }

    .accessActions{
      display:flex;
      gap:8px;
      justify-content:flex-end;
    }

    .qrModal{
      position:fixed;
      inset:0;
      z-index:10000;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:rgba(15,23,42,.55);
      backdrop-filter:blur(6px);
    }

    .qrModal.show{
      display:flex;
    }

    .qrCard{
      width:min(420px,100%);
      border-radius:22px;
      border:1px solid #d8e0ee;
      background:#fff;
      box-shadow:0 24px 80px rgba(15,23,42,.24);
      overflow:hidden;
    }

    .qrHead{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:16px 18px;
      border-bottom:1px solid #e2e8f0;
      background:#f8fafc;
    }

    .qrHead b{
      font-size:16px;
      font-weight:700;
    }

    .qrBody{
      padding:20px;
      text-align:center;
    }

    .qrBox{
      display:inline-flex;
      padding:14px;
      border-radius:18px;
      border:1px solid #e2e8f0;
      background:#fff;
      box-shadow:0 6px 18px rgba(15,23,42,.06);
    }

    #qrCanvas{
      width:220px;
      height:220px;
      image-rendering:pixelated;
    }

    .qrMeta{
      margin-top:14px;
      display:grid;
      gap:8px;
      color:#475569;
      font-size:13px;
      font-weight:500;
      line-height:1.45;
      text-align:left;
      word-break:keep-all;
      overflow-wrap:anywhere;
    }

    .qrMetaLine{
      display:grid;
      grid-template-columns:54px minmax(0,1fr);
      align-items:start;
      gap:8px;
      padding:8px 10px;
      border:1px solid #e2e8f0;
      border-radius:12px;
      background:#f8fafc;
    }

    .qrMetaKey{
      color:#64748b;
      font-weight:700;
      white-space:nowrap;
    }

    .qrMetaVal{
      color:#0f172a;
      font-weight:650;
    }

    .qrActions{
      display:flex;
      justify-content:flex-end;
      gap:8px;
      padding:14px 18px 18px;
    }

    @media(max-width:900px){
      :root{
        --topbarH:54px;
        --toolbarH:58px;
      }

      .titleBox b{
        font-size:16px;
      }

      .sheetInner{
        min-width:1280px;
      }

      .btn{
        height:36px;
        padding:0 12px;
      }
    }
  </style>
</head>

<body>
  <div class="app">
    <header class="topbar">
      <a id="mwBoardMenuToggle" class="logoMenuToggle" href="/index.html" title="마루웰 메뉴">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>쿠팡 캠프 조회</b>
        <small>캠프 정보 조회</small>
      </div>
      <div class="spacer"></div>
      <button id="btnReload" class="btn primary" type="button">불러오기</button>
      <button id="btnAddRow" class="btn ok" type="button">행 추가</button>
      <button id="btnSaveAll" class="btn ok" type="button">전체 저장</button>
      <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <section class="toolbar">
      <div class="group">
        <label class="toggle">
          <input id="toggleOnlyChanged" type="checkbox">
          <span>변경 행만 보기</span>
        </label>
      </div>
      <div class="group">
        <button id="btnClearFilters" class="btn" type="button">필터 초기화</button>
      </div>
      <div class="group">
        <span class="helper">조회는 사이트 접근자 전체 가능 / 추가·수정·삭제는 최고관리자만 가능</span>
      </div>
    </section>

    <main class="sheetWrap">
      <div class="sheetInner">
        <table>
          <colgroup>
            <col style="width:112px">
            <col style="width:154px">
            <col style="width:154px">
            <col style="width:360px">
            <col style="width:150px">
            <col style="width:130px">
            <col style="width:130px">
            <col style="width:130px">
            <col style="width:260px">
            <col style="width:96px">
          </colgroup>
          <thead>
            <tr>
              <th>구분</th>
              <th>캠프명</th>
              <th>MB캠프</th>
              <th>주소</th>
              <th>지역</th>
              <th>코드</th>
              <th>위도</th>
              <th>경도</th>
              <th>설명</th>
              <th>관리</th>
            </tr>
            <tr class="filterRow">
              <th>
                <select id="campTypeFilter" class="filterSelect" data-filter="camp_type">
                  <option value="">구분 전체</option>
                </select>
              </th>
              <th><input class="filterInput" data-filter="camp" placeholder="캠프명 / !일산2" /></th>
              <th><input class="filterInput" data-filter="mb_camp" placeholder="MB캠프 / M_익산" /></th>
              <th><input class="filterInput" data-filter="address" placeholder="주소 / 군산" /></th>
              <th>
                <select id="regionFilter" class="filterSelect" data-filter="area">
                  <option value="">지역 전체</option>
                  <option value="East">East</option>
                  <option value="South">South</option>
                  <option value="West">West</option>
                  <option value="__EMPTY__">없음</option>
                </select>
              </th>
              <th><input class="filterInput" data-filter="code" placeholder="코드" /></th>
              <th><input class="filterInput" data-filter="latitude" placeholder="위도" /></th>
              <th><input class="filterInput" data-filter="longitude" placeholder="경도" /></th>
              <th><input class="filterInput" data-filter="description" placeholder="설명" /></th>
              <th></th>
            </tr>
          </thead>
          <tbody id="sheetBody"></tbody>
        </table>
      </div>
    </main>

    <footer class="statusbar">
      <span id="pillReady" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillDirty" class="pill warn">변경 0</span>
      <span id="statusText" class="statusText">대기 중</span>
    </footer>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근할 수 없습니다</h2>
      <p id="accessDeniedText">페이지를 불러올 수 없습니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <div id="qrModal" class="qrModal" aria-hidden="true">
    <div class="qrCard">
      <div class="qrHead">
        <b id="qrTitle">QR 생성</b>
        <button id="btnQrClose" class="btn" type="button">닫기</button>
      </div>
      <div class="qrBody">
        <div class="qrBox">
          <canvas id="qrCanvas" width="220" height="220"></canvas>
        </div>
        <div id="qrMeta" class="qrMeta"></div>
      </div>
      <div class="qrActions">
        <button id="btnQrCopy" class="btn primary" type="button">이미지 복사</button>
        <button id="btnQrDownload" class="btn" type="button">다운로드</button>
        <button id="btnQrCloseBottom" class="btn" type="button">닫기</button>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const CONFIG = window.MARUWELL_CONFIG || {};
      const API_BASE =
        CONFIG.BACKENDS?.coupangCamp ||
        CONFIG.COUPANG_CAMP_API ||
        "https://coupangcamp.brain-0f6.workers.dev";

      const SUPABASE_URL = CONFIG.SUPABASE_URL || "";
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY || CONFIG.SUPABASE_PUBLISHABLE_KEY || "";
      const LOGIN_PATH = "/login.html";
      const INDEX_PATH = "/index.html";

      const DATA_COLUMNS = [
        "camp_type",
        "camp",
        "mb_camp",
        "address",
        "area",
        "code",
        "latitude",
        "longitude",
        "description"
      ];

      const NUMERIC_COLUMNS = new Set(["latitude", "longitude"]);

      const COLUMN_CONFIG = [
        { key:"camp_type", type:"text", className:"center" },
        { key:"camp", type:"text", className:"center" },
        { key:"mb_camp", type:"text", className:"center" },
        { key:"address", type:"textarea", className:"left" },
        { key:"area", type:"text", className:"center" },
        { key:"code", type:"text", className:"center" },
        { key:"latitude", type:"text", className:"right" },
        { key:"longitude", type:"text", className:"right" },
        { key:"description", type:"textarea", className:"left" }
      ];

      const $ = selector => document.querySelector(selector);

      const dom = {
        btnReload: $("#btnReload"),
        btnAddRow: $("#btnAddRow"),
        btnSaveAll: $("#btnSaveAll"),
        btnExportCsv: $("#btnExportCsv"),
        btnClearFilters: $("#btnClearFilters"),
        btnLogout: $("#btnLogout"),
        toggleOnlyChanged: $("#toggleOnlyChanged"),
        sheetBody: $("#sheetBody"),
        filterInputs: Array.from(document.querySelectorAll(".filterInput, .filterSelect")),
        campTypeFilter: $("#campTypeFilter"),
        regionFilter: $("#regionFilter"),
        pillReady: $("#pillReady"),
        pillRows: $("#pillRows"),
        pillDirty: $("#pillDirty"),
        statusText: $("#statusText"),
        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout"),
        qrModal: $("#qrModal"),
        qrTitle: $("#qrTitle"),
        qrMeta: $("#qrMeta"),
        qrCanvas: $("#qrCanvas"),
        btnQrClose: $("#btnQrClose"),
        btnQrCloseBottom: $("#btnQrCloseBottom"),
        btnQrCopy: $("#btnQrCopy"),
        btnQrDownload: $("#btnQrDownload")
      };

      const supabase = SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY)
        : null;

      const state = {
        rows: [],
        filteredRows: [],
        deletedIds: new Set(),
        tempId: 0,
        canEdit: false,
        loading: false,
        loggedIn: false,
        viewerEmail: "",
        viewerUserId: "",
        accessToken: "",
        currentQr: null
      };

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function normalizeText(value) {
        return String(value ?? "").trim();
      }

      function normalizeLower(value) {
        return normalizeText(value).toLowerCase();
      }

      function setStatus(msg, tone = "") {
        dom.statusText.textContent = msg || "";
        dom.statusText.className = tone ? "statusText " + tone : "statusText";
        dom.pillReady.textContent = tone === "err" ? "ERROR" : tone === "warn" ? "WAIT" : "READY";
        dom.pillReady.className = tone === "err" ? "pill warn" : "pill ok";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnAddRow.disabled = !!on || !state.canEdit;
        dom.btnSaveAll.disabled = !!on || !state.canEdit;
        dom.btnExportCsv.disabled = !!on;
        dom.btnClearFilters.disabled = !!on;

        updateEditButtons();

        if (on) setStatus(text || "처리 중...", "warn");
      }

      function updatePills() {
        const visibleCount = state.filteredRows.length;
        const dirtyCount = state.rows.filter(row => row.__dirty).length + state.deletedIds.size;

        dom.pillRows.textContent = "행 " + visibleCount;
        dom.pillDirty.textContent = "변경 " + dirtyCount;
      }

      function showAccessDenied(email, detail) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = detail || "페이지를 불러올 수 없습니다.";
        dom.accessDeniedEmail.textContent = email ? "현재 로그인: " + email : "로그인 정보 없음";
        document.documentElement.style.visibility = "visible";
      }

      function hideAccessDenied() {
        dom.accessDenied.classList.remove("show");
      }

      function formatCoord(v) {
        const s = String(v ?? "").trim();
        if (!s) return "";
        const n = Number(s);
        if (!Number.isFinite(n)) return s;
        return String(n);
      }

      function normalizeLoadedRow(row) {
        const out = { ...(row || {}) };

        for (const key of DATA_COLUMNS) {
          out[key] = out[key] == null ? "" : String(out[key]);
        }

        out.latitude = formatCoord(out.latitude);
        out.longitude = formatCoord(out.longitude);
        out.__dirty = false;
        out.__isNew = false;
        out.__dirtyFields = {};
        return out;
      }

      function rowId(row) {
        return row.id ?? row.__temp_id;
      }

      function blankRow() {
        const row = {
          __temp_id: "new_" + (++state.tempId),
          __isNew: true,
          __dirty: true,
          __dirtyFields: {}
        };

        for (const key of DATA_COLUMNS) {
          row[key] = "";
        }

        return row;
      }

      function hasAnyValue(row) {
        return DATA_COLUMNS.some(key => normalizeText(row[key]));
      }

      function parseNumericOrNull(value, key) {
        const s = String(value ?? "").trim();
        if (!s) return null;

        const n = Number(s);

        if (!Number.isFinite(n)) {
          throw new Error(`${key} 값이 숫자가 아닙니다: ${value}`);
        }

        return n;
      }

      function valueForSave(key, value) {
        const v = String(value ?? "").trim();
        if (!v) return null;
        if (NUMERIC_COLUMNS.has(key)) return parseNumericOrNull(v, key);
        return v;
      }

      function updateCampTypeFilterOptions() {
        const select = dom.campTypeFilter;
        if (!select) return;

        const current = select.value;

        const values = Array.from(new Set(
          state.rows
            .filter(row => !state.deletedIds.has(rowId(row)))
            .map(row => normalizeText(row.camp_type))
            .filter(Boolean)
        )).sort((a, b) => a.localeCompare(b, "ko", { numeric:true, sensitivity:"base" }));

        select.innerHTML = [
          `<option value="">구분 전체</option>`,
          ...values.map(value => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`)
        ].join("");

        if (values.includes(current)) {
          select.value = current;
        } else {
          select.value = "";
        }
      }

      function rowMatchesFilter(row, key, rawFilter) {
        const filter = normalizeText(rawFilter);
        if (!filter) return true;

        if ((key === "area" || key === "region") && filter === "__EMPTY__") {
          return !normalizeText(row.area ?? row.region);
        }

        const isExclude = filter.startsWith("!") || filter.startsWith("-");
        const needle = normalizeLower(isExclude ? filter.slice(1) : filter);
        const hay = normalizeLower(key === "area" ? (row.area ?? row.region) : row[key]);

        if (!needle) return true;

        const matched = hay.includes(needle);
        return isExclude ? !matched : matched;
      }

      function applyFilters() {
        const filters = {};

        for (const input of dom.filterInputs) {
          const key = input.dataset.filter;
          if (!key) continue;
          filters[key] = input.value;
        }

        const onlyChanged = dom.toggleOnlyChanged.checked;

        const pinnedNewRows = state.rows.filter(row => {
          const id = rowId(row);
          return row.__isNew && !state.deletedIds.has(id);
        });

        const matchedRows = state.rows.filter(row => {
          const id = rowId(row);

          if (state.deletedIds.has(id)) return false;
          if (row.__isNew) return false;
          if (onlyChanged && !row.__dirty) return false;

          for (const [key, value] of Object.entries(filters)) {
            if (!rowMatchesFilter(row, key, value)) return false;
          }

          return true;
        });

        state.filteredRows = [...pinnedNewRows, ...matchedRows];

        renderRows();
        updatePills();
      }

      function makeInput(row, col) {
        const id = rowId(row);
        const value = row[col.key] ?? "";
        const disabled = !state.canEdit;

        if (col.type === "select") {
          let options = col.options || [];

          const optionHtml = options.map(opt => {
            const label = opt || "";
            return `<option value="${escapeHtml(opt)}" ${String(value) === String(opt) ? "selected" : ""}>${escapeHtml(label || "선택")}</option>`;
          }).join("");

          return `
            <select
              class="cellSelect ${escapeHtml(col.className || "")}"
              data-id="${escapeHtml(id)}"
              data-key="${escapeHtml(col.key)}"
              ${disabled ? "disabled" : ""}
            >${optionHtml}</select>
          `;
        }

        if (col.type === "textarea") {
          return `
            <textarea
              class="cellTextarea addressCell ${escapeHtml(col.className || "")}"
              data-id="${escapeHtml(id)}"
              data-key="${escapeHtml(col.key)}"
              rows="1"
              ${disabled ? "disabled" : ""}
            >${escapeHtml(value)}</textarea>
          `;
        }

        const inputHtml = `
          <input
            class="cellInput ${escapeHtml(col.className || "")}"
            data-id="${escapeHtml(id)}"
            data-key="${escapeHtml(col.key)}"
            value="${escapeHtml(value)}"
            ${disabled ? "disabled" : ""}
          />
        `;

        if (col.key === "camp") {
          return `
            <div class="campCellWrap">
              ${inputHtml}
              <button class="campQrBtn" type="button" data-qr-id="${escapeHtml(id)}" title="본캠프 코드 QR 생성">QR</button>
            </div>
          `;
        }

        return inputHtml;
      }

      function renderRows() {
        if (!state.filteredRows.length) {
          dom.sheetBody.innerHTML = `
            <tr class="emptyDataRow">
              <td colspan="10">표시할 데이터가 없습니다.</td>
            </tr>
          `;
          return;
        }

        dom.sheetBody.innerHTML = state.filteredRows.map(row => {
          const id = rowId(row);
          const rowClass = row.__isNew ? "newRow" : "";
          const cells = COLUMN_CONFIG.map(col => {
            const tdClass = [
              row.__dirtyFields?.[col.key] ? "dirty-cell" : "",
              col.key === "address" ? "addressTd" : ""
            ].filter(Boolean).join(" ");

            return `<td class="${tdClass}">${makeInput(row, col)}</td>`;
          }).join("");

          const actionCell = state.canEdit
            ? `<button class="rowActionBtn" type="button" data-delete-id="${escapeHtml(id)}">삭제</button>`
            : "";

          return `
            <tr class="${rowClass}" data-row-id="${escapeHtml(id)}">
              ${cells}
              <td class="rowActionCell">${actionCell}</td>
            </tr>
          `;
        }).join("");

        for (const textarea of dom.sheetBody.querySelectorAll("textarea")) {
          resizeTextarea(textarea);
        }
      }

      function resizeTextarea(el) {
        if (!el || el.tagName !== "TEXTAREA") return;
        el.style.height = "44px";
        el.style.height = Math.max(44, el.scrollHeight) + "px";
      }

      function sortRows(rows) {
        return rows.slice().sort((a, b) => {
          return (
            normalizeText(a.camp).localeCompare(normalizeText(b.camp), "ko", { numeric:true }) ||
            normalizeText(a.mb_camp).localeCompare(normalizeText(b.mb_camp), "ko", { numeric:true }) ||
            normalizeText(a.code).localeCompare(normalizeText(b.code), "ko", { numeric:true })
          );
        });
      }

      function isKnownAdminEmail(email) {
        return /(^brain@maroowell\.com$|^maroowell1@maroowell\.com$|^nuclear_warp@naver\.com$)/i.test(String(email || "").trim());
      }

      function decodeJwtPayload(token) {
        try {
          const part = String(token || "").split(".")[1];
          if (!part) return {};
          const base64 = part.replace(/-/g, "+").replace(/_/g, "/");
          const padded = base64 + "=".repeat((4 - base64.length % 4) % 4);
          return JSON.parse(decodeURIComponent(escape(atob(padded))));
        } catch {
          return {};
        }
      }

      function extractSessionFromStoredValue(value) {
        try {
          const parsed = typeof value === "string" ? JSON.parse(value) : value;
          const session =
            parsed?.currentSession ||
            parsed?.session ||
            parsed?.data?.session ||
            parsed;

          const accessToken =
            session?.access_token ||
            parsed?.access_token ||
            parsed?.currentSession?.access_token;

          if (!accessToken) return null;

          const user = session?.user || parsed?.user || {};
          const payload = decodeJwtPayload(accessToken);

          return {
            access_token: accessToken,
            user: {
              id: user?.id || payload.sub || "",
              email: user?.email || payload.email || ""
            }
          };
        } catch {
          return null;
        }
      }

      function getStoredSupabaseSession() {
        const candidates = [];

        const collect = storage => {
          if (!storage) return;

          try {
            for (let i = 0; i < storage.length; i++) {
              const key = storage.key(i) || "";
              if (!/sb-|supabase|auth-token|gotrue/i.test(key)) continue;

              const value = storage.getItem(key);
              if (!value || !value.includes("access_token")) continue;

              candidates.push({
                key,
                value,
                storageName: storage === sessionStorage ? "sessionStorage" : "localStorage"
              });
            }
          } catch {}
        };

        // board-menu.js는 Supabase 세션을 sessionStorage로 잡고 있음.
        // 이 페이지도 같은 세션을 읽어야 /access 호출이 가능하다.
        collect(sessionStorage);
        collect(localStorage);

        for (const item of candidates) {
          const session = extractSessionFromStoredValue(item.value);

          if (session?.access_token) {
            session.source = `${item.storageName}:${item.key}`;
            return session;
          }
        }

        return null;
      }

      async function resolveAuthSession() {
        if (supabase) {
          try {
            const { data } = await supabase.auth.getSession();
            const session = data?.session;
            const user = session?.user;

            if (session?.access_token) {
              return {
                access_token: session.access_token,
                user: {
                  id: user?.id || "",
                  email: user?.email || decodeJwtPayload(session.access_token).email || ""
                },
                source: "supabase.auth.getSession"
              };
            }
          } catch (e) {
            console.warn("[coupang_camp] supabase getSession failed", e);
          }
        }

        const stored = getStoredSupabaseSession();
        if (stored?.access_token) {
          return {
            ...stored,
            source: stored.source || "storedSupabaseSession"
          };
        }

        return null;
      }

      function parseCanEditAccess(j) {
        const access = j?.access || j?.user || j?.data || {};
        const roleLevel = Number(
          j?.max_role_level ??
          j?.role_level ??
          j?.level ??
          access?.max_role_level ??
          access?.role_level ??
          access?.level ??
          0
        ) || 0;

        const email = String(
          j?.email ||
          j?.user?.email ||
          access?.email ||
          state.viewerEmail ||
          ""
        ).trim();

        const roleText = [
          j?.role,
          j?.role_name,
          j?.position,
          j?.position_title,
          access?.role,
          access?.role_name,
          access?.position,
          access?.position_title,
          access?.raw?.role,
          access?.raw?.role_name,
          access?.raw?.position,
          access?.raw?.position_title
        ].map(v => String(v || "").toLowerCase()).join(" ");

        return Boolean(
          isKnownAdminEmail(email) ||
          j?.canEdit === true ||
          j?.can_edit === true ||
          j?.can_write === true ||
          j?.editable === true ||
          j?.isAdmin === true ||
          j?.is_admin === true ||
          j?.admin === true ||
          j?.isSuperAdmin === true ||
          j?.is_super_admin === true ||
          j?.super_admin === true ||
          access?.hardcodedAdminEmail === true ||
          access?.canEdit === true ||
          access?.can_edit === true ||
          access?.can_write === true ||
          access?.editable === true ||
          access?.isAdmin === true ||
          access?.is_admin === true ||
          access?.admin === true ||
          access?.isSuperAdmin === true ||
          access?.is_super_admin === true ||
          access?.super_admin === true ||
          access?.is_super_admin === true ||
          access?.raw?.is_super_admin === true ||
          roleLevel >= 90 ||
          roleText.includes("admin") ||
          roleText.includes("super") ||
          roleText.includes("관리자") ||
          roleText.includes("최고관리자")
        );
      }

      function updateEditButtons() {
        // 버튼은 항상 보이게 둔다.
        // 권한이 없거나 로그인 세션이 없으면 비활성화만 한다.
        dom.btnAddRow.style.display = "inline-block";
        dom.btnSaveAll.style.display = "inline-block";
        dom.btnLogout.style.display = state.loggedIn ? "inline-block" : "none";

        const editable = state.loggedIn && state.canEdit;

        dom.btnAddRow.disabled = state.loading || !editable;
        dom.btnSaveAll.disabled = state.loading || !editable;

        if (!state.loggedIn) {
          dom.btnAddRow.title = "로그인 세션을 찾지 못했습니다. 새로고침 또는 재로그인이 필요합니다.";
          dom.btnSaveAll.title = "로그인 세션을 찾지 못했습니다. 새로고침 또는 재로그인이 필요합니다.";
        } else {
          dom.btnAddRow.title = editable ? "새 행 추가" : "추가·수정·삭제는 최고관리자만 가능합니다.";
          dom.btnSaveAll.title = editable ? "전체 저장" : "추가·수정·삭제는 최고관리자만 가능합니다.";
        }
      }

      async function getSessionAndAccess() {
        state.loggedIn = false;
        state.viewerEmail = "";
        state.viewerUserId = "";
        state.accessToken = "";
        state.canEdit = false;

        const session = await resolveAuthSession();

        if (session?.access_token) {
          state.loggedIn = true;
          state.accessToken = session.access_token;
          state.viewerEmail = session.user?.email || decodeJwtPayload(session.access_token).email || "";
          state.viewerUserId = session.user?.id || decodeJwtPayload(session.access_token).sub || "";
          console.info("[coupang_camp] auth session loaded:", session.source, state.viewerEmail || state.viewerUserId || "(no email)");
        }

        if (!state.loggedIn || !state.accessToken) {
          updateEditButtons();
          return;
        }

        try {
          const j = await apiFetch("/access", { method: "GET", auth: true });
          state.canEdit = parseCanEditAccess(j);

          if (!state.canEdit && isKnownAdminEmail(state.viewerEmail)) {
            state.canEdit = true;
          }

          console.info("[coupang_camp] access loaded:", {
            email: state.viewerEmail,
            canEdit: state.canEdit,
            response: j
          });
        } catch (e) {
          console.warn("[coupang_camp] access check failed", e);

          // 최고관리자 이메일 fallback. 실제 저장은 /camps/batch Worker에서 다시 검증한다.
          state.canEdit = isKnownAdminEmail(state.viewerEmail);
        }

        updateEditButtons();
      }

      async function apiFetch(path, options = {}) {
        const headers = {
          "Content-Type": "application/json",
          ...(options.headers || {})
        };

        if (options.auth && state.accessToken) {
          headers.Authorization = "Bearer " + state.accessToken;
        }

        const res = await fetch(API_BASE + path, {
          method: options.method || "GET",
          headers,
          body: options.body ? JSON.stringify(options.body) : undefined,
          cache: "no-store"
        });

        const text = await res.text();
        let data = null;

        if (text) {
          try {
            data = JSON.parse(text);
          } catch {
            data = text;
          }
        }

        if (!res.ok) {
          const msg =
            (data && typeof data === "object" && (data.error || data.message || data.detail)) ||
            (typeof data === "string" ? data : "") ||
            `HTTP ${res.status}`;
          throw new Error(String(msg));
        }

        return data;
      }

      async function loadRows() {
        setLoading(true, "캠프 데이터를 불러오는 중...");

        try {
          const data = await apiFetch("/camps", { method: "GET" });
          const rows = Array.isArray(data) ? data : (data?.rows || []);

          state.rows = sortRows(rows.map(normalizeLoadedRow));
          state.deletedIds.clear();

          updateCampTypeFilterOptions();
          applyFilters();
          setStatus(`불러오기 완료: ${state.rows.length.toLocaleString()}건`, "ok");
        } catch (e) {
          console.error(e);
          setStatus(e.message || String(e), "err");
        } finally {
          setLoading(false);
        }
      }

      function findRow(id) {
        return state.rows.find(row => String(rowId(row)) === String(id));
      }

      function handleCellChange(e) {
        const el = e.target.closest(".cellInput, .cellSelect, .cellTextarea");
        if (!el) return;
        if (!state.canEdit) return;
        if (e.type === "input" && e.isComposing) return;

        const id = el.dataset.id;
        const key = el.dataset.key;
        const row = findRow(id);

        if (!row || !key) return;

        let next = el.value;

        if (NUMERIC_COLUMNS.has(key)) {
          next = next.trim();
        }

        if (String(row[key] ?? "") === String(next ?? "")) return;

        row[key] = next;
        row.__dirty = true;
        row.__dirtyFields = row.__dirtyFields || {};
        row.__dirtyFields[key] = true;

        const td = el.closest("td");
        if (td) td.classList.add("dirty-cell");

        if (key === "camp_type") updateCampTypeFilterOptions();

        resizeTextarea(el);
        updatePills();
        setStatus("수정됨. 저장을 누르면 DB에 반영됩니다.", "warn");
      }

      function addRow() {
        if (!state.canEdit) {
          setStatus("행 추가는 최고관리자만 가능합니다.", "err");
          return;
        }

        const row = blankRow();
        state.rows.unshift(row);

        updateCampTypeFilterOptions();
        applyFilters();
        setStatus("새 행을 추가했습니다. 필터와 관계없이 제일 위에 표시됩니다.", "warn");
      }

      function deleteRowById(id) {
        if (!state.canEdit) {
          setStatus("삭제는 최고관리자만 가능합니다.", "err");
          return;
        }

        const row = findRow(id);
        if (!row) return;

        const campName = row.camp || row.mb_camp || row.code || id;
        const ok = confirm(`${campName}\n\n이 행을 삭제할까요?\n저장을 눌러야 DB에 반영됩니다.`);
        if (!ok) return;

        if (row.__isNew) {
          state.rows = state.rows.filter(item => String(rowId(item)) !== String(id));
        } else {
          state.deletedIds.add(id);
        }

        updateCampTypeFilterOptions();
        applyFilters();
        setStatus("삭제 표시 완료. 저장을 누르면 DB에 반영됩니다.", "warn");
      }

      function buildPayload(row) {
        const payload = {};

        for (const key of DATA_COLUMNS) {
          payload[key] = valueForSave(key, row[key]);
        }

        return payload;
      }

      async function saveAll() {
        if (!state.canEdit) {
          setStatus("저장은 최고관리자만 가능합니다.", "err");
          return;
        }

        const dirtyRows = state.rows.filter(row => row.__dirty && !state.deletedIds.has(rowId(row)));
        const deletedIds = Array.from(state.deletedIds).filter(id => !String(id).startsWith("new_"));

        if (!dirtyRows.length && !deletedIds.length) {
          setStatus("저장할 변경사항이 없습니다.", "ok");
          return;
        }

        setLoading(true, "저장 중...");

        try {
          const inserts = [];
          const updates = [];

          for (const row of dirtyRows) {
            if (!hasAnyValue(row)) continue;

            const payload = buildPayload(row);

            if (row.__isNew) {
              inserts.push(payload);
            } else {
              updates.push({
                id: row.id,
                payload
              });
            }
          }

          const result = await apiFetch("/camps/batch", {
            method: "POST",
            auth: true,
            body: {
              inserts,
              updates,
              deletes: deletedIds
            }
          });

          setStatus(
            `저장 완료: 추가 ${Number(result?.inserted || 0).toLocaleString()} / 수정 ${Number(result?.updated || 0).toLocaleString()} / 삭제 ${Number(result?.deleted || 0).toLocaleString()}`,
            "ok"
          );

          await loadRows();
        } catch (e) {
          console.error(e);
          setStatus(e.message || String(e), "err");
        } finally {
          setLoading(false);
        }
      }

      function clearFilters() {
        for (const input of dom.filterInputs) {
          input.value = "";
        }

        dom.toggleOnlyChanged.checked = false;
        applyFilters();
        setStatus("필터 초기화 완료", "ok");
      }

      function csvEscape(value) {
        const s = String(value ?? "");
        if (/[",\n\r]/.test(s)) {
          return '"' + s.replaceAll('"', '""') + '"';
        }
        return s;
      }

      function exportCsv() {
        const headers = [
          "구분",
          "캠프명",
          "MB캠프",
          "주소",
          "지역",
          "코드",
          "위도",
          "경도",
          "설명"
        ];

        const lines = [headers.map(csvEscape).join(",")];

        for (const row of state.filteredRows) {
          lines.push(DATA_COLUMNS.map(key => csvEscape(row[key])).join(","));
        }

        const csv = "\ufeff" + lines.join("\n");
        const blob = new Blob([csv], { type:"text/csv;charset=utf-8" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = `coupang_camps_${new Date().toISOString().slice(0,10)}.csv`;
        a.click();

        URL.revokeObjectURL(url);
        setStatus("CSV 다운로드 완료", "ok");
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
        } catch {}

        location.href = LOGIN_PATH;
      }

      function findBaseCampRowForQr(row) {
        const mbCamp = normalizeText(row?.mb_camp);
        const ownCode = normalizeText(row?.code);

        // 본캠프 행이면 그대로 사용.
        if (!mbCamp || mbCamp === "본캠프") {
          return row;
        }

        // 모캠/하위캠프 행이면 mb_camp에 적힌 본캠프명을 기준으로 본캠프 행을 찾는다.
        const byMainCampName = state.rows.filter(item => {
          const camp = normalizeText(item.camp);
          return camp && camp === mbCamp;
        });

        const baseWithCode =
          byMainCampName.find(item => normalizeText(item.mb_camp) === "본캠프" && normalizeText(item.code)) ||
          byMainCampName.find(item => normalizeText(item.code));

        if (baseWithCode) return baseWithCode;

        // 혹시 camp명이 아니라 코드/설명 쪽에 본캠프 기준값이 들어온 경우 대비.
        const byCodeOrDesc = state.rows.find(item => {
          const camp = normalizeText(item.camp);
          const code = normalizeText(item.code);
          const desc = normalizeText(item.description);
          return normalizeText(item.mb_camp) === "본캠프" && (
            camp === mbCamp ||
            code === mbCamp ||
            desc === mbCamp
          );
        });

        return byCodeOrDesc || row;
      }

      function qrPayloadForRow(row) {
        const baseRow = findBaseCampRowForQr(row);

        const camp = normalizeText(baseRow?.camp) || normalizeText(row?.camp);
        const address = normalizeText(baseRow?.address) || normalizeText(row?.address);
        const code = normalizeText(baseRow?.code) || normalizeText(row?.code) || camp;

        // QR 실제 스캔값은 캠프명이 아니라 캠프 코드다.
        // 모캠/하위캠프는 위 findBaseCampRowForQr()에서 본캠프 행의 code를 우선 사용한다.
        return {
          code,
          camp,
          address,
          label: camp || code || "camp",
          qrText: code,
          baseCamp: baseRow,
          metaHtml: `
            <div class="qrMetaLine">
              <span class="qrMetaKey">캠프</span>
              <span class="qrMetaVal">${escapeHtml(camp || "-")}</span>
            </div>
            <div class="qrMetaLine">
              <span class="qrMetaKey">주소</span>
              <span class="qrMetaVal">${escapeHtml(address || "-")}</span>
            </div>
          `
        };
      }

      async function renderRealQrCanvas(canvas, text) {
        if (!canvas) throw new Error("QR 캔버스가 없습니다.");

        const qrText = normalizeText(text);
        if (!qrText) throw new Error("QR로 만들 캠프 코드가 없습니다.");

        if (!window.QRCode || typeof window.QRCode.toCanvas !== "function") {
          throw new Error("QR 라이브러리를 불러오지 못했습니다. 새로고침 후 다시 시도해주세요.");
        }

        await window.QRCode.toCanvas(canvas, qrText, {
          width: 220,
          margin: 2,
          errorCorrectionLevel: "M",
          color: {
            dark: "#111827",
            light: "#ffffff"
          }
        });
      }

      async function openQrForRow(id) {
        const row = findRow(id);
        if (!row) return;

        const payload = qrPayloadForRow(row);

        if (!payload.qrText) {
          setStatus("QR을 만들 캠프 코드가 없습니다.", "err");
          return;
        }

        try {
          state.currentQr = payload;
          dom.qrTitle.textContent = `${payload.label || payload.code} QR`;
          dom.qrMeta.innerHTML = payload.metaHtml;
          await renderRealQrCanvas(dom.qrCanvas, payload.qrText);
          dom.qrModal.classList.add("show");
          dom.qrModal.setAttribute("aria-hidden", "false");
          setStatus(`QR 생성 완료: ${payload.qrText}`, "ok");
        } catch (e) {
          console.error(e);
          setStatus(e.message || String(e), "err");
          alert(e.message || String(e));
        }
      }

      function closeQrModal() {
        dom.qrModal.classList.remove("show");
        dom.qrModal.setAttribute("aria-hidden", "true");
      }

      function canvasToBlob(canvas) {
        return new Promise(resolve => canvas.toBlob(resolve, "image/png"));
      }

      async function copyQrImageToClipboard() {
        const blob = await canvasToBlob(dom.qrCanvas);
        if (!blob) throw new Error("QR 이미지 생성 실패");

        if (navigator.clipboard && window.ClipboardItem) {
          await navigator.clipboard.write([new ClipboardItem({ "image/png": blob })]);
          setStatus("QR 이미지 복사 완료", "ok");
          return;
        }

        downloadQrImage();
      }

      async function downloadQrImage() {
        const payload = state.currentQr || { label:"camp_qr", code:"camp_qr", camp:"camp_qr" };
        const blob = await canvasToBlob(dom.qrCanvas);
        if (!blob) {
          setStatus("QR 이미지 생성 실패", "err");
          return;
        }

        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `${(payload.label || payload.code || "camp_qr").replace(/[\\/:*?"<>|\s]+/g, "_").slice(0, 60)}_qr.png`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        setStatus(`QR 이미지 다운로드 완료: ${payload.label || payload.code}`, "ok");
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", loadRows);
        dom.btnAddRow.addEventListener("click", addRow);
        dom.btnSaveAll.addEventListener("click", saveAll);
        dom.btnExportCsv.addEventListener("click", exportCsv);
        dom.btnClearFilters.addEventListener("click", clearFilters);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.btnDeniedHome.addEventListener("click", () => {
          location.href = INDEX_PATH;
        });

        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        dom.toggleOnlyChanged.addEventListener("change", applyFilters);

        for (const input of dom.filterInputs) {
          input.addEventListener("input", applyFilters);
          input.addEventListener("change", applyFilters);
        }

        dom.sheetBody.addEventListener("change", handleCellChange);
        dom.sheetBody.addEventListener("input", handleCellChange);

        dom.sheetBody.addEventListener("click", e => {
          const qrBtn = e.target.closest("[data-qr-id]");
          if (qrBtn) {
            void openQrForRow(qrBtn.dataset.qrId);
            return;
          }

          const btn = e.target.closest("[data-delete-id]");
          if (!btn) return;
          deleteRowById(btn.dataset.deleteId);
        });

        dom.btnQrClose.addEventListener("click", closeQrModal);
        dom.btnQrCloseBottom.addEventListener("click", closeQrModal);
        dom.qrModal.addEventListener("click", e => {
          if (e.target === dom.qrModal) closeQrModal();
        });
        dom.btnQrCopy.addEventListener("click", async () => {
          try {
            await copyQrImageToClipboard();
          } catch (e) {
            const msg = e?.message || String(e);
            setStatus(`QR 이미지 복사 실패: ${msg}`, "err");
            alert(msg);
          }
        });
        dom.btnQrDownload.addEventListener("click", downloadQrImage);

        document.addEventListener("keydown", e => {
          if (e.key === "Escape" && dom.qrModal.classList.contains("show")) {
            closeQrModal();
          }
        });
      }

      bindEvents();

      try {
        await getSessionAndAccess();
        hideAccessDenied();
        document.documentElement.style.visibility = "visible";

        await loadRows();

        if (state.canEdit) {
          setStatus("캠프 데이터 조회/수정 가능 상태입니다.", "ok");
        } else {
          setStatus("캠프 데이터 조회 전용 상태입니다.", "ok");
        }
      } catch (e) {
        console.error(e);
        showAccessDenied(state.viewerEmail, e.message || String(e));
      }
    })();
  </script>

  <script src="/board-menu.js"></script>
</body>
</html>
