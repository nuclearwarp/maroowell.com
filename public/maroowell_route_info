    if (selectedPoint?.id) {
      const { data, error } = await supabaseClient
        .from(TABLE_POINT)
        .update(payload)
        .eq("id", selectedPoint.id)
        .select()
        .single();

      if (error) throw error;
      saved = data;
      pointRows = pointRows.map(row => row.id === saved.id ? saved : row);
    } else {
      const { data, error } = await supabaseClient
        .from(TABLE_POINT)
        .insert(payload)
        .select()
        .single();

      if (error) throw error;
      saved = data;
      pointRows.push(saved);
    }

    selectedPoint = saved;
    renderPointList();
    fillPointForm(saved);
    renderMapFeatures();
    renderCounts();

    try {
      await loadAttachments(saved.id, false);
    } catch (e) {
      console.warn("attachment load skipped:", e);
      clearAttachmentsState();
    }

    setPointStatus("포인트 저장 완료", "ok");
  }

