<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>마루웰 회수율</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    :root{
      --bg:#0b1220;
      --card:#121a2d;
      --line:rgba(255,255,255,.12);
      --txt:#e6eefc;
      --muted:#9fb0d2;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      min-height:100vh;
      background:linear-gradient(180deg,#0b1220,#070b13);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    .wrap{
      max-width:1720px;
      margin:0 auto;
      padding:22px 18px 44px;
    }

    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:18px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .brand img{
      width:34px;
      height:34px;
    }

    .title{
      font-size:28px;
      font-weight:950;
      letter-spacing:-.6px;
      line-height:1.15;
    }

    .sub{
      color:var(--muted);
      font-size:14px;
      margin-top:5px;
      line-height:1.45;
    }

    .card{
      background:rgba(18,26,45,.9);
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 18px 60px rgba(0,0,0,.25);
    }

    .row,
    .presetRow{
      display:flex;
      gap:10px;
      align-items:flex-end;
      flex-wrap:wrap;
    }

    .presetRow{
      margin-top:12px;
      padding-top:12px;
      border-top:1px solid rgba(255,255,255,.08);
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    .field label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-left:2px;
    }

    input,select{
      height:42px;
      border-radius:12px;
      border:1px solid var(--line);
      background:rgba(0,0,0,.25);
      color:var(--txt);
      padding:0 12px;
      outline:none;
      min-width:140px;
    }

    input:focus,select:focus{
      border-color:rgba(96,165,250,.55);
      box-shadow:0 0 0 2px rgba(96,165,250,.12);
    }

    select option{
      background:#111827;
      color:#fff;
    }

    .campInput{min-width:180px}
    .routeInput{min-width:280px}
    .presetNameField input{min-width:240px}
    .presetSelectField select{min-width:340px}

    button{
      min-height:42px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(59,130,246,.24);
      color:#fff;
      padding:0 18px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
    }

    button:hover{background:rgba(59,130,246,.36)}
    button.secondary{background:rgba(255,255,255,.07)}
    button.secondary:hover{background:rgba(255,255,255,.12)}
    button.danger{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.32)}
    button.danger:hover{background:rgba(239,68,68,.28)}

    .hint{
      color:var(--muted);
      font-size:13px;
      line-height:1.55;
      margin-top:10px;
    }

    .status{
      font-size:13px;
      color:var(--muted);
      margin-top:10px;
      line-height:1.55;
    }

    .status.ok{color:#bbf7d0}
    .status.bad{color:#fecaca}
    .status.warn{color:#fde68a}

    .summary{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      min-height:32px;
      padding:0 12px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.06);
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .pill strong{
      color:#fff;
      margin-left:5px;
    }

    .sectionTitle{
      font-size:18px;
      font-weight:950;
      margin:0 0 12px;
    }

    .tableWrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:rgba(0,0,0,.18);
      max-height:580px;
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:max-content;
      min-width:100%;
      table-layout:fixed;
      font-size:13px;
    }

    th,td{
      border-right:1px solid rgba(255,255,255,.12);
      border-bottom:1px solid rgba(255,255,255,.12);
      padding:8px 10px;
      text-align:center;
      white-space:nowrap;
      min-width:88px;
      max-width:180px;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    th{
      position:sticky;
      top:0;
      z-index:5;
      background:#263247;
      color:#fff;
      font-weight:950;
    }

    .ratioGood{background:#7dd3fc;color:#082f49;font-weight:950}
    .ratioNormal{background:#dbeafe;color:#0f172a;font-weight:950}
    .ratioLow{background:#fff;color:#ef4444;font-weight:950}
    .ratioEmpty{color:#64748b;background:rgba(255,255,255,.03);font-weight:700}

    .totalTable td:first-child,
    .totalTable td:nth-child(2),
    .totalTable td:nth-child(3),
    .weekTable td:first-child,
    .weekTable td:nth-child(2),
    .weekTable td:nth-child(3){
      background:#111827;
      color:#e6eefc;
      font-weight:900;
    }

    .weekBlock{
      margin-top:16px;
    }

    .weekTitle{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-bottom:8px;
      font-weight:950;
      color:#e6eefc;
    }

    .weekTitle small{
      color:var(--muted);
      font-weight:800;
    }

    .dayCell{
      min-width:116px;
      max-width:116px;
      cursor:default;
    }

    .dayCellInner{
      display:flex;
      flex-direction:column;
      gap:3px;
      line-height:1.25;
    }

    .dayCellInner .g1{
      color:#7dd3fc;
      font-weight:950;
    }

    .dayCellInner .g2{
      color:#fef3c7;
      font-weight:950;
    }

    .emptyDay{
      color:#64748b;
      background:rgba(255,255,255,.03);
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:9999;
    }

    .accessDenied.show{display:flex}

    .accessCard{
      width:min(540px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
      line-height:1.6;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media(max-width:900px){
      .top{flex-direction:column;align-items:flex-start}
      .row,.presetRow{flex-direction:column;align-items:stretch}
      input,select,button,
      .campInput,.routeInput,
      .presetNameField input,
      .presetSelectField select{
        width:100%;
        min-width:0;
      }
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <a href="#" id="mwBoardMenuToggle"><img src="/favicon.ico" alt="MarooWell"></a>
        <div>
          <div class="title">마루웰 회수율</div>
          <div class="sub">쿠팡 정산월 기준으로 월 누적 회수율과 주차별 일자 회수율을 조회합니다.</div>
        </div>
      </div>
      <div class="pill" id="userPill">세션 확인 중</div>
    </div>

    <div class="card">
      <div class="row">
        <div class="field">
          <label>연도</label>
          <select id="yearFilter"></select>
        </div>

        <div class="field">
          <label>월</label>
          <select id="monthFilter"></select>
        </div>

        <div class="field">
          <label>Camp</label>
          <input id="campFilter" class="campInput" placeholder="예: 일산2" />
        </div>

        <div class="field">
          <label>주야간</label>
          <select id="waveFilter">
            <option value="">전체</option>
            <option value="W2">주간</option>
            <option value="W1">야간</option>
          </select>
        </div>

        <div class="field">
          <label>Route</label>
          <input id="routeFilter" class="routeInput" placeholder="예: 126A/126B/126C 또는 126_A" />
        </div>

        <button id="loadBtn">조회</button>
        <button id="clearBtn" class="secondary">초기화</button>
        <button id="copyTextBtn" class="secondary">표 복사</button>
      </div>

      <div class="presetRow">
        <div class="field presetNameField">
          <label>프리셋 이름</label>
          <input id="presetNameInput" placeholder="예: 일산2 주간 126/130 회수율" />
        </div>

        <div class="field presetSelectField">
          <label>저장된 프리셋</label>
          <select id="savedPresetSelect">
            <option value="">저장된 프리셋 없음</option>
          </select>
        </div>

        <button id="savePresetBtn" class="secondary" type="button">프리셋 저장</button>
        <button id="loadPresetBtn" class="secondary" type="button">불러와서 조회</button>
        <button id="deletePresetBtn" class="danger" type="button">프리셋 삭제</button>
      </div>

      <div class="hint" id="periodHint">
        쿠팡 정산월 기준입니다. 예: 4월 데이터 = 3월 26일 ~ 4월 25일.
      </div>

      <div class="status" id="statusText">대기 중</div>

      <div class="summary">
        <span class="pill">월누적 <strong id="totalCount">0</strong></span>
        <span class="pill">일자별 <strong id="dailyCount">0</strong></span>
        <span class="pill">표시 행 <strong id="routeCount">0</strong></span>
        <span class="pill">캠프 <strong id="campCount">0</strong></span>
        <span class="pill">일자 <strong id="dateCount">0</strong></span>
      </div>
    </div>

    <div class="card">
      <div class="sectionTitle">월 누적 회수율</div>
      <div class="tableWrap">
        <table id="totalTable" class="totalTable">
          <thead></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="sectionTitle">주차별 일자 회수율</div>
      <div id="weekContainer"></div>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">마루웰 소속 권한이 필요합니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="deniedHomeBtn" class="secondary" type="button">홈으로</button>
        <button id="deniedLogoutBtn" class="danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};

  const DAILY_TABLE = "maroowell_freshbag_ration";
  const TOTAL_TABLE = "maroowell_freshbag_ration_month_total";
  const PRESET_STORAGE_KEY = "mw:maroowell_freshbag_ratio:presets:v2";

  let supabaseClient = null;
  let currentUser = null;

  let totalRows = [];
  let dailyRows = [];
  let routeRows = [];

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg;
    $("statusText").className = type ? "status " + type : "status";
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z가-힣]/g, "");
  }

  function waveLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "W2") return "주간";
    if (s === "W1") return "야간";
    return s || "";
  }

  function pad2(n) {
    return String(Number(n)).padStart(2, "0");
  }

  function isoDate(date) {
    return `${date.getFullYear()}-${pad2(date.getMonth() + 1)}-${pad2(date.getDate())}`;
  }

  function parseIsoDate(iso) {
    const [y, m, d] = String(iso).split("-").map(Number);
    return new Date(y, m - 1, d);
  }

  function addDays(date, days) {
    return new Date(date.getFullYear(), date.getMonth(), date.getDate() + days);
  }

  function formatKoreanDate(iso) {
    const d = parseIsoDate(iso);
    const days = ["일", "월", "화", "수", "목", "금", "토"];
    return `${d.getMonth() + 1}/${d.getDate()} ${days[d.getDay()]}`;
  }

  function formatPercent(v) {
    if (v === null || v === undefined || v === "") return "";
    const n = Number(v);
    if (!Number.isFinite(n)) return "";
    return n.toFixed(2) + "%";
  }

  function ratioClass(v) {
    if (v === null || v === undefined || v === "") return "ratioEmpty";
    const n = Number(v);
    if (!Number.isFinite(n)) return "ratioEmpty";
    if (n >= 100) return "ratioGood";
    if (n >= 95) return "ratioNormal";
    return "ratioLow";
  }

  function routeListFromInput() {
    const raw = clean($("routeFilter").value);
    if (!raw) return [];

    return raw
      .split(/[,\s/|]+/g)
      .map(normalizeRoute)
      .filter(Boolean);
  }

  function unique(arr) {
    return Array.from(new Set(arr.filter(Boolean)));
  }

  function initOptions() {
    const now = new Date();
    const thisYear = now.getFullYear();
    const thisMonth = now.getMonth() + 1;

    const years = [];
    for (let y = thisYear + 1; y >= thisYear - 8; y--) years.push(y);

    $("yearFilter").innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join("");
    $("yearFilter").value = String(thisYear);

    $("monthFilter").innerHTML = Array.from({ length:12 }, (_, i) => {
      const m = i + 1;
      return `<option value="${m}">${m}월</option>`;
    }).join("");

    $("monthFilter").value = String(thisMonth);
    updatePeriodHint();
  }

  function getSelectedPeriod() {
    const year = Number($("yearFilter").value);
    const month = Number($("monthFilter").value);

    const periodStart = new Date(year, month - 2, 26);
    const periodEnd = new Date(year, month - 1, 25);

    return {
      data_year: year,
      month_no: month,
      data_month: `${year}-${pad2(month)}`,
      period_start: isoDate(periodStart),
      period_end: isoDate(periodEnd)
    };
  }

  function updatePeriodHint() {
    const p = getSelectedPeriod();
    $("periodHint").innerHTML =
      `<b>${p.data_year}년 ${p.month_no}월</b> 쿠팡 정산월 기준: <b>${p.period_start}</b> ~ <b>${p.period_end}</b>`;
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  function showAccessDenied(detail = "") {
    $("accessDenied").classList.add("show");
    $("accessDeniedText").textContent = detail || "마루웰 소속 권한이 필요합니다.";
    $("accessDeniedEmail").textContent = currentUser?.email
      ? `현재 로그인: ${currentUser.email}`
      : "현재 로그인 이메일을 확인할 수 없습니다.";
    document.documentElement.style.visibility = "visible";
  }

  async function checkMaroowellAccess() {
    if (!supabaseClient) initSupabase();

    const { data: sessionData, error: sessionError } = await supabaseClient.auth.getSession();
    if (sessionError) throw sessionError;

    currentUser = sessionData?.session?.user;

    if (!currentUser) {
      const loginPath = cfg.PATHS?.login || "/login.html";
      location.href = loginPath + "?next=" + encodeURIComponent(location.pathname);
      return false;
    }

    $("userPill").textContent = currentUser.email || currentUser.id;

    const { data: access, error: accessError } = await supabaseClient
      .rpc("mw_my_access")
      .maybeSingle();

    if (accessError) {
      showAccessDenied(accessError.message);
      return false;
    }

    if (access?.is_maroowell !== true) {
      showAccessDenied("마루웰 소속 권한이 필요합니다.\n조건: user_access.is_maroowell = true");
      return false;
    }

    document.documentElement.style.visibility = "visible";
    return true;
  }

  function applyCommonFilters(query) {
    const camp = clean($("campFilter").value);
    const wave = clean($("waveFilter").value);
    const routes = routeListFromInput();

    let q = query;

    if (camp) q = q.eq("camp", camp);
    if (wave) q = q.eq("wave", wave);
    if (routes.length) q = q.in("route_norm", routes);

    return q;
  }

  async function fetchTotalRows() {
    const p = getSelectedPeriod();

    let q = supabaseClient
      .from(TOTAL_TABLE)
      .select(`
        data_year,
        month_no,
        data_month,
        period_start,
        period_end,
        wave,
        camp,
        route,
        route_norm,
        gajoong1,
        gajoong2,
        source_file_name,
        updated_at
      `)
      .eq("data_year", p.data_year)
      .eq("month_no", p.month_no)
      .order("camp", { ascending:true })
      .order("wave", { ascending:true })
      .order("route_norm", { ascending:true })
      .limit(20000);

    q = applyCommonFilters(q);

    const { data, error } = await q;
    if (error) throw error;

    return Array.isArray(data) ? data : [];
  }

  async function fetchDailyRows() {
    const p = getSelectedPeriod();

    let q = supabaseClient
      .from(DAILY_TABLE)
      .select(`
        date,
        wave,
        camp,
        route,
        route_norm,
        gajoong1,
        gajoong2,
        source_file_name,
        updated_at
      `)
      .gte("date", p.period_start)
      .lte("date", p.period_end)
      .order("date", { ascending:true })
      .order("camp", { ascending:true })
      .order("wave", { ascending:true })
      .order("route_norm", { ascending:true })
      .limit(50000);

    q = applyCommonFilters(q);

    const { data, error } = await q;
    if (error) throw error;

    return Array.isArray(data) ? data : [];
  }

  function rowKey(row) {
    return `${row.wave}||${row.camp}||${normalizeRoute(row.route_norm || row.route)}`;
  }

  function buildRouteRows() {
    const map = new Map();

    const add = (row) => {
      const key = rowKey(row);
      if (!map.has(key)) {
        map.set(key, {
          key,
          wave: row.wave,
          camp: row.camp,
          route_norm: normalizeRoute(row.route_norm || row.route),
          route: normalizeRoute(row.route_norm || row.route)
        });
      }
    };

    totalRows.forEach(add);
    dailyRows.forEach(add);

    return Array.from(map.values()).sort((a, b) => {
      const waveOrder = { W2: 1, W1: 2 };

      return (
        String(a.camp).localeCompare(String(b.camp), "ko", { numeric:true }) ||
        ((waveOrder[a.wave] || 9) - (waveOrder[b.wave] || 9)) ||
        String(a.route_norm).localeCompare(String(b.route_norm), "ko", { numeric:true })
      );
    });
  }

  async function loadData() {
    updatePeriodHint();
    setStatus("회수율 조회 중...", "warn");

    totalRows = await fetchTotalRows();
    dailyRows = await fetchDailyRows();
    routeRows = buildRouteRows();

    renderTotalTable();
    renderWeeklyTables();
    renderSummary();

    setStatus(
      `조회 완료: 월누적 ${totalRows.length.toLocaleString()}건 / 일자별 ${dailyRows.length.toLocaleString()}건 / 표시 행 ${routeRows.length.toLocaleString()}개`,
      "ok"
    );
  }

  function renderSummary() {
    $("totalCount").textContent = totalRows.length.toLocaleString();
    $("dailyCount").textContent = dailyRows.length.toLocaleString();
    $("routeCount").textContent = routeRows.length.toLocaleString();
    $("campCount").textContent = unique(routeRows.map(row => row.camp)).length.toLocaleString();
    $("dateCount").textContent = unique(dailyRows.map(row => row.date)).length.toLocaleString();
  }

  function renderTotalTable() {
    const thead = $("totalTable").querySelector("thead");
    const tbody = $("totalTable").querySelector("tbody");

    thead.innerHTML = `
      <tr>
        <th>주야간</th>
        <th>Camp</th>
        <th>Route</th>
        <th>누적 가중1</th>
        <th>누적 가중2</th>
        <th>기간</th>
        <th>파일명</th>
      </tr>
    `;

    if (!totalRows.length) {
      tbody.innerHTML = `<tr><td colspan="7" class="ratioEmpty">월 누적 데이터 없음</td></tr>`;
      return;
    }

    tbody.innerHTML = totalRows.map(row => `
      <tr>
        <td>${esc(waveLabel(row.wave))}</td>
        <td>${esc(row.camp)}</td>
        <td>${esc(normalizeRoute(row.route_norm || row.route))}</td>
        <td class="${ratioClass(row.gajoong1)}">${esc(formatPercent(row.gajoong1))}</td>
        <td class="${ratioClass(row.gajoong2)}">${esc(formatPercent(row.gajoong2))}</td>
        <td>${esc(row.period_start)} ~ ${esc(row.period_end)}</td>
        <td>${esc(row.source_file_name || "")}</td>
      </tr>
    `).join("");
  }

  function dateRange(startIso, endIso) {
    const out = [];
    let d = parseIsoDate(startIso);
    const end = parseIsoDate(endIso);

    while (d <= end) {
      out.push(isoDate(d));
      d = addDays(d, 1);
    }

    return out;
  }

  function getWeeks() {
    const p = getSelectedPeriod();
    const start = parseIsoDate(p.period_start);
    const end = parseIsoDate(p.period_end);

    const firstSunday = addDays(start, -start.getDay());
    const weeks = [];

    let wStart = firstSunday;
    let seq = 1;

    while (wStart <= end) {
      const days = [];

      for (let i = 0; i < 7; i++) {
        const d = addDays(wStart, i);
        const iso = isoDate(d);

        days.push({
          iso,
          inPeriod: d >= start && d <= end
        });
      }

      const activeDays = days.filter(day => day.inPeriod);

      if (activeDays.length) {
        weeks.push({
          seq,
          start: activeDays[0].iso,
          end: activeDays[activeDays.length - 1].iso,
          days
        });
        seq++;
      }

      wStart = addDays(wStart, 7);
    }

    return weeks;
  }

  function dailyMap() {
    const map = new Map();

    for (const row of dailyRows) {
      map.set(`${rowKey(row)}||${row.date}`, row);
    }

    return map;
  }

  function renderWeeklyTables() {
    const container = $("weekContainer");
    const weeks = getWeeks();
    const dmap = dailyMap();

    if (!routeRows.length) {
      container.innerHTML = `<div class="ratioEmpty" style="padding:20px;text-align:center;border:1px solid var(--line);border-radius:16px">일자별 데이터 없음</div>`;
      return;
    }

    container.innerHTML = weeks.map(week => {
      const headers = week.days.map(day => {
        return `<th class="dayCell">${day.inPeriod ? esc(formatKoreanDate(day.iso)) : ""}</th>`;
      }).join("");

      const bodyRows = routeRows.map(routeRow => {
        const cells = week.days.map(day => {
          if (!day.inPeriod) return `<td class="emptyDay"></td>`;

          const item = dmap.get(`${routeRow.key}||${day.iso}`);

          if (!item) {
            return `<td class="emptyDay">-</td>`;
          }

          return `
            <td class="dayCell ${ratioClass(item.gajoong1)}">
              <div class="dayCellInner">
                <div class="g1">1: ${esc(formatPercent(item.gajoong1))}</div>
                <div class="g2">2: ${esc(formatPercent(item.gajoong2))}</div>
              </div>
            </td>
          `;
        }).join("");

        return `
          <tr>
            <td>${esc(waveLabel(routeRow.wave))}</td>
            <td>${esc(routeRow.camp)}</td>
            <td>${esc(routeRow.route)}</td>
            ${cells}
          </tr>
        `;
      }).join("");

      return `
        <div class="weekBlock">
          <div class="weekTitle">
            <div>${week.seq}주차</div>
            <small>${esc(week.start)} ~ ${esc(week.end)}</small>
          </div>
          <div class="tableWrap">
            <table class="weekTable">
              <thead>
                <tr>
                  <th>주야간</th>
                  <th>Camp</th>
                  <th>Route</th>
                  ${headers}
                </tr>
              </thead>
              <tbody>${bodyRows}</tbody>
            </table>
          </div>
        </div>
      `;
    }).join("");
  }

  function copyTextTable() {
    if (!routeRows.length) {
      setStatus("복사할 데이터가 없습니다.", "bad");
      return;
    }

    const p = getSelectedPeriod();
    const lines = [];

    lines.push(`마루웰 회수율\t${p.data_year}년 ${p.month_no}월\t${p.period_start} ~ ${p.period_end}`);
    lines.push("");

    lines.push("[월 누적]");
    lines.push(["주야간", "Camp", "Route", "누적 가중1", "누적 가중2", "기간"].join("\t"));

    for (const row of totalRows) {
      lines.push([
        waveLabel(row.wave),
        row.camp,
        normalizeRoute(row.route_norm || row.route),
        formatPercent(row.gajoong1),
        formatPercent(row.gajoong2),
        `${row.period_start} ~ ${row.period_end}`
      ].join("\t"));
    }

    lines.push("");
    lines.push("[주차별 일자]");

    const dmap = dailyMap();

    for (const week of getWeeks()) {
      lines.push("");
      lines.push(`${week.seq}주차\t${week.start} ~ ${week.end}`);

      const headers = ["주야간", "Camp", "Route"];

      for (const day of week.days) {
        headers.push(day.inPeriod ? `${formatKoreanDate(day.iso)} 가중1` : "");
        headers.push(day.inPeriod ? `${formatKoreanDate(day.iso)} 가중2` : "");
      }

      lines.push(headers.join("\t"));

      for (const routeRow of routeRows) {
        const cols = [waveLabel(routeRow.wave), routeRow.camp, routeRow.route];

        for (const day of week.days) {
          if (!day.inPeriod) {
            cols.push("");
            cols.push("");
            continue;
          }

          const item = dmap.get(`${routeRow.key}||${day.iso}`);
          cols.push(item ? formatPercent(item.gajoong1) : "");
          cols.push(item ? formatPercent(item.gajoong2) : "");
        }

        lines.push(cols.join("\t"));
      }
    }

    navigator.clipboard.writeText(lines.join("\n"))
      .then(() => setStatus("표 복사 완료", "ok"))
      .catch(() => setStatus("클립보드 복사 실패", "bad"));
  }

  function safeLocalStorageGet(key, fallback) {
    try {
      const raw = localStorage.getItem(key);
      if (!raw) return fallback;
      return JSON.parse(raw);
    } catch {
      return fallback;
    }
  }

  function safeLocalStorageSet(key, value) {
    try {
      localStorage.setItem(key, JSON.stringify(value));
      return true;
    } catch {
      return false;
    }
  }

  function getSavedPresets() {
    const list = safeLocalStorageGet(PRESET_STORAGE_KEY, []);
    return Array.isArray(list) ? list : [];
  }

  function setSavedPresets(list) {
    return safeLocalStorageSet(PRESET_STORAGE_KEY, Array.isArray(list) ? list : []);
  }

  function makePresetId() {
    return "preset_" + Date.now().toString(36) + "_" + Math.random().toString(36).slice(2, 8);
  }

  function buildPreset(name) {
    const presetName = clean(name);
    if (!presetName) throw new Error("프리셋 이름을 입력하세요.");

    return {
      id:"",
      name:presetName,
      updatedAt:new Date().toISOString(),
      year:$("yearFilter").value || "",
      month:$("monthFilter").value || "",
      camp:clean($("campFilter").value),
      wave:clean($("waveFilter").value),
      route:clean($("routeFilter").value)
    };
  }

  function renderPresetOptions(selectedId = "") {
    const presets = getSavedPresets()
      .slice()
      .sort((a, b) => String(b.updatedAt || "").localeCompare(String(a.updatedAt || "")));

    if (!presets.length) {
      $("savedPresetSelect").innerHTML = `<option value="">저장된 프리셋 없음</option>`;
      return;
    }

    $("savedPresetSelect").innerHTML = [
      `<option value="">저장된 프리셋 선택</option>`,
      ...presets.map(preset => {
        const date = String(preset.updatedAt || "").slice(0, 10);
        return `<option value="${esc(preset.id)}">${esc(preset.name)} · ${esc(date)}</option>`;
      })
    ].join("");

    if (selectedId) $("savedPresetSelect").value = selectedId;
  }

  function savePreset() {
    const preset = buildPreset($("presetNameInput").value);
    const presets = getSavedPresets();

    const selectedId = $("savedPresetSelect").value;
    const selectedIndex = presets.findIndex(item => item.id === selectedId);
    const sameNameIndex = presets.findIndex(item => item.name === preset.name);

    if (selectedIndex >= 0) {
      const ok = confirm(`선택된 프리셋을 덮어쓸까요?\n\n${presets[selectedIndex].name}`);
      if (!ok) return;

      preset.id = selectedId;
      presets[selectedIndex] = {
        ...presets[selectedIndex],
        ...preset,
        updatedAt:new Date().toISOString()
      };
    } else if (sameNameIndex >= 0) {
      const ok = confirm(`같은 이름의 프리셋이 있습니다. 덮어쓸까요?\n\n${preset.name}`);
      if (!ok) return;

      preset.id = presets[sameNameIndex].id;
      presets[sameNameIndex] = {
        ...presets[sameNameIndex],
        ...preset,
        updatedAt:new Date().toISOString()
      };
    } else {
      preset.id = makePresetId();
      presets.unshift(preset);
    }

    setSavedPresets(presets);
    renderPresetOptions(preset.id);
    setStatus(`프리셋 저장 완료: ${preset.name}`, "ok");
  }

  function applyPreset(preset) {
    if (!preset) return;

    if (preset.year) $("yearFilter").value = String(preset.year);
    if (preset.month) $("monthFilter").value = String(preset.month);

    $("campFilter").value = preset.camp || "";
    $("waveFilter").value = preset.wave || "";
    $("routeFilter").value = preset.route || "";
    $("presetNameInput").value = preset.name || "";

    updatePeriodHint();
  }

  async function loadPresetAndQuery() {
    const selectedId = $("savedPresetSelect").value;

    if (!selectedId) throw new Error("불러올 프리셋을 선택하세요.");

    const preset = getSavedPresets().find(item => item.id === selectedId);
    if (!preset) throw new Error("저장된 프리셋을 찾을 수 없습니다.");

    applyPreset(preset);
    await loadData();
  }

  function deletePreset() {
    const selectedId = $("savedPresetSelect").value;

    if (!selectedId) {
      setStatus("삭제할 프리셋을 선택하세요.", "bad");
      return;
    }

    const presets = getSavedPresets();
    const preset = presets.find(item => item.id === selectedId);

    if (!preset) {
      setStatus("삭제할 프리셋을 찾을 수 없습니다.", "bad");
      return;
    }

    const ok = confirm(`프리셋을 삭제할까요?\n\n${preset.name}`);
    if (!ok) return;

    setSavedPresets(presets.filter(item => item.id !== selectedId));
    renderPresetOptions();
    $("presetNameInput").value = "";
    setStatus("프리셋 삭제 완료", "ok");
  }

  function clearAll() {
    const now = new Date();

    $("yearFilter").value = String(now.getFullYear());
    $("monthFilter").value = String(now.getMonth() + 1);
    $("campFilter").value = "";
    $("waveFilter").value = "";
    $("routeFilter").value = "";
    $("presetNameInput").value = "";
    $("savedPresetSelect").value = "";

    totalRows = [];
    dailyRows = [];
    routeRows = [];

    updatePeriodHint();
    renderTotalTable();
    renderWeeklyTables();
    renderSummary();

    setStatus("초기화 완료", "ok");
  }

  async function signOut() {
    try {
      await supabaseClient?.auth?.signOut();
    } catch {}

    location.href = cfg.PATHS?.login || "/login.html";
  }

  function handleError(e) {
    console.error(e);
    setStatus(e.message || String(e), "bad");
  }

  function run(fn) {
    Promise.resolve().then(fn).catch(handleError);
  }

  function bindEvents() {
    $("loadBtn").addEventListener("click", () => run(loadData));
    $("clearBtn").addEventListener("click", clearAll);
    $("copyTextBtn").addEventListener("click", copyTextTable);

    $("savePresetBtn").addEventListener("click", () => run(async () => savePreset()));
    $("loadPresetBtn").addEventListener("click", () => run(loadPresetAndQuery));
    $("deletePresetBtn").addEventListener("click", deletePreset);

    $("savedPresetSelect").addEventListener("change", () => {
      const selectedId = $("savedPresetSelect").value;
      const preset = getSavedPresets().find(item => item.id === selectedId);
      if (preset) $("presetNameInput").value = preset.name || "";
    });

    ["yearFilter", "monthFilter"].forEach(id => {
      $(id).addEventListener("change", updatePeriodHint);
    });

    ["campFilter", "routeFilter"].forEach(id => {
      $(id).addEventListener("keydown", e => {
        if (e.key === "Enter") run(loadData);
      });
    });

    $("deniedHomeBtn").addEventListener("click", () => {
      location.href = cfg.PATHS?.index || "/index.html";
    });

    $("deniedLogoutBtn").addEventListener("click", signOut);
  }

  initOptions();
  bindEvents();

  try {
    initSupabase();

    run(async () => {
      const ok = await checkMaroowellAccess();
      if (!ok) return;

      renderPresetOptions();
      renderTotalTable();
      renderWeeklyTables();
      renderSummary();

      setStatus("마루웰 권한 확인 완료. 조건을 입력하고 조회하세요.", "ok");
    });
  } catch (e) {
    document.documentElement.style.visibility = "visible";
    handleError(e);
  }
})();
</script>

<script src="/board-menu.js"></script>
</body>
