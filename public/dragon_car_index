                location.replace(LOGIN_PATH + "?next=" + encodeURIComponent(next));
              }
            });
            return true;
          }
        } catch (e) {}

        const next = safeNextUrl(location.pathname + location.search + location.hash);
        location.replace(LOGIN_PATH + "?next=" + encodeURIComponent(next));
        return false;
      }

      function esc(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function nullIfBlank(v) {
        const s = String(v ?? "").trim();
        return s === "" ? null : s;
      }

      function toDateInput(v) {
        if (!v) return "";
        const s = String(v).slice(0, 10);
        return /^\d{4}-\d{2}-\d{2}$/.test(s) ? s : "";
      }

      function formatDateDisplay(v) {
        const s = toDateInput(v);
        if (!s) return "";
        const dt = new Date(s + "T00:00:00");
        if (Number.isNaN(dt.getTime())) return s;
        const yyyy = dt.getFullYear();
        const mm = String(dt.getMonth() + 1).padStart(2, "0");
        const dd = String(dt.getDate()).padStart(2, "0");
        const ww = WEEKDAYS[dt.getDay()];
        return `${yyyy}.${mm}.${dd} (${ww})`;
      }


      function parseIsoDate(v) {
        const s = toDateInput(v);
        if (!s) return null;
        const [y, m, d] = s.split("-").map(Number);
        const dt = new Date(y, m - 1, d);
        return Number.isNaN(dt.getTime()) ? null : dt;
      }

      function isoFromDate(dt) {
        if (!(dt instanceof Date) || Number.isNaN(dt.getTime())) return "";
        const yyyy = dt.getFullYear();
        const mm = String(dt.getMonth() + 1).padStart(2, "0");
        const dd = String(dt.getDate()).padStart(2, "0");
        return `${yyyy}-${mm}-${dd}`;
      }

      function formatDbError(e) {
        if (!e) return "알 수 없는 오류";
        const parts = [];
        if (e.code) parts.push(`code ${e.code}`);
        if (e.message) parts.push(e.message);
        if (e.details) parts.push(e.details);
        if (e.hint) parts.push(`hint: ${e.hint}`);
        return parts.join(" / ") || String(e);
      }

      function getKstNow() {
        const now = new Date();
        const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
        return new Date(utc + (9 * 60 * 60 * 1000));
      }

      function settlementMonthInfo(year, month) {
        const safeYear = Number(year);
        const safeMonth = Number(month);
        if (!Number.isInteger(safeYear) || !Number.isInteger(safeMonth) || safeMonth < 1 || safeMonth > 12) return null;

        const cycleStart = new Date(safeYear, safeMonth - 2, 26);
        const cycleEnd = new Date(safeYear, safeMonth - 1, 25);

        return {
          year: safeYear,
          month: safeMonth,
          monthKey: `${safeYear}-${String(safeMonth).padStart(2, "0")}`,
          label: `${String(safeYear).slice(-2)}년 ${safeMonth}월 정산`,
          cycleStart,
          cycleEnd,
          cycleStartIso: isoFromDate(cycleStart),
          cycleEndIso: isoFromDate(cycleEnd)
        };
      }

      function getDefaultSettlementMonthInfo(baseDate = getKstNow()) {
        const year = baseDate.getFullYear();
        const month = baseDate.getMonth() + 1;
        const day = baseDate.getDate();
        if (day >= 26) {
          if (month === 12) return settlementMonthInfo(year + 1, 1);
          return settlementMonthInfo(year, month + 1);
        }
        return settlementMonthInfo(year, month);
      }

      function parseSettlementMonthInput(value) {
        const raw = String(value ?? "").trim();
        if (!raw) return null;

        const compact = raw.replace(/\s+/g, "");
        let match = compact.match(/^(\d{4})[-./]?(\d{1,2})$/);
        if (match) return settlementMonthInfo(Number(match[1]), Number(match[2]));

        match = compact.match(/^(\d{2})[-./]?(\d{1,2})$/);
        if (match) return settlementMonthInfo(2000 + Number(match[1]), Number(match[2]));

        match = compact.match(/^(\d{4})년(\d{1,2})월$/);
        if (match) return settlementMonthInfo(Number(match[1]), Number(match[2]));

        match = compact.match(/^(\d{2})년(\d{1,2})월$/);
        if (match) return settlementMonthInfo(2000 + Number(match[1]), Number(match[2]));

        match = compact.match(/^(\d{1,2})월$/);
        if (match) {
          const fallback = getDefaultSettlementMonthInfo();
          return settlementMonthInfo(fallback.year, Number(match[1]));
        }

        return null;
      }

      function getSelectedSettlementMonthInfo() {
        const raw = String(toolbarMonthFilter.value ?? "").trim();
        if (!raw) return null;
        return parseSettlementMonthInput(raw);
      }

      function applyDefaultSettlementMonth() {
