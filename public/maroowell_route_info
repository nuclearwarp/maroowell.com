      throw new Error("먼저 라우트를 선택하세요.");
    }

    const routeCode = normalizeRoute(selectedPoint?.route_code || routeCodeOf(selectedRoute));
    const camp = selectedPoint?.camp || selectedRoute?.camp;

    const lat = Number($("pointLatInput").value);
    const lng = Number($("pointLngInput").value);

    if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
      throw new Error("위도/경도 값이 올바르지 않습니다.");
    }

    const polygon = polygonRows.find(poly => {
      return poly.camp === camp && polygonCodeOf(poly) === routeCode && poly.is_active !== false;
    });

    return {
      camp,
      route_code: routeCode,
      route_info_id: selectedRoute?.id || selectedPoint?.route_info_id || null,
      polygon_id: polygon?.id || selectedPoint?.polygon_id || null,
      lat,
      lng,
      point_type: $("pointTypeInput").value || "tip",
      title: clean($("pointTitleInput").value) || null,
      delivery_tip: clean($("deliveryTipInput").value) || null,
      password_note: clean($("passwordNoteInput").value) || null,
      entrance_note: clean($("entranceNoteInput").value) || null,
      parking_note: clean($("parkingNoteInput").value) || null,
      caution_note: clean($("cautionNoteInput").value) || null,
      memo: clean($("pointMemoInput").value) || null,
      marker_shape: "pin",
      marker_color: null,
      marker_json: {}
    };
  }

