<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰 용차</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --line:rgba(255,255,255,.10);
      --txt:#e6eefc;
      --muted:#93a4c7;
      --sheetBg:#eef3f8;
      --headBg:#dde7f3;
      --cellBg:#ffffff;
      --cellAlt:#f9fbfe;
      --cellTxt:#0f172a;
      --line2:#d4dbe5;
      --greenBg:#d9f0c7;
      --greenTxt:#46691c;
      --redBg:#ffd6d0;
      --redTxt:#a33d2c;
      --blueBg:#d8e8ff;
      --blueTxt:#245ecb;
      --grayBg:#e5e7eb;
      --grayTxt:#6b7280;
      --headerH:56px;
      --toolbarH:58px;
      --statusH:46px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      height: 100%;
      font-family: system-ui, -apple-system, "Noto Sans KR", Segoe UI, Roboto, Arial, sans-serif;
      background: var(--bg);
      color: var(--txt);
    }

    body { overflow: hidden; }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--headerH) var(--toolbarH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:#0c1422;
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
    }

    .spacer{ flex:1; }

    .btn{
      height:38px;
      padding:0 14px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      cursor:pointer;
      font-weight:800;
      font-size:13px;
      color:#fff;
      background:rgba(255,255,255,.06);
      white-space:nowrap;
    }

    .btn:hover{ background:rgba(255,255,255,.11); }
    .btn.primary{ background:rgba(29,78,216,.88); }
    .btn.primary:hover{ background:rgba(29,78,216,.98); }
    .btn.danger{
      background:rgba(185,28,28,.22);
      color:#fecaca;
      border-color:rgba(248,113,113,.24);
    }
    .btn.danger:hover{ background:rgba(185,28,28,.34); }

    .toolbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:10px 12px;
      background:#0b1422;
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .toolGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolGroup label{
      font-size:12px;
      color:var(--muted);
      font-weight:800;
      white-space:nowrap;
    }

    .toolbar input,
    .toolbar select{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbar input:focus,
    .toolbar select:focus{
      border-color:rgba(96,165,250,.55);
    }

    .sheetWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .sheetInner{
      min-width:2080px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
    }

    th, td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child, td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:3;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:13px;
      font-weight:900;
      white-space:nowrap;
    }

    thead tr.filterRow th{
      top:43px;
      z-index:2;
      background:#edf3fb;
      padding:6px;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    .cellInput,
    .cellSelect,
    .cellTextarea{
      width:100%;
      border:none;
      background:transparent;
      color:var(--cellTxt);
      outline:none;
      font:inherit;
    }

    .cellInput,
    .cellSelect{
      height:44px;
      padding:0 10px;
      font-size:14px;
    }

    .cellTextarea{
      min-height:44px;
      resize:vertical;
      padding:10px;
      line-height:1.4;
      font-size:14px;
    }

    .cellInput:focus,
    .cellSelect:focus,
    .cellTextarea:focus{
      background:rgba(59,130,246,.08);
      box-shadow:inset 0 0 0 2px rgba(59,130,246,.18);
    }

    .readonlyCell{
      height:44px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:900;
      background:rgba(15,23,42,.04);
    }

    .filterInput,
    .filterSelect{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      outline:none;
    }

    .filterInput:focus,
    .filterSelect:focus{
      border-color:#60a5fa;
    }

    .chipSelect{
      width:calc(100% - 12px);
      margin:6px;
      height:32px;
      border-radius:999px;
      font-weight:900;
      text-align:center;
      appearance:none;
      -webkit-appearance:none;
      padding:0 28px 0 10px;
      border:1px solid rgba(0,0,0,.06);
      background-position:right 10px center;
      background-repeat:no-repeat;
      background-size:10px 10px;
      background-image:url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="%236b7280"><path d="M5.5 7.5 10 12l4.5-4.5" stroke="%236b7280" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>');
    }

    .taxTrue{ background:var(--greenBg); color:var(--greenTxt); }
    .taxFalse{ background:var(--redBg); color:var(--redTxt); }
    .payTrue{ background:var(--blueBg); color:var(--blueTxt); }
    .payFalse{ background:var(--grayBg); color:var(--grayTxt); }

    .rowActions{
      display:flex;
      gap:6px;
      justify-content:center;
      align-items:center;
      padding:6px;
      min-height:44px;
    }

    .miniBtn{
      height:30px;
      min-width:30px;
      padding:0 8px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      cursor:pointer;
      font-size:12px;
      font-weight:800;
    }

    .miniBtn:hover{ background:#f5f7fb; }
    .miniBtn.save{ background:#effcf3; color:#166534; border-color:#b8e3c5; }
    .miniBtn.copy{ background:#eff6ff; color:#1d4ed8; border-color:#c7dcff; }
    .miniBtn.del{ background:#fff1f2; color:#b91c1c; border-color:#fecdd3; }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:6px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{ color:#bbf7d0; }
    .pill.warn{ color:#fde68a; }
    .pill.err{ color:#fecaca; }

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .dateCell{
      position:relative;
      height:44px;
      display:flex;
      align-items:center;
      gap:6px;
      padding:0 8px;
    }

    .dateDisplay{
      flex:1;
      height:32px;
      border:1px solid #c7d2e2;
      border-radius:10px;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:14px;
      text-align:left;
      cursor:pointer;
    }

    .dateDisplay:focus{
      outline:none;
      border-color:#60a5fa;
    }

    .dateNative{
      position:absolute;
      inset:0;
      opacity:0;
      pointer-events:none;
    }

    .dateIconBtn{
      height:30px;
      min-width:30px;
      border:1px solid #c7d2e2;
      background:#fff;
      border-radius:10px;
      cursor:pointer;
      font-size:14px;
    }


    .dateDisplay,
    .toolbarDateDisplay,
    .filterDateDisplay{
      appearance:none;
      -webkit-appearance:none;
      display:flex;
      align-items:center;
      width:100%;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      text-align:left;
      justify-content:flex-start;
    }

    .dateDisplay{
      font-weight:700;
    }

    .dateDisplay.empty,
    .toolbarDateDisplay.empty,
    .filterDateDisplay.empty{
      color:#94a3b8;
      font-weight:700;
    }

    .redDateText{
      color:#dc2626 !important;
      font-weight:900 !important;
    }

    .toolbarDateField,
    .filterDateField{
      display:flex;
      align-items:center;
      gap:6px;
      min-width:0;
    }

    .toolbarDateField{
      width:146px;
    }

    .toolbarDateDisplay{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbarDateDisplay:focus{
      border-color:rgba(96,165,250,.55);
    }

    .toolbarDateSep{
      color:var(--muted);
      font-size:12px;
      font-weight:900;
    }

    .filterDateDisplay{
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      outline:none;
    }

    .filterDateDisplay:focus{
      border-color:#60a5fa;
    }

    .toolbarMini,
    .filterMini{
      flex:0 0 auto;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .toolbarMini{
      height:38px;
      min-width:38px;
      border-color:rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
    }

    .filterMini{
      height:34px;
      min-width:34px;
    }

    .calendarPopover{
      position:fixed;
      z-index:9999;
      width:320px;
      padding:12px;
      border:1px solid #d5deeb;
      border-radius:16px;
      background:#fff;
      color:#0f172a;
      box-shadow:0 20px 50px rgba(15,23,42,.22);
    }

    .calendarPopover.hidden{
      display:none;
    }

    .calendarHeader{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      margin-bottom:10px;
    }

    .calendarHeaderLeft{
      display:flex;
      align-items:center;
      gap:8px;
      min-width:0;
    }

    .calendarMonthLabel{
      font-size:16px;
      font-weight:900;
      min-width:88px;
      text-align:center;
    }

    .calendarNavBtn,
    .calendarCloseBtn,
    .calendarActionBtn{
      height:32px;
      min-width:32px;
      border-radius:10px;
      border:1px solid #d7dee9;
      background:#fff;
      color:#0f172a;
      font-size:14px;
      font-weight:900;
      cursor:pointer;
    }

    .calendarNavBtn:hover,
    .calendarCloseBtn:hover,
    .calendarActionBtn:hover{
      background:#f8fafc;
    }

    .calendarActionBtn{
      padding:0 10px;
      min-width:auto;
      font-size:12px;
    }

    .calendarActionBtn.danger{
      color:#b91c1c;
      border-color:#fecdd3;
      background:#fff1f2;
    }

    .calendarWeekHead,
    .calendarGrid{
      display:grid;
      grid-template-columns:repeat(7, 1fr);
      gap:6px;
    }

    .calendarWeekHead{
      margin-bottom:6px;
    }

    .calendarWeekHead div{
      text-align:center;
      font-size:12px;
      font-weight:900;
      color:#64748b;
      padding:4px 0;
    }

    .calendarWeekHead .sun{
      color:#dc2626;
    }

    .calendarDay{
      position:relative;
      height:40px;
      border:1px solid #e2e8f0;
      border-radius:12px;
      background:#fff;
      color:#0f172a;
      cursor:pointer;
      font-size:13px;
      font-weight:800;
    }

    .calendarDay:hover{
      background:#f8fafc;
      border-color:#cbd5e1;
    }

    .calendarDay.otherMonth{
      color:#94a3b8;
      background:#f8fafc;
    }

    .calendarDay.redDate{
      color:#dc2626;
    }

    .calendarDay.today{
      box-shadow:inset 0 0 0 2px rgba(59,130,246,.35);
    }

    .calendarDay.selected{
      border-color:#60a5fa;
      background:#eff6ff;
      box-shadow:inset 0 0 0 2px rgba(59,130,246,.25);
    }

    .calendarDay.selected.redDate{
      color:#dc2626;
    }

    .calendarDayNum{
      display:block;
      line-height:38px;
      text-align:center;
    }

    .calendarFooter{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      margin-top:12px;
    }

    .calendarMeta{
      flex:1;
      min-width:0;
      color:#64748b;
      font-size:12px;
      font-weight:800;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .calendarFooterBtns{
      display:flex;
      gap:6px;
      flex:0 0 auto;
    }

    @media (max-width:900px){
      .btn{ padding:0 10px; font-size:12px; }
      .toolbar{ padding:8px; }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <a href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>마루웰 용차</b>
      </div>
      <div class="spacer"></div>
      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnAdd" class="btn" type="button">새 행</button>
      <button id="btnSaveAll" class="btn primary" type="button">전체 저장</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="toolGroup">
        <label for="quickSearch">빠른 검색</label>
        <input id="quickSearch" type="text" placeholder="Order / 기사 / 라우트 / 비고" />
      </div>

      <div class="toolGroup">
        <label for="toolbarVendorFilter">연결 벤더</label>
        <select id="toolbarVendorFilter"></select>
      </div>

      <div class="toolGroup">
        <label for="toolbarMonthFilter">정산월</label>
        <input id="toolbarMonthFilter" type="text" placeholder="예: 2026-03 / 3월" />
      </div>

      <div class="toolGroup">
        <label for="toolbarDateFrom">기간</label>
        <div class="toolbarDateField">
          <button
            id="toolbarDateFromDisplay"
            class="toolbarDateDisplay empty"
            type="button"
            data-action="open-external-date"
            data-target="toolbarDateFrom"
            data-date-display-for="toolbarDateFrom"
            data-placeholder="시작일"
          >시작일</button>
          <button class="dateIconBtn toolbarMini" type="button" data-action="open-external-date" data-target="toolbarDateFrom" title="달력 열기">📅</button>
          <input id="toolbarDateFrom" type="hidden" />
        </div>
        <span class="toolbarDateSep">~</span>
        <div class="toolbarDateField">
          <button
            id="toolbarDateToDisplay"
            class="toolbarDateDisplay empty"
            type="button"
            data-action="open-external-date"
            data-target="toolbarDateTo"
            data-date-display-for="toolbarDateTo"
            data-placeholder="종료일"
          >종료일</button>
          <button class="dateIconBtn toolbarMini" type="button" data-action="open-external-date" data-target="toolbarDateTo" title="달력 열기">📅</button>
          <input id="toolbarDateTo" type="hidden" />
        </div>
      </div>

      <div class="toolGroup">
        <button id="btnClearFilters" class="btn" type="button">필터 초기화</button>
        <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      </div>
    </div>

    <div class="sheetWrap">
      <div class="sheetInner">
        <table>
          <colgroup>
            <col style="width:130px">
            <col style="width:180px">
            <col style="width:170px">
            <col style="width:140px">
            <col style="width:120px">
            <col style="width:130px">
            <col style="width:120px">
            <col style="width:120px">
            <col style="width:120px">
            <col style="width:180px">
            <col style="width:110px">
            <col style="width:110px">
            <col style="width:90px">
            <col style="width:120px">
            <col style="width:150px">
            <col style="width:160px">
            <col style="width:120px">
            <col style="width:120px">
            <col style="width:240px">
            <col style="width:150px">
          </colgroup>

          <thead>
            <tr>
              <th>Date</th>
              <th>연결 벤더</th>
              <th>Order</th>
              <th>캠프</th>
              <th>주간/야간</th>
              <th>라우트</th>
              <th>단가</th>
              <th>정산일자</th>
              <th>투입 기사</th>
              <th>Order Vendor</th>
              <th>배송 수량</th>
              <th>반품 수량</th>
              <th>합계</th>
              <th>정산월</th>
              <th>dragon_car_id</th>
              <th>dragon_car_pw</th>
              <th>세금계산서</th>
              <th>입금여부</th>
              <th>비고</th>
              <th>행 작업</th>
            </tr>
            <tr class="filterRow">
              <th>
                <div class="filterDateField">
                  <button
                    id="headOrderDateDisplay"
                    class="filterDateDisplay empty"
                    type="button"
                    data-action="open-external-date"
                    data-target="headOrderDate"
                    data-date-display-for="headOrderDate"
                    data-placeholder="날짜"
                  >날짜</button>
                  <button class="dateIconBtn filterMini" type="button" data-action="open-external-date" data-target="headOrderDate" title="달력 열기">📅</button>
                  <input id="headOrderDate" class="filterInput" data-filter="order_date" type="hidden" />
                </div>
              </th>
              <th><select class="filterSelect" data-filter="vendor_id"></select></th>
              <th><input class="filterInput" data-filter="order_name" placeholder="Order" /></th>
              <th><input class="filterInput" data-filter="camp" placeholder="캠프" /></th>
              <th><input class="filterInput" data-filter="wave" placeholder="주간/야간" /></th>
              <th><input class="filterInput" data-filter="route" placeholder="라우트" /></th>
              <th><input class="filterInput" data-filter="price" placeholder="단가" /></th>
              <th><input class="filterInput" data-filter="settlement_day" placeholder="정산일자" /></th>
              <th><input class="filterInput" data-filter="delivery_driver" placeholder="기사" /></th>
              <th><input class="filterInput" data-filter="order_vendor" placeholder="Order Vendor" /></th>
              <th><input class="filterInput" data-filter="parcel" placeholder="배송" /></th>
              <th><input class="filterInput" data-filter="return_count" placeholder="반품" /></th>
              <th><input class="filterInput" data-filter="total_count" placeholder="합계" /></th>
              <th><input class="filterInput" data-filter="settlement_month" placeholder="정산월" /></th>
              <th><input class="filterInput" data-filter="dragon_car_id" placeholder="ID" /></th>
              <th><input class="filterInput" data-filter="dragon_car_pw" placeholder="PW" /></th>
              <th>
                <select class="filterSelect" data-filter="tax_invoice">
                  <option value="">전체</option>
                  <option value="true">발행</option>
                  <option value="false">미발행</option>
                </select>
              </th>
              <th>
                <select class="filterSelect" data-filter="payment_confirm">
                  <option value="">전체</option>
                  <option value="true">입금</option>
                  <option value="false">미입금</option>
                </select>
              </th>
              <th><input class="filterInput" data-filter="dragon_car_note" placeholder="비고" /></th>
              <th></th>
            </tr>
          </thead>

          <tbody id="sheetBody"></tbody>
        </table>
      </div>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillDirty" class="pill warn">변경 0</span>
      <span id="statusText" class="statusText">불러오기 후 편집하세요.</span>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INDEX_PATH = PATHS?.index || "/index.html";

      const authStorage = (() => {
        try { return window.sessionStorage; } catch { return null; }
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      const TABLE = "dragon_car";
      const VENDORS_TABLE = "vendors";
      const WEEKDAYS = ["일","월","화","수","목","금","토"];

      const FIXED_HOLIDAYS = Object.freeze({
        "01-01": "신정",
        "03-01": "삼일절",
        "05-05": "어린이날",
        "06-06": "현충일",
        "08-15": "광복절",
        "10-03": "개천절",
        "10-09": "한글날",
        "12-25": "성탄절"
      });

      const SPECIAL_HOLIDAYS = Object.freeze({
        "2025-01-27": "설날 연휴",
        "2025-01-28": "설날 연휴",
        "2025-01-29": "설날",
        "2025-01-30": "설날 연휴",
        "2025-03-03": "삼일절 대체휴일",
        "2025-05-06": "어린이날 대체휴일",
        "2025-06-03": "대통령 선거일",
        "2025-10-05": "추석 연휴",
        "2025-10-06": "추석",
        "2025-10-07": "추석 연휴",
        "2025-10-08": "추석 대체휴일",

        "2026-02-16": "설날 연휴",
        "2026-02-17": "설날",
        "2026-02-18": "설날 연휴",
        "2026-03-02": "삼일절 대체휴일",
        "2026-05-24": "부처님오신날",
        "2026-05-25": "부처님오신날 대체휴일",
        "2026-06-03": "지방선거일",
        "2026-08-17": "광복절 대체휴일",
        "2026-09-24": "추석 연휴",
        "2026-09-25": "추석",
        "2026-09-26": "추석 연휴",
        "2026-10-05": "개천절 대체휴일",

        "2027-02-06": "설날",
        "2027-02-08": "설날 연휴",
        "2027-05-13": "부처님오신날",
        "2027-09-14": "추석 연휴",
        "2027-09-15": "추석",
        "2027-09-16": "추석 연휴",
        "2027-10-11": "한글날 대체휴일",

        "2028-01-26": "설날",
        "2028-01-27": "설날 연휴",
        "2028-05-02": "부처님오신날",
        "2028-10-02": "추석 연휴",
        "2028-10-03": "추석 / 개천절",
        "2028-10-04": "추석 연휴"
      });

      const calendarState = {
        root: null,
        ctx: null,
        anchorEl: null,
        selectedIso: "",
        viewYear: null,
        viewMonth: null
      };


      const state = {
        user: null,
        vendors: [],
        rows: []
      };

      const sheetBody = document.getElementById("sheetBody");
      const btnReload = document.getElementById("btnReload");
      const btnAdd = document.getElementById("btnAdd");
      const btnSaveAll = document.getElementById("btnSaveAll");
      const btnLogout = document.getElementById("btnLogout");
      const btnClearFilters = document.getElementById("btnClearFilters");
      const btnExportCsv = document.getElementById("btnExportCsv");

      const quickSearch = document.getElementById("quickSearch");
      const toolbarVendorFilter = document.getElementById("toolbarVendorFilter");
      const toolbarMonthFilter = document.getElementById("toolbarMonthFilter");
      const toolbarDateFrom = document.getElementById("toolbarDateFrom");
      const toolbarDateTo = document.getElementById("toolbarDateTo");

      const pillState = document.getElementById("pillState");
      const pillRows = document.getElementById("pillRows");
      const pillDirty = document.getElementById("pillDirty");
      const statusText = document.getElementById("statusText");

      function setStatus(msg, kind = "ok") {
        pillState.className = "pill " + kind;
        pillState.textContent = kind.toUpperCase();
        statusText.textContent = msg || "";
      }

      function safeNextUrl(raw) {
        if (!raw) return INDEX_PATH;
        if (/^https?:\/\//i.test(raw)) return INDEX_PATH;
        if (!raw.startsWith("/")) return INDEX_PATH;
        return raw;
      }

      async function requireAuth() {
        if (!supabase?.auth) {
          setStatus("Supabase 설정 오류", "err");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();
          if (session?.user) {
            state.user = session.user;
            document.documentElement.style.visibility = "visible";
            supabase.auth.onAuthStateChange((evt, s) => {
              if (evt === "SIGNED_OUT" || !s) {
                const next = safeNextUrl(location.pathname + location.search + location.hash);
                location.replace(LOGIN_PATH + "?next=" + encodeURIComponent(next));
              }
            });
            return true;
          }
        } catch (e) {}

        const next = safeNextUrl(location.pathname + location.search + location.hash);
        location.replace(LOGIN_PATH + "?next=" + encodeURIComponent(next));
        return false;
      }

      function esc(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function nullIfBlank(v) {
        const s = String(v ?? "").trim();
        return s === "" ? null : s;
      }

      function toDateInput(v) {
        if (!v) return "";
        const s = String(v).slice(0, 10);
        return /^\d{4}-\d{2}-\d{2}$/.test(s) ? s : "";
      }

      function formatDateDisplay(v) {
        const s = toDateInput(v);
        if (!s) return "";
        const dt = new Date(s + "T00:00:00");
        if (Number.isNaN(dt.getTime())) return s;
        const yyyy = dt.getFullYear();
        const mm = String(dt.getMonth() + 1).padStart(2, "0");
        const dd = String(dt.getDate()).padStart(2, "0");
        const ww = WEEKDAYS[dt.getDay()];
        return `${yyyy}.${mm}.${dd} (${ww})`;
      }


      function parseIsoDate(v) {
        const s = toDateInput(v);
        if (!s) return null;
        const [y, m, d] = s.split("-").map(Number);
        const dt = new Date(y, m - 1, d);
        return Number.isNaN(dt.getTime()) ? null : dt;
      }

      function isoFromDate(dt) {
        if (!(dt instanceof Date) || Number.isNaN(dt.getTime())) return "";
        const yyyy = dt.getFullYear();
        const mm = String(dt.getMonth() + 1).padStart(2, "0");
        const dd = String(dt.getDate()).padStart(2, "0");
        return `${yyyy}-${mm}-${dd}`;
      }

      function formatDbError(e) {
        if (!e) return "알 수 없는 오류";
        const parts = [];
        if (e.code) parts.push(`code ${e.code}`);
        if (e.message) parts.push(e.message);
        if (e.details) parts.push(e.details);
        if (e.hint) parts.push(`hint: ${e.hint}`);
        return parts.join(" / ") || String(e);
      }

      function getHolidayName(v) {
        const iso = toDateInput(v);
        if (!iso) return "";
        const mmdd = iso.slice(5);
        return SPECIAL_HOLIDAYS[iso] || FIXED_HOLIDAYS[mmdd] || "";
      }

      function isSunday(v) {
        const dt = parseIsoDate(v);
        return !!dt && dt.getDay() === 0;
      }

      function isRedDate(v) {
        return !!getHolidayName(v) || isSunday(v);
      }

      function setDisplayButtonState(btn, iso, placeholder) {
        if (!btn) return;
        const normalized = toDateInput(iso);
        const pretty = formatDateDisplay(normalized);
        btn.textContent = pretty || placeholder || "날짜 선택";
        btn.classList.toggle("empty", !pretty);
        btn.classList.toggle("redDateText", !!pretty && isRedDate(normalized));

        const holidayName = getHolidayName(normalized);
        btn.title = holidayName
          ? `${pretty} · ${holidayName}`
          : (pretty || placeholder || "날짜 선택");
      }

      function setExternalDateValue(targetId, iso, fireEvents = true) {
        const input = document.getElementById(targetId);
        if (!input) return;

        const normalized = toDateInput(iso);
        input.value = normalized;

        const display = document.getElementById(targetId + "Display");
        const placeholder = display?.dataset.placeholder || "날짜 선택";
        setDisplayButtonState(display, normalized, placeholder);

        if (fireEvents) {
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.dispatchEvent(new Event("change", { bubbles: true }));
        }
      }

      function syncExternalDateDisplays() {
        document.querySelectorAll("[data-date-display-for]").forEach(btn => {
          const targetId = btn.dataset.dateDisplayFor;
          const input = document.getElementById(targetId);
          if (!input) return;
          setDisplayButtonState(btn, input.value, btn.dataset.placeholder || "날짜 선택");
        });
      }

      function closeCalendar() {
        if (!calendarState.root) return;
        calendarState.root.classList.add("hidden");
        calendarState.ctx = null;
        calendarState.anchorEl = null;
      }

      function positionCalendar() {
        if (!calendarState.root || calendarState.root.classList.contains("hidden") || !calendarState.anchorEl) return;

        const rect = calendarState.anchorEl.getBoundingClientRect();
        const root = calendarState.root;
        const margin = 8;
        const width = root.offsetWidth || 320;
        const height = root.offsetHeight || 380;

        let left = rect.left;
        let top = rect.bottom + 8;

        if (left + width > window.innerWidth - margin) left = window.innerWidth - width - margin;
        if (left < margin) left = margin;

        if (top + height > window.innerHeight - margin) {
          top = Math.max(margin, rect.top - height - 8);
        }

        root.style.left = `${Math.round(left)}px`;
        root.style.top = `${Math.round(top)}px`;
      }

      function renderCalendar() {
        ensureCalendar();

        const root = calendarState.root;
        const monthLabel = root.querySelector(".calendarMonthLabel");
        const grid = root.querySelector(".calendarGrid");
        const meta = root.querySelector(".calendarMeta");

        const firstDay = new Date(calendarState.viewYear, calendarState.viewMonth, 1);
        const startOffset = firstDay.getDay();
        const visibleStart = new Date(calendarState.viewYear, calendarState.viewMonth, 1 - startOffset);
        const todayIso = isoFromDate(new Date());

        monthLabel.textContent = `${calendarState.viewYear}.${String(calendarState.viewMonth + 1).padStart(2, "0")}`;

        const cells = [];
        for (let i = 0; i < 42; i += 1) {
          const dt = new Date(visibleStart.getFullYear(), visibleStart.getMonth(), visibleStart.getDate() + i);
          const iso = isoFromDate(dt);
          const holidayName = getHolidayName(iso);
          const inMonth = dt.getMonth() === calendarState.viewMonth;

          const classes = ["calendarDay"];
          if (!inMonth) classes.push("otherMonth");
          if (iso === todayIso) classes.push("today");
          if (iso === calendarState.selectedIso) classes.push("selected");
          if (isRedDate(iso)) classes.push("redDate");

          const title = holidayName
            ? `${formatDateDisplay(iso)} · ${holidayName}`
            : formatDateDisplay(iso);

          cells.push(
            `<button class="${classes.join(" ")}" type="button" data-cal-action="pick" data-date="${iso}" title="${esc(title)}">
              <span class="calendarDayNum">${dt.getDate()}</span>
            </button>`
          );
        }

        grid.innerHTML = cells.join("");

        const selectedHoliday = getHolidayName(calendarState.selectedIso);
        meta.textContent = calendarState.selectedIso
          ? `${formatDateDisplay(calendarState.selectedIso)}${selectedHoliday ? ` · ${selectedHoliday}` : ""}`
          : "날짜 선택";

        positionCalendar();
      }

      function commitCalendarSelection(iso) {
        const ctx = calendarState.ctx;
        if (!ctx) return;

        if (iso) {
          ctx.onSelect?.(iso);
        } else if (ctx.onClear) {
          ctx.onClear();
        } else {
          ctx.onSelect?.("");
        }

        closeCalendar();
      }

      function ensureCalendar() {
        if (calendarState.root) return;

        const root = document.createElement("div");
        root.className = "calendarPopover hidden";
        root.innerHTML = `
          <div class="calendarHeader">
            <div class="calendarHeaderLeft">
              <button class="calendarNavBtn" type="button" data-cal-action="prev-month">‹</button>
              <strong class="calendarMonthLabel"></strong>
              <button class="calendarNavBtn" type="button" data-cal-action="next-month">›</button>
            </div>
            <button class="calendarCloseBtn" type="button" data-cal-action="close">✕</button>
          </div>
          <div class="calendarWeekHead">
            <div class="sun">일</div>
            <div>월</div>
            <div>화</div>
            <div>수</div>
            <div>목</div>
            <div>금</div>
            <div>토</div>
          </div>
          <div class="calendarGrid"></div>
          <div class="calendarFooter">
            <span class="calendarMeta">날짜 선택</span>
            <div class="calendarFooterBtns">
              <button class="calendarActionBtn" type="button" data-cal-action="today">오늘</button>
              <button class="calendarActionBtn danger" type="button" data-cal-action="clear">지우기</button>
            </div>
          </div>
        `;

        root.addEventListener("click", (e) => {
          const btn = e.target.closest("[data-cal-action]");
          if (!btn) return;

          const action = btn.dataset.calAction;

          if (action === "prev-month") {
            const dt = new Date(calendarState.viewYear, calendarState.viewMonth - 1, 1);
            calendarState.viewYear = dt.getFullYear();
            calendarState.viewMonth = dt.getMonth();
            renderCalendar();
            return;
          }

          if (action === "next-month") {
            const dt = new Date(calendarState.viewYear, calendarState.viewMonth + 1, 1);
            calendarState.viewYear = dt.getFullYear();
            calendarState.viewMonth = dt.getMonth();
            renderCalendar();
            return;
          }

          if (action === "pick") {
            commitCalendarSelection(btn.dataset.date || "");
            return;
          }

          if (action === "today") {
            commitCalendarSelection(isoFromDate(new Date()));
            return;
          }

          if (action === "clear") {
            commitCalendarSelection("");
            return;
          }

          if (action === "close") {
            closeCalendar();
          }
        });

        document.body.appendChild(root);
        calendarState.root = root;

        document.addEventListener("mousedown", (e) => {
          if (!calendarState.root || calendarState.root.classList.contains("hidden")) return;
          const target = e.target;
          if (calendarState.root.contains(target)) return;
          if (calendarState.anchorEl && calendarState.anchorEl.contains && calendarState.anchorEl.contains(target)) return;
          closeCalendar();
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") closeCalendar();
        });

        window.addEventListener("resize", positionCalendar);
        document.addEventListener("scroll", () => {
          if (!calendarState.root || calendarState.root.classList.contains("hidden")) return;
          positionCalendar();
        }, true);
      }

      function openCalendar(options) {
        ensureCalendar();

        calendarState.ctx = options || null;
        calendarState.anchorEl = options?.anchorEl || null;
        calendarState.selectedIso = toDateInput(options?.value) || "";

        const baseDate = parseIsoDate(calendarState.selectedIso) || new Date();
        calendarState.viewYear = baseDate.getFullYear();
        calendarState.viewMonth = baseDate.getMonth();

        calendarState.root.classList.remove("hidden");
        renderCalendar();
      }


      function toInt(v) {
        if (v === "" || v == null) return 0;
        const n = Number(String(v).replace(/,/g, ""));
        return Number.isFinite(n) ? Math.trunc(n) : 0;
      }

      function toNum(v) {
        if (v === "" || v == null) return null;
        const n = Number(String(v).replace(/,/g, ""));
        return Number.isFinite(n) ? n : null;
      }

      function totalCount(row) {
        return toInt(row.parcel) + toInt(row.return_count);
      }

      function normalize(v) {
        return String(v ?? "").trim().toLowerCase();
      }

      function vendorNameById(id) {
        const found = state.vendors.find(v => String(v.id) === String(id || ""));
        return found ? (found.name || "") : "";
      }

      function vendorOptions(selected) {
        const options = ['<option value="">직접입력 / 미연결</option>'];
        for (const v of state.vendors) {
          const sel = String(v.id) === String(selected || "") ? " selected" : "";
          options.push('<option value="' + esc(v.id) + '"' + sel + '>' + esc(v.name || "-") + '</option>');
        }
        return options.join("");
      }

      function setVendorFilterOptions() {
        const currentToolbar = toolbarVendorFilter.value || "";
        const currentHead = document.querySelector('.filterSelect[data-filter="vendor_id"]')?.value || "";

        const make = (selected, label) => {
          const options = ['<option value="">' + label + '</option>'];
          for (const v of state.vendors) {
            const sel = String(v.id) === String(selected || "") ? " selected" : "";
            options.push('<option value="' + esc(v.id) + '"' + sel + '>' + esc(v.name || "-") + '</option>');
          }
          return options.join("");
        };

        toolbarVendorFilter.innerHTML = make(currentToolbar, "전체 벤더");

        const head = document.querySelector('.filterSelect[data-filter="vendor_id"]');
        if (head) head.innerHTML = make(currentHead, "전체");
      }

      function emptyRow() {
        return {
          id: null,
          vendor_id: "",
          order_date: "",
          order_name: "",
          order_vendor: "",
          camp: "",
          wave: "",
          route: "",
          price: "",
          settlement_day: "",
          delivery_driver: "",
          parcel: 0,
          return_count: 0,
          settlement_month: "",
          dragon_car_id: "",
          dragon_car_pw: "",
          tax_invoice: false,
          payment_confirm: false,
          dragon_car_note: "",
          __dirty: true,
          __new: true
        };
      }

      function getHeaderFilters() {
        const out = {};
        document.querySelectorAll(".filterInput, .filterSelect").forEach(el => {
          out[el.dataset.filter] = el.value || "";
        });
        return out;
      }

      function matchesFilter(row, key, filterValue) {
        if (!filterValue) return true;
        if (key === "vendor_id") return String(row.vendor_id || "") === String(filterValue);
        if (key === "tax_invoice" || key === "payment_confirm") return String(!!row[key]) === String(filterValue);

        let raw = "";
        if (key === "total_count") raw = String(totalCount(row));
        else raw = String(row[key] ?? "");

        return normalize(raw).includes(normalize(filterValue));
      }

      function getFilteredRows() {
        const head = getHeaderFilters();
        const quick = quickSearch.value || "";
        const toolbarVendor = toolbarVendorFilter.value || "";
        const toolbarMonth = toolbarMonthFilter.value || "";
        const dateFrom = toolbarDateFrom.value || "";
        const dateTo = toolbarDateTo.value || "";

        return state.rows.filter(row => {
          const keys = [
            "order_date","vendor_id","order_name","camp","wave","route","price","settlement_day",
            "delivery_driver","order_vendor","parcel","return_count","total_count","settlement_month",
            "dragon_car_id","dragon_car_pw","tax_invoice","payment_confirm","dragon_car_note"
          ];

          for (const key of keys) {
            if (!matchesFilter(row, key, head[key])) return false;
          }

          if (toolbarVendor && String(row.vendor_id || "") !== String(toolbarVendor)) return false;
          if (toolbarMonth && !normalize(row.settlement_month).includes(normalize(toolbarMonth))) return false;

          const d = toDateInput(row.order_date);
          if (dateFrom && d && d < dateFrom) return false;
          if (dateTo && d && d > dateTo) return false;

          if (quick) {
            const joined = [
              row.order_name, row.order_vendor, row.camp, row.wave, row.route,
              row.delivery_driver, row.dragon_car_note, row.dragon_car_id, row.dragon_car_pw
            ].join(" ");
            if (!normalize(joined).includes(normalize(quick))) return false;
          }

          return true;
        });
      }

      function refreshStatus() {
        pillRows.textContent = "행 " + getFilteredRows().length;
        pillDirty.textContent = "변경 " + state.rows.filter(r => r.__dirty).length;
      }

      function renderDateCell(row, rowIndex) {
        const raw = toDateInput(row.order_date);
        const pretty = formatDateDisplay(row.order_date);
        const displayClasses = ["dateDisplay"];
        if (!pretty) displayClasses.push("empty");
        if (isRedDate(raw)) displayClasses.push("redDateText");

        const title = getHolidayName(raw)
          ? `${pretty} · ${getHolidayName(raw)}`
          : (pretty || "날짜 선택");

        return `
          <div class="dateCell">
            <button
              class="${displayClasses.join(" ")}"
              type="button"
              data-action="open-date"
              data-row="${rowIndex}"
              title="${esc(title)}"
            >${esc(pretty || "날짜 선택")}</button>
            <button class="dateIconBtn" type="button" data-action="open-date" data-row="${rowIndex}" title="달력 열기">📅</button>
          </div>
        `;
      }

      function render() {
        const rows = getFilteredRows();

        sheetBody.innerHTML = rows.map(row => {
          const rowIndex = state.rows.indexOf(row);
          const total = totalCount(row);
          const taxClass = row.tax_invoice ? "taxTrue" : "taxFalse";
          const payClass = row.payment_confirm ? "payTrue" : "payFalse";

          return `
            <tr data-row="${rowIndex}">
              <td>${renderDateCell(row, rowIndex)}</td>
              <td><select class="cellSelect" data-row="${rowIndex}" data-field="vendor_id">${vendorOptions(row.vendor_id)}</select></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="order_name" value="${esc(row.order_name || "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="camp" value="${esc(row.camp || "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="wave" value="${esc(row.wave || "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="route" value="${esc(row.route || "")}"></td>
              <td><input class="cellInput" inputmode="decimal" data-row="${rowIndex}" data-field="price" value="${esc(row.price ?? "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="settlement_day" value="${esc(row.settlement_day || "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="delivery_driver" value="${esc(row.delivery_driver || "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="order_vendor" value="${esc(row.order_vendor || "")}" ${row.vendor_id ? "readonly" : ""} placeholder="${row.vendor_id ? "" : "직접입력 가능"}"></td>
              <td><input class="cellInput" inputmode="numeric" data-row="${rowIndex}" data-field="parcel" value="${esc(row.parcel ?? 0)}"></td>
              <td><input class="cellInput" inputmode="numeric" data-row="${rowIndex}" data-field="return_count" value="${esc(row.return_count ?? 0)}"></td>
              <td><div class="readonlyCell">${esc(total)}</div></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="settlement_month" value="${esc(row.settlement_month || "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="dragon_car_id" value="${esc(row.dragon_car_id || "")}"></td>
              <td><input class="cellInput" data-row="${rowIndex}" data-field="dragon_car_pw" value="${esc(row.dragon_car_pw || "")}"></td>
              <td>
                <select class="chipSelect ${taxClass}" data-row="${rowIndex}" data-field="tax_invoice">
                  <option value="true" ${row.tax_invoice ? "selected" : ""}>발행</option>
                  <option value="false" ${!row.tax_invoice ? "selected" : ""}>미발행</option>
                </select>
              </td>
              <td>
                <select class="chipSelect ${payClass}" data-row="${rowIndex}" data-field="payment_confirm">
                  <option value="true" ${row.payment_confirm ? "selected" : ""}>입금</option>
                  <option value="false" ${!row.payment_confirm ? "selected" : ""}>미입금</option>
                </select>
              </td>
              <td><textarea class="cellTextarea" data-row="${rowIndex}" data-field="dragon_car_note">${esc(row.dragon_car_note || "")}</textarea></td>
              <td>
                <div class="rowActions">
                  <button class="miniBtn save" data-action="save" data-row="${rowIndex}" type="button">저장</button>
                  <button class="miniBtn copy" data-action="copy" data-row="${rowIndex}" type="button">복제</button>
                  <button class="miniBtn del" data-action="delete" data-row="${rowIndex}" type="button">삭제</button>
                </div>
              </td>
            </tr>
          `;
        }).join("");

        refreshStatus();
      }

      function markDirty(row) {
        row.__dirty = true;
        refreshStatus();
      }

      function buildPayload(row) {
        return {
          vendor_id: row.vendor_id || null,
          order_date: toDateInput(row.order_date) || null,
          order_name: nullIfBlank(row.order_name),
          order_vendor: nullIfBlank(row.order_vendor),
          camp: nullIfBlank(row.camp),
          wave: nullIfBlank(row.wave),
          route: nullIfBlank(row.route),
          price: toNum(row.price),
          settlement_day: nullIfBlank(row.settlement_day),
          delivery_driver: nullIfBlank(row.delivery_driver),
          parcel: toInt(row.parcel),
          return_count: toInt(row.return_count),
          settlement_month: nullIfBlank(row.settlement_month),
          dragon_car_id: nullIfBlank(row.dragon_car_id),
          dragon_car_pw: nullIfBlank(row.dragon_car_pw),
          tax_invoice: !!row.tax_invoice,
          payment_confirm: !!row.payment_confirm,
          dragon_car_note: nullIfBlank(row.dragon_car_note)
        };
      }

      async function saveRowByObject(row) {
        const payload = buildPayload(row);

        if (row.id) {
          const { data, error } = await supabase
            .from(TABLE)
            .update(payload)
            .eq("id", row.id)
            .select("*")
            .single();
          if (error) throw error;
          Object.assign(row, data, { __dirty: false, __new: false });
        } else {
          const { data, error } = await supabase
            .from(TABLE)
            .insert(payload)
            .select("*")
            .single();
          if (error) throw error;
          Object.assign(row, data, { __dirty: false, __new: false });
        }
      }

      async function saveRow(rowIndex) {
        const row = state.rows[rowIndex];
        if (!row) return;
        try {
          setStatus("저장 중...", "warn");
          await saveRowByObject(row);
          render();
          setStatus("저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("저장 실패: " + formatDbError(e), "err");
        }
      }

      async function deleteRow(rowIndex) {
        const row = state.rows[rowIndex];
        if (!row) return;
        if (!confirm("이 행을 삭제할까요?")) return;

        try {
          if (row.id) {
            const { error } = await supabase.from(TABLE).delete().eq("id", row.id);
            if (error) throw error;
          }
          state.rows.splice(rowIndex, 1);
          render();
          setStatus("삭제 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("삭제 실패: " + formatDbError(e), "err");
        }
      }

      async function saveAll() {
        const dirtyRows = state.rows.filter(r => r.__dirty);
        if (!dirtyRows.length) {
          setStatus("저장할 변경이 없습니다.", "ok");
          return;
        }
        try {
          setStatus("변경분 저장 중...", "warn");
          for (const row of dirtyRows) {
            await saveRowByObject(row);
          }
          render();
          setStatus("전체 저장 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("전체 저장 실패: " + formatDbError(e), "err");
        }
      }

      async function loadVendors() {
        try {
          const { data, error } = await supabase
            .from(VENDORS_TABLE)
            .select("id,name,vendor_code,business_number")
            .order("name", { ascending: true });

          if (error) throw error;

          state.vendors = Array.isArray(data) ? data : [];
          setVendorFilterOptions();

          if (!state.vendors.length) {
            setStatus("벤더 목록이 0건입니다. 권한(RLS) 또는 vendor_members 연결을 확인하세요.", "warn");
          }
        } catch (e) {
          console.error(e);
          state.vendors = [];
          setVendorFilterOptions();
          setStatus("벤더 불러오기 실패: " + formatDbError(e), "err");
        }
      }

      async function loadRows() {
        try {
          setStatus("불러오는 중...", "warn");
          const { data, error } = await supabase
            .from(TABLE)
            .select("*")
            .order("order_date", { ascending: false, nullsFirst: false })
            .order("id", { ascending: false });

          if (error) throw error;

          state.rows = (Array.isArray(data) ? data : []).map(row => ({
            ...row,
            __dirty: false,
            __new: false
          }));

          render();
          setStatus("불러오기 완료", "ok");
        } catch (e) {
          console.error(e);
          setStatus("불러오기 실패: " + formatDbError(e), "err");
        }
      }

      function exportCsv() {
        const rows = getFilteredRows();
        const headers = [
          "order_date","vendor_name","order_name","camp","wave","route","price","settlement_day",
          "delivery_driver","order_vendor","parcel","return_count","total_count","settlement_month",
          "dragon_car_id","dragon_car_pw","tax_invoice","payment_confirm","dragon_car_note"
        ];

        const lines = [headers.join(",")];

        for (const row of rows) {
          const values = [
            toDateInput(row.order_date),
            vendorNameById(row.vendor_id),
            row.order_name || "",
            row.camp || "",
            row.wave || "",
            row.route || "",
            row.price ?? "",
            row.settlement_day || "",
            row.delivery_driver || "",
            row.order_vendor || "",
            toInt(row.parcel),
            toInt(row.return_count),
            totalCount(row),
            row.settlement_month || "",
            row.dragon_car_id || "",
            row.dragon_car_pw || "",
            row.tax_invoice ? "발행" : "미발행",
            row.payment_confirm ? "입금" : "미입금",
            row.dragon_car_note || ""
          ].map(v => '"' + String(v).replace(/"/g, '""') + '"');

          lines.push(values.join(","));
        }

        const blob = new Blob(["\uFEFF" + lines.join("\n")], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "dragon_car_" + new Date().toISOString().slice(0, 10) + ".csv";
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      function clearFilters() {
        quickSearch.value = "";
        toolbarVendorFilter.value = "";
        toolbarMonthFilter.value = "";
        toolbarDateFrom.value = "";
        toolbarDateTo.value = "";
        document.querySelectorAll(".filterInput, .filterSelect").forEach(el => {
          el.value = "";
        });
        syncExternalDateDisplays();
        setVendorFilterOptions();
        render();
      }

      sheetBody.addEventListener("input", (e) => {
        const el = e.target;
        const rowIndex = Number(el.dataset.row);
        const field = el.dataset.field;
        if (!Number.isInteger(rowIndex) || !field || !state.rows[rowIndex]) return;

        const row = state.rows[rowIndex];
        row[field] = el.value;

        if (field === "parcel" || field === "return_count") {
          const tr = el.closest("tr");
          const totalCell = tr ? tr.querySelector(".readonlyCell") : null;
          if (totalCell) totalCell.textContent = String(totalCount(row));
        }

        markDirty(row);
      });

      sheetBody.addEventListener("change", (e) => {
        const el = e.target;
        const rowIndex = Number(el.dataset.row);
        const field = el.dataset.field;
        if (!Number.isInteger(rowIndex) || !field || !state.rows[rowIndex]) return;

        const row = state.rows[rowIndex];

        if (field === "order_date") {
          row.order_date = el.value || "";
          markDirty(row);
          render();
          return;
        }

        if (field === "vendor_id") {
          row.vendor_id = el.value || "";
          if (row.vendor_id) {
            row.order_vendor = vendorNameById(row.vendor_id) || row.order_vendor || "";
          }
          markDirty(row);
          render();
          return;
        }

        if (field === "tax_invoice" || field === "payment_confirm") {
          row[field] = String(el.value) === "true";
          markDirty(row);
          render();
        }
      });

      sheetBody.addEventListener("click", async (e) => {
        const btn = e.target.closest("[data-action]");
        if (!btn) return;

        const action = btn.dataset.action;
        const rowIndex = Number(btn.dataset.row);

        if (action === "open-date") {
          const row = state.rows[rowIndex];
          if (!row) return;

          openCalendar({
            anchorEl: btn.closest(".dateCell") || btn,
            value: row.order_date,
            onSelect: (iso) => {
              row.order_date = iso || "";
              markDirty(row);
              render();
            },
            onClear: () => {
              row.order_date = "";
              markDirty(row);
              render();
            }
          });
          return;
        }

        if (action === "save") {
          await saveRow(rowIndex);
          return;
        }

        if (action === "copy") {
          const row = state.rows[rowIndex];
          if (!row) return;
          state.rows.unshift({
            ...row,
            id: null,
            __dirty: true,
            __new: true
          });
          render();
          setStatus("행 복제 완료", "ok");
          return;
        }

        if (action === "delete") {
          await deleteRow(rowIndex);
        }
      });

      document.addEventListener("click", (e) => {
        const btn = e.target.closest('[data-action="open-external-date"]');
        if (!btn) return;

        const targetId = btn.dataset.target;
        const input = document.getElementById(targetId);
        if (!input) return;

        openCalendar({
          anchorEl: btn.closest(".toolbarDateField, .filterDateField") || btn,
          value: input.value,
          onSelect: (iso) => setExternalDateValue(targetId, iso),
          onClear: () => setExternalDateValue(targetId, "")
        });
      });

      quickSearch.addEventListener("input", render);
      toolbarVendorFilter.addEventListener("change", render);
      toolbarMonthFilter.addEventListener("input", render);
      toolbarDateFrom.addEventListener("change", render);
      toolbarDateTo.addEventListener("change", render);

      document.addEventListener("input", (e) => {
        if (e.target.classList.contains("filterInput")) render();
      });

      document.addEventListener("change", (e) => {
        if (e.target.classList.contains("filterSelect")) render();
      });

      btnReload.addEventListener("click", loadRows);
      btnAdd.addEventListener("click", () => {
        state.rows.unshift(emptyRow());
        render();
        setStatus("새 행 추가 완료", "ok");
      });
      btnSaveAll.addEventListener("click", saveAll);
      btnClearFilters.addEventListener("click", clearFilters);
      btnExportCsv.addEventListener("click", exportCsv);

      btnLogout.addEventListener("click", async () => {
        if (!confirm("로그아웃할까요?")) return;
        try { await supabase.auth.signOut(); } catch {}
        location.replace(LOGIN_PATH);
      });

      syncExternalDateDisplays();

      if (!(await requireAuth())) return;
      await loadVendors();
      render();
      await loadRows();
    })();
  </script>
</body>
</html>
