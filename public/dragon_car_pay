      async function fetchAllRows(tableName) {
        const pageSize = 1000;
        let from = 0;
        const rows = [];
        while (true) {
          const { data, error } = await supabase
            .from(tableName)
            .select("*")
            .range(from, from + pageSize - 1);
          if (error) throw error;
          rows.push(...(data || []));
          if (!data || data.length < pageSize) break;
          from += pageSize;
        }
        return rows;
      }

      async function loadVendorRows() {
        try {
          state.vendorRows = await fetchAllRows(VENDORS_TABLE);
          state.vendorById.clear();
          for (const row of state.vendorRows) {
            const id = normalizeText(valueByCandidates(row, ["id", "vendor_id", "pk_id", "seq"]));
            if (id) state.vendorById.set(String(id), row);
          }
        } catch (err) {
          console.warn("vendors load skipped", err);
          state.vendorRows = [];
          state.vendorById.clear();
        }
      }

      async function loadDriverInfoRows() {
        try {
          state.driverInfoRows = await fetchAllRows(DRIVER_INFO_TABLE);
          state.driverInfoByName.clear();
          for (const row of state.driverInfoRows) {
            const name = driverInfoName(row);
            if (name) state.driverInfoByName.set(compactText(name), row);
          }
        } catch (err) {
          console.warn("driver info load skipped", err);
          state.driverInfoRows = [];
          state.driverInfoByName.clear();
        }
      }

