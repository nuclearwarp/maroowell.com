        setStatePill("warn", "LOAD");
        setStatus("용차 정산 데이터를 불러오는 중입니다.");
        dom.btnReload.disabled = true;

        await Promise.all([loadVendorRows(), loadDriverInfoRows()]);
        state.allRows = await fetchAllRows(DATA_TABLE);
        render();

        setStatePill("ok", "READY");
        setStatus("불러오기 완료: 원본 " + fmtNumber(state.allRows.length) + "행 / 기사정보 " + fmtNumber(state.driverInfoRows.length) + "행");
        dom.btnReload.disabled = false;
