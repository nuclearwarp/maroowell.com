  <style>
    :root{
      --bg:#0b1220;
      --card:#121a2d;
      --line:rgba(255,255,255,.12);
      --line2:rgba(255,255,255,.18);
      --txt:#e6eefc;
      --muted:#9fb0d2;
      --blue:#60a5fa;
      --red:#ef4444;
      --green:#22c55e;
      --yellow:#f59e0b;
      --cell:#111827;
      --head:#263247;
      --sep:#94a3b8;
      --sepCamp:#f8fafc;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      min-height:100vh;
      background:linear-gradient(180deg,#0b1220,#070b13);
      color:var(--txt);
      font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif;
    }

    .wrap{
      max-width:1720px;
      margin:0 auto;
      padding:22px 18px 44px;
    }

    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:18px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .brand img{
      width:34px;
      height:34px;
    }

    .title{
      font-size:28px;
      font-weight:950;
      letter-spacing:-.6px;
      line-height:1.15;
    }

    .sub{
      color:var(--muted);
      font-size:14px;
      margin-top:5px;
      line-height:1.45;
    }

    .card{
      background:rgba(18,26,45,.9);
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 18px 60px rgba(0,0,0,.25);
    }

    .row{
      display:flex;
      gap:10px;
      align-items:flex-end;
      flex-wrap:wrap;
    }

    .presetRow{
      display:flex;
      gap:10px;
      align-items:flex-end;
      flex-wrap:wrap;
      margin-top:12px;
      padding-top:12px;
      border-top:1px solid rgba(255,255,255,.08);
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    .field label{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      margin-left:2px;
    }

    input,select{
      height:42px;
      border-radius:12px;
      border:1px solid var(--line);
      background:rgba(0,0,0,.25);
      color:var(--txt);
      padding:0 12px;
      outline:none;
      min-width:150px;
    }

    .presetNameField input{
      min-width:240px;
    }

    .presetSelectField select{
      min-width:300px;
    }

    select option{
      background:#111827;
      color:#fff;
    }

    input:focus,select:focus{
      border-color:rgba(96,165,250,.55);
      box-shadow:0 0 0 2px rgba(96,165,250,.12);
    }

    button{
      min-height:42px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(59,130,246,.24);
      color:#fff;
      padding:0 18px;
      font-weight:900;
      cursor:pointer;
      white-space:nowrap;
    }

    button:hover{
      background:rgba(59,130,246,.36);
    }

    button.secondary{
      background:rgba(255,255,255,.07);
    }

    button.secondary:hover{
      background:rgba(255,255,255,.12);
    }

    button.ok{
      background:rgba(34,197,94,.18);
      border-color:rgba(34,197,94,.32);
    }

    button.ok:hover{
      background:rgba(34,197,94,.28);
    }

    button.danger{
      background:rgba(239,68,68,.18);
      border-color:rgba(239,68,68,.32);
    }

    button.danger:hover{
      background:rgba(239,68,68,.28);
    }

    button.small{
      min-height:28px;
      padding:0 9px;
      font-size:12px;
      border-radius:999px;
    }

    .hideMonthBtn{
      min-height:22px;
      padding:0 8px;
      font-size:11px;
      border-radius:999px;
      border:1px solid #f0a6bd;
      background:#fde2ec;
      color:#a21caf;
      line-height:20px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      margin-left:5px;
      vertical-align:middle;
    }

    .hideMonthBtn:hover{
      background:#fbcfe8;
      color:#86198f;
      border-color:#ec4899;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      min-height:32px;
      padding:0 12px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.06);
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      white-space:nowrap;
    }

    .pill strong{
      color:#fff;
      margin-left:5px;
    }

    .status{
      font-size:13px;
      color:var(--muted);
      margin-top:10px;
      line-height:1.55;
    }

    .status.ok{color:#bbf7d0}
    .status.bad{color:#fecaca}
    .status.warn{color:#fde68a}

    .summary{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .hint{
      color:var(--muted);
      font-size:13px;
      line-height:1.55;
      margin-top:10px;
    }

    .hiddenMonthBar{
      display:flex;
      align-items:center;
      gap:8px;
      padding:9px 2px 12px;
      overflow:auto hidden;
      min-height:44px;
    }

    .hiddenMonthBar.empty{
      display:none;
    }

    .hiddenMonthLabel{
      color:#bfdbfe;
      font-size:12px;
      font-weight:1000;
      flex:0 0 auto;
    }

    .hiddenMonthChip{
      height:30px;
      padding:0 11px;
      border-radius:999px;
      border:1px solid rgba(147,197,253,.35);
      background:rgba(37,99,235,.22);
      color:#dbeafe;
      font-size:12px;
      font-weight:1000;
      cursor:pointer;
      white-space:nowrap;
      flex:0 0 auto;
    }

    .hiddenMonthChip:hover{
      background:rgba(37,99,235,.34);
    }

    .hiddenMonthChip.all{
      border-color:rgba(134,239,172,.35);
      background:rgba(22,163,74,.24);
      color:#dcfce7;
    }

    .tableWrap{
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      background:rgba(0,0,0,.18);
      max-height:calc(100vh - 380px);
    }

    table{
      border-collapse:separate;
      border-spacing:0;
      width:max-content;
      min-width:100%;
      table-layout:fixed;
      font-size:13px;
    }

    th,td{
      border-right:1px solid rgba(255,255,255,.12);
      border-bottom:1px solid rgba(255,255,255,.12);
      padding:5px 4px;
      text-align:center;
      white-space:nowrap;
      min-width:52px;
      max-width:120px;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    th{
      position:sticky;
      top:0;
      z-index:5;
      background:#263247;
      color:#fff;
      font-weight:950;
    }

    thead tr.monthSubRow th{
      top:34px;
      z-index:6;
      background:#2d3a51;
      font-size:12px;
      padding:5px 4px;
    }

    th.actionCol,
    td.actionCol{
      position:sticky;
      left:0;
      z-index:4;
      width:66px;
      min-width:66px;
      max-width:66px;
      background:#111827;
    }

    th.actionCol{
      z-index:8;
      background:#263247;
    }

    th.sticky1,
    td.sticky1{
      position:sticky;
      left:66px;
      z-index:4;
      width:76px;
      min-width:76px;
      max-width:76px;
    }

    th.sticky1{z-index:8}

    td.sticky1{
      background:#111827;
      color:#e6eefc;
      font-weight:900;
    }

    th.sticky2,
    td.sticky2{
      position:sticky;
      left:142px;
      z-index:4;
      width:88px;
      min-width:88px;
      max-width:88px;
    }

    th.sticky2{z-index:8}

    td.sticky2{
      background:#111827;
      color:#e6eefc;
      font-weight:900;
    }

    th.sticky3,
    td.sticky3{
      position:sticky;
      left:230px;
      z-index:4;
      width:78px;
      min-width:78px;
      max-width:78px;
    }

    th.sticky3{z-index:8}

    td.sticky3{
      background:#111827;
      color:#bfdbfe;
      font-weight:950;
    }

    th.monthGroup{
      width:112px;
      min-width:112px;
      max-width:112px;
      border-left:2px solid rgba(255,255,255,.25);
    }

    th.monthValue,
    td.monthValue{
      width:56px;
      min-width:56px;
      max-width:56px;
    }

    th.monthFirst,
    td.monthFirst{
      border-left:1px solid rgba(255,255,255,.14);
    }

    tr.routeSep td{
      border-top:2px solid var(--sep);
    }

    tr.campSep td{
      border-top:4px double var(--sepCamp);
    }

    td.editable{
      cursor:cell;
    }

    td.editable:hover,
    td.editable:focus{
      outline:2px solid rgba(96,165,250,.45);
      outline-offset:-2px;
      background-color:rgba(96,165,250,.12);
    }

    td.readonlyValue{
      cursor:default;
      user-select:text;
    }

    td.readonlyValue:hover{
      outline:none;
    }

    .yes{
      background:#7dd3fc;
      color:#082f49;
      font-weight:950;
    }

    .no{
      background:#fff;
      color:#ef4444;
      font-weight:950;
    }

    .empty{
      color:#6b7280;
      background:rgba(255,255,255,.03);
    }

    .tableWrap input.editorInput,
    .tableWrap select.editorSelect{
      width:100% !important;
      min-width:0 !important;
      max-width:100% !important;
      height:28px !important;
      border-radius:8px;
      padding:0 6px;
      font-size:13px;
      box-shadow:none;
    }

    @media(max-width:900px){
      .top{
        flex-direction:column;
        align-items:flex-start;
      }

      .row,
      .presetRow{
        flex-direction:column;
        align-items:stretch;
      }

      input,select,button,
      .presetNameField input,
      .presetSelectField select{
        width:100%;
        min-width:0;
      }
    }
  </style>

