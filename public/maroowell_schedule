      function openWeekPicker(){
        state.pickerMonth=state.pickerMonth||firstOfMonth(parseIso(state.weekStart)||new Date());
        renderWeekPicker();
        els.weekPopup.classList.add("open");
      }
      function closeWeekPicker(){els.weekPopup.classList.remove("open")}
      function firstOfMonth(d){return new Date(d.getFullYear(),d.getMonth(),1)}
      function addMonths(d,months){return new Date(d.getFullYear(),d.getMonth()+months,1)}
      function sameIso(a,b){return clean(a)===clean(b)}

      function renderWeekPicker(){
        const month=state.pickerMonth||firstOfMonth(new Date());
        const y=month.getFullYear();
        const m=month.getMonth();
        els.weekMonthTitle.textContent=`${y}년 ${m+1}월`;

        const first=new Date(y,m,1);
        const gridStart=new Date(first);
        gridStart.setDate(first.getDate()-first.getDay());

        const selectedStart=state.weekStart;
        const today=todayIso();
        let html="";

        DAYS.forEach(d=>{html+=`<div class="weekDow">${esc(d)}</div>`});

        for(let r=0;r<6;r++){
          const rowStart=new Date(gridStart);
          rowStart.setDate(gridStart.getDate()+r*7);
          const rowStartIso=toIso(rowStart);
          const rowEndIso=addDays(rowStartIso,6);
          const isSelectedRow=sameIso(rowStartIso,selectedStart);

          for(let c=0;c<7;c++){
            const d=new Date(rowStart);
            d.setDate(rowStart.getDate()+c);
            const iso=toIso(d);
            const other=d.getMonth()!==m;
            const selected=isSelectedRow;
            const isToday=iso===today;

            html+=`
              <button
                type="button"
                class="weekDay ${other?"other":""} ${isToday?"today":""} ${selected?"selected weekRowHighlight":""}"
                data-week-start="${esc(rowStartIso)}"
                data-week-end="${esc(rowEndIso)}"
                title="${esc(mdLabel(rowStartIso)+" ~ "+mdLabel(rowEndIso))}"
              >${d.getDate()}</button>
            `;
          }
        }

        els.weekGrid.innerHTML=html;

        els.weekGrid.querySelectorAll(".weekDay").forEach(btn=>{
          btn.addEventListener("mouseenter",()=>{
            const ws=btn.dataset.weekStart;
            els.weekGrid.querySelectorAll(`[data-week-start="${CSS.escape(ws)}"]`).forEach(x=>x.classList.add("weekRowHighlight"));
          });
          btn.addEventListener("mouseleave",()=>{
            els.weekGrid.querySelectorAll(".weekDay").forEach(x=>{
              if(!x.classList.contains("selected"))x.classList.remove("weekRowHighlight");
            });
          });
          btn.addEventListener("click",()=>{
            const ws=btn.dataset.weekStart;
            state.baseDate=ws;
            state.weekStart=ws;
            state.weekDates=weekDatesFromStart(ws);
            state.weekEnd=state.weekDates[6];

            const w=isoWeekInfoFromMondayRef(ws);
            state.isoYear=w.isoYear;
            state.isoWeek=w.isoWeek;
            state.weekLabel=w.weekLabel;

            state.dirty.clear();
            closeWeekPicker();
            hideSuggest();

            els.weekButtonText.textContent=weekRangeLabel();
            els.weekPill.textContent=`${weekRangeLabel()} / ${state.weekLabel}`;
            renderHeader();
            updatePills();

            if(state.camp)loadAll();
          });
        });
      }

      function bind(){
        els.waveSelect.value=state.wave;

        els.btnLogout.addEventListener("click",async()=>{
          try{await supabase.auth.signOut()}catch{}
          location.href=LOGIN_PATH;
        });

        els.btnLoad.addEventListener("click",loadAll);
        els.btnSave.addEventListener("click",saveAll);
        els.btnExportMeta.addEventListener("click",exportMetaExcel);
        els.btnCopyImage.addEventListener("click",copyImage);
        els.btnReset.addEventListener("click",resetFilters);
        els.btnImportWeek.addEventListener("click",importWeek);

        els.btnPrevWeek.addEventListener("click",()=>{
          state.baseDate=addDays(state.weekStart||state.baseDate,-7);
          state.dirty.clear();
          updateWeekState();
          state.pickerMonth=firstOfMonth(parseIso(state.weekStart)||new Date());
          renderHeader();
          renderWeekPicker();
          hideSuggest();
          if(state.camp)loadAll();
        });

        els.btnNextWeek.addEventListener("click",()=>{
          state.baseDate=addDays(state.weekStart||state.baseDate,7);
          state.dirty.clear();
          updateWeekState();
          state.pickerMonth=firstOfMonth(parseIso(state.weekStart)||new Date());
          renderHeader();
          renderWeekPicker();
          hideSuggest();
          if(state.camp)loadAll();
        });

        els.weekButton.addEventListener("click",e=>{
          e.stopPropagation();
          hideSuggest();
          if(els.weekPopup.classList.contains("open"))closeWeekPicker();
          else openWeekPicker();
        });

        els.btnPickerPrev.addEventListener("click",e=>{
          e.stopPropagation();
          state.pickerMonth=addMonths(state.pickerMonth||new Date(),-1);
          renderWeekPicker();
        });

        els.btnPickerNext.addEventListener("click",e=>{
          e.stopPropagation();
          state.pickerMonth=addMonths(state.pickerMonth||new Date(),1);
          renderWeekPicker();
        });

        els.btnPickerToday.addEventListener("click",e=>{
          e.stopPropagation();
          state.baseDate=todayIso();
          updateWeekState();
          state.pickerMonth=firstOfMonth(parseIso(state.weekStart)||new Date());
          renderWeekPicker();
          renderHeader();
          hideSuggest();
          if(state.camp)loadAll();
        });

        document.addEventListener("click",e=>{
          if(!e.target.closest(".weekPickerWrap"))closeWeekPicker();
          if(!e.target.closest(".suggestBox")&&!e.target.closest(".cellEdit"))hideSuggest();
        });

        document.addEventListener("keydown",e=>{
          if(e.key==="Escape"){
            closeWeekPicker();
            hideSuggest();
          }
        });

        els.boardWrap.addEventListener("scroll",hideSuggest,{passive:true});
        window.addEventListener("resize",hideSuggest);

        els.waveSelect.addEventListener("change",()=>{
          state.wave=normalizeWave(els.waveSelect.value);
          els.waveSelect.value=state.wave;
          state.dirty.clear();
          hideSuggest();
          if(state.camp)loadAll();
          else renderHeader();
        });

        els.campInput.addEventListener("keydown",e=>{
          if(e.key==="Enter")loadAll();
        });

        els.searchInput.addEventListener("input",()=>render());

        window.addEventListener("beforeunload",e=>{
          if(state.dirty.size>0){
            e.preventDefault();
            e.returnValue="";
          }
        });
      }

      async function boot(){
        bind();
        updateWeekState();
        state.pickerMonth=firstOfMonth(parseIso(state.weekStart)||new Date());
        renderWeekPicker();
        renderHeader();
        updatePills();

        const authed=await ensureAuth();
        if(!authed)return;

        const ok=await checkAccess();
        if(!ok)return;

        document.documentElement.style.visibility="visible";
        setState("ok","READY");
        els.apiPill.textContent="Worker API";
        setStatus("캠프와 주/야를 선택하고 불러오기를 누르세요.");
      }

      boot().catch(e=>{
        console.error(e);
        document.documentElement.style.visibility="visible";
        setState("err","ERROR");
        setStatus(e?.message||String(e));
      });
    })();
  </script>
</body>
</html>
