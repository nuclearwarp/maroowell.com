<script id="mwDragonDriverSettlementPatch">
(function () {
  "use strict";

  const DATA_TABLE = "dragon_car";
  const INFO_TABLE = "maroowell_info";

  const ZERO_COMMISSION_DRIVERS = new Set(["김용준", "장세인", "이우람"]);
  const TEAM_LEADER_NAME = "한재봉";
  const DEFAULT_COMMISSION_RATE = 0.08;
  const INSURANCE_RATE = 0.0168;
  const FILLER_ROW_TARGET = 27;

  let client = null;
  let loaded = false;
  let rawRows = [];
  let infoByName = new Map();
  let patchTimer = null;
  let patchRunning = false;

  function $(sel) {
    return document.querySelector(sel);
  }

  function $all(sel) {
    return Array.from(document.querySelectorAll(sel));
  }

  function clean(value) {
    return String(value ?? "").trim();
  }

  function compact(value) {
    return clean(value).replace(/\s+/g, "");
  }

  function esc(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function toNumber(value) {
    if (typeof value === "number" && Number.isFinite(value)) return value;

    const n = Number(
      String(value ?? "")
        .replace(/[₩원,%\s]/g, "")
        .replace(/,/g, "")
    );

    return Number.isFinite(n) ? n : 0;
  }

  function roundWon(value) {
    return Math.round(Number(value) || 0);
  }

  function money(value) {
    return "₩" + roundWon(value).toLocaleString("ko-KR");
  }

  function qty(value) {
    return roundWon(value).toLocaleString("ko-KR");
  }

  function normalizedKey(key) {
    return String(key || "").replace(/[^a-zA-Z0-9가-힣]/g, "").toLowerCase();
  }

  function first(row, keys) {
    if (!row) return "";

    for (const key of keys) {
      if (Object.prototype.hasOwnProperty.call(row, key) && row[key] != null && clean(row[key]) !== "") {
        return row[key];
      }
    }

    const map = new Map();
    Object.keys(row).forEach(key => map.set(normalizedKey(key), key));

    for (const key of keys) {
      const realKey = map.get(normalizedKey(key));
      if (realKey && row[realKey] != null && clean(row[realKey]) !== "") {
        return row[realKey];
      }
    }

    return "";
  }

  function parseMonth(value) {
    const raw = clean(value);

    let m = raw.match(/(20\d{2})\s*[-./년 ]\s*(\d{1,2})/);
    if (m) return m[1] + "-" + String(Number(m[2])).padStart(2, "0");

    m = raw.match(/(^|\D)(\d{2})\s*년\s*(\d{1,2})\s*월/);
    if (m) return "20" + m[2] + "-" + String(Number(m[3])).padStart(2, "0");

    m = raw.match(/^(20\d{2})(\d{2})$/);
    if (m) return m[1] + "-" + m[2];

    return raw;
  }

  function currentMonth() {
    return parseMonth($("#monthInput")?.value || new Date().toISOString().slice(0, 7));
  }

  function monthYear(month) {
    return String(month || "").slice(0, 4);
  }

  function monthNumber(month) {
    return Number(String(month || "").slice(5, 7)) || "";
  }

  function excelDate(value) {
    if (typeof value === "number" && value > 20000 && value < 80000) {
      return new Date(Math.round((value - 25569) * 86400 * 1000));
    }
    return null;
  }

  function parseDate(value, month) {
    if (value instanceof Date && !Number.isNaN(value.getTime())) return value;

    const excel = excelDate(value);
    if (excel) return excel;

    const raw = clean(value);
    if (!raw) return null;

    let m = raw.match(/(20\d{2})\D+(\d{1,2})\D+(\d{1,2})/);
    if (m) return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));

    m = raw.match(/^(\d{1,2})\s*[/.-]\s*(\d{1,2})/);
    if (m) {
      const year = Number(monthYear(month)) || new Date().getFullYear();
      return new Date(year, Number(m[1]) - 1, Number(m[2]));
    }

    const d = new Date(raw);
    return Number.isNaN(d.getTime()) ? null : d;
  }

  function rowMonth(value, fallbackMonth) {
    const d = parseDate(value, fallbackMonth);
    if (!d) return "";
    return d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0");
  }

  function formatDate(value, month) {
    const d = parseDate(value, month);
    if (!d) return clean(value) || "-";

    const week = ["일", "월", "화", "수", "목", "금", "토"][d.getDay()];
    return (d.getMonth() + 1) + "/" + d.getDate() + " " + week;
  }

  function isSunday(value, month) {
    const d = parseDate(value, month);
    return !!d && d.getDay() === 0;
  }

  function taxIssued(value) {
    if (typeof value === "boolean") return value;
    if (typeof value === "number") return value !== 0;

    const text = compact(value).toLowerCase();

    if (!text) return false;
    if (["발행", "발행완료", "완료", "o", "y", "yes", "true", "1", "issued"].includes(text)) return true;
    if (["미발행", "미", "무", "x", "n", "no", "false", "0", "notissued", "미완료"].includes(text)) return false;
    if (text.includes("미발행")) return false;

    return text.includes("발행");
  }

  function falseLike(value) {
    const text = compact(value).toLowerCase();
    return ["x", "n", "no", "false", "0", "미가입", "없음", "제외", "미적용"].includes(text);
  }

  function parseRate(value, fallback) {
    const raw = clean(value);
    if (!raw) return fallback;
    if (/^0+(\.0+)?%?$/.test(raw)) return 0;

    let n = toNumber(raw);
    if (!Number.isFinite(n)) return fallback;

    if (raw.includes("%") || n > 1) n = n / 100;
    return Math.max(0, n);
  }

  function normalizeDragonRow(raw, targetMonth) {
    const dateValue = first(raw, [
      "order_date",
      "orderDate",
      "delivery_date",
      "deliveryDate",
      "work_date",
      "workDate",
      "date",
      "배송일자",
      "배송 일자",
      "일자"
    ]);

    const monthValue = parseMonth(first(raw, [
      "settlement_month",
      "settlementMonth",
      "pay_month",
      "target_month",
      "month",
      "정산월"
    ]));

    const month = /^\d{4}-\d{2}$/.test(monthValue)
      ? monthValue
      : rowMonth(dateValue, targetMonth);

    const price = toNumber(first(raw, [
      "price",
      "unit_price",
      "unitPrice",
      "unit_cost",
      "delivery_unit_price",
      "단가"
    ]));

    const parcel = toNumber(first(raw, [
      "parcel",
      "parcel_count",
      "delivery_count",
      "deliveryCount",
      "delivery_quantity",
      "delivery_qty",
      "quantity",
      "qty",
      "count",
      "배송수량",
      "배송 수량",
      "수량"
    ]));

    let amount = toNumber(first(raw, [
      "amount",
      "settlement_amount",
      "settlementAmount",
      "total_amount",
      "totalAmount",
      "pay_amount",
      "payment_amount",
      "정산금액",
      "정산 금액",
      "금액",
      "총금액"
    ]));

    if (!amount && price && parcel) amount = price * parcel;

    return {
      raw,
      month,
      date: dateValue,
      driver: clean(first(raw, [
        "delivery_driver",
        "deliveryDriver",
        "driver_name",
        "driverName",
        "driver",
        "투입 기사",
        "기사",
        "기사명",
        "용차기사"
      ])),
      camp: clean(first(raw, [
        "camp",
        "camp_code",
        "campCode",
        "camp_name",
        "캠프"
      ])),
      wave: clean(first(raw, [
        "wave",
        "day_night",
        "dayNight",
        "shift",
        "주야",
        "주/야",
        "주간/야간"
      ])),
      route: clean(first(raw, [
        "route",
        "route_name",
        "routeName",
        "route_code",
        "라우트"
      ])).replace(/\s+/g, " "),
      price,
      parcel,
      amount: roundWon(amount),
      taxIssued: taxIssued(first(raw, [
        "tax_invoice",
        "taxInvoice",
        "tax_invoice_status",
        "tax_status",
        "invoice_status",
        "tax_bill",
        "tax_issued",
        "is_tax_invoice_issued",
        "is_tax_issued",
        "세금계산서",
        "세금계산서발행",
        "세금계산서 발행"
      ]))
    };
  }

  function infoName(row) {
    return clean(first(row, [
      "person_name",
      "name",
      "driver_name",
      "기사명",
      "이름"
    ]));
  }

  function driverInfo(name) {
    return infoByName.get(compact(name)) || {};
  }

  function infoValue(name, keys) {
    return clean(first(driverInfo(name), keys));
  }

  function businessName(name) {
    return infoValue(name, [
      "business_name",
      "businessName",
      "사업자 상호",
      "사업자상호",
      "상호"
    ]) || name || "-";
  }

  function businessNumber(name) {
    return infoValue(name, [
      "business_registration_number",
      "businessRegistrationNumber",
      "business_no",
      "사업자 번호",
      "사업자번호"
    ]) || "-";
  }

  function payrollBank(name) {
    return infoValue(name, [
      "payroll_bank_name",
      "payrollBankName",
      "bank_name",
      "급여 은행",
      "급여은행",
      "은행"
    ]) || "-";
  }

  function payrollAccount(name) {
    return infoValue(name, [
      "payroll_account_number",
      "payrollAccountNumber",
      "account_number",
      "급여 계좌",
      "급여계좌",
      "계좌 번호",
      "계좌번호"
    ]) || "-";
  }

  function commissionRate(name) {
    if (ZERO_COMMISSION_DRIVERS.has(compact(name))) return 0;

    return parseRate(
      infoValue(name, [
        "dragon_car_commission",
        "dragonCarCommission",
        "용차 수수료",
        "용차수수료"
      ]),
      DEFAULT_COMMISSION_RATE
    );
  }

  function insuranceEnabled(name) {
    const raw = infoValue(name, [
      "employment_accident_insurance",
      "employmentAccidentInsurance",
      "고용산재"
    ]);

    if (!raw) return true;
    return !falseLike(raw);
  }

  function taxBreakdown(issuedAmount) {
    const supply = roundWon(issuedAmount / 1.1);
    const vat = roundWon(issuedAmount - supply);
    return { supply, vat };
  }

  function baseStats(rows, name) {
    const total = rows.reduce((sum, row) => sum + row.amount, 0);
    const issued = rows.filter(row => row.taxIssued).reduce((sum, row) => sum + row.amount, 0);
    const unissued = total - issued;
    const tax = taxBreakdown(issued);
    const rate = commissionRate(name);
    const commission = roundWon(total * rate);
    const insurance = insuranceEnabled(name) ? roundWon(tax.supply * INSURANCE_RATE) : 0;

    return {
      total,
      issued,
      unissued,
      supply: tax.supply,
      vat: tax.vat,
      rate,
      commission,
      insurance,
      afterCommission: total - commission,
      afterInsurance: total - commission - insurance,
      teamBonus: 0,
      finalPay: total - commission - insurance
    };
  }

  function monthlyTeamStats(monthRows) {
    const byDriver = new Map();

    for (const row of monthRows) {
      const name = row.driver || "미지정";
      if (!byDriver.has(name)) byDriver.set(name, []);
      byDriver.get(name).push(row);
    }

    let commission = 0;
    let insurance = 0;

    for (const [name, rows] of byDriver.entries()) {
      const stats = baseStats(rows, name);
      commission += stats.commission;
      insurance += stats.insurance;
    }

    const insuranceHalf = roundWon(insurance * 0.5);
    const pool = Math.max(0, commission - insuranceHalf);
    const bonus = roundWon(pool * 0.5);

    return { commission, insurance, insuranceHalf, pool, bonus };
  }

  function selectedDriverName() {
    const activeName = clean($("#groupList .groupItem.active .groupName")?.textContent || "").split("\n")[0];
    if (activeName) return clean(activeName);

    const targetText = clean($("#infoTarget")?.textContent || "");
    if (targetText) return clean(targetText.split("\n").pop());

    return "";
  }

  async function fetchAll(table) {
    const pageSize = 1000;
    const out = [];
    let from = 0;

    while (true) {
      const { data, error } = await client
        .from(table)
        .select("*")
        .range(from, from + pageSize - 1);

      if (error) throw error;

      out.push(...(data || []));
      if (!data || data.length < pageSize) break;
      from += pageSize;
    }

    return out;
  }

  async function loadData() {
    if (loaded) return;

    const cfg = window.MARUWELL_CONFIG || {};
    if (!window.supabase || !cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY) return;

    client = client || window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        storage: window.sessionStorage,
        persistSession: true,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });

    const [dragonRows, infoRows] = await Promise.all([
      fetchAll(DATA_TABLE),
      fetchAll(INFO_TABLE)
    ]);

    rawRows = dragonRows || [];
    infoByName = new Map();

    for (const row of infoRows || []) {
      const name = infoName(row);
      if (name) infoByName.set(compact(name), row);
    }

    loaded = true;
  }

