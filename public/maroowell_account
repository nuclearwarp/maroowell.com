      function parseCellLines(cell){
        const qtyMain = cell.querySelector?.(".qtyMain")?.textContent?.trim();
        const qtyAvg = cell.querySelector?.(".qtyAvg")?.textContent?.trim();
        const qtyChangeEl = cell.querySelector?.(".qtyChange");
