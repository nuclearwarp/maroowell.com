      function render(){
        buildDisplayRows();
        renderHeader();
        renderTable();
        updatePills();
      }

      function renderHeader(){
        els.boardTitle.textContent=`${state.camp||"-"} / ${waveLabel(state.wave)}`;
        els.boardSubTitle.textContent=`${weekRangeLabel()} · ${state.weekLabel} · ${state.wave}`;
      }

      function valueForCell(date,routeLabel){
        const normalized=normalizeRouteLabel(routeLabel);
        const dirtyKey=scheduleKey(date,normalized);
        if(state.dirty.has(dirtyKey)){
          const d=state.dirty.get(dirtyKey);
          return clean(d.driver_display_name||d.driver_name);
        }
        const found=state.scheduleMap.get(scheduleLookupKey(date,normalized));
        return clean(found?.driver_display_name||found?.driver_name);
      }

      function rowForCell(date,routeLabel){
        const normalized=normalizeRouteLabel(routeLabel);
        return state.dirty.get(scheduleKey(date,normalized)) || state.scheduleMap.get(scheduleLookupKey(date,normalized)) || null;
      }

      function renderTable(){
        if(!state.routeParents.length){
          els.tableHost.innerHTML=`<div class="emptyBoard">조회된 라우트가 없습니다.<br>Camp명이 maroowell_route_info.camp 값과 같은지 확인하세요.</div>`;
          return;
        }

        const rows=state.displayRows;
        const weekRowSpan=Math.max(rows.length,1);

        let html=`
          <table class="scheduleTable">
            <colgroup>
              <col style="width:120px">
              <col style="width:110px">
              <col style="width:160px">
              ${state.weekDates.map(()=>`<col style="width:130px">`).join("")}
            </colgroup>
            <thead>
              <tr>
                <th>Week</th>
                <th>Camp</th>
                <th class="routeHead">Route</th>
                ${state.weekDates.map((d,i)=>`
                  <th class="${i===0?"sun":""}">
                    <div class="dayHeader">
                      <div>${esc(dateLabel(d))}</div>
                      <div class="dayActions">
                        <button class="dayBtn share" type="button" data-day-action="share" data-date="${esc(d)}">공유</button>
                        <button class="dayBtn copy" type="button" data-day-action="copy" data-date="${esc(d)}">복사</button>
                        <button class="dayBtn paste" type="button" data-day-action="paste" data-date="${esc(d)}">붙여넣기</button>
                      </div>
                    </div>
                  </th>
                `).join("")}
              </tr>
            </thead>
            <tbody>
        `;

        rows.forEach((row,rowIndex)=>{
          const hasChildren=row.type==="parent"&&row.children&&row.children.length>0;
          const isExpanded=state.expanded.has(row.key);
          const routeClass=row.type==="child"?"childRoute":"";
          const offClass=row.isOff?"off":"";
          const lockedParentClass=(row.type==="parent" && hasChildren && state.weekDates.some(date=>isParentCellLocked(row,date))) ? "lockedParent" : "";

          html+=`<tr class="${routeClass}">`;

          if(rowIndex===0){
            html+=`<td class="weekCell" rowspan="${weekRowSpan}">${esc(state.weekLabel)}</td>`;
            html+=`<td class="campCell" rowspan="${weekRowSpan}">${esc(state.camp)}</td>`;
          }

          html+=`
            <td class="routeCell ${offClass} ${lockedParentClass}">
              <div class="routeInner">
                <div class="routeLabel" title="${esc(row.description||row.memo||row.subPackage||"")}">
                  ${esc(row.label)}
                  ${row.type==="child"?`<span class="childBadge">${esc(row.subSub)}</span>`:""}
                </div>
                <button class="expander ${hasChildren?"":"empty"}" type="button" data-expand="${esc(row.key)}" title="서서브 펼치기/접기">${isExpanded?"▼":"▶"}</button>
              </div>
            </td>
          `;

          state.weekDates.forEach(date=>{
            const parentLocked=row.type==="parent" && isParentCellLocked(row,date);
            const childLocked=row.type==="child" && isChildCellLocked(row,date);
            const locked=parentLocked || childLocked;
            const rawVal=valueForCell(date,row.label);
            const val=locked ? "×" : rawVal;
            const has=!!compact(rawVal);
            const isOff=row.isOff;
            const conflicts=!locked && isOff ? offConflictNames(date,rawVal) : [];
            const conflict=conflicts.length>0;
            const bg=!locked&&has&&!conflict?colorForValue(rawVal):"";
            const color=!locked&&has&&!conflict?textColorForBg(bg):"";
            const dirty=state.dirty.has(scheduleKey(date,row.label));
            const title=parentLocked
              ? "해당 날짜에 서서브 배정이 있어 서브 입력이 잠겼습니다. 해당 날짜의 서서브 값을 모두 지우면 다시 입력 가능합니다."
              : childLocked
                ? "해당 날짜에 서브 배정이 있어 서서브 입력이 잠겼습니다. 해당 날짜의 서브 값을 지우면 다시 입력 가능합니다."
                : conflict
                  ? `확인 필요: 휴무자인 ${conflicts.join(", ")}이(가) 같은 날짜 배정에 남아 있습니다.`
                  : cellTitle(rawVal);

            html+=`
              <td>
                <input
                  class="cellEdit ${has?"hasValue":""} ${dirty&&!locked?"dirty":""} ${conflict?"offConflict":""} ${parentLocked?"parentLocked":""} ${childLocked?"childLocked":""}"
                  style="${!locked&&has&&!conflict?`background:${bg};color:${color};`:""}"
                  value="${esc(val)}"
                  placeholder="-"
                  autocomplete="off"
                  data-date="${esc(date)}"
                  data-route="${esc(row.label)}"
                  data-row-order="${rowIndex}"
                  data-parent-key="${esc(row.parentKey||row.key||"")}"
                  ${locked?"disabled":""}
                  title="${esc(title)}"
                />
              </td>
            `;
          });

          html+=`</tr>`;
        });

        html+=`</tbody></table>`;
        els.tableHost.innerHTML=html;

        els.tableHost.querySelectorAll("[data-expand]").forEach(btn=>{
          btn.addEventListener("click",e=>{
            const key=e.currentTarget.dataset.expand;
            if(!key)return;
            if(state.expanded.has(key))state.expanded.delete(key);
            else state.expanded.add(key);
            render();
          });
        });

        els.tableHost.querySelectorAll(".cellEdit").forEach(input=>{
          if(input.disabled)return;
          input.addEventListener("input",onCellInput);
          input.addEventListener("focus",e=>{e.currentTarget.select();showSuggest(e.currentTarget)});
          input.addEventListener("keyup",e=>{
            if(e.key==="Escape"){hideSuggest();e.currentTarget.blur();return}
            showSuggest(e.currentTarget);
          });
        });

        els.tableHost.querySelectorAll("[data-day-action]").forEach(btn=>{
          btn.addEventListener("click",e=>{
            e.preventDefault();
            e.stopPropagation();
            const action=btn.dataset.dayAction;
            const date=btn.dataset.date;
            if(action==="share") sharePddForDate(date);
            if(action==="copy") copyDay(date);
            if(action==="paste") pasteDay(date);
          });
        });
      }

      function cellTitle(name){
        const d=resolveAccount(name);
        if(!d)return name||"";
        return [d.displayName,d.accountType?"구분: "+d.accountType:"",d.exportId?"ID: "+d.exportId:"",d.exportName?"엑셀 이름: "+d.exportName:""].filter(Boolean).join("\n");
      }

      function makeDirtyRecord({date,routeLabel,value,rowOrder,source}){
        const account=value?resolveAccount(value):null;
        return {
          schedule_date:date,
          camp:state.camp,
          wave:state.wave,
          route_label:normalizeRouteLabel(routeLabel),
          driver_name:value||null,
          driver_display_name:value||null,
          driver_owner_name:clean(source?.driver_owner_name)||account?.ownerName||value||null,
          driver_export_name:clean(source?.driver_export_name)||account?.exportName||value||null,
          driver_coupang_id:clean(source?.driver_coupang_id)||account?.exportId||null,
          driver_account_type:clean(source?.driver_account_type)||account?.accountType||null,
          memo:clean(source?.memo)||null,
          row_order:Number(rowOrder||source?.row_order||0),
          cell_color:value?colorForValue(value):null,
          is_active:!!value
        };
      }

      function applyInputVisual(input,value){
        if(input.disabled)return;

        const date=input.dataset.date;
        const routeLabel=normalizeRouteLabel(input.dataset.route);
        const has=!!compact(value);
        const isOff=isOffRoute(routeLabel);
        const conflicts=isOff ? offConflictNames(date,value) : [];
        const conflict=conflicts.length>0;

        input.classList.toggle("hasValue",has);
        input.classList.toggle("offConflict",conflict);

        if(!has){
          input.style.background="";
          input.style.color="";
          input.title="";
          return;
        }

        if(conflict){
          input.style.background="";
          input.style.color="";
          input.title=`확인 필요: 휴무자인 ${conflicts.join(", ")}이(가) 같은 날짜 배정에 남아 있습니다.`;
          return;
        }

        const bg=colorForValue(value);
        input.style.background=bg;
        input.style.color=textColorForBg(bg);
        input.title=cellTitle(value);
      }

      function refreshOffConflictForDate(date){
        const route=normalizeRouteLabel(OFF_ROUTE_LABEL);
        const input=els.tableHost.querySelector(`.cellEdit[data-date="${CSS.escape(date)}"][data-route="${CSS.escape(route)}"]`);
        if(input && !input.disabled){
          applyInputVisual(input,clean(input.value));
        }
      }

      function refreshParentLockForChildInput(date,parentKey){
        const parent=state.routeParents.find(p=>p.key===parentKey);
        if(!parent)return;

        syncParentClearForDate(date,parentKey);

        const parentInput=els.tableHost.querySelector(`.cellEdit[data-date="${CSS.escape(date)}"][data-route="${CSS.escape(parent.label)}"]`);
        if(!parentInput)return;

        const locked=isParentCellLocked(parent,date);

        if(locked){
          parentInput.value="×";
          parentInput.disabled=true;
          parentInput.classList.add("parentLocked");
          parentInput.classList.remove("dirty","hasValue","offConflict");
          parentInput.style.background="";
          parentInput.style.color="";
          parentInput.title="해당 날짜에 서서브 배정이 있어 서브 입력이 잠겼습니다. 해당 날짜의 서서브 값을 모두 지우면 다시 입력 가능합니다.";
        }else{
          const val=valueForCell(date,parent.label);
          const dirty=state.dirty.has(scheduleKey(date,parent.label));
          parentInput.disabled=false;
          parentInput.classList.remove("parentLocked");
          parentInput.classList.toggle("dirty",dirty);
          parentInput.value=val;
          applyInputVisual(parentInput,val);
        }

        updatePills();
      }

      function refreshChildLocksForParentInput(date,parentKey){
        const parent=state.routeParents.find(p=>p.key===parentKey);
        if(!parent || !Array.isArray(parent.children))return;

        syncChildrenClearForDate(date,parentKey);

        for(const child of parent.children){
          const childInput=els.tableHost.querySelector(`.cellEdit[data-date="${CSS.escape(date)}"][data-route="${CSS.escape(child.label)}"]`);
          if(!childInput)continue;

          const locked=isRouteChildLockedForDate(date,child.label);

          if(locked){
            childInput.value="×";
            childInput.disabled=true;
            childInput.classList.add("childLocked");
            childInput.classList.remove("dirty","hasValue","offConflict");
            childInput.style.background="";
            childInput.style.color="";
            childInput.title="해당 날짜에 서브 배정이 있어 서서브 입력이 잠겼습니다. 해당 날짜의 서브 값을 지우면 다시 입력 가능합니다.";
          }else{
            const val=valueForCell(date,child.label);
            const dirty=state.dirty.has(scheduleKey(date,child.label));
            childInput.disabled=false;
            childInput.classList.remove("childLocked");
            childInput.classList.toggle("dirty",dirty);
            childInput.value=val;
            applyInputVisual(childInput,val);
          }
        }

        updatePills();
      }

      function onCellInput(e){
        const input=e.currentTarget;
        if(input.disabled)return;

        const date=input.dataset.date;
        const routeLabel=normalizeRouteLabel(input.dataset.route);
        const rowOrder=Number(input.dataset.rowOrder||0);
        const value=clean(input.value);
        const key=scheduleKey(date,routeLabel);

        state.dirty.set(key,makeDirtyRecord({date,routeLabel,value,rowOrder}));
        applyInputVisual(input,value);

        const info=state.routeLookup.get(routeLabel);

        if(info?.isChild && info.parentKey){
          refreshParentLockForChildInput(date,info.parentKey);
        }else if(info && !info.isChild && !info.isOff){
          const parent=state.routeParents.find(p=>p.key===info.parentKey || p.key===routeLabel || normalizeRouteLabel(p.label)===routeLabel);
          if(parent?.children?.length){
            refreshChildLocksForParentInput(date,parent.key);
          }
        }

        if(!isOffRoute(routeLabel)){
          refreshOffConflictForDate(date);
        }

        input.classList.add("dirty");
        updatePills();
      }

      function isOffSuggestCandidate(acc){
        if(!acc || !state.camp) return false;

        const camp=clean(acc.camp);
        const wave=clean(acc.wave);
        const position=clean(acc.position);

        // 휴무 추천은 "현재 캠프 / 현재 주야"에 실제 소속된 본계정만 대상으로 한다.
        // 엑셀 ID 보정용 전역 계정, 서브계정, 퇴사자, 타 캠프 인원은 여기서 제외한다.
        if(!camp || !campMatches(camp,state.camp)) return false;
        if(!wave || !explicitWaveMatches(wave,state.wave)) return false;
        if(isRetiredPosition(position)) return false;
        if(isSubAccountRole(position)) return false;
        if(acc.accountType === "서브계정") return false;

        return true;
      }

      function offSuggestAccountsForDate(date,q){
        const assigned=assignedPersonKeySetForDate(date);
        const out=[];
        const seen=new Set();

        for(const acc of state.driverAccounts){
          if(!isOffSuggestCandidate(acc)) continue;

          const displayName=clean(acc.displayName || acc.ownerName || acc.exportName);
          if(!displayName) continue;

          const keys=[acc.displayName,acc.ownerName,acc.exportName,acc.exportId,...(acc.aliases||[])].map(keyOf).filter(Boolean);
          if(keys.some(k=>assigned.has(k))) continue;

          const searchKey=keyOf([acc.displayName,acc.ownerName,acc.exportName,acc.exportId,...(acc.aliases||[]),acc.camp,acc.wave].join(" "));
          if(q && !searchKey.includes(q)) continue;

          const unique=keyOf(displayName);
          if(!unique || seen.has(unique)) continue;
          seen.add(unique);

          out.push({
            displayName,
            exportId:clean(acc.exportId),
            exportName:clean(acc.exportName),
            camp:clean(acc.camp),
            accountType:"휴무 후보"
          });
        }

        return out.sort((a,b)=>sortText(a.displayName,b.displayName));
      }

      function showOffSuggest(input){
        state.suggestInput=input;

        const q=keyOf(input.value);
        const date=input.dataset.date;
        const list=offSuggestAccountsForDate(date,q).slice(0,40);

        if(!list.length){
          hideSuggest();
          return;
        }

        const items=list.map(acc=>({
          display:acc.displayName,
          title:acc.displayName,
          type:"휴무 후보",
          meta:`ID: ${acc.exportId||"-"} · 엑셀 이름: ${acc.exportName||"-"} · 캠프: ${acc.camp||"-"}`
        }));

        if(list.length>=2){
          const combined=list.map(acc=>acc.displayName).join(",");
          items.push({
            display:combined,
            title:combined,
            type:"전체 추천",
            meta:`${dateLabel(date)} 미배정자 ${list.length}명`
          });
        }

        els.suggestBox.innerHTML=items.map((item,idx)=>`
          <button class="suggestItem" type="button" data-idx="${idx}" data-display="${esc(item.display)}">
            <div class="suggestTop">
              <span>${esc(item.title)}</span>
              <span class="suggestType">${esc(item.type)}</span>
            </div>
            <div class="suggestMeta">${esc(item.meta)}</div>
          </button>
        `).join("");

        els.suggestBox.querySelectorAll(".suggestItem").forEach(btn=>{
          btn.addEventListener("mousedown",e=>{
            e.preventDefault();
            const display=btn.getAttribute("data-display")||"";
            const target=state.suggestInput;
            if(target){
              target.value=display;
              onCellInput({currentTarget:target});
              hideSuggest();
              requestAnimationFrame(()=>{
                target.focus();
                const len=target.value.length;
                try{target.setSelectionRange(len,len)}catch{}
              });
            }else{
              hideSuggest();
            }
          });
        });

        const rect=input.getBoundingClientRect();
        const width=Math.max(320,Math.min(460,rect.width+190));
        let left=rect.left,top=rect.bottom+6;
        if(left+width>window.innerWidth-8)left=window.innerWidth-width-8;
        if(top+290>window.innerHeight-8)top=Math.max(8,rect.top-296);
        els.suggestBox.style.left=`${Math.max(8,left)}px`;
        els.suggestBox.style.top=`${top}px`;
        els.suggestBox.style.width=`${width}px`;
        els.suggestBox.classList.add("open");
      }

      function showSuggest(input){
        if(input.disabled){
          hideSuggest();
          return;
        }

        if(isOffRoute(input.dataset.route)){
          showOffSuggest(input);
          return;
        }

        state.suggestInput=input;
        const q=keyOf(input.value);

        let list=state.driverAccounts
          .filter(accountCampAllowed)
          .filter(acc=>!isExcludedDriverPosition(acc.position))
          .filter(acc=>acc.accountType !== "서브계정")
          .filter(acc=>!q||keyOf(acc.search).includes(q));

        if(!list.length&&q){
          list=state.driverAccounts
            .filter(accountCampAllowed)
            .filter(acc=>!isExcludedDriverPosition(acc.position))
            .filter(acc=>acc.accountType !== "서브계정")
            .filter(acc=>keyOf(acc.ownerName).includes(q)||keyOf(acc.displayName).includes(q)||keyOf(acc.exportName).includes(q)||keyOf(acc.exportId).includes(q));
        }

        list=list.slice(0,40);

        if(!list.length){hideSuggest();return}

        els.suggestBox.innerHTML=list.map((acc,idx)=>`
          <button class="suggestItem" type="button" data-idx="${idx}" data-display="${esc(acc.displayName)}">
            <div class="suggestTop">
              <span>${esc(acc.displayName)}</span>
              <span class="suggestType">${esc(acc.accountType)}</span>
            </div>
            <div class="suggestMeta">ID: ${esc(acc.exportId||"-")} · 엑셀 이름: ${esc(acc.exportName||"-")} · 캠프: ${esc(acc.camp||"-")}</div>
          </button>
        `).join("");

        els.suggestBox.querySelectorAll(".suggestItem").forEach(btn=>{
          btn.addEventListener("mousedown",e=>{
            e.preventDefault();
            const display=btn.getAttribute("data-display")||"";
            const target=state.suggestInput;
            if(target){
              target.value=display;
              onCellInput({currentTarget:target});
              hideSuggest();
              requestAnimationFrame(()=>{
                target.focus();
                const len=target.value.length;
                try{target.setSelectionRange(len,len)}catch{}
              });
            }else{
              hideSuggest();
            }
          });
        });

        const rect=input.getBoundingClientRect();
        const width=Math.max(280,Math.min(360,rect.width+130));
        let left=rect.left,top=rect.bottom+6;
        if(left+width>window.innerWidth-8)left=window.innerWidth-width-8;
        if(top+290>window.innerHeight-8)top=Math.max(8,rect.top-296);
        els.suggestBox.style.left=`${Math.max(8,left)}px`;
        els.suggestBox.style.top=`${top}px`;
        els.suggestBox.style.width=`${width}px`;
        els.suggestBox.classList.add("open");
      }

      function hideSuggest(){
        els.suggestBox.classList.remove("open");
        els.suggestBox.innerHTML="";
        state.suggestInput=null;
      }

      function updatePills(){
        const routeCount=state.displayRows.filter(r=>!r.isOff).length;
        els.rowPill.textContent=`라우트 ${routeCount}`;
        els.dirtyPill.textContent=`미저장 ${state.dirty.size}`;
      }

      async function saveAll(){
        if(!state.camp||!state.weekDates.length){alert("먼저 불러오기를 해주세요.");return}
        if(state.dirty.size===0){alert("저장할 변경사항이 없습니다.");return}

        hideSuggest();

        const records=Array.from(state.dirty.values()).map(item=>({
          schedule_date:item.schedule_date,
          route_label:normalizeRouteLabel(item.route_label),
          driver_name:item.driver_name,
          driver_display_name:item.driver_display_name,
          driver_owner_name:item.driver_owner_name,
          driver_export_name:item.driver_export_name,
          driver_coupang_id:item.driver_coupang_id,
          driver_account_type:item.driver_account_type,
          memo:item.memo,
          row_order:item.row_order,
          cell_color:item.cell_color,
          is_active:item.is_active
        }));

        setState("warn","SAVE");
        setStatus(`저장 중: ${records.length}건`);
        els.btnSave.disabled=true;

        try{
          const json=await apiFetch("/schedule/save",{method:"POST",body:JSON.stringify({camp:state.camp,wave:state.wave,week_start:state.weekStart,records})});
          state.dirty.clear();
          await loadAll();
          setState("ok","READY");
          setStatus(`저장 완료: ${json.saved||records.length}건`);
        }catch(e){
          console.error(e);
          setState("err","ERROR");
          setStatus("저장 실패: "+(e?.message||e));
          alert("저장 실패: "+(e?.message||e));
        }finally{
          els.btnSave.disabled=false;
        }
      }

      async function importWeek(){
        if(!state.camp){alert("먼저 Camp를 입력하고 현재 주차를 불러오세요.");return}

        const defaultSource=addDays(state.weekStart,-7);
        const input=prompt("불러올 기준 주차를 입력하세요.\n예: 2026 - 20W 또는 2026-05-10\n해당 주차 데이터를 현재 주차에 덮어씁니다.",fullWeekOptionLabel(defaultSource).replace(/\s*\(.+\)$/,""));
        if(input===null)return;

        const sourceWeekStart=parseWeekLabelInput(input) || sundayOf(normalizeDateInput(input));
        if(!sourceWeekStart){alert("주차 또는 날짜 형식을 인식하지 못했습니다.");return}

        if(sourceWeekStart===state.weekStart){
          alert("현재 주차와 같은 주차입니다.");
          return;
        }

        if(!confirm(`${fullWeekOptionLabel(sourceWeekStart)} 데이터를\n현재 주차 ${fullWeekOptionLabel(state.weekStart)}에 덮어쓸까요?\n저장은 '저장'을 눌러야 반영됩니다.`)) return;

        setState("warn","COPY");
        setStatus("다른 주차 데이터를 불러오는 중입니다.");

        try{
          const params=new URLSearchParams({camp:state.camp,wave:state.wave,week_start:sourceWeekStart});
          const json=await apiFetch("/schedule/week?"+params.toString());
          const sourceSchedules=(json.schedules||[]).map(r=>({...r,wave:normalizeWave(r.wave),route_label:normalizeRouteLabel(r.route_label)}));

          let count=0;
          for(const r of sourceSchedules){
            const idx=daysBetween(r.schedule_date,sourceWeekStart);
            if(idx<0||idx>6)continue;
            const targetDate=state.weekDates[idx];
            const routeLabel=normalizeRouteLabel(r.route_label);
            const value=clean(r.driver_display_name||r.driver_name);

            state.dirty.set(scheduleKey(targetDate,routeLabel),makeDirtyRecord({
              date:targetDate,
              routeLabel,
              value,
              rowOrder:r.row_order,
              source:r
            }));
            count++;
          }

          render();
          setState("ok","READY");
          setStatus(`주차 복사 완료: ${count}건. 저장을 누르면 DB에 반영됩니다.`);
        }catch(e){
          console.error(e);
          setState("err","ERROR");
          alert("주차 복사 실패: "+(e?.message||e));
        }
      }

      function copyDay(date){
        const labels=allRouteLabels({includeOff:true});
        const rows=[];

        for(const routeLabel of labels){
          if(isRouteLockedForDate(date,routeLabel))continue;
          const value=valueForCell(date,routeLabel);
          if(!value)continue;
          const source=rowForCell(date,routeLabel)||{};
          rows.push({routeLabel,value,source});
        }

        state.dayClipboard={date,rows};
        try{localStorage.setItem("mw_schedule_day_clipboard",JSON.stringify(state.dayClipboard))}catch{}
        setStatus(`${dateLabel(date)} 데이터 ${rows.length}건 복사 완료`);
      }

      function pasteDay(date){
        if(!state.dayClipboard){
          try{state.dayClipboard=JSON.parse(localStorage.getItem("mw_schedule_day_clipboard")||"null")}catch{}
        }

        if(!state.dayClipboard||!Array.isArray(state.dayClipboard.rows)||!state.dayClipboard.rows.length){
          alert("복사된 일자 데이터가 없습니다.");
          return;
        }

        if(!confirm(`${dateLabel(state.dayClipboard.date)} 데이터를 ${dateLabel(date)}에 붙여넣을까요?\n저장은 '저장'을 눌러야 반영됩니다.`))return;

        let count=0;
        for(const row of state.dayClipboard.rows){
          const routeLabel=normalizeRouteLabel(row.routeLabel);
          state.dirty.set(scheduleKey(date,routeLabel),makeDirtyRecord({
            date,
            routeLabel,
            value:row.value,
            rowOrder:row.source?.row_order || 0,
            source:row.source
          }));
          count++;
        }

        render();
        setStatus(`${dateLabel(date)}에 ${count}건 붙여넣기 완료. 저장을 누르면 DB에 반영됩니다.`);
      }

      function pddRowsForDate(date){
        const rows=[];
        const seen=new Set();

        for(const parent of state.routeParents){
          if(!parent || parent.isOff) continue;

          const parentLabel=normalizeRouteLabel(parent.label);
          const parentValue=clean(valueForCell(date,parentLabel));
          const parentSource=rowForCell(date,parentLabel) || {};
          const children=Array.isArray(parent.children) ? parent.children : [];

          if(children.length){
            const hasParentValue=!!parentValue;
            const hasAnyChildValue=children.some(child=>!!compact(valueForCell(date,child.label)));

            for(const child of children){
              const childLabel=normalizeRouteLabel(child.label);
              const childValue=valueForCell(date,childLabel);
              const childSource=rowForCell(date,childLabel) || {};

              const finalValue=hasParentValue ? parentValue : (hasAnyChildValue ? clean(childValue) : "");
              if(!finalValue) continue;

              const finalSource=hasParentValue ? parentSource : childSource;
              const route=childLabel;

              const directId=pddExportId(finalValue,finalSource);
              const fallbackAccount=resolvePddAccount(finalValue,finalSource);
              const finalId=clean(directId || fallbackAccount?.exportId);

              if(!finalId || !route){
                console.warn("[PDD SKIP] ID not found",{date,route,finalValue,parentLabel,childLabel,finalSource,driverAccounts:state.driverAccounts});
                continue;
              }

              const dedupeKey=`${finalId}||${route}`;
              if(seen.has(dedupeKey)) continue;
              seen.add(dedupeKey);

              rows.push({id:finalId,route,driver:finalValue,parentRoute:parentLabel,sourceRoute:hasParentValue ? parentLabel : childLabel});
            }

            continue;
          }

          const finalValue=clean(parentValue);
          if(!finalValue) continue;

          const route=parentLabel;
          const directId=pddExportId(finalValue,parentSource);
          const fallbackAccount=resolvePddAccount(finalValue,parentSource);
          const finalId=clean(directId || fallbackAccount?.exportId);

          if(!finalId || !route){
            console.warn("[PDD SKIP] ID not found",{date,route,finalValue,parentLabel,parentSource,driverAccounts:state.driverAccounts});
            continue;
          }

          const dedupeKey=`${finalId}||${route}`;
          if(seen.has(dedupeKey)) continue;
          seen.add(dedupeKey);

          rows.push({id:finalId,route,driver:finalValue,parentRoute:parentLabel,sourceRoute:parentLabel});
        }

        return rows.sort((a,b)=>sortText(a.route,b.route)||sortText(a.id,b.id));
      }

      async function sharePddForDate(date){
        const rows=pddRowsForDate(date);

        if(!rows.length){
          alert(`${dateLabel(date)}에 공유할 PDD 데이터가 없습니다.`);
          return;
        }

        const pddDate=pddDateForScheduleDate(date);

        const text=[
          `마루웰 / PDD ${pddTitleDate(pddDate)}`,
          ...rows.map(row=>`${row.id} ${row.route}`)
        ].join("\n");

        try{
          await navigator.clipboard.writeText(text);
          setStatus(`${dateLabel(date)} PDD 공유 텍스트 ${rows.length}줄 복사 완료`);
          alert(`${dateLabel(date)} PDD 공유 텍스트가 복사되었습니다.\n\n${text}`);
        }catch{
          prompt("아래 내용을 복사하세요.",text);
        }
      }

      function metaCampName(camp){
        const s=clean(camp).replace(/\s+/g,"");
        const m=s.match(/^([MV])_?(.+)$/i);
        if(m) return `${m[1].toUpperCase()}_${m[2]}`;
        return s;
      }

      function excelDateSerial(iso){
        const normalized=normalizeDateInput(iso);
        const m=normalized.match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if(!m)return "";
        const utc=Date.UTC(Number(m[1]),Number(m[2])-1,Number(m[3]));
        return Math.floor((utc - Date.UTC(1899,11,30)) / 86400000);
      }

      function forceMetaAdminCellTypes(ws,rowCount){
        if(!ws || !window.XLSX)return;

        for(let r=2;r<=rowCount;r++){
          const a=`A${r}`;
          const c=`C${r}`;
          const aValue=clean(ws[a]?.v);
          const cValue=clean(ws[c]?.v);

          const serial=excelDateSerial(aValue);
          if(serial){
            ws[a]={t:"n",v:serial,z:"yy-mm-dd"};
          }

          const businessNo=Number(cValue);
          if(Number.isFinite(businessNo)){
            ws[c]={t:"n",v:businessNo,z:"General"};
          }

          for(const col of ["B","D","E","F","G","H","I","J"]){
            const addr=`${col}${r}`;
            if(ws[addr]){
              ws[addr]={t:"s",v:clean(ws[addr].v)};
            }
          }
        }

        for(const col of ["A","B","C","D","E","F","G","H","I","J"]){
          const addr=`${col}1`;
          if(ws[addr]){
            ws[addr]={t:"s",v:clean(ws[addr].v)};
          }
        }
      }

      function collectMetaRows(){
        const grouped=new Map();
        const labels=allRouteLabels({includeOff:false});
        const exportStartDate=excelExportStartScheduleDate();

        for(const date of state.weekDates){
          if(date < exportStartDate) continue;

          for(const routeLabel of labels){
            const normalizedRoute=normalizeRouteLabel(routeLabel);
            if(isRouteLockedForDate(date,normalizedRoute))continue;

            const displayName=valueForCell(date,normalizedRoute);
            if(!displayName)continue;

            const source=rowForCell(date,normalizedRoute)||{};
            const identity=resolveMetaAdminExportIdentity(displayName,source);
            const exportName=identity.name;
            const exportId=identity.id;
            const adminRoute=adminRouteLabel(normalizedRoute);
            if(!adminRoute)continue;

            const exportDate=normalizeWave(state.wave)==="WAVE1" ? addDays(date,1) : date;
            const groupKey=[exportDate,exportName,exportId].join("||");

            if(!grouped.has(groupKey)){
              grouped.set(groupKey,{
                date:exportDate,
                scheduleDate:date,
                name:exportName,
                id:exportId,
                routes:[]
              });
            }

            const row=grouped.get(groupKey);
            if(adminRoute&&!row.routes.includes(adminRoute))row.routes.push(adminRoute);
          }
        }

        return Array.from(grouped.values()).map(row=>({
          ...row,
          routes:row.routes.sort((a,b)=>sortText(a,b))
        })).sort((a,b)=>{
          if(a.date!==b.date)return a.date.localeCompare(b.date);
          const nc=sortText(a.name,b.name);
          if(nc!==0)return nc;
          return sortText(a.id,b.id);
        });
      }

      async function exportMetaExcel(){
        if(!window.XLSX){
          alert("엑셀 생성 라이브러리를 불러오지 못했습니다.");
          return;
        }

        if(!state.camp||!state.weekDates.length){
          alert("먼저 불러오기를 해주세요.");
          return;
        }

        hideSuggest();

        setStatus("엑셀 계정 정보를 확인하는 중입니다.");
        await ensureGlobalInfoAccountsForNames(metaDisplayNamesOnBoard());

        const exportStartDate=excelExportStartScheduleDate();
        const rows=collectMetaRows();

        if(!rows.length){
          alert(
            "엑셀로 생성할 스케줄 데이터가 없습니다.\n\n" +
            excelExportRuleText() + "\n" +
            "현재 화면 주차에서 해당 기준 이후의 배정 데이터가 있는지 확인하세요."
          );
          return;
        }

        const header=["업무일","벤더명","사업자등록번호","캠프명","웨이브","이름","아이디","업무상태","회전","업무라우트"];
        const aoa=[
          header,
          ...rows.map(r=>[
            r.date,
            META_VENDOR_NAME,
            Number(META_BUSINESS_NO),
            metaCampName(state.camp),
            state.wave,
            r.name,
            r.id,
            META_WORK_STATUS,
            metaRotationByWave(state.wave),
            r.routes.join(",")
          ])
        ];

        const wb=XLSX.utils.book_new();
        const ws=XLSX.utils.aoa_to_sheet(aoa);

        // CLS Quickflex Admin 업로드 양식과 동일하게 주요 컬럼 타입을 강제한다.
        // A열 업무일: 날짜 serial number + yy-mm-dd 표시 / C열 사업자등록번호: 숫자 타입 / 나머지: 문자열 타입
        forceMetaAdminCellTypes(ws,aoa.length);

        ws["!cols"]=[{wch:12},{wch:14},{wch:16},{wch:12},{wch:10},{wch:12},{wch:18},{wch:10},{wch:16},{wch:34}];
        ws["!autofilter"]={ref:`A1:J${aoa.length}`};
        XLSX.utils.book_append_sheet(wb,ws,"Sheet0");

        const fileName=`${metaCampName(state.camp)}_${waveLabel(state.wave)}_${weekRangeLabel()}`
          .replace(/[\\/:*?"<>|]/g,"_")
          .replace(/\s+/g," ");

        XLSX.writeFile(wb,`${fileName}.xlsx`,{
          bookType:"xlsx",
          bookSST:true,
          cellDates:false
        });

        setStatus(`엑셀 생성 완료: ${rows.length}행 / ${excelExportRuleText()}`);
      }

      async function copyImage(){
        if(!window.htmlToImage){alert("이미지 변환 라이브러리를 불러오지 못했습니다.");return}
        hideSuggest();

        const clone=els.boardRoot.cloneNode(true);
        clone.classList.add("export");

        clone.querySelectorAll("input.cellEdit").forEach(input=>{
          const conflict=input.classList.contains("offConflict");
          const locked=input.classList.contains("parentLocked") || input.classList.contains("childLocked");
          const div=document.createElement("div");
          div.textContent=locked ? "×" : input.value ? (conflict ? `${input.value} ⚠` : input.value) : "-";
          div.style.cssText=input.getAttribute("style")||"";
          div.style.minHeight="42px";
          div.style.display="flex";
          div.style.alignItems="center";
          div.style.justifyContent="center";
          div.style.fontSize=locked?"18px":"13px";
          div.style.fontWeight="900";
          div.style.padding="5px 7px";
          div.style.background=locked ? "#1f2937" : conflict ? "#7f1d1d" : (input.value?(input.style.background||colorForValue(input.value)):"#111827");
          div.style.color=locked ? "#fca5a5" : conflict ? "#fff" : (input.value?"#0f172a":"#94a3b8");
          input.replaceWith(div);
        });

        clone.querySelectorAll("button").forEach(btn=>{
          if(btn.classList.contains("expander")){
            const span=document.createElement("span");
            span.textContent=btn.textContent||"";
            span.style.display="inline-flex";
            span.style.alignItems="center";
            span.style.justifyContent="center";
            span.style.width="24px";
            span.style.height="24px";
            span.style.borderRadius="999px";
            span.style.background="rgba(255,255,255,.65)";
            span.style.color="#111827";
            span.style.fontWeight="1000";
            btn.replaceWith(span);
          }else{
            btn.remove();
          }
        });

        const host=document.createElement("div");
        host.className="captureHost";
        host.appendChild(clone);
        document.body.appendChild(host);

        setState("warn","IMAGE");
        setStatus("이미지 생성 중입니다.");
        els.btnCopyImage.disabled=true;

        try{
          const blob=await window.htmlToImage.toBlob(clone,{
            cacheBust:true,
            pixelRatio:2,
            backgroundColor:"#0e1728",
            width:clone.scrollWidth,
            height:clone.scrollHeight,
            style:{transform:"none",transformOrigin:"top left"}
          });
          if(!blob)throw new Error("이미지 blob 생성 실패");

          if(navigator.clipboard&&window.ClipboardItem){
            await navigator.clipboard.write([new ClipboardItem({"image/png":blob})]);
            setStatus("이미지 복사 완료");
          }else{
            const url=URL.createObjectURL(blob);
            const a=document.createElement("a");
            a.href=url;
            a.download=`마루웰_스케줄_${state.camp}_${waveLabel(state.wave)}_${state.weekLabel}.png`.replace(/[\\/:*?"<>|]/g,"_");
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
            setStatus("클립보드 복사가 지원되지 않아 PNG로 다운로드했습니다.");
          }

          setState("ok","READY");
        }catch(e){
          console.error(e);
          setState("err","ERROR");
          alert("이미지 복사 실패: "+(e?.message||e));
        }finally{
          host.remove();
          els.btnCopyImage.disabled=false;
        }
      }

      function resetFilters(){
        hideSuggest();
        els.campInput.value="";
        els.searchInput.value="";
        state.camp="";
        state.routesRaw=[];
        state.routeParents=[];
        state.displayRows=[];
        state.schedules=[];
        state.scheduleMap.clear();
        state.dirty.clear();
        setUpdateStatusEmpty();
        renderHeader();
        els.tableHost.innerHTML=`<div class="emptyBoard">캠프를 입력하고 불러오기를 누르면 라우트 스케줄 표가 표시됩니다.</div>`;
        updatePills();
        setStatus("초기화 완료");
      }

      function openWeekPicker(){
        renderWeekOptions();
        els.weekPopup.classList.add("open");
        requestAnimationFrame(()=>els.weekManualInput.focus());
      }
      function closeWeekPicker(){els.weekPopup.classList.remove("open")}


      function setToolbarHidden(hidden){
        if(!els.toolbar || !els.btnToggleToolbar) return;

        els.toolbar.classList.toggle("toolbarHidden", !!hidden);
        els.btnToggleToolbar.textContent = hidden ? "메뉴 열기" : "메뉴 숨김";

        try{
          localStorage.setItem("mw_schedule_toolbar_hidden", hidden ? "1" : "0");
        }catch{}
      }

      function restoreToolbarState(){
        let hidden = false;

        try{
          hidden = localStorage.getItem("mw_schedule_toolbar_hidden") === "1";
        }catch{}

        setToolbarHidden(hidden);
      }

      function bind(){

        if(els.btnToggleToolbar){
          els.btnToggleToolbar.addEventListener("click",()=>{
            const hidden = !els.toolbar.classList.contains("toolbarHidden");
            setToolbarHidden(hidden);
          });
        }

        els.waveSelect.value=state.wave;

        els.btnLogout.addEventListener("click",async()=>{
          try{await supabase.auth.signOut()}catch{}
          location.href=LOGIN_PATH;
        });

        els.btnLoad.addEventListener("click",loadAll);
        els.btnSave.addEventListener("click",saveAll);
        els.btnExportMeta.addEventListener("click",exportMetaExcel);
        els.btnCopyImage.addEventListener("click",copyImage);
        els.btnReset.addEventListener("click",resetFilters);
        els.btnImportWeek.addEventListener("click",importWeek);
        els.btnUpdateStatusSave.addEventListener("click",saveUpdateStatus);

        els.btnPrevWeek.addEventListener("click",()=>{
          applyWeekStart(addDays(state.weekStart||state.baseDate,-7),!!state.camp);
        });

        els.btnNextWeek.addEventListener("click",()=>{
          applyWeekStart(addDays(state.weekStart||state.baseDate,7),!!state.camp);
        });

        els.weekButton.addEventListener("click",e=>{
          e.stopPropagation();
          hideSuggest();
          if(els.weekPopup.classList.contains("open"))closeWeekPicker();
          else openWeekPicker();
        });

        els.btnWeekManualApply.addEventListener("click",()=>{
          const ws=parseWeekLabelInput(els.weekManualInput.value);
          if(!ws){
            alert("주차 형식을 인식하지 못했습니다.\n예: 2026 - 01W");
            return;
          }
          applyWeekStart(ws,!!state.camp);
        });

        els.weekManualInput.addEventListener("keydown",e=>{
          if(e.key==="Enter"){
            e.preventDefault();
            els.btnWeekManualApply.click();
          }
        });

        document.addEventListener("click",e=>{
          if(!e.target.closest(".weekPickerWrap"))closeWeekPicker();
          if(!e.target.closest(".suggestBox")&&!e.target.closest(".cellEdit"))hideSuggest();
        });

        document.addEventListener("keydown",e=>{
          if(e.key==="Escape"){
            closeWeekPicker();
            hideSuggest();
          }
        });

        els.boardWrap.addEventListener("scroll",hideSuggest,{passive:true});
        window.addEventListener("resize",hideSuggest);

        els.waveSelect.addEventListener("change",()=>{
          state.wave=normalizeWave(els.waveSelect.value);
          els.waveSelect.value=state.wave;
          state.dirty.clear();
          hideSuggest();
          if(state.camp)loadAll();
          else{
            renderHeader();
            loadUpdateStatusOnly();
          }
        });

        els.campInput.addEventListener("keydown",e=>{
          if(e.key==="Enter")loadAll();
        });

        els.campInput.addEventListener("change",()=>{
          state.camp=clean(els.campInput.value);
          loadUpdateStatusOnly();
        });

        els.searchInput.addEventListener("input",()=>render());

        window.addEventListener("beforeunload",e=>{
          if(state.dirty.size>0){
            e.preventDefault();
            e.returnValue="";
          }
        });
      }

      async function boot(){
        bind();
        restoreToolbarState();
        updateWeekState();
        renderWeekOptions();
        renderHeader();
        updatePills();
        setUpdateStatusEmpty();

        const authed=await ensureAuth();
        if(!authed)return;

        const ok=await checkAccess();
        if(!ok)return;

        document.documentElement.style.visibility="visible";
        setState("ok","READY");
        els.apiPill.textContent="API";
        setStatus("캠프와 주/야를 선택하고 불러오기를 누르세요.");
      }

      boot().catch(e=>{
        console.error(e);
        document.documentElement.style.visibility="visible";
        setState("err","ERROR");
        setStatus(e?.message||String(e));
      });
    })();
  </script>
