        root.addEventListener('click', async (e) => {
          const actionEl = e.target.closest('[data-vendor-create-action]');
          if (actionEl) {
            const action = actionEl.dataset.vendorCreateAction;
            if (action === 'close' || action === 'cancel') {
              closeVendorCreateModal();
              return;
            }
            if (action === 'save') {
              if (vendorCreateState.submitting) return;
              const name = String(vendorCreateState.nameInput?.value || '').trim();
              const business_number = String(vendorCreateState.bizInput?.value || '').trim();
              if (!name) {
                vendorCreateState.nameInput?.focus();
                setStatus('벤더명은 필수입니다.', 'err');
                return;
              }
              if (!business_number) {
                vendorCreateState.bizInput?.focus();
                setStatus('사업자번호는 필수입니다.', 'err');
                return;
              }
              try {
                vendorCreateState.submitting = true;
                if (vendorCreateState.saveBtn) vendorCreateState.saveBtn.disabled = true;
                const created = await routeApiJson('POST', ROUTE_VENDOR_ENDPOINT, {
                  name,
                  business_number
                });
                const vendor = created?.row || created || {};
                const normalizedVendor = {
                  id: vendor.id ?? null,
                  name: String(vendor.name ?? name).trim(),
                  vendor_code: String(vendor.vendor_code ?? '').trim(),
                  business_number: String(vendor.business_number ?? business_number).trim()
                };
                upsertVendorInState(normalizedVendor);
                closeVendorCreateModal();
                vendorCreateState.ctx?.onCreated?.(normalizedVendor);
                setStatus('벤더 신규 등록 완료', 'ok');
                render();
              } catch (err) {
                console.error(err);
                vendorCreateState.submitting = false;
                if (vendorCreateState.saveBtn) vendorCreateState.saveBtn.disabled = false;
                setStatus('벤더 등록 실패: ' + formatDbError(err), 'err');
              }
              return;
            }
          }
          if (e.target === root) closeVendorCreateModal();
        });

        root.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && e.target && e.target.tagName === 'INPUT') {
            e.preventDefault();
            vendorCreateState.saveBtn?.click();
          }
        });
      }

      function openVendorCreateModal(options = {}) {
        ensureVendorCreateModal();
        vendorCreateState.ctx = options;
        vendorCreateState.submitting = false;
        if (vendorCreateState.saveBtn) vendorCreateState.saveBtn.disabled = false;
        vendorCreateState.nameInput.value = String(options.initialName || '').trim();
        vendorCreateState.bizInput.value = '';
        vendorCreateState.root.classList.remove('hidden');
        setTimeout(() => {
          vendorCreateState.nameInput?.focus();
          vendorCreateState.nameInput?.select();
        }, 0);
      }

      function emptyRow() {
        state.newRowSeq += 1;
        return {
          id: null,
          __newSeq: state.newRowSeq,
          vendor_id: "",
          order_date: "",
          order_name: "",
          order_vendor: "",
          camp: "",
          wave: "",
          route: "",
          price: "",
          settlement_day: "",
          delivery_driver: "",
          parcel: 0,
          return_count: 0,
          amount: "",
          settlement_month: "",
          dragon_car_id: "",
          dragon_car_pw: "",
          tax_invoice: false,
          payment_confirm: false,
          dragon_car_note: "",
          __subtractions: [],
          __amountManual: false,
          __dirty: true,
          __new: true
        };
      }

      function getHeaderFilters() {
        const out = {};
        document.querySelectorAll(".filterInput, .filterSelect").forEach(el => {
          out[el.dataset.filter] = el.value || "";
        });
        return out;
      }

      function matchesFilter(row, key, filterValue) {
        if (!filterValue) return true;
        if (key === "vendor_id") return String(row.vendor_id || "") === String(filterValue);
        if (key === "tax_invoice" || key === "payment_confirm") return String(!!row[key]) === String(filterValue);

        let raw = "";
        if (key === "total_count") {
          const total = totalCount(row);
          raw = `${total} ${formatNumber(total)}`;
        } else if (key === "amount") {
          const amount = amountValue(row);
          raw = amount == null ? "" : `${amount} ${formatNumber(amount)}`;
        } else raw = String(row[key] ?? "");

        return normalize(raw).includes(normalize(filterValue));
      }

      function getFilteredRows() {
        const head = getHeaderFilters();
        const quick = quickSearch.value || "";
        const toolbarVendor = toolbarVendorFilter.value || "";
        const dateFrom = toolbarDateFrom.value || "";
        const dateTo = toolbarDateTo.value || "";

        return state.rows.filter(row => {
          if (row.__subtractionOnly) return false;
          if (row.__new) return true;

          const keys = [
            "order_date","vendor_id","order_name","camp","wave","route","price","settlement_day",
            "delivery_driver","order_vendor","parcel","return_count","total_count","amount","settlement_month",
            "dragon_car_id","dragon_car_pw","tax_invoice","payment_confirm","dragon_car_note"
          ];

          for (const key of keys) {
            if (!matchesFilter(row, key, head[key])) return false;
          }

          if (toolbarVendor && String(row.vendor_id || "") !== String(toolbarVendor)) return false;

          const d = toDateInput(row.order_date);
          if (dateFrom && d && d < dateFrom) return false;
          if (dateTo && d && d > dateTo) return false;

          if (quick) {
            const joined = [
              row.order_name, row.order_vendor, row.camp, row.wave, row.route,
              row.delivery_driver, row.dragon_car_note, row.dragon_car_id, row.dragon_car_pw
            ].join(" ");
            if (!normalize(joined).includes(normalize(quick))) return false;
          }

          return true;
        }).slice().sort(compareRowsForDisplay);
      }

      function compareRowsForDisplay(a, b) {
        const aNew = !!a.__new;
        const bNew = !!b.__new;
        if (aNew !== bNew) return aNew ? -1 : 1;

        if (aNew && bNew) {
          const aSeq = Number(a.__newSeq || 0);
          const bSeq = Number(b.__newSeq || 0);
          if (aSeq !== bSeq) return bSeq - aSeq;
        }

        const da = toDateInput(a.order_date) || "";
        const db = toDateInput(b.order_date) || "";
        if (da !== db) return db.localeCompare(da);

        const aid = String(a.id ?? "");
        const bid = String(b.id ?? "");
        return bid.localeCompare(aid, "ko");
      }

      function computeSummary(rows) {
        return rows.reduce((acc, row) => {
          const parcel = toInt(row.parcel);
          const returnCount = toInt(row.return_count);
          const total = totalCount(row);
          const amount = Number(amountValue(row) || 0);

          acc.parcel += parcel;
          acc.returnCount += returnCount;
          acc.total += total;
          acc.amount += amount;

          if (row.payment_confirm) {
            acc.paidAmount += amount;
          } else if (total > 0) {
            acc.unpaidAmount += amount;
          }

          return acc;
        }, { parcel: 0, returnCount: 0, total: 0, amount: 0, paidAmount: 0, unpaidAmount: 0 });
      }

      function renderSummary(rows) {
        const summary = computeSummary(rows || []);
        summaryAmount.textContent = formatCurrency(summary.amount);
        summaryPaidAmount.textContent = formatCurrency(summary.paidAmount);
        summaryUnpaidAmount.textContent = formatCurrency(summary.unpaidAmount);
        summaryParcel.textContent = formatNumber(summary.parcel) || "0";
        summaryReturn.textContent = formatNumber(summary.returnCount) || "0";
        summaryTotal.textContent = formatNumber(summary.total) || "0";
      }

      function refreshStatus(rows = getFilteredRows()) {
        pillRows.textContent = "행 " + rows.length;
        pillDirty.textContent = "변경 " + state.rows.filter(r => r.__dirty).length;
        renderSummary(rows);
      }

