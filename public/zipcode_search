<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}
    /* =========================================================
       zipcode_search compact font override
       문경감홍사과체 기준 전체 글자 크기 과대 표시 보정
       기능 로직 변경 없음
       ========================================================= */

    body{
      font-size:13px !important;
    }

    header h1{
      font-size:17px !important;
      line-height:1.08 !important;
      letter-spacing:-.04em !important;
    }

    .headerSub{
      font-size:11px !important;
      line-height:1.2 !important;
    }

    .brand img{
      width:30px !important;
      height:30px !important;
    }

    header a.saveLink,
    header button,
    .panelToggle,
    button{
      font-size:11px !important;
      font-weight:950 !important;
      letter-spacing:-.03em !important;
    }

    .panelHead .muted,
    .muted,
    .hintBox,
    .pill,
    .modal-copy,
    .modalBody,
    .modalBody .pill{
      font-size:11px !important;
      line-height:1.45 !important;
      letter-spacing:-.03em !important;
    }

    label{
      font-size:11px !important;
      letter-spacing:-.03em !important;
    }

    textarea,
    input{
      font-size:13px !important;
      font-weight:900 !important;
      letter-spacing:-.035em !important;
    }

    textarea::placeholder,
    input::placeholder{
      font-size:13px !important;
      letter-spacing:-.04em !important;
    }

    .chip{
      font-size:11px !important;
      letter-spacing:-.03em !important;
    }

    .chip button{
      font-size:12px !important;
    }

    .map-controls button{
      font-size:11px !important;
      letter-spacing:-.03em !important;
    }

    .map-controls .hint{
      font-size:11px !important;
      letter-spacing:-.03em !important;
    }

    .zip-label{
      font-size:11px !important;
      letter-spacing:-.02em !important;
      padding:3px 8px !important;
    }

    .modal-title,
    .modalTop b{
      font-size:15px !important;
      letter-spacing:-.04em !important;
    }

    @media (max-width: 480px){
      body{
        font-size:12px !important;
      }

      header h1{
        font-size:16px !important;
      }

      header a.saveLink,
      header button,
      .panelToggle,
      button{
        font-size:10.5px !important;
      }

      textarea,
      input,
      textarea::placeholder,
      input::placeholder{
        font-size:12px !important;
      }
    }

  </style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />

  <meta property="og:image" content="https://maroowell.com/assets/og/maroowell-1200x630.png?v=1" />
  <meta property="og:image:secure_url" content="https://maroowell.com/assets/og/maroowell-1200x630.png?v=1" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Maroowell" />

  <title>마루웰</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <style>

    /*
      문경감홍사과체 실제 적용용
      - 아래 파일 중 하나를 repo의 public/assets/fonts/ 경로에 올려두면 적용됩니다.
      - 파일이 없으면 Noto Sans KR / system font로 자동 fallback 됩니다.
      - 권장 파일명: MungyeongGamhong.woff2
    */
    @font-face{
      font-family:"문경감홍사과체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    @font-face{
      font-family:"문경사과감홍체";
      src:
        url("/assets/fonts/MungyeongGamhong.woff2") format("woff2"),
        url("/assets/fonts/MungyeongGamhong.woff") format("woff"),
        url("/assets/fonts/MungyeongGamhong.ttf") format("truetype");
      font-weight:400 1000;
      font-style:normal;
      font-display:swap;
    }

    :root{
      --headerH:64px;
      --bg:#f6f8fc;
      --surface:#ffffff;
      --surface2:#f8fafc;
      --panel:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --muted2:#94a3b8;
      --line:#d8e0ee;
      --line2:#edf2f7;
      --blue:#2563eb;
      --blue2:#1d4ed8;
      --blueSoft:#dbeafe;
      --green:#16a34a;
      --greenSoft:#dcfce7;
      --red:#dc2626;
      --redSoft:#fee2e2;
      --yellow:#f59e0b;
      --shadow:0 14px 42px rgba(15,23,42,.10);
      --shadow2:0 8px 24px rgba(15,23,42,.08);
      --radius:18px;
      --font-mw:"문경감홍사과체","문경사과감홍체","Mungyeong Apple Gamhong","MungyeongGamhong","Noto Sans KR",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}

    html,body{
      height:100%;
      margin:0;
      overflow:hidden;
      background:
        radial-gradient(circle at 15% 8%, rgba(37,99,235,.08), transparent 32%),
        radial-gradient(circle at 88% 4%, rgba(14,165,233,.08), transparent 30%),
        linear-gradient(180deg,#ffffff 0%,var(--bg) 100%);
      color:var(--text);
      font-family:var(--font-mw);
      font-weight:800;
      -webkit-font-smoothing:antialiased;
      text-rendering:geometricPrecision;
    }

    body.panel-collapsed #panel{display:none}
    body.panel-collapsed #app{grid-template-columns:1fr}

    header{
      display:flex;
      gap:12px;
      align-items:center;
      padding:10px 16px;
      height:var(--headerH);
      background:rgba(255,255,255,.92);
      border-bottom:1px solid var(--line);
      position:sticky;
      top:0;
      z-index:50;
      backdrop-filter:blur(12px);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
    }

    .brand img{
      width:34px;
      height:34px;
      display:block;
      cursor:pointer;
      filter:drop-shadow(0 4px 10px rgba(15,23,42,.08));
    }

    .titleGroup{
      min-width:0;
      display:flex;
      flex-direction:column;
      gap:2px;
    }

    header h1{
      font-size:20px;
      font-weight:1000;
      letter-spacing:-.4px;
      margin:0;
      line-height:1.05;
      color:#0f172a;
      white-space:nowrap;
    }

    .headerSub{
      color:var(--muted);
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .spacer{flex:1}

    .headerActions{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    header a.saveLink,
    header button,
    .panelToggle{
      min-height:36px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:6px;
      color:#1e3a8a;
      font-size:12px;
      text-decoration:none;
      padding:0 12px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:#fff;
      cursor:pointer;
      font-weight:950;
      user-select:none;
      box-shadow:0 1px 0 rgba(255,255,255,.7);
      font-family:var(--font-mw);
    }

    header a.saveLink:hover,
    header button:hover,
    .panelToggle:hover{
      border-color:#93c5fd;
      background:#f8fbff;
    }

    header button.logoutBtn{
      color:#b91c1c;
      border-color:#fecaca;
      display:none;
    }

    header button.logoutBtn:hover{
      background:#fff5f5;
      border-color:#fca5a5;
    }

    #app{
      display:grid;
      grid-template-columns:minmax(320px,390px) 1fr;
      height:calc(100dvh - var(--headerH));
      min-height:0;
      gap:0;
    }

    #panel{
      padding:14px;
      border-right:1px solid var(--line);
      background:linear-gradient(180deg,#ffffff,#f8fafc);
      overflow:auto;
      min-height:0;
    }

    .panelCard{
      background:#fff;
      border:1px solid var(--line);
      border-radius:20px;
      padding:14px;
      box-shadow:var(--shadow2);
    }

    .panelHead{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
      margin-bottom:12px;
    }

    .muted{
      color:var(--muted);
      font-size:12px;
      font-weight:900;
      line-height:1.45;
    }

    label{
      display:block;
      margin:12px 0 7px;
      color:#334155;
      font-size:12px;
      font-weight:1000;
      letter-spacing:.01em;
    }

    input,textarea,button{
      font:inherit;
      font-family:var(--font-mw);
    }

    textarea,
    input{
      width:100%;
      background:#f8fafc;
      border:1px solid #cbd5e1;
      color:var(--text);
      padding:11px 12px;
      border-radius:14px;
      outline:none;
      font-weight:900;
      font-size:14px;
    }

    textarea{
      min-height:116px;
      line-height:1.45;
      resize:vertical;
    }

    textarea:focus,
    input:focus{
      background:#fff;
      border-color:#60a5fa;
      box-shadow:0 0 0 3px rgba(37,99,235,.12);
    }

    textarea::placeholder,
    input::placeholder{
      color:#94a3b8;
      font-weight:800;
    }

    button{
      min-height:38px;
      background:#fff;
      border:1px solid #cbd5e1;
      color:#0f172a;
      padding:0 13px;
      border-radius:999px;
      cursor:pointer;
      font-weight:950;
      box-shadow:0 1px 0 rgba(255,255,255,.7);
    }

    button:hover{
      border-color:#93c5fd;
      background:#f8fbff;
    }

    button:disabled{
      opacity:.62;
      cursor:not-allowed;
      transform:none;
    }

    button.primary,
    #searchBtn{
      background:linear-gradient(180deg,#3475f7,#2563eb);
      color:#fff;
      border-color:#1d4ed8;
      box-shadow:0 10px 22px rgba(37,99,235,.18);
    }

    button.primary:hover,
    #searchBtn:hover{
      background:linear-gradient(180deg,#2f6ff0,#1d4ed8);
    }

    button.danger{
      background:#fff;
      border-color:#fecaca;
      color:#b91c1c;
    }

    button.danger:hover{
      background:#fff5f5;
      border-color:#fca5a5;
    }

    #shareMapBtn{
      display:none;
    }

    #shareMapBtn.share-visible{
      display:inline-flex;
      background:linear-gradient(180deg,#22c55e,#16a34a);
      color:#fff;
      border-color:#15803d;
      box-shadow:0 10px 22px rgba(22,163,74,.18);
    }

    #shareMapBtn.share-visible:hover{
      background:linear-gradient(180deg,#16b84f,#15803d);
      border-color:#166534;
    }

    .shareToast{
      position:fixed;
      left:50%;
      bottom:24px;
      z-index:2147483000;
      transform:translate(-50%, 16px);
      min-width:170px;
      max-width:calc(100vw - 32px);
      padding:12px 18px;
      border-radius:999px;
      background:rgba(15,23,42,.94);
      color:#fff;
      font-size:13px;
      font-weight:1000;
      text-align:center;
      box-shadow:0 18px 42px rgba(15,23,42,.24);
      opacity:0;
      pointer-events:none;
      transition:opacity .18s ease, transform .18s ease;
    }

    .shareToast.show{
      opacity:1;
      transform:translate(-50%, 0);
    }

    button.merge-on{
      background:#ecfdf5;
      border-color:#86efac;
      color:#166534;
    }

    button.merge-on:hover{
      background:#dcfce7;
      border-color:#4ade80;
    }

    .row{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .row .grow{flex:1}

    .list{
      margin-top:12px;
      display:flex;
      flex-wrap:wrap;
      gap:7px;
      min-height:38px;
    }

    .chip{
      border:1px solid #cbd5e1;
      border-radius:999px;
      padding:7px 9px 7px 11px;
      background:#fff;
      display:inline-flex;
      align-items:center;
      gap:7px;
      font-size:12px;
      font-weight:1000;
      color:#0f172a;
      box-shadow:0 1px 0 rgba(255,255,255,.8);
    }

    .chip button{
      min-height:0;
      width:22px;
      height:22px;
      padding:0;
      border:none;
      background:#f1f5f9;
      color:#64748b;
      cursor:pointer;
      box-shadow:none;
    }

    .chip button:hover{
      background:#e2e8f0;
      color:#0f172a;
    }

    .hintBox{
      margin-top:12px;
      padding:11px 12px;
      border-radius:16px;
      border:1px solid #e2e8f0;
      background:#f8fafc;
      color:#64748b;
      font-size:12px;
      font-weight:900;
      line-height:1.55;
    }

    #mapWrap{
      position:relative;
      height:100%;
      min-height:0;
      display:flex;
      background:#eaf0f8;
      overflow:hidden;
      overscroll-behavior:contain;
      touch-action:none;
    }

    #map,#roadview{
      flex:1;
      width:100%;
      height:100%;
      min-width:0;
      min-height:0;
      overscroll-behavior:contain;
      touch-action:none;
    }

    #roadview{display:none}
    #mapWrap.roadview-open #roadview{display:block}

    .map-controls{
      position:absolute;
      top:12px;
      right:12px;
      z-index:10;
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .map-controls button{
      background:rgba(255,255,255,.92);
      border-color:#cbd5e1;
      backdrop-filter:blur(8px);
      color:#0f172a;
      box-shadow:0 6px 16px rgba(15,23,42,.10);
    }

    .map-controls .hint{
      display:inline-flex;
      align-items:center;
      min-height:36px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid #cbd5e1;
      background:rgba(255,255,255,.92);
      color:#475569;
      font-size:12px;
      font-weight:950;
      box-shadow:0 6px 16px rgba(15,23,42,.10);
    }

    .zip-label{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:4px 10px;
      border-radius:999px;
      font-weight:1000;
      font-size:12px;
      letter-spacing:.2px;
      color:#0b1220;
      background:rgba(255,255,255,.96);
      border:2px solid rgba(15,23,42,.24);
      box-shadow:0 4px 12px rgba(15,23,42,.22);
      user-select:none;
      pointer-events:none;
      transform:translateY(-2px);
      white-space:nowrap;
    }

    .modal{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      background:rgba(15,23,42,.36);
      backdrop-filter:blur(10px);
      z-index:9999;
      padding:16px;
    }

    .modal.open{display:flex}

    .modalCard{
      width:min(520px, 100%);
      background:#fff;
      border:1px solid var(--line);
      border-radius:22px;
      box-shadow:0 24px 80px rgba(15,23,42,.20);
      overflow:hidden;
    }

    .modalTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:15px 16px;
      background:#fff;
      border-bottom:1px solid #eef2f7;
    }

    .modalTop b{
      font-size:17px;
      font-weight:1000;
      color:#0f172a;
    }

    .modalTop button{
      min-height:34px;
      padding:0 12px;
      background:#f8fafc;
      border-color:#dbe3ef;
      color:#334155;
    }

    .modalBody{
      padding:16px;
    }

    .modalBody .row{
      justify-content:flex-end;
      margin-top:12px;
    }

    .pill{
      display:flex;
      align-items:flex-start;
      gap:8px;
      padding:11px 12px;
      border:1px solid #e2e8f0;
      border-radius:16px;
      background:#f8fafc;
      color:#475569;
      font-size:12px;
      margin-bottom:12px;
      line-height:1.55;
      width:100%;
      font-weight:850;
    }

    @media (max-width: 900px){
      html,body{
        height:auto;
        min-height:100%;
        overflow:auto;
      }

      header{
        height:auto;
        min-height:var(--headerH);
        align-items:flex-start;
        flex-wrap:wrap;
      }

      .headerSub{
        display:none;
      }

      .headerActions{
        width:100%;
        justify-content:flex-start;
      }

      #app{
        grid-template-columns:1fr;
        height:auto;
        min-height:calc(100dvh - var(--headerH));
      }

      #panel{
        order:2;
        height:auto;
        max-height:none;
        border-right:none;
        border-top:1px solid var(--line);
      }

      body.panel-collapsed #panel{
        display:none;
      }

      body.panel-collapsed #mapWrap{
        height:calc(100dvh - 114px);
      }

      #mapWrap{
        order:1;
        height:62dvh;
        min-height:360px;
      }

      #mapWrap.roadview-open{
        flex-direction:column;
        height:72dvh;
      }

      .map-controls{
        top:10px;
        right:10px;
        left:10px;
      }

      .panelCard{
        box-shadow:none;
      }
    }

    @media (max-width: 480px){
      header{
        padding:9px 11px;
        gap:9px;
      }

      .brand img{
        width:30px;
        height:30px;
      }

      header h1{
        font-size:18px;
      }

      .headerActions{
        gap:6px;
      }

      header a.saveLink,
      header button,
      .panelToggle,
      button{
        min-height:34px;
        padding:0 10px;
        font-size:12px;
      }

      #panel{
        padding:10px;
      }

      .panelCard{
        padding:12px;
        border-radius:18px;
      }

      textarea{
        min-height:94px;
      }

      #mapWrap{
        min-height:330px;
      }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/proj4js/2.9.1/proj4.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@turf/turf@6.5.0/turf.min.js"></script>
  <script src="https://dapi.kakao.com/v2/maps/sdk.js?appkey=add4ce93b38c0ff9d9b9053728e067b3"></script>
</head>

<body>
  <header>
    <div class="brand">
      <a id="mwBoardMenuToggle" href="#" style="display:flex;align-items:center">
        <img src="/favicon.ico" alt="Maroowell Logo" />
      </a>
      <div class="titleGroup">
        <h1>우편번호 검색기</h1>
        <div class="headerSub">우편번호 폴리곤 조회 · 저장</div>
      </div>
    </div>
    <span class="spacer"></span>
    <div class="headerActions">
      <button id="panelToggle" class="panelToggle" type="button">검색 패널 접기</button>
      <a id="saveLink" class="saveLink" href="https://map.kakao.com" target="_blank" rel="noreferrer">폴리곤 저장</a>
      <button id="logoutBtn" class="logoutBtn" type="button">로그아웃</button>
    </div>
  </header>

  <div id="app">
    <aside id="panel">
      <div class="panelCard">
        <div class="panelHead">
          <div>
            <div class="muted">우편번호 여러 개 동시 조회</div>
            <div class="muted">쉼표 / 공백 / 줄바꿈 모두 가능</div>
          </div>
        </div>

        <label for="zipInput">우편번호 목록</label>
        <textarea id="zipInput" placeholder="예: 07420, 07421 07422&#10;또는 붙여넣기"></textarea>

        <div class="row" style="margin-top:10px">
          <button id="addBtn" type="button">추가</button>
          <button id="searchBtn" type="button">지도표시</button>
          <button id="mergeBtn" type="button">병합</button>
          <button id="saveBtn" type="button">저장</button>
          <button id="clearBtn" class="danger" type="button">초기화</button>
          <button id="shareMapBtn" type="button" title="최고관리자 전용 · 72시간 만료 지도 공유 링크 생성">지도 공유</button>
        </div>

        <div class="list" id="zipList"></div>

        <div class="hintBox">
          • 잘못된 우편번호나 데이터가 없는 경우 미탑재로 안내됩니다.<br/>
          • 모바일에서는 상단의 “검색 패널 접기”로 지도를 넓게 볼 수 있습니다.
        </div>
      </div>
    </aside>

    <div id="mapWrap">
      <div id="map"></div>
      <div id="roadview"></div>
      <div class="map-controls">
        <button id="toggleMapType" type="button" title="일반/위성 전환">위성</button>
        <button id="toggleRoadview" type="button" title="로드뷰 보기/종료">로드뷰</button>
        <span id="roadviewHint" class="hint" style="display:none">로드뷰: 파란 길(ROADVIEW) 클릭</span>
      </div>
    </div>
  </div>

  <div id="shareToast" class="shareToast" role="status" aria-live="polite">링크 복사 완료!</div>

  <div id="saveModal" class="modal" aria-hidden="true">
    <div class="modalCard" role="dialog" aria-modal="true" aria-label="폴리곤 저장">
      <div class="modalTop">
        <b>폴리곤 저장</b>
        <button id="saveCloseBtn" type="button">닫기</button>
      </div>
      <div class="modalBody">
        <div class="pill">
          • 현재 선택된 우편번호 폴리곤들을 “병합 결과”로 저장합니다.<br/>
          • 저장 시 최종 링은 “원본 면적”으로 클립되어 절대 커지지 않습니다.<br/>
          • 저장 포맷은 기존 그대로 polygon_wgs84 = Array&lt;ring&gt; 입니다.
        </div>

        <label for="saveCampInput">캠프(camp)</label>
        <input id="saveCampInput" placeholder="예: M익산1 ..." />

        <label for="saveCodeInput" style="margin-top:10px">라우트 코드(code)</label>
        <input id="saveCodeInput" placeholder="예: 익산0그룹 ..." />

        <div class="row">
          <button id="saveDoBtn" class="primary" type="button">저장</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    (async function(){
      "use strict";

      console.log("[mw] zipcode_search loaded white design");

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const INDEX_PATH = (PATHS?.index || "/zipcode_search");
      const LOGIN_PATH = (PATHS?.login || "/");

      function getSupabaseProjectRef(url) {
        try {
          const host = new URL(url).hostname || "";
          return host.split(".")[0] || "";
        } catch {
          return "";
        }
      }

      function createSupabaseSessionBridge(url) {
        const projectRef = getSupabaseProjectRef(url);
        const prefixes = projectRef ? [
          "sb-" + projectRef + "-auth-token",
          "sb-" + projectRef + "-auth-token-code-verifier"
        ] : [];
        const origin = window.location.origin;
        const channelName = projectRef ? ("mw-auth-bridge:" + projectRef) : "";
        const tabId = (Date.now().toString(36) + Math.random().toString(36).slice(2));
        const pending = new Map();
        let channel = null;
        let started = false;

        function matchesKey(key) {
          return !!key && prefixes.some(prefix => key === prefix || key.startsWith(prefix));
        }

        function readEntries(storage) {
          const target = storage || window.sessionStorage;
          const rows = [];
          try {
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (!matchesKey(key)) continue;
              rows.push({ key, value: target.getItem(key) });
            }
          } catch {}
          return rows;
        }

        function hasSession(storage) {
          return readEntries(storage).some(row => row.key.includes("-auth-token") && !row.key.includes("code-verifier") && !!row.value);
        }

        function writeEntries(entries, storage) {
          const target = storage || window.sessionStorage;
          try {
            for (const row of entries || []) {
              if (!row || !matchesKey(row.key)) continue;
              if (row.value == null) target.removeItem(row.key);
              else target.setItem(row.key, row.value);
            }
          } catch {}
        }

        function clearSession(storage) {
          const target = storage || window.sessionStorage;
          try {
            const keys = [];
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (matchesKey(key)) keys.push(key);
            }
            keys.forEach(key => target.removeItem(key));
          } catch {}
        }

        function resolvePending(requestId, entries) {
          const item = pending.get(requestId);
          if (!item) return;
          pending.delete(requestId);
          clearTimeout(item.timer);
          if (Array.isArray(entries) && entries.length) writeEntries(entries, window.sessionStorage);
          item.resolve(hasSession(window.sessionStorage));
        }

        function handleSyncState(state) {
          if (state === "SIGNED_OUT") {
            clearSession(window.sessionStorage);
            return;
          }
          if (state === "SESSION_UPDATED" && !hasSession(window.sessionStorage)) {
            requestSessionCopy(1200).catch(() => {});
          }
        }

        function onWindowMessage(event) {
          if (event.origin !== origin) return;
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              event.source?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              }, origin);
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function onChannelMessage(event) {
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              channel?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              });
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function start() {
          if (started || !projectRef) return;
          started = true;
          window.addEventListener("message", onWindowMessage);
          try {
            if ("BroadcastChannel" in window) {
              channel = new BroadcastChannel(channelName);
              channel.addEventListener("message", onChannelMessage);
            }
          } catch {}
        }

        function requestSessionCopy(timeoutMs) {
          start();
          if (!projectRef) return Promise.resolve(false);
          if (hasSession(window.sessionStorage)) return Promise.resolve(true);

          const requestId = tabId + ":" + Date.now().toString(36) + Math.random().toString(36).slice(2);
          const payload = {
            type: "MW_SESSION_REQUEST",
            projectRef,
            requestId,
            fromTabId: tabId
          };

          return new Promise(resolve => {
            const timer = window.setTimeout(() => {
              pending.delete(requestId);
              resolve(hasSession(window.sessionStorage));
            }, Math.max(300, Number(timeoutMs) || 900));

            pending.set(requestId, { resolve, timer });

            try { channel?.postMessage(payload); } catch {}
            try {
              if (window.opener && window.opener !== window) {
                window.opener.postMessage(payload, origin);
              }
            } catch {}
          });
        }

        function broadcastAuthState(state) {
          start();
          const payload = {
            type: "MW_AUTH_SYNC",
            projectRef,
            state,
            fromTabId: tabId
          };
          try { channel?.postMessage(payload); } catch {}
          try {
            if (window.opener && window.opener !== window) {
              window.opener.postMessage(payload, origin);
            }
          } catch {}
        }

        return {
          start,
          requestSessionCopy,
          broadcastAuthState
        };
      }

      const authStorage = (() => {
        try { return window.sessionStorage; } catch {}
        return null;
      })();
      const logoutBtnEl = document.getElementById("logoutBtn");
      const sessionBridge = createSupabaseSessionBridge(SUPABASE_URL);
      sessionBridge.start();
      await sessionBridge.requestSessionCopy(1200);

      const supabase = window.supabase?.createClient?.(SUPABASE_URL, SUPABASE_ANON_KEY, {
        auth: {
          persistSession: !!authStorage,
          storage: authStorage || undefined,
          autoRefreshToken: true,
          detectSessionInUrl: true
        }
      });

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      async function requireAuthOrRedirect() {
        if (!supabase || !supabase.auth) {
          console.error("[Auth Guard] Supabase client not initialized");
          alert("Supabase SDK 로딩 실패: 새로고침 후 다시 시도하세요.");
          document.documentElement.style.visibility = "visible";
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();
          if (session) {
            document.documentElement.style.visibility = "visible";
            if (logoutBtnEl) logoutBtnEl.style.display = "inline-flex";

            supabase.auth.onAuthStateChange((evt, s) => {
              if (evt === "SIGNED_OUT" || !s) {
                sessionBridge.broadcastAuthState("SIGNED_OUT");
                const next = safeNextPath(location.pathname + location.search + location.hash);
                location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
                return;
              }
              if (evt === "SIGNED_IN" || evt === "TOKEN_REFRESHED" || evt === "USER_UPDATED") {
                sessionBridge.broadcastAuthState("SESSION_UPDATED");
              }
            });

            return true;
          }
        } catch (e) {
          console.error("[Auth Guard] getSession failed", e);
        }

        const next = safeNextPath(location.pathname + location.search + location.hash);
        location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
        return false;
      }

      if (!(await requireAuthOrRedirect())) return;

      const ZIP_API_URL = "https://zip.maroowell.com/?zipcode=";
      const ROUTE_ENDPOINT = "https://route.maroowell.com/route";
      const ZIP_SHARE_API_BASE = String(
        (window.MARUWELL_CONFIG || {}).ZIPCODE_SHARE_API_BASE ||
        (window.MARUWELL_CONFIG || {}).ZIP_SHARE_API_BASE ||
        "https://zip.maroowell.com"
      ).replace(/\/+$/, "");
      const ZIP_SHARE_PAGE_PATH = "/zipcode_share";
      const MERGE_SNAP_METERS = 35;
      const MIN_COMPONENT_AREA_SQM = 800;
      const ZIP_FETCH_TIMEOUT_MS = 15000;

      let loadingDepth = 0;

      function setBusy(on, message) {
        loadingDepth = on ? (loadingDepth + 1) : Math.max(0, loadingDepth - 1);
        const active = loadingDepth > 0;
        const labels = [
          ["#addBtn", "추가"],
          ["#searchBtn", "지도표시"],
          ["#mergeBtn", "병합"],
          ["#saveBtn", "저장"],
          ["#clearBtn", "초기화"],
          ["#shareMapBtn", "지도 공유"]
        ];

        labels.forEach(([sel, label]) => {
          const el = document.querySelector(sel);
          if (!el) return;
          if (active) {
            el.dataset.prevDisabled = el.disabled ? "1" : "0";
            if (sel === "#searchBtn") el.textContent = message || "조회 중...";
            el.disabled = true;
          } else {
            if (el.dataset.prevDisabled !== "1") el.disabled = false;
            delete el.dataset.prevDisabled;
            el.textContent = label;
          }
        });
      }

      async function fetchWithTimeout(url, options = {}, timeoutMs = ZIP_FETCH_TIMEOUT_MS) {
        const controller = new AbortController();
        const timer = window.setTimeout(() => controller.abort(new DOMException("timeout", "AbortError")), timeoutMs);
        try {
          const merged = { ...options, signal: controller.signal };
          return await fetch(url, merged);
        } finally {
          window.clearTimeout(timer);
        }
      }

      const $ = (sel) => document.querySelector(sel);
      const parseZips = (raw) => [...new Set((raw || "").match(/\d{5}/g) || [])];
      const isTouchDevice = () =>
        !!window.matchMedia?.("(pointer: coarse)")?.matches ||
        (navigator.maxTouchPoints || 0) > 0 ||
        "ontouchstart" in window;

      const state = {
        map: null,
        polygons: new Map(),
        labels: new Map(),
        geoByZip: new Map(),
        selectedZips: new Set(),
        mergeMode: false,
        mergedPolygons: [],
        mergedOutlinePolylines: [],
        mergedRingsWgs84: null,
        isSatellite: false,
        roadviewOn: false,
        roadviewOpen: false,
        roadview: null,
        roadviewClient: null,
        roadviewClickHandler: null,
        colors: [
          "#ff4b4b","#22c55e","#fbbf24","#3b82f6",
          "#22d3ee","#c084fc","#f472b6","#60a5fa",
          "#34d399","#f97316"
        ]
      };

      function enableMobileMapInteractions() {
        if (!state.map || !isTouchDevice()) return;
        try { state.map.setDraggable(true); } catch {}
        try { state.map.setZoomable(true); } catch {}

        ["mapWrap", "map", "roadview"].forEach((id) => {
          const el = document.getElementById(id);
          if (!el) return;
          el.style.touchAction = "none";
          el.style.overscrollBehavior = "contain";
        });
      }

      function pickColor(seed) {
        let h = 0;
        const s = String(seed);
        for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
        return state.colors[h % state.colors.length];
      }

      function darkenHex(hex, amt = 0.18) {
        if (!hex || hex[0] !== "#" || hex.length !== 7) return hex;
        const r = Math.max(0, Math.min(255, Math.round(parseInt(hex.slice(1,3),16) * (1-amt))));
        const g = Math.max(0, Math.min(255, Math.round(parseInt(hex.slice(3,5),16) * (1-amt))));
        const b = Math.max(0, Math.min(255, Math.round(parseInt(hex.slice(5,7),16) * (1-amt))));
        return "#" + [r,g,b].map(v => v.toString(16).padStart(2,"0")).join("");
      }

      proj4.defs(
        "EPSG:5179",
        "+proj=tmerc +lat_0=38 +lon_0=127.5 +k=0.9996 " +
          "+x_0=1000000 +y_0=2000000 +ellps=GRS80 " +
          "+towgs84=0,0,0,0,0,0,0 +units=m +no_defs"
      );
      proj4.defs("EPSG:4326", "+proj=longlat +datum=WGS84 +no_defs");

      function convertPoint(x, y) {
        let lon;
        let lat;
        try {
          const out = proj4("EPSG:5179", "EPSG:4326", [x, y]);
          lon = out[0];
          lat = out[1];
        } catch {}

        if (!isFinite(lat) || !isFinite(lon) || lat < 30 || lat > 45 || lon < 120 || lon > 135) {
          lon = x;
          lat = y;
        }

        return { lat, lon };
      }

      function createMap() {
        if (!(window.kakao && kakao.maps)) {
          alert("카카오 지도 SDK 로딩 실패");
          return;
        }

        state.map = new kakao.maps.Map($("#map"), {
          center: new kakao.maps.LatLng(37.5665, 126.978),
          level: 8
        });

        enableMobileMapInteractions();

        window.addEventListener("resize", () => {
          if (!state.map) return;
          const c = state.map.getCenter();
          state.map.relayout();
          state.map.setCenter(c);

          if (state.roadviewOn && state.roadview && typeof state.roadview.relayout === "function") {
            state.roadview.relayout();
          }

          enableMobileMapInteractions();
        });
      }

      function relayoutMapSoon() {
        window.setTimeout(() => {
          if (!state.map) return;
          const c = state.map.getCenter();
          state.map.relayout();
          state.map.setCenter(c);
        }, 80);
      }

      function setMapTypeSatellite(on) {
        state.isSatellite = !!on;
        if (!state.map) return;

        state.map.setMapTypeId(
          state.isSatellite ? kakao.maps.MapTypeId.HYBRID : kakao.maps.MapTypeId.ROADMAP
        );

        $("#toggleMapType").textContent = state.isSatellite ? "일반" : "위성";
      }

      function ensureRoadview() {
        if (state.roadview && state.roadviewClient) return;
        state.roadview = new kakao.maps.Roadview($("#roadview"));
        state.roadviewClient = new kakao.maps.RoadviewClient();
      }

      function setRoadviewOverlay(on) {
        if (!state.map) return;
        try {
          if (on) state.map.addOverlayMapTypeId(kakao.maps.MapTypeId.ROADVIEW);
          else state.map.removeOverlayMapTypeId(kakao.maps.MapTypeId.ROADVIEW);
        } catch {}
      }

      function setRoadviewAt(latlng) {
        ensureRoadview();
        const radii = [80, 200, 500, 1200];

        const tryFind = (i) => {
          state.roadviewClient.getNearestPanoId(latlng, radii[i], (panoId) => {
            if (panoId === null || panoId === undefined) {
              if (i < radii.length - 1) return tryFind(i + 1);
              alert("이 위치 근처에는 로드뷰가 없습니다.");
              return;
            }

            state.roadviewOpen = true;
            $("#mapWrap").classList.add("roadview-open");
            setTimeout(() => state.roadview.relayout(), 0);
            state.roadview.setPanoId(panoId, latlng);
          });
        };

        tryFind(0);
      }

      function setRoadviewOn(on) {
        state.roadviewOn = !!on;
        if (!state.roadviewOn) state.roadviewOpen = false;

        $("#roadviewHint").style.display = state.roadviewOn ? "inline-flex" : "none";
        $("#toggleRoadview").textContent = state.roadviewOn ? "로드뷰 종료" : "로드뷰";

        if (!state.roadviewOn) $("#mapWrap").classList.remove("roadview-open");

        if (state.map) {
          const c = state.map.getCenter();
          state.map.relayout();
          state.map.setCenter(c);
          enableMobileMapInteractions();
        }

        if (state.roadviewOn) {
          setRoadviewOverlay(true);
          if (!state.roadviewClickHandler && state.map) {
            state.roadviewClickHandler = (mouseEvent) => {
              if (!state.roadviewOn) return;
              if (mouseEvent && mouseEvent.latLng) setRoadviewAt(mouseEvent.latLng);
            };
            kakao.maps.event.addListener(state.map, "click", state.roadviewClickHandler);
          }
        } else {
          setRoadviewOverlay(false);
          if (state.roadviewClickHandler && state.map) {
            kakao.maps.event.removeListener(state.map, "click", state.roadviewClickHandler);
          }
          state.roadviewClickHandler = null;
        }
      }

      function renderZipChips() {
        const list = $("#zipList");
        list.innerHTML = "";

        [...state.selectedZips].sort().forEach((z) => {
          const div = document.createElement("div");
          div.className = "chip";
          const color = pickColor(z);
          div.innerHTML =
            `<b>${z}</b>` +
            `<span style="display:inline-block;width:10px;height:10px;border-radius:3px;background:${color}"></span>` +
            `<button title="삭제" type="button">×</button>`;

          div.querySelector("button").onclick = async () => {
            state.selectedZips.delete(z);
            removeZipData(z);
            renderZipChips();
            if (state.mergeMode) await mergeOn(true);
          };

          list.appendChild(div);
        });
      }

      function removeZipData(zip) {
        if (state.polygons.has(zip)) {
          state.polygons.get(zip).forEach(p => p.setMap(null));
          state.polygons.delete(zip);
        }

        if (state.labels.has(zip)) {
          state.labels.get(zip).forEach(l => l.setMap(null));
          state.labels.delete(zip);
        }

        state.geoByZip.delete(zip);
      }

      function setOriginalVisible(on) {
        const map = on ? state.map : null;
        for (const arr of state.polygons.values()) arr.forEach(p => p.setMap(map));
        for (const arr of state.labels.values()) arr.forEach(l => l.setMap(map));
      }

      function centroidOfLngLatRing(ringLngLat) {
        if (!ringLngLat || ringLngLat.length < 3) return null;
        const pts = ringLngLat.slice();
        const f = pts[0];
        const l = pts[pts.length - 1];
        if (f[0] !== l[0] || f[1] !== l[1]) pts.push([f[0], f[1]]);

        let area2 = 0;
        let cx6 = 0;
        let cy6 = 0;

        for (let i = 0; i < pts.length - 1; i++) {
          const x0 = pts[i][0];
          const y0 = pts[i][1];
          const x1 = pts[i+1][0];
          const y1 = pts[i+1][1];
          const f2 = x0*y1 - x1*y0;
          area2 += f2;
          cx6 += (x0 + x1) * f2;
          cy6 += (y0 + y1) * f2;
        }

        if (!isFinite(area2) || Math.abs(area2) < 1e-14) return null;

        const cx = cx6 / (3 * area2);
        const cy = cy6 / (3 * area2);

        if (!isFinite(cx) || !isFinite(cy)) return null;

        return new kakao.maps.LatLng(cy, cx);
      }

      function createZipLabelOverlay(zip, color, pos) {
        const el = document.createElement("div");
        el.className = "zip-label";
        el.textContent = zip;
        el.style.borderColor = color;

        return new kakao.maps.CustomOverlay({
          position: pos,
          content: el,
          yAnchor: 0.5,
          zIndex: 9999
        });
      }

      function isPoint(v) {
        return Array.isArray(v) && v.length >= 2 && isFinite(v[0]) && isFinite(v[1]);
      }

      function normalizeToMultiPolygon5179(polygon5179) {
        if (!Array.isArray(polygon5179) || polygon5179.length === 0) return null;
        if (isPoint(polygon5179[0])) return [[polygon5179]];
        if (Array.isArray(polygon5179[0]) && polygon5179[0].length && isPoint(polygon5179[0][0])) return [polygon5179];
        if (
          Array.isArray(polygon5179[0]) &&
          polygon5179[0].length &&
          Array.isArray(polygon5179[0][0]) &&
          polygon5179[0][0].length &&
          isPoint(polygon5179[0][0][0])
        ) return polygon5179;
        return null;
      }

      function closeRingLngLat(ring) {
        if (!ring || ring.length < 3) return ring;
        const f = ring[0];
        const l = ring[ring.length - 1];
        if (f[0] !== l[0] || f[1] !== l[1]) ring.push([f[0], f[1]]);
        return ring;
      }

      function convert5179MultiToWgs84(multi5179) {
        const out = [];

        for (const poly of multi5179) {
          const ringsOut = [];

          for (const ring of poly) {
            const ringOut = [];

            for (const pt of ring) {
              if (!isPoint(pt)) continue;
              const x = Number(pt[0]);
              const y = Number(pt[1]);
              const { lat, lon } = convertPoint(x, y);
              if (!isFinite(lat) || !isFinite(lon)) continue;
              ringOut.push([lon, lat]);
            }

            if (ringOut.length >= 3) {
              closeRingLngLat(ringOut);
              if (ringOut.length >= 4) ringsOut.push(ringOut);
            }
          }

          if (ringsOut.length) out.push(ringsOut);
        }

        return out.length ? out : null;
      }

      function drawZipMultiPolygon(zip, wgsMultiCoords) {
        const color = pickColor(zip);
        const polys = [];
        const overlays = [];

        for (const polyRings of wgsMultiCoords) {
          const ringsLatLng = polyRings
            .map(ring => {
              const latlngs = ring.map(([lng, lat]) => new kakao.maps.LatLng(lat, lng));

              if (latlngs.length > 1) {
                const f = latlngs[0];
                const l = latlngs[latlngs.length - 1];
                if (f.getLat() === l.getLat() && f.getLng() === l.getLng()) latlngs.pop();
              }

              return latlngs;
            })
            .filter(r => r.length >= 3);

          if (!ringsLatLng.length) continue;

          const pathForKakao = ringsLatLng.length === 1 ? ringsLatLng[0] : ringsLatLng;

          const poly = new kakao.maps.Polygon({
            map: state.map,
            path: pathForKakao,
            strokeWeight: 3,
            strokeColor: color,
            strokeOpacity: 1,
            strokeStyle: "solid",
            fillColor: color,
            fillOpacity: 0.24
          });

          polys.push(poly);

          const outerRing = polyRings[0];
          const center = centroidOfLngLatRing(outerRing);

          if (center) {
            const ov = createZipLabelOverlay(zip, color, center);
            ov.setMap(state.map);
            overlays.push(ov);
          }
        }

        if (polys.length) state.polygons.set(zip, polys);
        if (overlays.length) state.labels.set(zip, overlays);
      }

      async function drawSelected() {
        const targets = [...state.selectedZips].filter(z => !state.geoByZip.has(z));
        if (!targets.length) return;

        const notFound = [];
        const reasons = [];

        setBusy(true, "조회 중...");

        try {
          for (const zip of targets) {
            const url = `${ZIP_API_URL}${encodeURIComponent(zip)}`;

            try {
              const res0 = await fetchWithTimeout(url, { cache: "no-store" }, ZIP_FETCH_TIMEOUT_MS);
              const resClone = res0.clone();

              if (!res0.ok) {
                const t = await res0.text().catch(() => "");
                console.warn("[ZIP_API] HTTP error", zip, res0.status, t.slice(0, 300));
                reasons.push(`${zip}: HTTP ${res0.status}`);
                notFound.push(zip);
                continue;
              }

              let data = null;

              try {
                data = await res0.json();
              } catch (e) {
                const t = await resClone.text().catch(() => "");
                console.warn("[ZIP_API] JSON parse fail", zip, String(e), t.slice(0, 300));
                reasons.push(`${zip}: JSON parse fail`);
                notFound.push(zip);
                continue;
              }

              const polyRaw = (data && (data.polygon5179 ?? data.polygon_5179 ?? data.polygon)) ?? null;

              if (!Array.isArray(polyRaw) || polyRaw.length === 0) {
                console.warn("[ZIP_API] polygon5179 missing/empty", zip, data);
                reasons.push(`${zip}: polygon missing`);
                notFound.push(zip);
                continue;
              }

              const norm = normalizeToMultiPolygon5179(polyRaw);
              if (!norm) {
                reasons.push(`${zip}: normalize fail`);
                notFound.push(zip);
                continue;
              }

              const wgs = convert5179MultiToWgs84(norm);
              if (!wgs) {
                reasons.push(`${zip}: convert fail`);
                notFound.push(zip);
                continue;
              }

              const feature = {
                type: "Feature",
                properties: { zip },
                geometry: { type: "MultiPolygon", coordinates: wgs }
              };

              state.geoByZip.set(zip, feature);
              drawZipMultiPolygon(zip, wgs);
            } catch (err) {
              const msg = String(err || "");
              console.warn("[ZIP_API] fetch failed", zip, msg);

              if (err?.name === "AbortError") {
                reasons.push(`${zip}: 요청 시간초과(${Math.round(ZIP_FETCH_TIMEOUT_MS / 1000)}초)`);
              } else {
                reasons.push(`${zip}: fetch failed`);
              }

              notFound.push(zip);
            }
          }
        } finally {
          setBusy(false);
        }

        if (notFound.length) {
          const detail = reasons.length ? `\n\n상세(최대 8개):\n- ${reasons.slice(0, 8).join("\n- ")}` : "";
          alert(`폴리곤을 그리지 못한 우편번호: ${notFound.join(", ")}${detail}`);
        }
      }

      function fitBoundsAllOriginal() {
        if (!state.map) return;

        const b = new kakao.maps.LatLngBounds();
        let has = false;

        for (const arr of state.polygons.values()) {
          for (const poly of arr) {
            const path = poly.getPath();

            if (Array.isArray(path)) {
              path.forEach(ll => {
                b.extend(ll);
                has = true;
              });
              continue;
            }

            if (path && typeof path.getLength === "function" && typeof path.getAt === "function") {
              for (let i = 0; i < path.getLength(); i++) {
                const ring = path.getAt(i);
                if (ring && typeof ring.getLength === "function") {
                  for (let j = 0; j < ring.getLength(); j++) {
                    b.extend(ring.getAt(j));
                    has = true;
                  }
                }
              }
            }
          }
        }

        if (has) {
          state.map.setBounds(b);
          enableMobileMapInteractions();
        }
      }

      function fitBoundsToRings(rings) {
        if (!state.map || !Array.isArray(rings) || !rings.length) return;

        const b = new kakao.maps.LatLngBounds();
        let has = false;

        for (const ring of rings) {
          if (!Array.isArray(ring) || ring.length < 2) continue;

          for (const pt of ring) {
            if (!Array.isArray(pt) || pt.length < 2) continue;
            const lng = Number(pt[0]);
            const lat = Number(pt[1]);
            if (!isFinite(lat) || !isFinite(lng)) continue;
            b.extend(new kakao.maps.LatLng(lat, lng));
            has = true;
          }
        }

        if (has) {
          state.map.setBounds(b);
          enableMobileMapInteractions();
        }
      }

