        });

        root.addEventListener("change", (e) => {
          const el = e.target;
          const idx = Number(el.dataset.deductionIndex);
          const field = el.dataset.deductionField;
          const item = state.deduction.items[idx];

          if (!item || !field) return;

          if (field === "subtraction_confirm" || field === "payment_confirm") {
            item[field] = String(el.value) === "true";
            renderDeductionSummaryOnly();
          }
