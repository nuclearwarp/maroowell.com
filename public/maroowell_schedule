  <script>
    (async function(){
      "use strict";

      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY;
      const LOGIN_PATH = CONFIG.PATHS?.login || "/login.html";
      const SCHEDULE_API_BASE = String(CONFIG.SCHEDULE_API_BASE || CONFIG.SCHEDULE_API_URL || "https://schedule.maroowell.com").replace(/\/+$/,"");

      const META_VENDOR_NAME = CONFIG.METAADMIN_VENDOR_NAME || "마루웰/MARUL";
      const META_BUSINESS_NO = CONFIG.METAADMIN_BUSINESS_NO || "2591501828";
      const META_WORK_STATUS = CONFIG.METAADMIN_WORK_STATUS || "출근";
      const OFF_ROUTE_LABEL = "휴무자";

      const DAYS = ["일","월","화","수","목","금","토"];
      const WAVE_LABEL = { WAVE1:"야간", WAVE2:"주간" };
      const WAVE_ALIASES = {
        WAVE1:["WAVE1","W1","야간","NIGHT","N"],
        WAVE2:["WAVE2","W2","주간","DAY","D"]
      };

      const LIGHT_PALETTE = [
        "#e9d5ff","#bae6fd","#fde68a","#bbf7d0","#fecaca","#bfdbfe","#fbcfe8","#fed7aa","#ccfbf1","#ddd6fe",
        "#d9f99d","#fef3c7","#cffafe","#fae8ff","#dcfce7","#fee2e2","#e0f2fe","#fce7f3","#ede9fe","#ecfccb",
        "#dbeafe","#ffedd5","#fef9c3","#f5d0fe","#c7d2fe","#fecdd3","#e2e8f0","#fef2f2","#f0fdf4","#eff6ff","#fff7ed"
      ];

      const els = {
        userBadge:document.getElementById("userBadge"),
        btnLogout:document.getElementById("btnLogout"),
        btnToggleToolbar:document.getElementById("btnToggleToolbar"),
        toolbar:document.getElementById("toolbar"),
        campInput:document.getElementById("campInput"),
        waveSelect:document.getElementById("waveSelect"),
        weekButton:document.getElementById("weekButton"),
        weekButtonText:document.getElementById("weekButtonText"),
        weekPopup:document.getElementById("weekPopup"),
        weekMonthTitle:document.getElementById("weekMonthTitle"),
        weekOptionList:document.getElementById("weekOptionList"),
        weekManualInput:document.getElementById("weekManualInput"),
        btnWeekManualApply:document.getElementById("btnWeekManualApply"),
        searchInput:document.getElementById("searchInput"),
        actualUpdateInput:document.getElementById("actualUpdateInput"),
        fakeUpdateInput:document.getElementById("fakeUpdateInput"),
        btnUpdateStatusSave:document.getElementById("btnUpdateStatusSave"),
        btnPrevWeek:document.getElementById("btnPrevWeek"),
        btnNextWeek:document.getElementById("btnNextWeek"),
        btnLoad:document.getElementById("btnLoad"),
        btnSave:document.getElementById("btnSave"),
        btnExportMeta:document.getElementById("btnExportMeta"),
        btnCopyImage:document.getElementById("btnCopyImage"),
        btnReset:document.getElementById("btnReset"),
        btnImportWeek:document.getElementById("btnImportWeek"),
        statePill:document.getElementById("statePill"),
        weekPill:document.getElementById("weekPill"),
        rowPill:document.getElementById("rowPill"),
        dirtyPill:document.getElementById("dirtyPill"),
        apiPill:document.getElementById("apiPill"),
        statusText:document.getElementById("statusText"),
        boardRoot:document.getElementById("boardRoot"),
        boardTitle:document.getElementById("boardTitle"),
        boardSubTitle:document.getElementById("boardSubTitle"),
        tableHost:document.getElementById("tableHost"),
        boardWrap:document.getElementById("boardWrap"),
        suggestBox:document.getElementById("suggestBox")
      };

      const state = {
        session:null,email:"",userId:"",accessToken:"",
        camp:"",wave:"WAVE2",
        baseDate:todayIso(),weekStart:"",weekEnd:"",weekDates:[],isoYear:0,isoWeek:0,weekLabel:"",
        routesRaw:[],routeParents:[],displayRows:[],routeLookup:new Map(),
        schedules:[],scheduleMap:new Map(),
        driversRaw:[],driverAccounts:[],accountByDisplay:new Map(),accountByExportName:new Map(),accountById:new Map(),metaInfoAccountsByName:new Map(),personColorMap:new Map(),
        expanded:new Set(),dirty:new Map(),loading:false,suggestInput:null,dayClipboard:null,
        updateStatus:null
      };

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth:{storage:window.sessionStorage,persistSession:true,autoRefreshToken:true,detectSessionInUrl:true}
          })
        : null;

      function clean(v){return String(v ?? "").trim()}
      function compact(v){return clean(v).replace(/\s+/g,"")}
      function keyOf(v){return compact(v).toUpperCase()}
      function campKey(v){return compact(v).replace(/_/g,"").toUpperCase()}
      function esc(v){return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;")}

      function normalizeWave(v){
        const raw = compact(v).toUpperCase();
        if(raw==="야간"||raw==="NIGHT"||raw==="N"||raw==="W1"||raw==="WAVE1") return "WAVE1";
        if(raw==="주간"||raw==="DAY"||raw==="D"||raw==="W2"||raw==="WAVE2") return "WAVE2";
        return "WAVE2";
      }

      function waveLabel(v){return WAVE_LABEL[normalizeWave(v)] || v || "-"}
      function metaRotationByWave(wave){return normalizeWave(wave)==="WAVE1" ? "D1,D2,F3" : "1회전,2회전"}

      function todayIso(){return toIso(new Date())}
      function toIso(d){
        if(!(d instanceof Date)||Number.isNaN(d.getTime())) return "";
        return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
      }
      function parseIso(v){
        const m=clean(v).match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if(!m) return null;
        return new Date(Number(m[1]),Number(m[2])-1,Number(m[3]));
      }
      function addDays(iso,days){const d=parseIso(iso)||new Date();d.setDate(d.getDate()+days);return toIso(d)}
      function daysBetween(a,b){const da=parseIso(a),db=parseIso(b);if(!da||!db)return 0;return Math.round((da-db)/86400000)}
      function sundayOf(iso){const d=parseIso(iso)||new Date();d.setDate(d.getDate()-d.getDay());return toIso(d)}
      function weekDatesFromStart(startIso){return Array.from({length:7},(_,i)=>addDays(startIso,i))}
      function isoWeekInfoFromMondayRef(startIso){
        const sunday=parseIso(startIso)||new Date();
        const ref=new Date(sunday);ref.setDate(ref.getDate()+1);
        const target=new Date(Date.UTC(ref.getFullYear(),ref.getMonth(),ref.getDate()));
        const dayNum=target.getUTCDay()||7;
        target.setUTCDate(target.getUTCDate()+4-dayNum);
        const isoYear=target.getUTCFullYear();
        const yearStart=new Date(Date.UTC(isoYear,0,1));
        const isoWeek=Math.ceil((((target-yearStart)/86400000)+1)/7);
        return {isoYear,isoWeek,weekLabel:`${isoYear} - ${isoWeek}W`};
      }
      function weekStartFromIsoWeek(isoYear,isoWeek){
        const jan4=new Date(Date.UTC(isoYear,0,4));
        const jan4Day=jan4.getUTCDay()||7;
        const monday=new Date(jan4);
        monday.setUTCDate(jan4.getUTCDate()-jan4Day+1+(isoWeek-1)*7);
        const sunday=new Date(monday);
        sunday.setUTCDate(monday.getUTCDate()-1);
        return toIso(new Date(sunday.getUTCFullYear(),sunday.getUTCMonth(),sunday.getUTCDate()));
      }
      function parseWeekLabelInput(v){
        const raw=clean(v).toUpperCase();
        const m=raw.match(/^(20\d{2})\s*[-./년\s]*\s*(\d{1,2})\s*W?$/) || raw.match(/^(20\d{2})\s*-\s*(\d{1,2})W$/);
        if(!m)return "";
        const year=Number(m[1]);
        const week=Number(m[2]);
        if(!year||!week||week<1||week>53)return "";
        return weekStartFromIsoWeek(year,week);
      }
      function dateLabel(iso){const d=parseIso(iso);return d?`${d.getMonth()+1}/${d.getDate()} ${DAYS[d.getDay()]}`:iso}
      function mdLabel(iso){const d=parseIso(iso);return d?`${d.getMonth()+1}/${d.getDate()}`:iso}
      function weekRangeLabel(){return state.weekDates.length?`${mdLabel(state.weekDates[0])} ~ ${mdLabel(state.weekDates[6])}`:"-"}
      function fullWeekOptionLabel(startIso){
        const dates=weekDatesFromStart(startIso);
        const info=isoWeekInfoFromMondayRef(startIso);
        return `${info.weekLabel} (${mdLabel(dates[0])} ~ ${mdLabel(dates[6])})`;
      }

      function dateDot(v){
        const iso=normalizeDateInput(v);
        if(!iso)return "-";
        const d=parseIso(iso);
        if(!d)return "-";
        return `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,"0")}.${String(d.getDate()).padStart(2,"0")}`;
      }

      function pddDateForScheduleDate(date){
        return normalizeWave(state.wave)==="WAVE1" ? addDays(date,1) : date;
      }

      function pddTitleDate(iso){
        const d=parseIso(iso);
        if(!d)return iso;
        return `${String(d.getMonth()+1).padStart(2,"0")}.${String(d.getDate()).padStart(2,"0")}`;
      }

      function koreaNowParts(){
        const parts = new Intl.DateTimeFormat("en-CA", {
          timeZone: "Asia/Seoul",
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
          hourCycle: "h23"
        }).formatToParts(new Date());

        const map = {};
        for(const p of parts){
          if(p.type !== "literal") map[p.type] = p.value;
        }

        return {
          date: `${map.year}-${map.month}-${map.day}`,
          hour: Number(map.hour || 0),
          minute: Number(map.minute || 0),
          second: Number(map.second || 0)
        };
      }

      function excelExportStartScheduleDate(){
        const now = koreaNowParts();
        return addDays(now.date, now.hour >= 15 ? 2 : 1);
      }

      function isExcelExportAllowedScheduleDate(scheduleDate){
        const date = normalizeDateInput(scheduleDate);
        if(!date) return false;
        return date >= excelExportStartScheduleDate();
      }

      function excelExportRuleText(){
        const now = koreaNowParts();
        const startDate = excelExportStartScheduleDate();
        const rule = now.hour >= 15 ? "15시 이후 기준" : "15시 전 기준";
        return `${rule}: ${dateLabel(startDate)} 스케줄부터 엑셀 생성`;
      }

      function normalizeDateInput(v){
        const raw=clean(v);
        if(!raw) return "";
        let m=raw.match(/^(20\d{2})[-./년\s]+(\d{1,2})[-./월\s]+(\d{1,2})/);
        if(m) return toIso(new Date(Number(m[1]),Number(m[2])-1,Number(m[3])));
        m=raw.match(/^(\d{1,2})[-./\s]+(\d{1,2})$/);
        if(m) return toIso(new Date(state.isoYear || new Date().getFullYear(),Number(m[1])-1,Number(m[2])));
        const d=new Date(raw);
        return Number.isNaN(d.getTime()) ? "" : toIso(d);
      }

      function normalizeRoutePart(v){return clean(v).replace(/[^0-9A-Za-z가-힣]/g,"").toUpperCase()}
      function normalizeRouteLabel(v){return normalizeRoutePart(v)}
      function routeBaseLabel(route,sub){return normalizeRoutePart(route)+normalizeRoutePart(sub)}
      function routeChildLabel(route,sub,subSub){return routeBaseLabel(route,sub)+normalizeRoutePart(subSub)}
      function isOffRoute(v){return normalizeRouteLabel(v)===normalizeRouteLabel(OFF_ROUTE_LABEL)}
      function sortText(a,b){return String(a||"").localeCompare(String(b||""),"ko",{numeric:true,sensitivity:"base"})}

      function setState(kind,text){els.statePill.className="pill "+(kind||"ok");els.statePill.textContent=text||"READY"}
      function setStatus(text){els.statusText.textContent=text||""}
      function updateWeekState(){
        state.weekStart=sundayOf(state.baseDate);
        state.weekDates=weekDatesFromStart(state.weekStart);
        state.weekEnd=state.weekDates[6];
        const w=isoWeekInfoFromMondayRef(state.weekStart);
        state.isoYear=w.isoYear;state.isoWeek=w.isoWeek;state.weekLabel=w.weekLabel;
        els.weekButtonText.textContent=fullWeekOptionLabel(state.weekStart);
        els.weekPill.textContent=`${weekRangeLabel()} / ${state.weekLabel}`;
      }

      function applyWeekStart(weekStart,shouldLoad){
        const ws=sundayOf(weekStart);
        state.baseDate=ws;
        state.weekStart=ws;
        state.weekDates=weekDatesFromStart(ws);
        state.weekEnd=state.weekDates[6];
        const w=isoWeekInfoFromMondayRef(ws);
        state.isoYear=w.isoYear;
        state.isoWeek=w.isoWeek;
        state.weekLabel=w.weekLabel;
        state.dirty.clear();
        closeWeekPicker();
        hideSuggest();
        els.weekButtonText.textContent=fullWeekOptionLabel(ws);
        els.weekPill.textContent=`${weekRangeLabel()} / ${state.weekLabel}`;
        renderHeader();
        updatePills();
        renderWeekOptions();
        if(shouldLoad && state.camp)loadAll();
      }

      function renderWeekOptions(){
        const center=state.weekStart || sundayOf(todayIso());
        const options=[];
        for(let i=-5;i<=5;i++){
          const ws=addDays(center,i*7);
          const info=isoWeekInfoFromMondayRef(ws);
          const dates=weekDatesFromStart(ws);
          options.push({start:ws,info,dates});
        }

        els.weekMonthTitle.textContent="주차 선택";
        els.weekManualInput.value="";
        els.weekOptionList.innerHTML=options.map(opt=>`
          <button type="button" class="weekOption ${opt.start===state.weekStart?"selected":""}" data-week-start="${esc(opt.start)}">
            <span>${esc(opt.info.weekLabel)}</span>
            <small>${esc(mdLabel(opt.dates[0])+" ~ "+mdLabel(opt.dates[6]))}</small>
          </button>
        `).join("");

        els.weekOptionList.querySelectorAll(".weekOption").forEach(btn=>{
          btn.addEventListener("click",()=>{
            applyWeekStart(btn.dataset.weekStart,true);
          });
        });
      }

      function assignColorKey(key){
        const k=clean(key)||"-";
        if(state.personColorMap.has(k)) return state.personColorMap.get(k);
        const color=LIGHT_PALETTE[state.personColorMap.size % LIGHT_PALETTE.length];
        state.personColorMap.set(k,color);
        return color;
      }
      function colorForValue(value){
        const account=resolveAccount(value);
        const key=account?.colorKey || account?.ownerName || clean(value) || "-";
        return assignColorKey(key);
      }
      function textColorForBg(){return "#0f172a"}

      function splitPersonNames(value){
        return clean(value).split(/[,\n/、，]+/).map(v=>clean(v)).filter(Boolean);
      }

      function personKeyCandidates(value){
        const raw=clean(value);
        if(!raw) return [];
        const acc=resolveAccount(raw);
        return [raw,acc?.displayName,acc?.ownerName,acc?.exportName,acc?.exportId].map(keyOf).filter(Boolean);
      }

      function assignedPersonKeySetForDate(date){
        const set=new Set();
        const labels=allRouteLabels({includeOff:false});
        for(const routeLabel of labels){
          if(isRouteLockedForDate(date,routeLabel)) continue;
          const value=valueForCell(date,routeLabel);
          if(!value) continue;
          personKeyCandidates(value).forEach(k=>set.add(k));
        }
        return set;
      }

      function offConflictNames(date,value){
        const names=splitPersonNames(value);
        if(!names.length) return [];
        const assigned=assignedPersonKeySetForDate(date);
        const conflicts=[];
        for(const name of names){
          const keys=personKeyCandidates(name);
          if(keys.some(k=>assigned.has(k))) conflicts.push(name);
        }
        return conflicts;
      }

      async function ensureAuth(){
        if(!supabase){
          document.documentElement.style.visibility="visible";
          alert("Supabase 설정을 찾을 수 없습니다.");
          return false;
        }
        const {data}=await supabase.auth.getSession();
        state.session=data?.session||null;
        if(!state.session){location.href=LOGIN_PATH;return false}
        state.email=state.session.user?.email||"";
        state.userId=state.session.user?.id||"";
        state.accessToken=state.session.access_token||"";
        els.userBadge.textContent=state.email||"로그인";
        return true;
      }

      async function apiFetch(path,options){
        const {data}=await supabase.auth.getSession();
        const token=data?.session?.access_token;
        if(!token){location.href=LOGIN_PATH;throw new Error("로그인 세션이 없습니다.")}
        const res=await fetch(SCHEDULE_API_BASE+path,{
          ...(options||{}),
          headers:{"Content-Type":"application/json","Authorization":`Bearer ${token}`,...(options?.headers||{})}
        });
        const text=await res.text();
        let json=null;
        try{json=text?JSON.parse(text):null}catch{json={ok:false,error:text}}
        if(!res.ok||json?.ok===false){
          const err=new Error(json?.error||json?.message||`API 오류 ${res.status}`);
          err.status=res.status;err.detail=json?.detail||json;throw err;
        }
        return json;
      }

      async function checkAccess(){
        try{const me=await apiFetch("/me");if(me?.ok)return true}
        catch(e){
          console.error(e);
          document.documentElement.style.visibility="visible";
          alert("스케줄 접근 권한이 없거나 API 연결에 실패했습니다.\n"+(e?.message||e));
          location.href="/";
          return false;
        }
        return false;
      }

      function campMatches(infoCamp,selectedCamp){
        const a=campKey(infoCamp);
        const b=campKey(selectedCamp);
        if(!a||!b)return false;
        return a===b;
      }

      function waveMatches(infoWave,selectedWave){
        const raw=compact(infoWave).toUpperCase();
        if(!raw || raw==="-" || raw==="전체" || raw==="ALL")return true;
        const selected=normalizeWave(selectedWave);
        const aliases=WAVE_ALIASES[selected]||[selected];
        return aliases.some(x=>raw===compact(x).toUpperCase()||raw.includes(compact(x).toUpperCase()));
      }

      function explicitWaveMatches(infoWave,selectedWave){
        const raw=compact(infoWave).toUpperCase();
        if(!raw || raw==="-" || raw==="전체" || raw==="ALL")return false;
        const selected=normalizeWave(selectedWave);
        const aliases=WAVE_ALIASES[selected]||[selected];
        return aliases.some(x=>raw===compact(x).toUpperCase()||raw.includes(compact(x).toUpperCase()));
      }

      function isRetiredPosition(position){
        const p=compact(position).toUpperCase();
        return p.includes("퇴사") || p.includes("퇴직") || p.includes("퇴사자") || p.includes("RETIRED") || p.includes("RESIGNED") || p.includes("INACTIVE");
      }

      function isSubAccountRole(position){
        const p=compact(position).toUpperCase();
        return p.includes("서브") || p.includes("SUB");
      }

      function isExcludedDriverPosition(position){
        return isRetiredPosition(position) || isSubAccountRole(position);
      }

      function hasSelectedWaveContract(){
        if(!state.camp)return false;

        return state.driversRaw.some(row=>{
          const r=normalizeDriverRow(row);
          const camp=clean(r.camp_code || r.camp);
          const wave=clean(r.wave_raw || r.wave);
          const position=clean(r.position_title);

          if(isExcludedDriverPosition(position))return false;
          if(!campMatches(camp,state.camp))return false;

          return explicitWaveMatches(wave,state.wave);
        });
      }

      function looksLikeId(v){
        const s=clean(v);
        if(!s)return false;
        if(/[가-힣]/.test(s))return false;
        return /[A-Za-z0-9]/.test(s);
      }

      function parseAccountToken(text,defaultName){
        const raw=clean(text);
        const fallback=clean(defaultName);
        if(!raw)return {id:"",adminName:fallback};
        const parts=raw.split(/[／/]/).map(x=>clean(x)).filter(Boolean);
        if(parts.length>=2){
          const first=parts[0];
          const rest=parts.slice(1).join(" / ");
          const last=parts[parts.length-1];
          if(looksLikeId(first) && !looksLikeId(rest)) return {id:first,adminName:rest||fallback};
          if(!looksLikeId(first) && looksLikeId(last)) return {id:last,adminName:first||fallback};
          if(looksLikeId(first)) return {id:first,adminName:rest||fallback};
          if(looksLikeId(last)) return {id:last,adminName:first||fallback};
          return {id:first,adminName:rest||fallback};
        }
        return {id:raw,adminName:fallback};
      }

      function parseSubAccounts(v){
        const raw=clean(v);
        if(!raw)return [];
        return raw.split(/[\n;]+/).map(s=>clean(s)).filter(Boolean).flatMap(line=>{
          if(line.includes(",")){
            const parts=line.split(",").map(x=>clean(x)).filter(Boolean);
            if(parts.length>=2&&parts.every(x=>!/[/:：]/.test(x))) return parts.map(x=>({id:x,adminName:""}));
          }
          return [line];
        }).map(item=>{
          if(typeof item==="object")return item;
          const parsed=parseAccountToken(item,"");
          return {id:parsed.id,adminName:parsed.adminName};
        }).filter(x=>x.id||x.adminName);
      }

      function normalizeDriverRow(row){
        return {
          ...row,
          person_name:clean(row.person_name||row.name),
          name:clean(row.name||row.person_name),
          camp_code:clean(row.camp_code||row.camp),
          camp:clean(row.camp||row.camp_code),
          wave:clean(row.wave),
          wave_raw:clean(row.wave_raw||row.wave),
          coupang_id:clean(row.coupang_id),
          coupang_admin_name:clean(row.coupang_admin_name),
          sub_account_info:clean(row.sub_account_info),
          position_title:clean(row.position_title),
          is_sub_account_row:row.is_sub_account_row===true,
          is_global_sub_account:row.is_global_sub_account===true
        };
      }

      function buildDriverAccounts(){
        state.driverAccounts=[];
        state.accountByDisplay.clear();
        state.accountByExportName.clear();
        state.accountById.clear();
        state.personColorMap.clear();

        const drivers=state.driversRaw.map(r=>{
          const row=normalizeDriverRow(r);
          return {
            raw:row,
            name:clean(row.person_name||row.name),
            camp:clean(row.camp_code||row.camp),
            wave:clean(row.wave_raw||row.wave),
            coupangId:clean(row.coupang_id),
            coupangAdminName:clean(row.coupang_admin_name),
            subAccounts:Array.isArray(row.sub_accounts)
              ? row.sub_accounts.map(x=>typeof x==="object"?x:(parseSubAccounts(x)[0]||{id:clean(x),adminName:""}))
              : parseSubAccounts(row.sub_account_info),
            position:clean(row.position_title),
            explicitSub:row.is_sub_account_row===true || isSubAccountRole(row.position_title),
            globalSub:row.is_global_sub_account===true
          };
        })
        .filter(d=>d.name||d.coupangId||d.subAccounts.length)
        .sort((a,b)=>{
          const aw=waveMatches(a.wave,state.wave)?0:1,bw=waveMatches(b.wave,state.wave)?0:1;
          if(aw!==bw)return aw-bw;
          return sortText(a.name,b.name);
        });

        const seen=new Set();

        for(const d of drivers){
          const baseName=d.name || d.coupangId;
          const mainParsed=parseAccountToken(d.coupangId,baseName);
          const mainId=clean(mainParsed.id);
          const mainExportName=clean(d.coupangAdminName||mainParsed.adminName)||baseName;
          const isSubOnly=d.explicitSub || d.globalSub || isSubAccountRole(d.position);

          assignColorKey(baseName);

          if(baseName || mainId){
            addAccount({
              displayName:baseName || mainExportName || mainId,
              ownerName:baseName || mainExportName || mainId,
              exportName:mainExportName || baseName || mainId,
              exportId:mainId,
              accountType:isSubOnly ? "서브계정" : "본계정",
              colorKey:baseName || mainExportName || mainId,
              camp:d.camp || state.camp,
              wave:d.wave,
              position:d.position,
              globalSub:d.globalSub || isSubOnly,
              aliases:[mainExportName,mainId].filter(Boolean),
              search:[baseName,mainExportName,mainId,d.camp,d.wave,d.position,isSubOnly?"서브계정":"본계정"].join(" ")
            },seen);
          }

          d.subAccounts.forEach((sub,idx)=>{
            const rawSub=typeof sub==="object" ? sub : (parseSubAccounts(sub)[0] || {id:clean(sub),adminName:""});
            const parsed=parseAccountToken(
              clean(rawSub.id || rawSub.account_id || rawSub.coupang_id || rawSub.login_id || rawSub.text || rawSub.value),
              clean(rawSub.adminName || rawSub.name || rawSub.person_name || rawSub.display_name)
            );

            const subId=clean(rawSub.id || rawSub.account_id || rawSub.coupang_id || rawSub.login_id || parsed.id);
            const subName=clean(rawSub.adminName || rawSub.name || rawSub.person_name || rawSub.display_name || parsed.adminName);
            const aliasNumber=idx+2;
            const numberedAlias=baseName ? `${baseName}${aliasNumber}` : "";
            const displayName=numberedAlias || subName || subId;
            const ownerName=baseName || subName || subId;
            const exportName=subName || displayName || subId;
            const subCamp=clean(rawSub.camp || rawSub.camp_code || d.camp);
            const subWave=clean(rawSub.wave || rawSub.wave_raw || d.wave);

            if(!displayName && !subId) return;

            assignColorKey(ownerName || displayName || subId);

            addAccount({
              displayName:displayName || subId,
              ownerName:ownerName || displayName || subId,
              exportName:exportName || displayName || subId,
              exportId:subId,
              accountType:"서브계정",
              colorKey:ownerName || displayName || subId,
              camp:subCamp || "",
              wave:subWave || "",
              position:d.position,
              globalSub:true,
              aliases:[subName,subId,numberedAlias].filter(Boolean),
              search:[displayName,numberedAlias,subName,ownerName,exportName,subId,subCamp,subWave,d.position,"서브계정"].join(" ")
            },seen);
          });
        }

        state.driverAccounts.sort((a,b)=>{
          const ao=sortText(a.ownerName,b.ownerName);
          if(ao!==0)return ao;
          return sortText(a.displayName,b.displayName);
        });

        for(const acc of state.driverAccounts){
          const keys=[acc.displayName,acc.ownerName,acc.exportName,acc.exportId,...(acc.aliases||[])].map(keyOf).filter(Boolean);
          for(const k of keys){
            if(!state.accountByDisplay.has(k)) state.accountByDisplay.set(k,acc);
          }
          if(acc.exportName) state.accountByExportName.set(keyOf(acc.exportName),acc);
          if(acc.exportId) state.accountById.set(keyOf(acc.exportId),acc);
        }
      }

      function addAccount(account,seen){
        const uniqueKey=keyOf(account.exportId) || keyOf(account.displayName);
        if(!uniqueKey)return;
        const displayKey=keyOf(account.displayName);
        const idKey=keyOf(account.exportId);
        const aliasKeys=(account.aliases||[]).map(keyOf).filter(Boolean);
        const comboKey=keyOf(`${account.displayName}|${account.exportId}|${account.accountType}`);
        if(seen.has(comboKey))return;
        seen.add(comboKey);
        state.driverAccounts.push(account);
        if(displayKey&&!state.accountByDisplay.has(displayKey))state.accountByDisplay.set(displayKey,account);
        for(const aliasKey of aliasKeys){
          if(aliasKey&&!state.accountByDisplay.has(aliasKey))state.accountByDisplay.set(aliasKey,account);
        }
        if(idKey&&!state.accountById.has(idKey))state.accountById.set(idKey,account);
      }

      function accountCampAllowed(acc){
        if(!state.camp)return true;
        if(acc?.globalSub)return true;
        return !!clean(acc?.camp) && campMatches(acc.camp,state.camp);
      }

      function resolveAccount(value){
        const raw=clean(value);
        if(!raw)return null;
        const k=keyOf(raw);
        const exact=state.accountByDisplay.get(k) || state.accountByExportName.get(k) || state.accountById.get(k);
        if(exact)return exact;
        const found=state.driverAccounts.find(acc=>{
          const keys=[acc.displayName,acc.ownerName,acc.exportName,acc.exportId,...(acc.aliases||[])].map(keyOf).filter(Boolean);
          return keys.includes(k);
        });
        if(found)return found;
        return {displayName:raw,ownerName:raw,exportName:raw,exportId:"",accountType:"직접입력",colorKey:raw,search:raw};
      }

      function resolvePddAccount(value,source){
        const candidates=[value,source?.driver_display_name,source?.driver_name,source?.driver_owner_name,source?.driver_export_name,source?.driver_coupang_id].map(clean).filter(Boolean);
        for(const c of candidates){
          const k=keyOf(c);
          const found=state.accountByDisplay.get(k) || state.accountByExportName.get(k) || state.accountById.get(k);
          if(found) return found;
        }
        for(const c of candidates){
          const ck=keyOf(c);
          const found=state.driverAccounts.find(acc=>{
            const keys=[acc.displayName,acc.ownerName,acc.exportName,acc.exportId,...(acc.aliases||[])].map(keyOf).filter(Boolean);
            return keys.includes(ck);
          });
          if(found) return found;
        }
        for(const c of candidates){
          const ck=keyOf(c);
          if(!ck)continue;
          const found=state.driverAccounts.find(acc=>{
            const display=keyOf(acc.displayName);
            const owner=keyOf(acc.ownerName);
            const exportName=keyOf(acc.exportName);
            const exportId=keyOf(acc.exportId);
            const aliasKeys=(acc.aliases||[]).map(keyOf).filter(Boolean);
            return display===ck || owner===ck || exportName===ck || exportId===ck || aliasKeys.includes(ck) ||
              (display && ck.includes(display)) || (owner && ck.includes(owner)) || (exportName && ck.includes(exportName)) ||
              aliasKeys.some(alias=>alias && ck.includes(alias));
          });
          if(found) return found;
        }
        return resolveAccount(value);
      }

      function pddExportId(value,source){
        const direct=clean(source?.driver_coupang_id || source?.driver_export_id || source?.coupang_id || source?.export_id);
        if(direct) return direct;
        const acc=resolvePddAccount(value,source);
        return clean(acc?.exportId);
      }

      function metaNameCandidates(value){
        const out=[];
        const names=splitPersonNames(value);
        for(const name of names){
          const raw=clean(name);
          if(!raw) continue;
          out.push(raw);

          const m=raw.match(/^(.+?)(\d+)$/);
          if(m && clean(m[1])){
            out.push(clean(m[1]));
          }
        }
        return Array.from(new Set(out.map(clean).filter(Boolean)));
      }

      function assignedNamesFromSchedules(){
        const names=[];
        for(const row of state.schedules || []){
          [row.driver_display_name,row.driver_name,row.driver_owner_name,row.driver_export_name,row.driver_coupang_id]
            .map(clean)
            .filter(Boolean)
            .forEach(value=>{
              metaNameCandidates(value).forEach(name=>names.push(name));
            });
        }
        return Array.from(new Set(names.map(clean).filter(Boolean)));
      }

      function metaDisplayNamesOnBoard(){
        const names=[];
        const labels=allRouteLabels({includeOff:false});
        for(const date of state.weekDates || []){
          for(const routeLabel of labels){
            const normalizedRoute=normalizeRouteLabel(routeLabel);
            if(isRouteLockedForDate(date,normalizedRoute)) continue;
            const value=valueForCell(date,normalizedRoute);
            if(!value) continue;
            metaNameCandidates(value).forEach(name=>names.push(name));
          }
        }
        return Array.from(new Set(names.map(clean).filter(Boolean)));
      }

      function accountHasExportId(value){
        const account=resolvePddAccount(value,{});
        return !!clean(account?.exportId);
      }

      function splitMetaNameNumber(value){
        const raw=clean(value);
        if(!raw)return {raw:"",base:"",number:0};
        const m=raw.match(/^(.+?)(\d+)$/);
        if(m && clean(m[1])){
          return {raw,base:clean(m[1]),number:Number(m[2]||0)};
        }
        return {raw,base:raw,number:0};
      }

      function makeMetaInfoAccount({displayName,ownerName,exportName,exportId,accountType,camp,wave,position,aliases}){
        const dn=clean(displayName);
        const on=clean(ownerName)||dn;
        const en=clean(exportName)||dn;
        const id=clean(exportId);
        return {
          displayName:dn,
          ownerName:on,
          exportName:en,
          exportId:id,
          accountType:clean(accountType)||"본계정",
          colorKey:on||dn||en||id,
          camp:clean(camp),
          wave:clean(wave),
          position:clean(position),
          globalSub:true,
          aliases:Array.from(new Set((aliases||[]).map(clean).filter(Boolean))),
          search:[dn,on,en,id,camp,wave,position,accountType,...(aliases||[])].join(" ")
        };
      }

      function putMetaInfoAccount(account){
        if(!account) return;
        const keys=[
          account.displayName,
          account.ownerName,
          account.exportName,
          account.exportId,
          ...(account.aliases||[])
        ].map(keyOf).filter(Boolean);

        for(const key of keys){
          if(!state.metaInfoAccountsByName.has(key)){
            state.metaInfoAccountsByName.set(key,account);
          }
        }
      }

      function indexMaroowellInfoRows(rows){
        state.metaInfoAccountsByName.clear();

        for(const original of rows || []){
          const row=normalizeDriverRow(original || {});
          const person=clean(row.person_name || row.name);
          const mainParsed=parseAccountToken(row.coupang_id, person);
          const mainId=clean(mainParsed.id);
          const mainExportName=clean(row.coupang_admin_name || mainParsed.adminName) || person;
          const camp=clean(row.camp_code || row.camp);
          const wave=clean(row.wave_raw || row.wave);
          const position=clean(row.position_title);
          const subs=Array.isArray(original?.sub_accounts)
            ? original.sub_accounts.map(x=>typeof x==="object"?x:(parseSubAccounts(x)[0]||{id:clean(x),adminName:""}))
            : parseSubAccounts(row.sub_account_info);

          if(person || mainId){
            putMetaInfoAccount(makeMetaInfoAccount({
              displayName:person || mainExportName || mainId,
              ownerName:person || mainExportName || mainId,
              exportName:mainExportName || person || mainId,
              exportId:mainId,
              accountType:isSubAccountRole(position) ? "서브계정" : "본계정",
              camp,
              wave,
              position,
              aliases:[person,mainExportName,mainId].filter(Boolean)
            }));
          }

          subs.forEach((sub,idx)=>{
            const rawSub=typeof sub==="object" ? sub : (parseSubAccounts(sub)[0] || {id:clean(sub),adminName:""});
            const parsed=parseAccountToken(
              clean(rawSub.id || rawSub.account_id || rawSub.coupang_id || rawSub.login_id || rawSub.text || rawSub.value),
              clean(rawSub.adminName || rawSub.name || rawSub.person_name || rawSub.display_name)
            );

            const subId=clean(rawSub.id || rawSub.account_id || rawSub.coupang_id || rawSub.login_id || parsed.id);
            const subName=clean(rawSub.adminName || rawSub.name || rawSub.person_name || rawSub.display_name || parsed.adminName);
            const aliasNumber=idx+2;
            const numberedAlias=person ? `${person}${aliasNumber}` : "";
            const displayName=numberedAlias || subName || subId;

            if(!displayName && !subId) return;

            putMetaInfoAccount(makeMetaInfoAccount({
              displayName:displayName || subId,
              ownerName:person || subName || subId,
              exportName:subName || displayName || subId,
              exportId:subId,
              accountType:"서브계정",
              camp:clean(rawSub.camp || rawSub.camp_code || camp),
              wave:clean(rawSub.wave || rawSub.wave_raw || wave),
              position,
              aliases:[numberedAlias,subName,subId,person].filter(Boolean)
            }));
          });
        }
      }

      function resolveMetaInfoAccount(value){
        const raw=clean(value);
        if(!raw)return null;

        const direct=state.metaInfoAccountsByName.get(keyOf(raw));
        if(direct) return direct;

        const parsed=splitMetaNameNumber(raw);
        if(parsed.number){
          const alias=parsed.base ? `${parsed.base}${parsed.number}` : raw;
          const byAlias=state.metaInfoAccountsByName.get(keyOf(alias));
          if(byAlias) return byAlias;

          const byBase=state.metaInfoAccountsByName.get(keyOf(parsed.base));
          if(byBase && parsed.number===1) return byBase;
        }

        const key=keyOf(raw);
        for(const account of state.metaInfoAccountsByName.values()){
          const keys=[
            account.displayName,
            account.ownerName,
            account.exportName,
            account.exportId,
            ...(account.aliases||[])
          ].map(keyOf).filter(Boolean);

          if(keys.includes(key)) return account;
        }

        return null;
      }

      function infoRowKey(row){
        const r=normalizeDriverRow(row || {});
        return keyOf([
          row?.id || row?.pk_id || row?.seq || "",
          r.person_name || r.name,
          r.coupang_id,
          r.coupang_admin_name,
          r.sub_account_info,
          r.camp_code || r.camp,
          r.wave_raw || r.wave
        ].join("|"));
      }

      function appendInfoRowsToDrivers(rows){
        if(!Array.isArray(rows) || !rows.length) return 0;

        const seen=new Set((state.driversRaw || []).map(infoRowKey).filter(Boolean));
        let added=0;

        for(const row of rows){
          const normalized=normalizeDriverRow(row || {});
          const key=infoRowKey(normalized);
          if(!key || seen.has(key)) continue;

          seen.add(key);
          state.driversRaw.push(normalized);
          added++;
        }

        return added;
      }

      async function loadAllMaroowellInfoRowsForAccountLookup(){
        if(state._mwInfoAccountLookupLoaded) return 0;
        if(!supabase) return 0;

        try{
          const { data, error } = await supabase
            .from("maroowell_info")
            .select("*")
            .range(0,9999);

          if(error){
            console.warn("[MetaAdmin Excel] maroowell_info lookup failed", error);
            return 0;
          }

          state._mwInfoAccountLookupLoaded=true;
          state._mwInfoRowsForLookup=Array.isArray(data) ? data : [];
          indexMaroowellInfoRows(state._mwInfoRowsForLookup);

          return appendInfoRowsToDrivers(state._mwInfoRowsForLookup);
        }catch(e){
          console.warn("[MetaAdmin Excel] maroowell_info lookup failed", e);
          return 0;
        }
      }

      async function ensureGlobalInfoAccountsForNames(names){
        const targetNames=Array.from(new Set((names || []).flatMap(metaNameCandidates).map(clean).filter(Boolean)));
        if(!targetNames.length) return false;

        const added=await loadAllMaroowellInfoRowsForAccountLookup();
        if(added>0) buildDriverAccounts();

        const missing=targetNames.filter(name=>{
          const meta=resolveMetaInfoAccount(name);
          if(meta && clean(meta.exportId)) return false;
          return !accountHasExportId(name);
        });

        if(missing.length){
          console.warn("[MetaAdmin Excel] ID not found after name lookup", missing);
        }

        return true;
      }

      function resolveMetaAdminExportIdentity(displayName,source){
        const raw=clean(displayName);
        const directSourceRaw=clean(
          source?.driver_coupang_id ||
          source?.driver_export_id ||
          source?.coupang_id ||
          source?.export_id ||
          ""
        );
        const directParsed=parseAccountToken(directSourceRaw, clean(source?.driver_export_name || raw));
        const directSourceId=clean(directParsed.id);
        const directSourceName=clean(source?.driver_export_name || directParsed.adminName || raw);

        const candidates=[
          raw,
          source?.driver_display_name,
          source?.driver_name,
          source?.driver_owner_name,
          source?.driver_export_name,
          directSourceRaw,
          directParsed.adminName,
          directParsed.id
        ].map(clean).filter(Boolean);

        for(const candidate of candidates){
          const meta=resolveMetaInfoAccount(candidate);
          if(meta && clean(meta.exportId)){
            const parsedMetaId=parseAccountToken(meta.exportId, clean(meta.exportName || meta.displayName || raw));
            return {
              name:clean(meta.exportName || parsedMetaId.adminName || meta.displayName || raw),
              id:clean(parsedMetaId.id),
              account:meta
            };
          }
        }

        const account=resolvePddAccount(raw,source);
        const parsedAccountId=parseAccountToken(account?.exportId, clean(account?.exportName || raw));
        const accountId=clean(parsedAccountId.id);
        if(accountId){
          return {
            name:clean(source?.driver_export_name || account?.exportName || parsedAccountId.adminName || raw),
            id:accountId,
            account
          };
        }

        if(directSourceId){
          return {
            name:directSourceName,
            id:directSourceId,
            account:null
          };
        }

        return {
          name:clean(source?.driver_export_name || account?.exportName || raw),
          id:"",
          account:account || null
        };
      }


      function buildRoutes(){
        const contracted=hasSelectedWaveContract();

        const rows=contracted
          ? state.routesRaw
              .filter(r=>r.is_active!==false)
              .filter(r=>campMatches(r.camp,state.camp))
              .sort((a,b)=>{
                const aParent=normalizeRouteLabel(clean(a.parent_route_label)||routeBaseLabel(a.route,a.sub)||clean(a.route_label));
                const bParent=normalizeRouteLabel(clean(b.parent_route_label)||routeBaseLabel(b.route,b.sub)||clean(b.route_label));
                const pc=sortText(aParent,bParent);
                if(pc!==0)return pc;

                const aChild=normalizeRouteLabel(clean(a.route_label)||routeChildLabel(a.route,a.sub,a.sub_sub)||aParent);
                const bChild=normalizeRouteLabel(clean(b.route_label)||routeChildLabel(b.route,b.sub,b.sub_sub)||bParent);
                const cc=sortText(aChild,bChild);
                if(cc!==0)return cc;

                return Number(a.sort_order||0)-Number(b.sort_order||0);
              })
          : [];

        const parentMap=new Map();
        state.routeLookup.clear();

        for(const r of rows){
          const subSub=clean(r.sub_sub);
          const parentLabel=normalizeRouteLabel(clean(r.parent_route_label)||routeBaseLabel(r.route,r.sub)||clean(r.route_label));
          const routeLabelFromRow=normalizeRouteLabel(clean(r.route_label));
          const childByFields=routeChildLabel(r.route,r.sub,r.sub_sub);

          const childLabel=subSub
            ? normalizeRouteLabel(routeLabelFromRow && routeLabelFromRow!==parentLabel ? routeLabelFromRow : childByFields)
            : parentLabel;

          if(!parentLabel&&!childLabel)continue;
          const key=parentLabel||childLabel;

          if(!parentMap.has(key)){
            parentMap.set(key,{
              key,route:String(r.route||""),sub:String(r.sub||""),label:key,
              description:clean(r.description),memo:clean(r.memo),subPackage:clean(r.sub_package),
              sortOrder:Number(r.sort_order||0),children:[]
            });
          }

          state.routeLookup.set(key,{label:key,parentKey:key,isChild:false});
          const parent=parentMap.get(key);

          if(subSub && childLabel && childLabel!==key){
            const child={
              key:childLabel,route:String(r.route||""),sub:String(r.sub||""),subSub:normalizeRoutePart(subSub),
              label:childLabel,description:clean(r.description),memo:clean(r.memo),subPackage:clean(r.sub_package),
              sortOrder:Number(r.sort_order||0)
            };
            parent.children.push(child);
            state.routeLookup.set(childLabel,{label:childLabel,parentKey:key,isChild:true,subSub:normalizeRoutePart(subSub)});
          }
        }

        state.routeParents=Array.from(parentMap.values()).map(p=>{
          const dedup=new Map();
          for(const c of p.children){
            if(!dedup.has(c.key))dedup.set(c.key,c);
          }
          p.children=Array.from(dedup.values()).sort((a,b)=>sortText(a.label,b.label)||sortText(a.subSub,b.subSub));
          return p;
        }).sort((a,b)=>sortText(a.label,b.label)||Number(a.sortOrder||0)-Number(b.sortOrder||0));

        state.routeParents.unshift({
          key:OFF_ROUTE_LABEL,label:OFF_ROUTE_LABEL,route:"",sub:"",description:"휴무자",memo:"",subPackage:"",
          sortOrder:-999999,children:[],isOff:true
        });

        state.routeLookup.set(normalizeRouteLabel(OFF_ROUTE_LABEL),{
          label:OFF_ROUTE_LABEL,parentKey:OFF_ROUTE_LABEL,isChild:false,isOff:true
        });

        state.expanded.clear();
        for(const p of state.routeParents){
          if(!p.children || !p.children.length) continue;
          if(childScheduleExistsInCurrentWeek(p)){
            state.expanded.add(p.key);
          }
        }

        buildDisplayRows();
      }

      function childScheduleExistsInCurrentWeek(parent){
        if(!parent || !Array.isArray(parent.children) || !parent.children.length) return false;
        for(const child of parent.children){
          for(const date of state.weekDates){
            if(compact(valueForCell(date,child.label))) return true;
          }
        }
        return false;
      }

      function parentHasAnyChildValueForDate(parent,date){
        if(!parent || !Array.isArray(parent.children) || !parent.children.length)return false;
        return parent.children.some(child=>!!compact(valueForCell(date,child.label)));
      }

      function parentValueForDate(parent,date){
        if(!parent)return "";
        return clean(valueForCell(date,parent.label));
      }

      function isParentCellLocked(parent,date){
        if(!parent || parent.isOff || !Array.isArray(parent.children) || !parent.children.length)return false;
        const parentValue=parentValueForDate(parent,date);
        if(parentValue)return false;
        return parentHasAnyChildValueForDate(parent,date);
      }

      function isChildCellLocked(row,date){
        if(!row || row.type!=="child" || !row.parentKey)return false;
        const parent=state.routeParents.find(p=>p.key===row.parentKey);
        if(!parent)return false;
        return !!parentValueForDate(parent,date);
      }

      function isRouteParentLockedForDate(date,routeLabel){
        const n=normalizeRouteLabel(routeLabel);
        const p=state.routeParents.find(parent=>normalizeRouteLabel(parent.label)===n);
        if(!p)return false;
        return isParentCellLocked(p,date);
      }

      function isRouteChildLockedForDate(date,routeLabel){
        const n=normalizeRouteLabel(routeLabel);
        const info=state.routeLookup.get(n);
        if(!info?.isChild || !info.parentKey)return false;
        const parent=state.routeParents.find(p=>p.key===info.parentKey);
        if(!parent)return false;
        return !!parentValueForDate(parent,date);
      }

      function isRouteLockedForDate(date,routeLabel){
        return isRouteParentLockedForDate(date,routeLabel) || isRouteChildLockedForDate(date,routeLabel);
      }

      function syncParentClearForDate(date,parentKey){
        const parent=state.routeParents.find(p=>p.key===parentKey);
        if(!parent || !Array.isArray(parent.children) || !parent.children.length)return;

        const parentLabel=normalizeRouteLabel(parent.label);
        const dirtyKey=scheduleKey(date,parentLabel);
        const hasChildValue=parentHasAnyChildValueForDate(parent,date);
        const parentValue=parentValueForDate(parent,date);
        const currentDirty=state.dirty.get(dirtyKey);

        if(hasChildValue && !parentValue){
          const source=state.scheduleMap.get(scheduleLookupKey(date,parentLabel)) || currentDirty || {};
          const clearRecord=makeDirtyRecord({date,routeLabel:parentLabel,value:"",rowOrder:source.row_order || 0,source});
          clearRecord._autoParentClear=true;
          state.dirty.set(dirtyKey,clearRecord);
          return;
        }

        if(currentDirty && currentDirty._autoParentClear){
          state.dirty.delete(dirtyKey);
        }
      }

      function syncChildrenClearForDate(date,parentKey){
        const parent=state.routeParents.find(p=>p.key===parentKey);
        if(!parent || !Array.isArray(parent.children) || !parent.children.length)return;

        const parentValue=parentValueForDate(parent,date);

        for(const child of parent.children){
          const childLabel=normalizeRouteLabel(child.label);
          const dirtyKey=scheduleKey(date,childLabel);
          const currentDirty=state.dirty.get(dirtyKey);

          if(parentValue){
            const childValue=valueForCell(date,childLabel);
            if(childValue || currentDirty){
              const source=state.scheduleMap.get(scheduleLookupKey(date,childLabel)) || currentDirty || {};
              const clearRecord=makeDirtyRecord({date,routeLabel:childLabel,value:"",rowOrder:source.row_order || 0,source});
              clearRecord._autoChildClear=true;
              state.dirty.set(dirtyKey,clearRecord);
            }
          }else if(currentDirty && currentDirty._autoChildClear){
            state.dirty.delete(dirtyKey);
          }
        }
      }

      function buildDisplayRows(){
        const q=compact(els.searchInput.value).toUpperCase();
        const out=[];

        for(const p of state.routeParents){
          const parentMatch=!q||compact(p.label+p.description+p.memo+p.subPackage).toUpperCase().includes(q);
          const childMatches=(p.children||[]).filter(c=>!q||compact(c.label+c.description+c.memo+c.subPackage).toUpperCase().includes(q));

          if(parentMatch||childMatches.length){
            out.push({type:"parent",...p});
            if(state.expanded.has(p.key)){
              for(const c of (q?childMatches:p.children||[])) out.push({type:"child",parentKey:p.key,...c});
            }
          }
        }

        state.displayRows=out;
      }

      function allRouteLabels(options){
        const includeOff=options?.includeOff!==false;
        const labels=[];
        for(const p of state.routeParents){
          if(includeOff || !p.isOff) labels.push(p.label);
          for(const c of p.children||[]) labels.push(c.label);
        }
        return Array.from(new Set(labels.map(normalizeRouteLabel).filter(Boolean)));
      }

      function adminRouteLabel(routeLabel){
        const n=normalizeRouteLabel(routeLabel);
        if(isOffRoute(n))return "";
        const info=state.routeLookup.get(n);
        if(info?.isChild && info.parentKey) return normalizeRouteLabel(info.parentKey);
        return n;
      }

      function scheduleKey(date,routeLabel){return `${date}||${state.camp}||${state.wave}||${normalizeRouteLabel(routeLabel)}`}
      function scheduleLookupKey(date,routeLabel){return `${date}||${state.wave}||${normalizeRouteLabel(routeLabel)}`}

      function makeScheduleMap(){
        state.scheduleMap.clear();
        for(const r of state.schedules){
          const normalizedWave=normalizeWave(r.wave);
          const route=normalizeRouteLabel(r.route_label);
          state.scheduleMap.set(`${r.schedule_date}||${normalizedWave}||${route}`,r);
          const colorKey=r.driver_owner_name || resolveAccount(r.driver_display_name||r.driver_name)?.colorKey || r.driver_name;
          if(colorKey) assignColorKey(colorKey);
        }
      }

