          ctx.lineTo(chartX+chartW,y);
          ctx.stroke();
        }

        const gap=14;
        const barW=Math.max(30,(chartW-(rows.length+1)*gap)/Math.max(rows.length,1));

        rows.forEach((r,i)=>{
          const x=chartX+gap+i*(barW+gap);
          const value=Number(r.value)||0;
          const h=chartH*(value/max);
          const y=chartY+chartH-h;
          const barColor=data.metric==="avg_day" ? "#16a34a" : "#2563eb";

          ctx.fillStyle=barColor;
          ctx.fillRect(x,y,barW,h);

          const valueText=formatGraphValue(value,data.metric);
          const isMaxValue=hasExtremeColors&&value===Number(extremeStats.max.value);
          const isMinValue=hasExtremeColors&&value===Number(extremeStats.min.value);
          const valueColor=isMaxValue?"#dc2626":isMinValue?"#2563eb":h>=34?"#ffffff":"#0f172a";
          const valueX=x+barW/2;
          const valueY=h>=34?y+h/2:Math.max(chartY+12,y-12);

          ctx.font=`700 18px ${graphFont}`;
          ctx.textAlign="center";
          ctx.textBaseline="middle";

          if(isMaxValue||isMinValue){
            ctx.save();
            ctx.lineWidth=5;
            ctx.strokeStyle="#ffffff";
            ctx.lineJoin="round";
            ctx.strokeText(valueText,valueX,valueY);
            ctx.restore();
          }

          ctx.fillStyle=valueColor;
          ctx.fillText(valueText,valueX,valueY);

          const labelFontSize=data.kind==="daily"?9:16;
          const labelMaxWidth=data.kind==="daily"?barW+16:barW+26;

          ctx.fillStyle=isSundayText(r.label) ? "#dc2626" : "#111827";
          ctx.font=`600 ${labelFontSize}px ${graphFont}`;
          ctx.textBaseline="top";

          const label=fitCanvasText(ctx,r.label,labelMaxWidth);
          ctx.fillText(label,x+barW/2,chartY+chartH+16);
        });

        ctx.textAlign="left";
        ctx.textBaseline="alphabetic";
      }

      async function openGraph(kind){await ensureMaroowellFontLoaded();drawGraph(kind);els.graphModal.classList.add("show")}function closeGraph(){els.graphModal.classList.remove("show")}async function copyGraph(){const canvas=els.graphCanvas;if(!canvas.width){alert("복사할 그래프가 없습니다.");return}canvas.toBlob(async blob=>{if(!blob){alert("그래프 이미지 생성 실패");return}if(navigator.clipboard&&window.ClipboardItem){await navigator.clipboard.write([new ClipboardItem({"image/png":blob})]);alert("그래프 이미지를 클립보드에 복사했습니다.");return}const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="account_graph.png";a.click();URL.revokeObjectURL(a.href)},"image/png")}
      function bind(){els.btnLogout.addEventListener("click",logout);els.deniedLogoutBtn.addEventListener("click",logout);els.deniedHomeBtn.addEventListener("click",()=>{location.href=HOME_PATH});els.btnLoad.addEventListener("click",loadRows);els.btnReset.addEventListener("click",resetTables);els.btnCloseGraph.addEventListener("click",closeGraph);els.graphModal.addEventListener("click",e=>{if(e.target===els.graphModal)closeGraph()});els.btnCopyGraph.addEventListener("click",copyGraph);document.querySelectorAll("[data-copy-table]").forEach(btn=>btn.addEventListener("click",()=>copyTable(btn.dataset.copyTable)));document.querySelectorAll("[data-graph]").forEach(btn=>btn.addEventListener("click",()=>openGraph(btn.dataset.graph)));const upperRouteInput=el=>{const s=el.selectionStart,e=el.selectionEnd,v=el.value.toUpperCase();if(el.value!==v){el.value=v;try{el.setSelectionRange(s,e)}catch{}}};[els.currentRouteInput,els.pastRoutesInput].forEach(el=>el.addEventListener("input",()=>upperRouteInput(el)));[els.waveSelect,els.currentRouteInput,els.pastRoutesInput,els.searchInput].forEach(el=>{el.addEventListener("input",()=>{if(state.rawRows.length)buildStats()});el.addEventListener("change",()=>{if(state.rawRows.length)buildStats()})});els.currentCampInput.addEventListener("change",()=>{if(clean(els.currentCampInput.value)){loadRows()}else{resetTables()}});[els.yearSelect,els.startMonthSelect,els.endMonthSelect].forEach(el=>el.addEventListener("change",resetTables));els.searchInput.addEventListener("keydown",e=>{if(e.key==="Enter"&&state.rawRows.length)buildStats()})}
      async function boot(){initPeriodSelects();bind();renderAll();try{await checkAccess()}catch(e){console.error(e);showAccessDenied(e.message||String(e))}}boot();
    })();
