  async function checkMaroowellAccess() {
    if (!supabaseClient) initSupabase();

    const { data: sessionData, error: sessionError } = await supabaseClient.auth.getSession();
    if (sessionError) throw sessionError;

    const session = sessionData?.session;
    currentUser = session?.user;
    currentAccessToken = session?.access_token || "";

    if (!currentUser || !currentAccessToken) {
      const loginPath = cfg.PATHS?.login || "/login.html";
      location.href = loginPath + "?next=" + encodeURIComponent(location.pathname);
      return false;
    }

    $("userPill").textContent = currentUser.email || currentUser.id;

    const { data: access, error: accessError } = await supabaseClient
      .rpc("mw_my_access")
      .maybeSingle();

    if (accessError) {
      showAccessDenied(accessError.message);
      return false;
    }

    currentAccess = {
      is_maroowell: access?.is_maroowell === true,
      is_admin: access?.is_admin === true,
      max_role_level: Number(access?.max_role_level || 0),
      is_dragon_car_admin: access?.is_dragon_car_admin === true
    };

    if (currentAccess.is_maroowell !== true) {
      showAccessDenied("마루웰 소속 권한이 필요합니다.\n조건: user_access.is_maroowell = true");
      return false;
    }

    document.documentElement.style.visibility = "visible";
    return true;
  }

  async function ratioApi(path, body = {}) {
    if (!currentAccessToken) await checkMaroowellAccess();

    const res = await fetch(API_BASE + path, {
      method:"POST",
      headers:{
        "Content-Type":"application/json",
        "Authorization":"Bearer " + currentAccessToken
      },
      body:JSON.stringify(body),
      cache:"no-store"
    });

    const text = await res.text();
    let data = null;

    if (text) {
      try { data = JSON.parse(text); }
      catch { data = text; }
    }

    if (!res.ok || data?.ok === false) {
      const msg =
        (data && typeof data === "object" && (data.error || data.message || data.detail)) ||
        (typeof data === "string" ? data : "") ||
        `HTTP ${res.status}`;

      throw new Error(String(msg));
    }

    return data;
  }

  function currentQueryPayload() {
    const p = getSelectedPeriod();
    const selectedCamp = clean($("campFilter").value);
    const camp = campDbValue(selectedCamp);
    const wave = waveForCamp(selectedCamp) || clean($("waveFilter").value);
    const routes = routeListFromInput();

    return {
      ...p,
      camp,
      displayCamp:selectedCamp,
      wave,
      routes
    };
  }

  async function fetchRatioRows() {
    const result = await ratioApi("/ratio/query", currentQueryPayload());

    const total =
      result?.totalRows ||
      result?.total_rows ||
      result?.monthTotalRows ||
      result?.month_total_rows ||
      result?.total ||
      [];

    const daily =
      result?.dailyRows ||
      result?.daily_rows ||
      result?.daily ||
      [];

    return {
      totalRows:Array.isArray(total) ? total : [],
      dailyRows:Array.isArray(daily) ? daily : []
    };
  }

  function applyCommonData(rows) {
    return rows.map(row => ({
      ...row,
      wave: clean(row.wave).toUpperCase(),
      camp: clean(row.camp),
      route: normalizeRoute(row.route_norm || row.route),
      route_norm: normalizeRoute(row.route_norm || row.route)
    }));
  }

  function rowKey(row) {
    return `${row.wave}||${row.camp}||${normalizeRoute(row.route_norm || row.route)}`;
  }

  function buildRouteRows() {
    const map = new Map();

    const add = (row) => {
      const key = rowKey(row);

      if (!map.has(key)) {
        map.set(key, {
          key,
          wave: row.wave,
          camp: row.camp,
          route_norm: normalizeRoute(row.route_norm || row.route),
          route: normalizeRoute(row.route_norm || row.route)
        });
      }
    };

    totalRows.forEach(add);
    dailyRows.forEach(add);

    return Array.from(map.values()).sort((a, b) => {
      const waveOrder = { W2: 1, W1: 2 };

      return (
        String(a.camp).localeCompare(String(b.camp), "ko", { numeric:true }) ||
        ((waveOrder[a.wave] || 9) - (waveOrder[b.wave] || 9)) ||
        String(a.route_norm).localeCompare(String(b.route_norm), "ko", { numeric:true })
      );
    });
  }

