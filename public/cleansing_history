  function tableCellCanvasParts(cell) {
    const mainText = (() => {
      if (cell?.classList?.contains("zipCell")) {
        const zipTexts = Array.from(cell.querySelectorAll(".zipLink"))
          .map(el => (el.textContent || "").trim())
          .filter(Boolean);

