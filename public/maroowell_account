    .grid2{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:14px}.tableWrap{overflow:auto;max-height:560px;background:rgba(0,0,0,.14)}table{width:100%;min-width:980px;border-collapse:separate;border-spacing:0;font-size:12px}th,td{border-right:1px solid rgba(255,255,255,.11);border-bottom:1px solid rgba(255,255,255,.11);padding:8px 8px;text-align:center;vertical-align:middle;white-space:nowrap}th{position:sticky;top:0;z-index:2;background:#27364d;color:#fff;font-size:12px;font-weight:1000}td{background:rgba(255,255,255,.025);font-weight:800}tr:hover td{background:rgba(96,165,250,.08)}.left{text-align:left!important}.right{text-align:right!important;font-variant-numeric:tabular-nums}.center{text-align:center!important}.emptyBox{padding:44px 12px;text-align:center;color:#cbd5e1;font-size:14px;font-weight:900}
