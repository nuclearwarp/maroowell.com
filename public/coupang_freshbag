<script>
(() => {
  "use strict";

  const $ = (id) => document.getElementById(id);
  const cfg = window.MARUWELL_CONFIG || {};
  const FRESHBAG_API_BASE = String(
    cfg.BACKENDS?.freshbag ||
    cfg.FRESHBAG_API ||
    "https://freshbag.brain-0f6.workers.dev"
  ).replace(/\/+$/, "");

  let supabaseClient = null;
  let currentUser = null;
  let currentAccessToken = "";
  let currentAccess = null;
  let rawRows = [];
  let tableRows = [];
  let localSeq = 1;
  let hiddenMonths = new Set();

  const PRESET_STORAGE_KEY = "mw:coupang_freshbag:query_presets:v3";
  const LAST_QUERY_STORAGE_KEY = "mw:coupang_freshbag:last_query:v3";
  const HIDDEN_MONTHS_STORAGE_KEY = "mw:coupang_freshbag:hidden_months:v1";

  const DEFAULT_PRESETS = [
    {
      id: "default_mw_ilsan2_day",
      defaultPreset: true,
      name: "마루웰 일산2 주간",
      updatedAt: "default",
      year: "",
      camp: "일산2",
      wave: "W2",
      gajoong1: "",
      gajoong2: "",
      rows: ["126A","126B","126C","126D","130A","130B"].map(route => ({ wave:"W2", camp:"일산2", route }))
    },
    {
      id: "default_mw_yongin3_day",
      defaultPreset: true,
      name: "마루웰 용인3 주간",
      updatedAt: "default",
      year: "",
      camp: "용인3",
      wave: "W2",
      gajoong1: "",
      gajoong2: "",
      rows: ["602A","602B","612A"].map(route => ({ wave:"W2", camp:"용인3", route }))
    },
    {
      id: "default_mw_daegu3_day",
      defaultPreset: true,
      name: "마루웰 대구3 주간",
      updatedAt: "default",
      year: "",
      camp: "대구3",
      wave: "W2",
      gajoong1: "",
      gajoong2: "",
      rows: ["213A","213B","213C","213D"].map(route => ({ wave:"W2", camp:"대구3", route }))
    },
    {
      id: "default_mw_miksan1_night",
      defaultPreset: true,
      name: "마루웰 M익산1 야간",
      updatedAt: "default",
      year: "",
      camp: "M익산1",
      wave: "W1",
      gajoong1: "",
      gajoong2: "",
      rows: [
        "405A","405B","405C","405D",
        "406A","406B","406C","406D",
        "407A","407B","407C","407D",
        "408A","408B","408C","408D"
      ].map(route => ({ wave:"W1", camp:"M익산1", route }))
    }
  ];

  function setStatus(msg, type = "") {
    $("statusText").textContent = msg;
    $("statusText").className = type ? "status " + type : "status";
  }

  function esc(v) {
    return String(v ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function clean(v) {
    return String(v ?? "").trim();
  }

  function compactText(v) {
    return clean(v).replace(/\s+/g, "");
  }

  function normalizeCampForDb(value) {
    const s = compactText(value);
    if (!s) return "";

    // M캠프는 화면/프리셋에서 M익산1처럼 입력해도
    // DB 조회는 M_익산1처럼 언더바가 들어간 camp 값으로 조회한다.
    if (/^M(?!_)/i.test(s)) {
      return "M_" + s.slice(1);
    }

    return s;
  }

  function normalizeCampForDisplay(value) {
    const s = compactText(value);
    if (/^M_/i.test(s)) {
      return "M" + s.slice(2);
    }
    return s;
  }

  function normalizeRoute(v) {
    return String(v || "")
      .toUpperCase()
      .replace(/[^0-9A-Z]/g, "");
  }

  function sanitizeRouteInputValue(v) {
    return normalizeRoute(v);
  }

  function routeGroup(v) {
    const s = normalizeRoute(v);
    const m = s.match(/^(\d+)/);
    return m ? m[1] : s;
  }

  function waveLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "W2") return "주간";
    if (s === "W1") return "야간";
    return "";
  }

  function waveValueFromLabel(v) {
    const s = clean(v).toUpperCase();
    if (s === "주간") return "W2";
    if (s === "야간") return "W1";
    if (s === "W2") return "W2";
    if (s === "W1") return "W1";
    return "";
  }

  function isNoneGajoongValue(v) {
    const s = clean(v).replace(/\s+/g, "");
    return s === "해당없음" || s === "해당X" || s === "해당Ｎ" || s === "해당N";
  }

  function isMissGajoongValue(v) {
    const s = clean(v).replace(/\s+/g, "");
    return s === "미해당";
  }

  function isNoGajoongValue(v) {
    return isNoneGajoongValue(v) || isMissGajoongValue(v);
  }

  function displayGajoongValue(v) {
    const s = clean(v);
    if (!s) return "";
    if (isNoneGajoongValue(s)) return "해당X";
    if (isMissGajoongValue(s)) return "미해당";
    return s;
  }

  function valueClass(v) {
    const s = clean(v);
    if (s === "해당") return "yes";
    if (isNoneGajoongValue(s)) return "no";
    if (isMissGajoongValue(s)) return "miss";
    if (!s) return "empty";
    return "";
  }

  function effectiveWave(row) {
    return waveValueFromLabel(row.wave) || clean($("waveFilter").value).toUpperCase();
  }

  function effectiveCamp(row) {
    return clean(row.camp) || clean($("campFilter").value);
  }

  function effectiveRoute(row) {
    return normalizeRoute(row.route);
  }

  function visibleMonths(maxMonth = 12) {
    const out = [];
    for (let m = 1; m <= maxMonth; m++) {
      if (!hiddenMonths.has(m)) out.push(m);
    }
    return out;
  }

  function loadHiddenMonths() {
    try {
      const arr = JSON.parse(localStorage.getItem(HIDDEN_MONTHS_STORAGE_KEY) || "[]");
      hiddenMonths = new Set((Array.isArray(arr) ? arr : []).map(Number).filter(m => m >= 1 && m <= 12));
    } catch {
      hiddenMonths = new Set();
    }
  }

  function saveHiddenMonths() {
    try {
      localStorage.setItem(HIDDEN_MONTHS_STORAGE_KEY, JSON.stringify(Array.from(hiddenMonths)));
    } catch {}
  }

  function hideMonth(month) {
    const m = Number(month);
    if (m < 1 || m > 12) return;
    hiddenMonths.add(m);
    saveHiddenMonths();
    renderTable();
    renderSummary();
    setStatus(`${m}월 열을 접었습니다. 이미지 복사에서도 제외됩니다.`, "ok");
  }

  function showMonth(month) {
    const m = Number(month);
    hiddenMonths.delete(m);
    saveHiddenMonths();
    renderTable();
    renderSummary();
  }

  function showAllMonths() {
    hiddenMonths.clear();
    saveHiddenMonths();
    renderTable();
    renderSummary();
    setStatus("접힌 월을 모두 다시 표시했습니다.", "ok");
  }

  function renderHiddenMonthBar() {
    const bar = $("hiddenMonthBar");
    const hidden = Array.from(hiddenMonths).sort((a,b) => a - b);

    if (!hidden.length) {
      bar.className = "hiddenMonthBar empty";
      bar.innerHTML = "";
      return;
    }

    bar.className = "hiddenMonthBar";
    bar.innerHTML = `
      <span class="hiddenMonthLabel">숨김 월</span>
      <button class="hiddenMonthChip all" type="button" data-show-all-months="1">전체 월 보기</button>
      ${hidden.map(m => `<button class="hiddenMonthChip" type="button" data-show-month="${m}">${m}월 다시 보기</button>`).join("")}
    `;
  }

  function initYearOptions() {
    const now = new Date().getFullYear();
    const years = [];

    for (let y = now + 1; y >= now - 6; y--) {
      years.push(y);
    }

    $("yearFilter").innerHTML =
      years.map(y => `<option value="${y}">${y}</option>`).join("");

    $("yearFilter").value = String(now);
  }

  function initSupabase() {
    if (!cfg.SUPABASE_URL || !cfg.SUPABASE_ANON_KEY || !window.supabase?.createClient) {
      throw new Error("config.js의 SUPABASE_URL / SUPABASE_ANON_KEY를 확인하세요.");
    }

    const storage = (() => {
      try { return window.sessionStorage; } catch { return undefined; }
    })();

    supabaseClient = window.supabase.createClient(cfg.SUPABASE_URL, cfg.SUPABASE_ANON_KEY, {
      auth: {
        persistSession: !!storage,
        storage,
        autoRefreshToken: true,
        detectSessionInUrl: true
      }
    });
  }

  async function checkSession() {
    if (!supabaseClient) initSupabase();

    const { data, error } = await supabaseClient.auth.getSession();
    if (error) throw error;

    const session = data?.session;
    currentUser = session?.user;
    currentAccessToken = session?.access_token || "";

    if (!currentUser || !currentAccessToken) throw new Error("로그인이 필요합니다.");

    $("userPill").textContent = currentUser.email || currentUser.id;
  }

  function isSuperAdminAccess(access = currentAccess) {
    return (
      access?.is_maroowell === true &&
      access?.is_admin === true &&
      Number(access?.max_role_level || 0) >= 90
    );
  }

  async function loadMyAccess() {
    currentAccess = {
      is_maroowell: false,
      is_admin: false,
      max_role_level: 0,
      is_dragon_car_admin: false
    };

    if (!supabaseClient || !currentUser) return currentAccess;

    try {
      const { data, error } = await supabaseClient.rpc("mw_my_access").maybeSingle();
      if (error) throw error;

      currentAccess = {
        is_maroowell: data?.is_maroowell === true,
        is_admin: data?.is_admin === true,
        max_role_level: Number(data?.max_role_level || 0),
        is_dragon_car_admin: data?.is_dragon_car_admin === true
      };
    } catch (e) {
      console.warn("mw_my_access failed", e);
    }

    return currentAccess;
  }

  function initFreshbagUploadSwitchIfAllowed() {
    if (!isSuperAdminAccess()) return;

    const wrap = document.querySelector(".wrap");
    const top = wrap?.querySelector(":scope > .top");
    const userPill = $("userPill");

    if (!wrap || !top || !userPill) return;
    if ($("mwFreshbagUploadSwitchBtn")) return;

    const viewPanel = document.createElement("div");
    viewPanel.id = "mwFreshbagViewPanel";

    let node = top.nextSibling;
    while (node) {
      const next = node.nextSibling;
      viewPanel.appendChild(node);
      node = next;
    }
    wrap.appendChild(viewPanel);

    const uploadPanel = document.createElement("div");
    uploadPanel.id = "mwFreshbagUploadPanel";
    uploadPanel.hidden = true;

    const uploadFrameSrcBase = "/coupang_freshbag_upload?embed=1";
    uploadPanel.innerHTML = `
      <iframe
        id="mwFreshbagUploadFrame"
        class="mw-freshbag-upload-frame"
        title="프레시백 현황 업로드"
        data-src="${uploadFrameSrcBase}"
        src="${uploadFrameSrcBase}&preload=1"
      ></iframe>
    `;
    wrap.appendChild(uploadPanel);

    const uploadFrame = $("mwFreshbagUploadFrame");
    let uploadLoadTimer = 0;

    function buildUploadFrameSrc(reason = "load") {
      const sep = uploadFrameSrcBase.includes("?") ? "&" : "?";
      return `${uploadFrameSrcBase}${sep}t=${Date.now()}&r=${encodeURIComponent(reason)}`;
    }

    function reloadUploadFrame(reason = "reload") {
      if (!uploadFrame) return;
      uploadFrame.dataset.loaded = "";
      uploadFrame.setAttribute("src", buildUploadFrameSrc(reason));
    }

    if (uploadFrame) {
      uploadFrame.addEventListener("load", () => {
        uploadFrame.dataset.loaded = "1";
        if (uploadLoadTimer) {
          clearTimeout(uploadLoadTimer);
          uploadLoadTimer = 0;
        }
      });
    }

    function removeDuplicateUploadButtons() {
      const buttons = Array.from(top.querySelectorAll("button"));

      for (const button of buttons) {
        if (button.id === "mwFreshbagUploadSwitchBtn") continue;

        const text = String(button.textContent || "").trim();
        const looksLikeOldUpload =
          text === "업로드" ||
          button.id === "mwFreshbagViewSwitcher" ||
          button.id === "mwFreshbagUploadBtn" ||
          button.classList.contains("mw-freshbag-view-switcher") ||
          button.classList.contains("mw-freshbag-upload-switch-btn");

        if (looksLikeOldUpload) {
          button.remove();
        }
      }
    }

    removeDuplicateUploadButtons();

    const actions = document.createElement("div");
    actions.className = "mw-freshbag-top-actions";

    const btn = document.createElement("button");
    btn.id = "mwFreshbagUploadSwitchBtn";
    btn.type = "button";
    btn.textContent = "Upload";

    userPill.parentNode.insertBefore(actions, userPill);
    actions.appendChild(btn);
    actions.appendChild(userPill);

    removeDuplicateUploadButtons();

    const observer = new MutationObserver(() => {
      removeDuplicateUploadButtons();
    });

    observer.observe(top, {
      childList:true,
      subtree:true
    });

    const titleEl = top.querySelector(".title");
    const subEl = top.querySelector(".sub");
    const viewTitle = titleEl?.textContent || "프레시백 현황 조회";
    const viewSub = subEl?.textContent || "";

    function setMode(mode, updateHash = true) {
      const uploadMode = mode === "upload";
      const frame = $("mwFreshbagUploadFrame");

      viewPanel.hidden = uploadMode;
      uploadPanel.hidden = !uploadMode;

      btn.textContent = uploadMode ? "View" : "Upload";
      btn.classList.toggle("is-upload", uploadMode);
      btn.setAttribute("aria-pressed", uploadMode ? "true" : "false");

      if (titleEl) {
        titleEl.textContent = uploadMode ? "프레시백 현황 업로드" : viewTitle;
      }

      if (subEl) {
        subEl.textContent = uploadMode
          ? "엑셀 업로드 화면입니다. View 버튼을 누르면 조회 화면으로 돌아갑니다."
          : viewSub;
      }

      if (uploadMode && frame) {
        if (!frame.getAttribute("src")) {
          reloadUploadFrame("empty-src");
        }

        if (frame.dataset.loaded !== "1") {
          if (uploadLoadTimer) clearTimeout(uploadLoadTimer);

          uploadLoadTimer = setTimeout(() => {
            if (frame.dataset.loaded !== "1") {
              reloadUploadFrame("retry-visible");
            }
          }, 900);
        }
      }

      if (updateHash && window.history?.replaceState) {
        const nextUrl = uploadMode
          ? `${location.pathname}${location.search}#upload`
          : `${location.pathname}${location.search}`;
        history.replaceState(null, "", nextUrl);
      }
    }

    btn.addEventListener("click", () => {
      setMode(uploadPanel.hidden ? "upload" : "view");
    });

    if (location.hash === "#upload") {
      setMode("upload", false);
    }
  }


  async function freshbagApi(path, body = {}) {
    if (!currentAccessToken) {
      await checkSession();
    }

    const res = await fetch(FRESHBAG_API_BASE + path, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + currentAccessToken
      },
      body: JSON.stringify(body),
      cache: "no-store"
    });

    const text = await res.text();
    let data = null;

    if (text) {
      try {
        data = JSON.parse(text);
      } catch {
        data = text;
      }
    }

    if (!res.ok) {
      const msg =
        (data && typeof data === "object" && (data.error || data.message || data.detail)) ||
        (typeof data === "string" ? data : "") ||
        `HTTP ${res.status}`;
      throw new Error(String(msg));
    }

    return data;
  }

  function createBlankRow() {
    return {
      localId: `row_${localSeq++}`,
      wave: "",
      camp: "",
      route: "",
      months: {}
    };
  }

  function initDefaultRows() {
    tableRows = [];

    for (let i = 0; i < 4; i++) {
      tableRows.push(createBlankRow());
    }

    renderTable();
    renderSummary();
  }

  function addRow() {
    tableRows.push(createBlankRow());
    renderTable();
    renderSummary();
    setStatus("행이 추가되었습니다. Camp/주간·야간은 상단값을 기본으로 사용하고, Route는 행에 입력하세요.", "ok");
  }

  function safeLocalStorageGet(key, fallback) {
    try {
      const raw = localStorage.getItem(key);
      if (!raw) return fallback;
      return JSON.parse(raw);
    } catch {
      return fallback;
    }
  }

  function safeLocalStorageSet(key, value) {
    try {
      localStorage.setItem(key, JSON.stringify(value));
      return true;
    } catch {
      return false;
    }
  }

  function getSavedPresets() {
    const list = safeLocalStorageGet(PRESET_STORAGE_KEY, []);
    return Array.isArray(list) ? list : [];
  }

  function getAllPresets() {
    const userPresets = getSavedPresets();
    const userIds = new Set(userPresets.map(item => item.id));
    return [
      ...DEFAULT_PRESETS.filter(item => !userIds.has(item.id)),
      ...userPresets
    ];
  }

  function setSavedPresets(list) {
    return safeLocalStorageSet(PRESET_STORAGE_KEY, Array.isArray(list) ? list : []);
  }

  function makePresetId() {
    return "preset_" + Date.now().toString(36) + "_" + Math.random().toString(36).slice(2, 8);
  }

  function getPresetRowsFromTable() {
    const rows = tableRows
      .map(row => ({
        wave: effectiveWave(row),
        camp: normalizeCampForDisplay(effectiveCamp(row)),
        route: effectiveRoute(row)
      }))
      .filter(row => row.route);

    const seen = new Set();
    const out = [];

    for (const row of rows) {
      const key = `${row.wave}||${row.camp}||${row.route}`;
      if (seen.has(key)) continue;
      seen.add(key);
      out.push(row);
    }

    return out;
  }

  function makeDefaultPresetName(preset) {
    const year = preset.year || $("yearFilter").value || "";
    const camp = preset.camp || preset.rows?.[0]?.camp || "Camp";
    const wave = preset.wave
      ? waveLabel(preset.wave)
      : preset.rows?.length
        ? "주/야"
        : "";

    const routes = (preset.rows || [])
      .map(row => row.route)
      .filter(Boolean)
      .slice(0, 8)
      .join("/");

    return [year, camp, wave, routes].filter(Boolean).join(" / ");
  }

  function buildCurrentPreset(nameOverride = "") {
    const rows = getPresetRowsFromTable();

    if (!rows.length) {
      throw new Error("저장할 Route 행이 없습니다. Route를 먼저 입력하거나 조회 후 저장하세요.");
    }

    const preset = {
      id: "",
      name: clean(nameOverride),
      updatedAt: new Date().toISOString(),
      year: $("yearFilter").value || "",
      camp: normalizeCampForDisplay($("campFilter").value),
      wave: clean($("waveFilter").value).toUpperCase(),
      rows
    };

    if (!preset.name) {
      preset.name = makeDefaultPresetName(preset);
    }

    return preset;
  }

  function renderPresetOptions(selectedId = "") {
    const select = $("savedPresetSelect");
    if (!select) return;

    const presets = getAllPresets()
      .slice()
      .sort((a, b) => {
        if (a.defaultPreset && !b.defaultPreset) return -1;
        if (!a.defaultPreset && b.defaultPreset) return 1;
        return String(b.updatedAt || "").localeCompare(String(a.updatedAt || ""));
      });

    if (!presets.length) {
      select.innerHTML = `<option value="">저장된 프리셋 없음</option>`;
      return;
    }

    select.innerHTML = [
      `<option value="">저장된 프리셋 선택</option>`,
      ...presets.map(preset => {
        const date = preset.defaultPreset ? "기본" : String(preset.updatedAt || "").slice(0, 10);
        const count = Array.isArray(preset.rows) ? preset.rows.length : 0;
        const label = `${preset.name || "이름 없음"} · ${count}행 · ${date}`;
        return `<option value="${esc(preset.id)}">${esc(label)}</option>`;
      })
    ].join("");

    if (selectedId) {
      select.value = selectedId;
    }
  }

  function saveCurrentPreset() {
    const name = clean($("presetNameInput").value);

    if (!name) {
      throw new Error("프리셋 이름을 입력하세요. 예: 일산2 주간 126/130");
    }

    const preset = buildCurrentPreset(name);
    const presets = getSavedPresets();

    const selectedId = $("savedPresetSelect").value;
    const selectedIndex = presets.findIndex(item => item.id === selectedId);
    const sameNameIndex = presets.findIndex(item => item.name === preset.name);

    if (selectedIndex >= 0) {
      const ok = confirm(`선택된 프리셋을 덮어쓸까요?\n\n${presets[selectedIndex].name}`);
      if (!ok) return;

      preset.id = selectedId;
      presets[selectedIndex] = {
        ...presets[selectedIndex],
        ...preset,
        updatedAt: new Date().toISOString()
      };
    } else if (sameNameIndex >= 0) {
      const ok = confirm(`같은 이름의 프리셋이 있습니다. 덮어쓸까요?\n\n${preset.name}`);
      if (!ok) return;

      preset.id = presets[sameNameIndex].id;
      presets[sameNameIndex] = {
        ...presets[sameNameIndex],
        ...preset,
        updatedAt: new Date().toISOString()
      };
    } else {
      preset.id = makePresetId();
      presets.unshift(preset);
    }

    setSavedPresets(presets);
    renderPresetOptions(preset.id);

    $("presetNameInput").value = preset.name;
    setStatus(`프리셋 저장 완료: ${preset.name}`, "ok");
  }

  function makeRowFromPresetItem(item) {
    const row = createBlankRow();

    row.wave = waveValueFromLabel(item.wave);
    row.camp = normalizeCampForDisplay(item.camp);
    row.route = normalizeRoute(item.route);
    row.months = {};

    return row;
  }

  function applyPresetToScreen(preset) {
    if (!preset) throw new Error("불러올 프리셋이 없습니다.");

    if (preset.year) {
      const exists = Array.from($("yearFilter").options).some(opt => opt.value === String(preset.year));

      if (!exists) {
        const option = document.createElement("option");
        option.value = String(preset.year);
        option.textContent = String(preset.year);
        $("yearFilter").appendChild(option);
      }

      $("yearFilter").value = String(preset.year);
    }

    $("campFilter").value = normalizeCampForDisplay(preset.camp || "");
    $("waveFilter").value = preset.wave || "";
    $("presetNameInput").value = preset.name || "";

    const rows = Array.isArray(preset.rows) ? preset.rows : [];

    tableRows = rows
      .map(makeRowFromPresetItem)
      .filter(row => effectiveRoute(row));

    while (tableRows.length < 4) {
      tableRows.push(createBlankRow());
    }

    rawRows = [];
    renderTable();
    renderSummary();
  }

  async function loadSelectedPresetAndQuery() {
    const selectedId = $("savedPresetSelect").value;

    if (!selectedId) {
      throw new Error("불러올 프리셋을 선택하세요.");
    }

    const preset = getAllPresets().find(item => item.id === selectedId);

    if (!preset) {
      throw new Error("저장된 프리셋을 찾을 수 없습니다.");
    }

    applyPresetToScreen(preset);
    setStatus(`프리셋 불러오기 완료: ${preset.name}. 조회 중...`, "warn");
    await loadData();
  }

  function deleteSelectedPreset() {
    const selectedId = $("savedPresetSelect").value;

    if (!selectedId) {
      setStatus("삭제할 프리셋을 선택하세요.", "bad");
      return;
    }

    const preset = getAllPresets().find(item => item.id === selectedId);

    if (!preset) {
      setStatus("삭제할 프리셋을 찾을 수 없습니다.", "bad");
      return;
    }

    if (preset.defaultPreset) {
      setStatus("기본 마루웰 프리셋은 삭제할 수 없습니다.", "warn");
      return;
    }

    const presets = getSavedPresets();
    const ok = confirm(`저장된 프리셋을 삭제할까요?\n\n${preset.name}`);

    if (!ok) return;

    setSavedPresets(presets.filter(item => item.id !== selectedId));
    renderPresetOptions();

    $("presetNameInput").value = "";
    setStatus("프리셋 삭제 완료", "ok");
  }

  function saveLastQueryPreset() {
    try {
      const preset = buildCurrentPreset("최근 조회");
      preset.id = "last_query";
      preset.updatedAt = new Date().toISOString();
      safeLocalStorageSet(LAST_QUERY_STORAGE_KEY, preset);
    } catch {}
  }

  async function loadLastQueryPresetAndQuery() {
    const preset = safeLocalStorageGet(LAST_QUERY_STORAGE_KEY, null);

    if (!preset) {
      throw new Error("최근 조회조건이 없습니다.");
    }

    applyPresetToScreen(preset);
    setStatus("최근 조회조건 불러오기 완료. 조회 중...", "warn");
    await loadData();
  }

  function getCriteriaRows() {
    return tableRows
      .map(row => {
        const displayCamp = effectiveCamp(row);
        return {
          row,
          wave: effectiveWave(row),
          camp: normalizeCampForDb(displayCamp),
          displayCamp: normalizeCampForDisplay(displayCamp),
          route: effectiveRoute(row)
        };
      })
      .filter(item => item.route);
  }

  function validateCriteria() {
    const criteria = getCriteriaRows();

    if (criteria.length) {
      const missingWave = criteria.find(item => !item.wave);
      if (missingWave) {
        throw new Error("주간/야간을 선택하세요. 상단에서 주간/야간을 선택하거나 행의 주간/야간 셀을 입력하세요.");
      }

      const missingCamp = criteria.find(item => !item.camp);
      if (missingCamp) {
        throw new Error("Camp를 입력하세요. 상단 Camp에 입력하거나 행의 Camp 셀을 입력하세요.");
      }

      criteria.allRoutes = false;
      return criteria;
    }

    const topCamp = clean($("campFilter").value);
    const topWave = clean($("waveFilter").value).toUpperCase();

    if (!topCamp) {
      throw new Error("Route 없이 Camp 전체를 조회하려면 상단 Camp를 입력하세요.");
    }

    if (!topWave) {
      throw new Error("Route 없이 Camp 전체를 조회하려면 상단 주간/야간을 선택하세요.");
    }

    const allCampCriteria = [{
      row: null,
      wave: topWave,
      camp: normalizeCampForDb(topCamp),
      displayCamp: normalizeCampForDisplay(topCamp),
      route: "",
      allRoutes: true
    }];

    allCampCriteria.allRoutes = true;
    return allCampCriteria;
  }

  function unique(arr) {
    return Array.from(new Set(arr.filter(Boolean)));
  }

  async function fetchRowsByCriteria(criteria) {
    const year = Number($("yearFilter").value);

    const payloadCriteria = criteria.map(item => ({
      wave: item.wave,
      camp: item.camp,
      displayCamp: item.displayCamp,
      route: item.route,
      allRoutes: item.allRoutes === true
    }));

    const result = await freshbagApi("/freshbag/query", {
      year,
      criteria: payloadCriteria
    });

    return Array.isArray(result?.rows) ? result.rows : [];
  }

  async function loadData() {
    setStatus("freshbag 백엔드로 조회 중... Route가 비어 있으면 Camp 전체를 조회합니다.");

    const criteria = validateCriteria();
    rawRows = await fetchRowsByCriteria(criteria);

    applyFetchedRowsToTable(criteria, rawRows);

    renderTable();
    renderSummary();

    saveLastQueryPreset();
    setStatus(`조회 완료: DB row ${rawRows.length.toLocaleString()}건 / 표시 행 ${tableRows.length.toLocaleString()}행`, "ok");
  }

  function applyFetchedRowsToTable(criteria, rows) {
    const isAllRoutes = criteria.some(item => item.allRoutes);
    const rowMap = new Map();

    if (isAllRoutes) {
      const routeMeta = new Map();

      for (const row of rows) {
        const wave = clean(row.wave).toUpperCase();
        const camp = normalizeCampForDb(row.camp);
        const route = normalizeRoute(row.route_norm || row.route);

        if (!wave || !camp || !route) continue;

        const key = `${wave}||${camp}||${route}`;

        if (!routeMeta.has(key)) {
          routeMeta.set(key, {
            wave,
            camp,
            displayCamp: normalizeCampForDisplay(row.camp),
            route
          });
        }
      }

      tableRows = Array.from(routeMeta.values())
        .sort((a, b) => {
          const waveOrder = { W2: 1, W1: 2 };

          return (
            String(a.displayCamp).localeCompare(String(b.displayCamp), "ko", { numeric:true }) ||
            ((waveOrder[a.wave] || 9) - (waveOrder[b.wave] || 9)) ||
            String(a.route).localeCompare(String(b.route), "ko", { numeric:true })
          );
        })
        .map(meta => {
          const row = createBlankRow();

          row.wave = meta.wave;
          row.camp = meta.displayCamp;
          row.route = meta.route;
          row.months = {};

          rowMap.set(`${meta.wave}||${meta.camp}||${meta.route}`, row);

          return row;
        });
    } else {
      for (const item of criteria) {
        const key = `${item.wave}||${normalizeCampForDb(item.camp)}||${item.route}`;
        rowMap.set(key, item.row);

        item.row.wave = item.wave;
        item.row.camp = item.displayCamp || normalizeCampForDisplay(item.camp);
        item.row.route = item.route;
        item.row.months = {};
      }
    }

    for (const row of rows) {
      const wave = clean(row.wave).toUpperCase();
      const camp = normalizeCampForDb(row.camp);
      const route = normalizeRoute(row.route_norm || row.route);
      const month = Number(row.month_no || 0);

      if (month < 1 || month > 12) continue;

      const key = `${wave}||${camp}||${route}`;
      const target = rowMap.get(key);
      if (!target) continue;

      target.months[month] = {
        id: row.id || null,
        gajoong1: row.gajoong1 || "",
        gajoong2: row.gajoong2 || "",
        period: row.period_label || row.data_month || "",
        source_file_name: row.source_file_name || ""
      };
    }

    const targetRows = isAllRoutes ? tableRows : criteria.map(item => item.row).filter(Boolean);

    for (const row of targetRows) {
      for (let m = 1; m <= 12; m++) {
        if (!row.months[m]) {
          row.months[m] = {
            id: null,
            gajoong1: "",
            gajoong2: "",
            period: "",
            source_file_name: ""
          };
        }
      }
    }
  }

  function renderSummary() {
    const campSet = new Set();
    const monthSet = new Set();

    for (const row of rawRows) {
      if (row.camp) campSet.add(normalizeCampForDisplay(row.camp));
      if (row.month_no && !hiddenMonths.has(Number(row.month_no))) monthSet.add(row.month_no);
    }

    $("rawCount").textContent = rawRows.length.toLocaleString();
    $("routeCount").textContent = tableRows.length.toLocaleString();
    $("campCount").textContent = campSet.size.toLocaleString();
    $("monthCount").textContent = monthSet.size.toLocaleString();

    renderHiddenMonthBar();
  }

  function rowSeparatorClass(row, index) {
    if (index <= 0) return "";

    const prev = tableRows[index - 1];
    const prevCamp = effectiveCamp(prev);
    const thisCamp = effectiveCamp(row);

    if (prevCamp && thisCamp && prevCamp !== thisCamp) return "campSep";

    const prevGroup = routeGroup(effectiveRoute(prev));
    const thisGroup = routeGroup(effectiveRoute(row));

    if (prevGroup && thisGroup && prevGroup !== thisGroup) return "routeSep";

    return "";
  }

  function renderTable() {
    const thead = $("resultTable").querySelector("thead");
    const tbody = $("resultTable").querySelector("tbody");
    const months = visibleMonths(12);

    const monthGroups = months.map(m => `
      <th class="monthGroup" colspan="2">
        ${m}월
        <button class="hideMonthBtn" type="button" data-hide-month="${m}" title="${m}월 열 접기">접기</button>
      </th>
    `);

    const monthSubs = months.map(m => `
      <th class="monthValue monthFirst">가중1</th>
      <th class="monthValue">가중2</th>
    `);

    thead.innerHTML = `
      <tr>
        <th class="actionCol" rowspan="2">작업</th>
        <th class="sticky1" rowspan="2">주간/야간</th>
        <th class="sticky2" rowspan="2">Camp</th>
        <th class="sticky3" rowspan="2">Route</th>
        ${monthGroups.join("")}
      </tr>
      <tr class="monthSubRow">
        ${monthSubs.join("")}
      </tr>
    `;

    if (!tableRows.length) {
      tbody.innerHTML = `<tr><td colspan="${4 + months.length * 2}" class="empty">데이터 없음</td></tr>`;
      return;
    }

    tbody.innerHTML = tableRows.map((row, index) => {
      const rowWave = effectiveWave(row);
      const rowCamp = effectiveCamp(row);
      const rowRoute = effectiveRoute(row);
      const sepClass = rowSeparatorClass(row, index);

      const cells = [];

      for (const m of months) {
        const month = row.months[m] || {
          id: null,
          gajoong1: "",
          gajoong2: ""
        };

        cells.push(`
          <td
            class="monthValue monthFirst readonlyValue ${valueClass(month.gajoong1)}"
            title="조회값은 수정할 수 없습니다."
          >${esc(displayGajoongValue(month.gajoong1))}</td>
        `);

        cells.push(`
          <td
            class="monthValue readonlyValue ${valueClass(month.gajoong2)}"
            title="조회값은 수정할 수 없습니다."
          >${esc(displayGajoongValue(month.gajoong2))}</td>
        `);
      }

      return `
        <tr data-row="${esc(row.localId)}" class="${sepClass}">
          <td class="actionCol">
            <button class="small danger" data-action="delete" data-row="${esc(row.localId)}">삭제</button>
          </td>
          <td tabindex="0" class="sticky1 editable" data-row="${esc(row.localId)}" data-meta="wave" title="클릭해서 수정">${esc(waveLabel(rowWave))}</td>
          <td tabindex="0" class="sticky2 editable" data-row="${esc(row.localId)}" data-meta="camp" title="클릭해서 수정">${esc(rowCamp)}</td>
          <td tabindex="0" class="sticky3 editable" data-row="${esc(row.localId)}" data-meta="route" title="클릭해서 수정">${esc(rowRoute)}</td>
          ${cells.join("")}
        </tr>
      `;
    }).join("");

    renderHiddenMonthBar();
  }

  function getRowById(localId) {
    return tableRows.find(row => row.localId === localId);
  }

  function getEditableCells() {
    return Array.from(document.querySelectorAll("#resultTable td.editable"));
  }

  function focusNextEditableCell(currentTd, backwards = false) {
    const cells = getEditableCells();
    const index = cells.indexOf(currentTd);
    if (index < 0) return;

    const nextIndex = backwards
      ? Math.max(0, index - 1)
      : Math.min(cells.length - 1, index + 1);

    const next = cells[nextIndex];

    if (next && next !== currentTd) {
      next.focus({ preventScroll: false });
      startEditCell(next);
    }
  }

  function startEditCell(td) {
    if (td.querySelector("input,select")) return;

    const row = getRowById(td.dataset.row);
    if (!row) return;

    const meta = td.dataset.meta;

    if (!meta) {
      setStatus("조회된 가중1/가중2 값은 이 페이지에서 수정할 수 없습니다.", "warn");
      return;
    }

    editMetaCell(td, row, meta);
  }

  function editMetaCell(td, row, meta) {
    if (meta === "wave") {
      const select = document.createElement("select");
      select.className = "editorSelect";
      select.innerHTML = `
        <option value=""></option>
        <option value="W2">주간</option>
        <option value="W1">야간</option>
      `;

      select.value = row.wave || "";

      td.textContent = "";
      td.appendChild(select);
      select.focus();

      let committed = false;

      const commit = (moveDirection = null) => {
        if (committed) return;
        committed = true;

        row.wave = select.value;
        renderTable();

        if (moveDirection) {
          const newTd = document.querySelector(`[data-row="${CSS.escape(row.localId)}"][data-meta="${meta}"]`);
          if (newTd) focusNextEditableCell(newTd, moveDirection === "prev");
        }
      };

      select.addEventListener("blur", () => commit(), { once:true });
      select.addEventListener("keydown", e => {
        if (e.key === "Enter") {
          e.preventDefault();
          select.blur();
        }
        if (e.key === "Tab") {
          e.preventDefault();
          commit(e.shiftKey ? "prev" : "next");
        }
        if (e.key === "Escape") {
          e.preventDefault();
          committed = true;
          renderTable();
        }
      });

      return;
    }

    const input = document.createElement("input");
    input.className = "editorInput";

    if (meta === "camp") input.value = row.camp || "";
    if (meta === "route") input.value = row.route || "";

    td.textContent = "";
    td.appendChild(input);
    input.focus();
    input.select();

    let committed = false;

    const commit = (moveDirection = null) => {
      if (committed) return;
      committed = true;

      let next = clean(input.value);

      if (meta === "route") {
        next = normalizeRoute(next);
      }

      row[meta] = next;

      renderTable();

      if (moveDirection) {
        const newTd = document.querySelector(`[data-row="${CSS.escape(row.localId)}"][data-meta="${meta}"]`);
        if (newTd) focusNextEditableCell(newTd, moveDirection === "prev");
      }
    };

    if (meta === "route") {
      input.setAttribute("inputmode", "latin");
      input.setAttribute("autocomplete", "off");
      input.addEventListener("input", () => {
        const next = sanitizeRouteInputValue(input.value);
        if (input.value !== next) input.value = next;
      });
    }

    input.addEventListener("blur", () => commit(), { once:true });
    input.addEventListener("keydown", e => {
      if (e.key === "Enter") {
        e.preventDefault();
        input.blur();
      }
      if (e.key === "Tab") {
        e.preventDefault();
        commit(e.shiftKey ? "prev" : "next");
      }
      if (e.key === "Escape") {
        e.preventDefault();
        committed = true;
        renderTable();
      }
    });
  }

  function deleteRow(localId) {
    const row = getRowById(localId);
    if (!row) return;

    const wave = effectiveWave(row);
    const camp = effectiveCamp(row);
    const route = effectiveRoute(row);

    const ok = confirm(`${waveLabel(wave)} / ${camp} / ${route}\n\n이 조회 행을 화면에서 제거할까요?\nDB 데이터는 삭제되지 않습니다.`);

    if (!ok) return;

    tableRows = tableRows.filter(item => item.localId !== localId);

    while (tableRows.length < 4) {
      tableRows.push(createBlankRow());
    }

    renderTable();
    renderSummary();
    setStatus("조회 행을 화면에서 제거했습니다. DB 데이터는 변경되지 않았습니다.", "ok");
  }

  function getMonthsWithData() {
    const set = new Set();

    for (const row of tableRows) {
      for (let m = 1; m <= 12; m++) {
        if (hiddenMonths.has(m)) continue;

        const month = row.months[m] || {};
        const g1 = clean(month.gajoong1);
        const g2 = clean(month.gajoong2);

        if (g1 || g2) set.add(m);
      }
    }

    return Array.from(set).sort((a, b) => a - b);
  }

  function getLastMonthWithData() {
    const months = getMonthsWithData(12);
    return months.length ? months[months.length - 1] : 0;
  }

  function fitText(ctx, text, maxWidth) {
    let s = String(text ?? "");

    if (ctx.measureText(s).width <= maxWidth) return s;

    while (s.length > 0 && ctx.measureText(s + "…").width > maxWidth) {
      s = s.slice(0, -1);
    }

    return s ? s + "…" : "";
  }

  function drawCell(ctx, x, y, w, h, options = {}) {
    const {
      text = "",
      bg = "#ffffff",
      color = "#0f172a",
      border = "#d8e0ee",
      font = "700 13px Arial, 'Noto Sans KR', sans-serif",
      align = "center",
      lineWidth = 1
    } = options;

    ctx.fillStyle = bg;
    ctx.fillRect(x, y, w, h);

    ctx.strokeStyle = border;
    ctx.lineWidth = lineWidth;
    ctx.strokeRect(x, y, w, h);

    ctx.fillStyle = color;
    ctx.font = font;
    ctx.textBaseline = "middle";

    const safeText = fitText(ctx, text, w - 3);

    if (align === "left") {
      ctx.textAlign = "left";
      ctx.fillText(safeText, x + 3, y + h / 2);
    } else {
      ctx.textAlign = "center";
      ctx.fillText(safeText, x + w / 2, y + h / 2);
    }
  }

  function drawSeparator(ctx, x, y, w, type) {
  if (!type) return;
  ctx.save();

  const lineWidth = type === "camp" ? 3 : 2;
  const strokeStyle = type === "camp" ? "#64748b" : "#94a3b8";
  const lineY = y + lineWidth / 2;

  ctx.strokeStyle = strokeStyle;
  ctx.lineWidth = lineWidth;
  ctx.beginPath();
  ctx.moveTo(x, lineY);
  ctx.lineTo(x + w, lineY);
  ctx.stroke();

  ctx.restore();
}

  function drawMonthBoundary(ctx, x, top, bottom) {
    ctx.save();
    ctx.strokeStyle = "#64748b";
    ctx.lineWidth = 1.25;
    ctx.beginPath();
    ctx.moveTo(x + 0.5, top);
    ctx.lineTo(x + 0.5, bottom);
    ctx.stroke();
    ctx.restore();
  }

  function valueStyle(v) {
    const s = clean(v);

    if (s === "해당") {
      return {
        bg: "#dff4ff",
        color: "#075985"
      };
    }

    if (isNoneGajoongValue(s)) {
      return {
        bg: "#ffffff",
        color: "#111827"
      };
    }

    if (isMissGajoongValue(s)) {
      return {
        bg: "#fff7ed",
        color: "#c2410c"
      };
    }

    return {
      bg: "#f8fafc",
      color: "#94a3b8"
    };
  }

  function canvasToBlob(canvas) {
    return new Promise(resolve => {
      canvas.toBlob(blob => resolve(blob), "image/png", 1);
    });
  }

  function isMobileImageDelivery() {
    return /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent || "");
  }

  function downloadImageBlob(blob, fileName) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = fileName;
    document.body.appendChild(a);
    a.click();
    a.remove();

    setTimeout(() => {
      URL.revokeObjectURL(url);
    }, 1000);
  }

  async function deliverImageBlob(blob, fileName, statusText) {
    const mobile = isMobileImageDelivery();

    /*
      모바일 Chrome/삼성인터넷/카카오톡 공유 경로는 긴 PNG를 클립보드나 공유 과정에서
      기기 DPR 기준의 CSS 크기(약 1/4)로 다시 줄이는 경우가 있다.
      그래서 모바일에서는 clipboard/share를 쓰지 않고 원본 canvas PNG를 파일로 직접 저장한다.
      PC에서만 기존처럼 클립보드 복사를 유지한다.
    */
    if (mobile) {
      downloadImageBlob(blob, fileName);
      setStatus(`${statusText} / 모바일 원본 PNG 저장 완료`, "ok");
      return;
    }

    if (navigator.clipboard?.write && window.ClipboardItem) {
      try {
        await navigator.clipboard.write([
          new ClipboardItem({
            "image/png": blob
          })
        ]);

        setStatus(`${statusText} / 클립보드 복사 완료`, "ok");
        return;
      } catch (e) {
        console.warn("clipboard image copy failed", e);
      }
    }

    downloadImageBlob(blob, fileName);
    setStatus(`${statusText} / 원본 PNG 다운로드 완료`, "warn");
  }


  function normalizeFreshbagSeparatorsForCapture(root) {
    if (!root) return;

    root.querySelectorAll("tr.campSep").forEach(tr => {
      const prev = tr.previousElementSibling;

      if (prev) {
        prev.querySelectorAll("td,th").forEach(cell => {
          cell.style.borderBottom = "0";
        });
      }

      tr.querySelectorAll("td,th").forEach(cell => {
        cell.style.borderTop = "3px solid #64748b";
      });
    });
  }

  async function copyTableImage() {
    const months = getMonthsWithData();

    if (!tableRows.length) {
      setStatus("복사할 행이 없습니다.", "bad");
      return;
    }

    if (!months.length) {
      setStatus("데이터가 있는 월이 없습니다. 먼저 조회하세요.", "bad");
      return;
    }

    /*
      모바일 화질 최종 우회:
      - 이미지 자체는 한 장 세로 이미지 유지
      - canvas는 충분한 원본 해상도(scale=4)로 생성
      - 모바일에서는 클립보드/공유 압축을 피하려고 원본 PNG 파일로 저장
      - PC는 기존처럼 클립보드 복사
    */
    const fixedColumns = [
      { key: "wave", label: "주간/야간", width: 50 },
      { key: "camp", label: "Camp", width: 58 },
      { key: "route", label: "Route", width: 50 }
    ];

    const monthCellWidth = 48;
    const monthColumns = [];

    for (const m of months) {
      monthColumns.push({ month: m, field: "gajoong1", label: "가중1", width: monthCellWidth, first:true });
      monthColumns.push({ month: m, field: "gajoong2", label: "가중2", width: monthCellWidth, first:false });
    }

    const columns = [...fixedColumns, ...monthColumns];

    const titleHeight = 48;
    const monthHeaderHeight = 26;
    const subHeaderHeight = 25;
    const rowHeight = 30;
    const padding = 12;

    const tableWidth = columns.reduce((sum, col) => sum + col.width, 0);
    const canvasWidth = tableWidth + padding * 2;
    const canvasHeight = titleHeight + monthHeaderHeight + subHeaderHeight + tableRows.length * rowHeight + padding * 2;

    const scale = 4;
    const canvas = document.createElement("canvas");
    canvas.width = Math.ceil(canvasWidth * scale);
    canvas.height = Math.ceil(canvasHeight * scale);

    const ctx = canvas.getContext("2d", { alpha:false });
    ctx.scale(scale, scale);
    ctx.imageSmoothingEnabled = false;

    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0, 0, canvasWidth, canvasHeight);

    const titleParts = [
      $("yearFilter").value || "",
      clean($("campFilter").value) || "Camp",
      clean($("waveFilter").value) === "W2" ? "주간" : clean($("waveFilter").value) === "W1" ? "야간" : "주/야"
    ].filter(Boolean);

    ctx.fillStyle = "#0f172a";
    ctx.font = "800 20px 'Noto Sans KR', Arial, sans-serif";
    ctx.textAlign = "left";
    ctx.textBaseline = "middle";
    ctx.fillText("프레시백 현황 조회", padding, padding + 13);

    ctx.fillStyle = "#64748b";
    ctx.font = "600 12px 'Noto Sans KR', Arial, sans-serif";
    ctx.fillText(titleParts.join(" / "), padding, padding + 35);

    let y = padding + titleHeight;
    let x = padding;

    const fixedHeaderFont = "700 10px 'Noto Sans KR', Arial, sans-serif";
    const monthHeaderFont = "700 12px 'Noto Sans KR', Arial, sans-serif";
    const subHeaderFont = "700 10px 'Noto Sans KR', Arial, sans-serif";
    const rowFont = "700 11px 'Noto Sans KR', Arial, sans-serif";

    for (const col of fixedColumns) {
      drawCell(ctx, x, y, col.width, monthHeaderHeight + subHeaderHeight, {
        text: col.label,
        bg: "#eaf2fb",
        color: "#0f172a",
        border: "#cbd5e1",
        font: fixedHeaderFont
      });
      x += col.width;
    }

    const monthGroupWidth = monthCellWidth * 2;

    for (const m of months) {
      drawCell(ctx, x, y, monthGroupWidth, monthHeaderHeight, {
        text: `${m}월`,
        bg: "#dbeafe",
        color: "#0f172a",
        border: "#cbd5e1",
        font: monthHeaderFont,
        lineWidth: 1
      });
      x += monthGroupWidth;
    }

    y += monthHeaderHeight;
    x = padding + fixedColumns.reduce((sum, col) => sum + col.width, 0);

    for (const col of monthColumns) {
      drawCell(ctx, x, y, col.width, subHeaderHeight, {
        text: col.label,
        bg: "#eff6ff",
        color: "#0f172a",
        border: "#cbd5e1",
        font: subHeaderFont,
        lineWidth: 1
      });
      x += col.width;
    }

    y += subHeaderHeight;

    for (let rowIndex = 0; rowIndex < tableRows.length; rowIndex++) {
      const row = tableRows[rowIndex];
      x = padding;

      const sepClass = rowSeparatorClass(row, rowIndex);

      const fixedValues = {
        wave: waveLabel(effectiveWave(row)),
        camp: effectiveCamp(row),
        route: effectiveRoute(row)
      };

      for (const col of fixedColumns) {
        drawCell(ctx, x, y, col.width, rowHeight, {
          text: fixedValues[col.key],
          bg: "#f8fafc",
          color: col.key === "route" ? "#1d4ed8" : "#0f172a",
          border: "#d8e0ee",
          font: rowFont
        });

        x += col.width;
      }

      for (const col of monthColumns) {
        const month = row.months[col.month] || {};
        const value = clean(month[col.field]);
        const style = valueStyle(value);
        const displayValue = displayGajoongValue(value);

        drawCell(ctx, x, y, col.width, rowHeight, {
          text: displayValue,
          bg: style.bg,
          color: style.color,
          border: "#d8e0ee",
          font: rowFont,
          lineWidth: 1
        });

        x += col.width;
      }

      if (sepClass) {
        drawSeparator(ctx, padding, y, tableWidth, sepClass === "campSep" ? "camp" : "route");
      }

      y += rowHeight;
    }

    const monthBoundaryStart = padding + fixedColumns.reduce((sum, col) => sum + col.width, 0);
    const monthBoundaryTop = padding + titleHeight;
    const monthBoundaryBottom = canvasHeight - padding;

    for (let i = 0; i <= months.length; i++) {
      const boundaryX = monthBoundaryStart + i * monthGroupWidth;
      drawMonthBoundary(ctx, boundaryX, monthBoundaryTop, monthBoundaryBottom);
    }

    const blob = await canvasToBlob(canvas);

    if (!blob) {
      setStatus("이미지 생성에 실패했습니다.", "bad");
      return;
    }

    const fileName = `freshbag_${$("yearFilter").value || "year"}_${Date.now()}.png`;
    const statusText = `이미지 생성 완료: 원본 ${canvas.width}×${canvas.height}px / 한 장 세로 / ${months.join(", ")}월`;

    await deliverImageBlob(blob, fileName, statusText);
  }


  function clearAll() {
    const now = new Date().getFullYear();

    $("yearFilter").value = String(now);
    $("campFilter").value = "";
    $("waveFilter").value = "";
    $("presetNameInput").value = "";
    $("savedPresetSelect").value = "";

    rawRows = [];
    initDefaultRows();
    setStatus("초기화 완료. Route 없이 Camp만 입력하면 Camp 전체 조회가 가능합니다.", "ok");
  }

  function handleError(e) {
    console.error(e);
    setStatus(e.message || String(e), "bad");
  }

  function run(fn) {
    fn().catch(handleError);
  }

  initYearOptions();
  loadHiddenMonths();

  $("loadBtn").addEventListener("click", () => run(loadData));
  $("addRowBtn").addEventListener("click", addRow);
  $("clearBtn").addEventListener("click", clearAll);
  $("copyBtn").addEventListener("click", () => run(copyTableImage));

  $("savePresetBtn").addEventListener("click", () => run(async () => {
    saveCurrentPreset();
  }));

  $("loadPresetBtn").addEventListener("click", () => run(loadSelectedPresetAndQuery));
  $("deletePresetBtn").addEventListener("click", deleteSelectedPreset);
  $("loadLastPresetBtn").addEventListener("click", () => run(loadLastQueryPresetAndQuery));

  $("savedPresetSelect").addEventListener("change", () => {
    const selectedId = $("savedPresetSelect").value;
    const preset = getAllPresets().find(item => item.id === selectedId);

    if (preset) {
      $("presetNameInput").value = preset.name || "";
    }
  });

  $("hiddenMonthBar").addEventListener("click", e => {
    const btn = e.target.closest("button");
    if (!btn) return;

    if (btn.hasAttribute("data-show-all-months")) {
      showAllMonths();
      return;
    }

    const month = btn.getAttribute("data-show-month");
    if (month) showMonth(month);
  });

  $("resultTable").addEventListener("click", e => {
    const hideBtn = e.target.closest("[data-hide-month]");
    if (hideBtn) {
      e.stopPropagation();
      hideMonth(hideBtn.getAttribute("data-hide-month"));
      return;
    }

    const btn = e.target.closest("[data-action='delete']");
    if (btn) {
      deleteRow(btn.dataset.row);
      return;
    }

    const td = e.target.closest("td.editable");
    if (!td) return;

    startEditCell(td);
  });

  $("resultTable").addEventListener("keydown", e => {
    const td = e.target.closest("td.editable");
    if (!td) return;

    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      startEditCell(td);
    }
  });

  ["yearFilter", "waveFilter"].forEach(id => {
    $(id).addEventListener("change", () => {
      if (rawRows.length > 0) run(loadData);
      else renderTable();
    });
  });

  $("campFilter").addEventListener("keydown", e => {
    if (e.key === "Enter") run(loadData);
  });

  try {
    initSupabase();

    run(async () => {
      await checkSession();
      await loadMyAccess();
      initFreshbagUploadSwitchIfAllowed();
      initDefaultRows();
      renderPresetOptions();

      document.documentElement.style.visibility = "visible";
      setStatus("기본 4행이 준비되었습니다. 조회는 freshbag 백엔드를 통해 실행됩니다.", "ok");
    });
  } catch (e) {
    document.documentElement.style.visibility = "visible";
    handleError(e);
  }
})();
</script>

<script src="/board-menu.js"></script>
</body>
</html>