    }

    list.innerHTML = attachmentRows.map(row => {
      const url = attachmentSignedUrls.get(row.id) || row.signed_url || row.public_url || "";
      const caption = row.caption || row.file_name || "이미지";

      return `
        <div class="attachmentCard" data-attachment-id="${esc(row.id)}">
          ${url ? `<img src="${esc(url)}" alt="${esc(caption)}" data-preview-url="${esc(url)}" data-caption="${esc(caption)}">` : `<div class="detailEmpty">이미지 URL 없음</div>`}
          <div class="attachmentCaption">${esc(caption)}</div>
          <div class="attachmentActions">
            <button type="button" class="secondary" data-attachment-preview="${esc(row.id)}">보기</button>
            <button type="button" class="danger" data-attachment-delete="${esc(row.id)}">삭제</button>
          </div>
        </div>
      `;
    }).join("");
  }

  function arrayBufferToBase64(buffer) {
    let binary = "";
    const bytes = new Uint8Array(buffer);
    const chunkSize = 0x8000;

    for (let i = 0; i < bytes.length; i += chunkSize) {
      const chunk = bytes.subarray(i, i + chunkSize);
      binary += String.fromCharCode.apply(null, chunk);
    }

    return btoa(binary);
  }

  async function uploadAttachments() {
    if (!selectedPoint?.id) {
      setAttachmentStatus("이미지를 올릴 포인트를 먼저 저장하거나 선택하세요.", "bad");
      return;
    }

    const files = Array.from($("attachmentFileInput").files || []);

    if (!files.length) {
      setAttachmentStatus("업로드할 이미지 파일을 선택하세요.", "bad");
      return;
    }

    setAttachmentStatus("이미지 업로드 중...", "warn");

    const payloadFiles = [];

    for (const file of files) {
      const buffer = await file.arrayBuffer();

      payloadFiles.push({
        name: file.name,
        type: file.type || "application/octet-stream",
        size: file.size,
        base64: arrayBufferToBase64(buffer),
        caption: clean($("attachmentCaptionInput").value) || null
      });
    }

    const result = await routeInfoApi("/route-info/attachments/upload", {
      point_id: selectedPoint.id,
      route_info_id: selectedPoint.route_info_id || selectedRoute?.id || null,
      camp: selectedPoint.camp || selectedRoute?.camp || "",
      route_code: selectedPoint.route_code || routeCodeOf(selectedRoute),
      files: payloadFiles
    });

    attachmentRows = result.attachments || attachmentRows;

    if (Array.isArray(result.attachments)) {
      attachmentSignedUrls = new Map();
      for (const row of result.attachments) {
        if (row.signed_url) attachmentSignedUrls.set(row.id, row.signed_url);
        else if (row.public_url) attachmentSignedUrls.set(row.id, row.public_url);
      }
    } else {
      await loadAttachments(selectedPoint.id, false);
    }

    $("attachmentFileInput").value = "";
    $("attachmentCaptionInput").value = "";
    renderAttachments();
    setAttachmentStatus("이미지 업로드 완료", "ok");
  }

