<!doctype html>
<html lang="ko">
<head>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="referrer" content="origin" />
  <title>마루웰 정보</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <style>
    html { visibility: hidden; }

    :root{
      --bg:#0b1220;
      --line:rgba(255,255,255,.10);
      --txt:#e6eefc;
      --muted:#93a4c7;
      --sheetBg:#eef3f8;
      --headBg:#dde7f3;
      --cellBg:#ffffff;
      --cellAlt:#f9fbfe;
      --cellTxt:#0f172a;
      --line2:#d4dbe5;
      --greenBg:#d9f0c7;
      --greenTxt:#46691c;
      --redBg:#ffd6d0;
      --redTxt:#a33d2c;
      --blueBg:#d8e8ff;
      --blueTxt:#245ecb;
      --grayBg:#e5e7eb;
      --grayTxt:#6b7280;
      --headerH:56px;
      --toolbarH:58px;
      --summaryH:54px;
      --statusH:46px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      height: 100%;
      font-family: system-ui, -apple-system, "Noto Sans KR", Segoe UI, Roboto, Arial, sans-serif;
      background: var(--bg);
      color: var(--txt);
    }

    body { overflow: hidden; }

    .app{
      height:100%;
      display:grid;
      grid-template-rows:var(--headerH) var(--toolbarH) var(--summaryH) 1fr var(--statusH);
    }

    .topbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 14px;
      border-bottom:1px solid var(--line);
      background:#0c1422;
    }

    .topbar a{
      display:flex;
      align-items:center;
      text-decoration:none;
      color:inherit;
    }

    .topbar img{
      width:24px;
      height:24px;
      display:block;
    }

    .titleBox{
      display:flex;
      flex-direction:column;
      min-width:0;
    }

    .titleBox b{
      font-size:18px;
      line-height:1.1;
    }

    .titleBox small{
      color:var(--muted);
      font-size:11px;
      font-weight:800;
      margin-top:2px;
    }

    .spacer{ flex:1; }

    .btn{
      height:38px;
      padding:0 14px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.12);
      cursor:pointer;
      font-weight:800;
      font-size:13px;
      color:#fff;
      background:rgba(255,255,255,.06);
      white-space:nowrap;
    }

    .btn:hover{ background:rgba(255,255,255,.11); }
    .btn.primary{ background:rgba(29,78,216,.88); }
    .btn.primary:hover{ background:rgba(29,78,216,.98); }
    .btn.danger{
      background:rgba(185,28,28,.22);
      color:#fecaca;
      border-color:rgba(248,113,113,.24);
    }
    .btn.danger:hover{ background:rgba(185,28,28,.34); }

    .toolbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:10px 12px;
      background:#0b1422;
      border-bottom:1px solid var(--line);
      overflow:auto hidden;
    }

    .toolGroup{
      display:flex;
      align-items:center;
      gap:8px;
      padding-right:12px;
      border-right:1px solid var(--line);
      flex:0 0 auto;
    }

    .toolGroup:last-child{
      border-right:none;
      padding-right:0;
    }

    .toolGroup label{
      font-size:12px;
      color:var(--muted);
      font-weight:800;
      white-space:nowrap;
    }

    .toolbar input,
    .toolbar select{
      height:38px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.10);
      background:#0f1728;
      color:var(--txt);
      padding:0 12px;
      font-size:13px;
      outline:none;
    }

    .toolbar input:focus,
    .toolbar select:focus{
      border-color:rgba(96,165,250,.55);
    }

    .summaryBar{
      display:flex;
      align-items:center;
      gap:12px;
      padding:8px 12px;
      background:#0d1626;
      border-bottom:1px solid var(--line);
    }

    .summaryTitle{
      font-size:12px;
      font-weight:900;
      color:var(--muted);
      white-space:nowrap;
    }

    .summaryCards{
      display:flex;
      gap:10px;
      min-width:0;
      overflow:auto hidden;
    }

    .summaryCard{
      min-width:140px;
      padding:8px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      display:flex;
      flex-direction:column;
      gap:4px;
    }

    .summaryLabel{
      color:var(--muted);
      font-size:11px;
      font-weight:800;
    }

    .summaryValue{
      color:#f8fafc;
      font-size:18px;
      font-weight:900;
      line-height:1.1;
      font-variant-numeric:tabular-nums;
    }

    .summaryValue.blue{ color:#bfdbfe; }
    .summaryValue.green{ color:#bbf7d0; }

    .sheetWrap{
      overflow:auto;
      background:var(--sheetBg);
    }

    .sheetInner{
      min-width:2800px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      table-layout:fixed;
      color:var(--cellTxt);
    }

    th, td{
      border-right:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
    }

    th:first-child, td:first-child{
      border-left:1px solid var(--line2);
    }

    thead th{
      position:sticky;
      top:0;
      z-index:3;
      background:var(--headBg);
      padding:10px 8px;
      text-align:center;
      font-size:13px;
      font-weight:900;
      white-space:nowrap;
    }

    thead tr.filterRow th{
      top:43px;
      z-index:2;
      background:#edf3fb;
      padding:6px;
    }

    tbody td{
      background:var(--cellBg);
      padding:0;
      vertical-align:middle;
    }

    tbody tr:nth-child(even) td{
      background:var(--cellAlt);
    }

    .readonlyCell{
      min-height:44px;
      display:flex;
      align-items:center;
      padding:0 10px;
      font-size:13px;
      line-height:1.35;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .readonlyCell.center{
      justify-content:center;
      text-align:center;
    }

    .readonlyCell.right{
      justify-content:flex-end;
      text-align:right;
      font-variant-numeric:tabular-nums;
    }

    .readonlyCell.code{
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size:12px;
    }

    .readonlyCell.empty{
      color:#94a3b8;
    }

    .chip{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:48px;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
      margin:auto;
    }

    .chip.ok{
      background:var(--greenBg);
      color:var(--greenTxt);
    }

    .chip.no{
      background:var(--redBg);
      color:var(--redTxt);
    }

    .filterInput,
    .filterSelect{
      width:100%;
      height:34px;
      border-radius:10px;
      border:1px solid #c7d2e2;
      background:#fff;
      color:#0f172a;
      padding:0 10px;
      font-size:12px;
      outline:none;
    }

    .filterInput:focus,
    .filterSelect:focus{
      border-color:#60a5fa;
    }

    .emptyDataRow td{
      padding:18px 14px;
      text-align:center;
      color:#64748b;
      font-weight:800;
      background:#f8fbff !important;
    }

    .statusbar{
      display:flex;
      align-items:center;
      gap:10px;
      padding:0 12px;
      border-top:1px solid var(--line);
      background:#0a1320;
      font-size:12px;
    }

    .pill{
      padding:6px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      font-weight:900;
      white-space:nowrap;
    }

    .pill.ok{ color:#bbf7d0; }
    .pill.warn{ color:#fde68a; }
    .pill.err{ color:#fecaca; }

    .statusText{
      color:var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .accessDenied{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:linear-gradient(180deg, rgba(11,18,32,.96), rgba(11,18,32,.98));
      z-index:1000;
    }

    .accessDenied.show{
      display:flex;
    }

    .accessCard{
      width:min(520px, calc(100vw - 24px));
      border:1px solid rgba(255,255,255,.10);
      border-radius:22px;
      background:#101827;
      box-shadow:0 24px 60px rgba(0,0,0,.35);
      padding:24px;
    }

    .accessCard h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.2;
    }

    .accessCard p{
      margin:0;
      color:#b8c3d9;
      line-height:1.6;
      font-size:14px;
      white-space:pre-wrap;
    }

    .accessMeta{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.04);
      color:#e6eefc;
      font-size:13px;
      font-weight:800;
      word-break:break-word;
    }

    .accessActions{
      margin-top:18px;
      display:flex;
      gap:10px;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    @media (max-width:1280px){
      .summaryCards{
        gap:8px;
      }
    }

    @media (max-width:900px){
      .btn{ padding:0 10px; font-size:12px; }
      .toolbar{ padding:8px; }
      .summaryCard{ min-width:120px; }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
  <div class="app" id="app">
    <div class="topbar">
      <a href="/index.html" title="홈">
        <img src="/favicon.ico" alt="Maroowell" />
      </a>
      <div class="titleBox">
        <b>마루웰 정보</b>
        <small>직원 / 정산 베이스 정보 조회</small>
      </div>
      <div class="spacer"></div>
      <button id="btnReload" class="btn" type="button">불러오기</button>
      <button id="btnExportCsv" class="btn" type="button">CSV 다운로드</button>
      <button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </div>

    <div class="toolbar">
      <div class="toolGroup">
        <label for="quickSearch">빠른 검색</label>
        <input id="quickSearch" type="text" placeholder="이름 / 연락처 / 캠프 / ID / 차량 / 사업자 상호" />
      </div>

      <div class="toolGroup">
        <label for="insuranceFilter">고용산재</label>
        <select id="insuranceFilter">
          <option value="">전체</option>
          <option value="O">O</option>
          <option value="X">X</option>
        </select>
      </div>

      <div class="toolGroup">
        <label for="waveFilter">주간/야간</label>
        <select id="waveFilter">
          <option value="">전체</option>
          <option value="주간">주간</option>
          <option value="야간">야간</option>
          <option value="주/야">주/야</option>
        </select>
      </div>

      <div class="toolGroup">
        <button id="btnClearFilters" class="btn" type="button">필터 초기화</button>
      </div>
    </div>

    <div class="summaryBar">
      <div class="summaryTitle">검색 합계</div>
      <div class="summaryCards">
        <div class="summaryCard">
          <span class="summaryLabel">전체 행</span>
          <strong id="summaryTotalRows" class="summaryValue">0</strong>
        </div>
        <div class="summaryCard">
          <span class="summaryLabel">검색 결과</span>
          <strong id="summaryFilteredRows" class="summaryValue blue">0</strong>
        </div>
        <div class="summaryCard">
          <span class="summaryLabel">캠프 수</span>
          <strong id="summaryCampCount" class="summaryValue">0</strong>
        </div>
        <div class="summaryCard">
          <span class="summaryLabel">고용산재 O</span>
          <strong id="summaryInsuranceYes" class="summaryValue green">0</strong>
        </div>
      </div>
    </div>

    <div class="sheetWrap">
      <div class="sheetInner">
        <table>
          <colgroup>
            <col style="width:80px">
            <col style="width:120px">
            <col style="width:130px">
            <col style="width:110px">
            <col style="width:100px">
            <col style="width:90px">
            <col style="width:120px">
            <col style="width:130px">
            <col style="width:150px">
            <col style="width:150px">
            <col style="width:170px">
            <col style="width:120px">
            <col style="width:170px">
            <col style="width:150px">
            <col style="width:150px">
            <col style="width:120px">
            <col style="width:170px">
            <col style="width:120px">
            <col style="width:120px">
            <col style="width:120px">
            <col style="width:90px">
          </colgroup>

          <thead>
            <tr>
              <th>순번</th>
              <th>이름</th>
              <th>연락처</th>
              <th>직책</th>
              <th>camp</th>
              <th>wave</th>
              <th>coupang_id</th>
              <th>차량 번호</th>
              <th>주민번호</th>
              <th>운송자격증번호</th>
              <th>서브 계정</th>
              <th>급여 은행</th>
              <th>급여 계좌</th>
              <th>사업자 상호</th>
              <th>사업자 번호</th>
              <th>입사일</th>
              <th>비상 연락처 / 관계</th>
              <th>고정 수수료</th>
              <th>고정 단가</th>
              <th>용차 수수료</th>
              <th>고용산재</th>
            </tr>

            <tr class="filterRow">
              <th></th>
              <th><input class="filterInput" data-filter="person_name" placeholder="이름" /></th>
              <th><input class="filterInput" data-filter="contact_phone" placeholder="연락처" /></th>
              <th><input class="filterInput" data-filter="position_title" placeholder="직책" /></th>
              <th><input class="filterInput" data-filter="camp_code" placeholder="camp" /></th>
              <th><input class="filterInput" data-filter="wave" placeholder="wave" /></th>
              <th><input class="filterInput" data-filter="coupang_id" placeholder="ID" /></th>
              <th><input class="filterInput" data-filter="vehicle_plate_number" placeholder="차량 번호" /></th>
              <th><input class="filterInput" data-filter="resident_registration_number" placeholder="주민번호" /></th>
              <th><input class="filterInput" data-filter="transport_qualification_number" placeholder="자격증번호" /></th>
              <th><input class="filterInput" data-filter="sub_account_info" placeholder="서브 계정" /></th>
              <th><input class="filterInput" data-filter="payroll_bank_name" placeholder="은행" /></th>
              <th><input class="filterInput" data-filter="payroll_account_number" placeholder="계좌" /></th>
              <th><input class="filterInput" data-filter="business_name" placeholder="사업자 상호" /></th>
              <th><input class="filterInput" data-filter="business_registration_number" placeholder="사업자 번호" /></th>
              <th><input class="filterInput" data-filter="hire_date" placeholder="입사일" /></th>
              <th><input class="filterInput" data-filter="emergency" placeholder="비상 연락처 / 관계" /></th>
              <th><input class="filterInput" data-filter="fixed_commission_amount" placeholder="고정 수수료" /></th>
              <th><input class="filterInput" data-filter="fixed_unit_price" placeholder="고정 단가" /></th>
              <th><input class="filterInput" data-filter="dragon_car_commission" placeholder="용차 수수료" /></th>
              <th>
                <select class="filterSelect" data-filter="employment_accident_insurance">
                  <option value="">전체</option>
                  <option value="O">O</option>
                  <option value="X">X</option>
                </select>
              </th>
            </tr>
          </thead>

          <tbody id="sheetBody"></tbody>
        </table>
      </div>
    </div>

    <div class="statusbar">
      <span id="pillState" class="pill ok">READY</span>
      <span id="pillRows" class="pill">행 0</span>
      <span id="pillFilter" class="pill warn">필터 0</span>
      <span id="statusText" class="statusText">등록된 순서대로 조회됩니다. 헤더 아래 줄은 필터입니다.</span>
    </div>
  </div>

  <div id="accessDenied" class="accessDenied">
    <div class="accessCard">
      <h2>접근 권한 없음</h2>
      <p id="accessDeniedText">이 페이지는 마루웰 벤더 소속 계정만 조회 가능합니다.</p>
      <div id="accessDeniedEmail" class="accessMeta"></div>
      <div class="accessActions">
        <button id="btnDeniedHome" class="btn" type="button">홈으로</button>
        <button id="btnDeniedLogout" class="btn danger" type="button">로그아웃</button>
      </div>
    </div>
  </div>

  <script>
    (async function () {
      "use strict";

      const { SUPABASE_URL, SUPABASE_ANON_KEY, PATHS } = (window.MARUWELL_CONFIG || {});
      const LOGIN_PATH = PATHS?.login || "/login.html";
      const INDEX_PATH = PATHS?.index || "/index.html";
      const TABLE = "maroowell_info";

      // ------------------------------------------------------------
      // 여기만 수정하면 됨
      // ------------------------------------------------------------
      const ALLOWED_EMAILS = [
        // "yourname@example.com"
      ];

      const ALLOWED_EMAIL_SUFFIXES = [
        "@maroowell.com"
      ];

      // ------------------------------------------------------------
      // 공통
      // ------------------------------------------------------------
      const $ = (sel) => document.querySelector(sel);

      const dom = {
        body: document.body,
        app: $("#app"),
        sheetBody: $("#sheetBody"),
        quickSearch: $("#quickSearch"),
        insuranceFilter: $("#insuranceFilter"),
        waveFilter: $("#waveFilter"),
        btnReload: $("#btnReload"),
        btnExportCsv: $("#btnExportCsv"),
        btnClearFilters: $("#btnClearFilters"),
        btnLogout: $("#btnLogout"),
        pillState: $("#pillState"),
        pillRows: $("#pillRows"),
        pillFilter: $("#pillFilter"),
        statusText: $("#statusText"),
        summaryTotalRows: $("#summaryTotalRows"),
        summaryFilteredRows: $("#summaryFilteredRows"),
        summaryCampCount: $("#summaryCampCount"),
        summaryInsuranceYes: $("#summaryInsuranceYes"),
        accessDenied: $("#accessDenied"),
        accessDeniedText: $("#accessDeniedText"),
        accessDeniedEmail: $("#accessDeniedEmail"),
        btnDeniedHome: $("#btnDeniedHome"),
        btnDeniedLogout: $("#btnDeniedLogout"),
        filterInputs: Array.from(document.querySelectorAll("[data-filter]"))
      };

      const authStorage = (() => {
        try { return window.sessionStorage; } catch { return null; }
      })();

      const supabase = (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase?.createClient)
        ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
            auth: {
              persistSession: !!authStorage,
              storage: authStorage || undefined,
              autoRefreshToken: true,
              detectSessionInUrl: true
            }
          })
        : null;

      const state = {
        rows: [],
        filteredRows: [],
        session: null,
        viewerEmail: "",
        loading: false
      };

      function safeNextPath(p) {
        if (!p) return INDEX_PATH;
        if (p.startsWith("http://") || p.startsWith("https://")) return INDEX_PATH;
        if (!p.startsWith("/")) return INDEX_PATH;
        return p;
      }

      function getSupabaseProjectRef(url) {
        try {
          const host = new URL(url).hostname || "";
          return host.split(".")[0] || "";
        } catch {
          return "";
        }
      }

      function createSupabaseSessionBridge(url) {
        const projectRef = getSupabaseProjectRef(url);
        const prefixes = projectRef ? [
          "sb-" + projectRef + "-auth-token",
          "sb-" + projectRef + "-auth-token-code-verifier"
        ] : [];
        const origin = window.location.origin;
        const channelName = projectRef ? ("mw-auth-bridge:" + projectRef) : "";
        const tabId = (Date.now().toString(36) + Math.random().toString(36).slice(2));
        const pending = new Map();
        let channel = null;
        let started = false;

        function matchesKey(key) {
          return !!key && prefixes.some(prefix => key === prefix || key.startsWith(prefix));
        }

        function readEntries(storage) {
          const target = storage || window.sessionStorage;
          const rows = [];
          try {
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (!matchesKey(key)) continue;
              rows.push({ key, value: target.getItem(key) });
            }
          } catch {}
          return rows;
        }

        function hasSession(storage) {
          return readEntries(storage).some(row => row.key.includes("-auth-token") && !row.key.includes("code-verifier") && !!row.value);
        }

        function writeEntries(entries, storage) {
          const target = storage || window.sessionStorage;
          try {
            for (const row of entries || []) {
              if (!row || !matchesKey(row.key)) continue;
              if (row.value == null) target.removeItem(row.key);
              else target.setItem(row.key, row.value);
            }
          } catch {}
        }

        function clearSession(storage) {
          const target = storage || window.sessionStorage;
          try {
            const keys = [];
            for (let i = 0; i < target.length; i++) {
              const key = target.key(i);
              if (matchesKey(key)) keys.push(key);
            }
            keys.forEach(key => target.removeItem(key));
          } catch {}
        }

        function resolvePending(requestId, entries) {
          const item = pending.get(requestId);
          if (!item) return;
          pending.delete(requestId);
          clearTimeout(item.timer);
          if (Array.isArray(entries) && entries.length) writeEntries(entries, window.sessionStorage);
          item.resolve(hasSession(window.sessionStorage));
        }

        function handleSyncState(stateValue) {
          if (stateValue === "SIGNED_OUT") {
            clearSession(window.sessionStorage);
            return;
          }
          if (stateValue === "SESSION_UPDATED" && !hasSession(window.sessionStorage)) {
            requestSessionCopy(1200).catch(() => {});
          }
        }

        function onWindowMessage(event) {
          if (event.origin !== origin) return;
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              event.source?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              }, origin);
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function onChannelMessage(event) {
          const msg = event.data || {};
          if (msg.projectRef !== projectRef || msg.fromTabId === tabId) return;

          if (msg.type === "MW_SESSION_REQUEST") {
            if (!hasSession(window.sessionStorage)) return;
            try {
              channel?.postMessage({
                type: "MW_SESSION_RESPONSE",
                projectRef,
                requestId: msg.requestId,
                entries: readEntries(window.sessionStorage),
                fromTabId: tabId
              });
            } catch {}
            return;
          }

          if (msg.type === "MW_SESSION_RESPONSE") {
            resolvePending(msg.requestId, msg.entries);
            return;
          }

          if (msg.type === "MW_AUTH_SYNC") {
            handleSyncState(msg.state);
          }
        }

        function start() {
          if (started || !projectRef) return;
          started = true;
          window.addEventListener("message", onWindowMessage);
          try {
            if ("BroadcastChannel" in window) {
              channel = new BroadcastChannel(channelName);
              channel.addEventListener("message", onChannelMessage);
            }
          } catch {}
        }

        function requestSessionCopy(timeoutMs) {
          start();
          if (!projectRef) return Promise.resolve(false);
          if (hasSession(window.sessionStorage)) return Promise.resolve(true);

          const requestId = tabId + ":" + Date.now().toString(36) + Math.random().toString(36).slice(2);
          const payload = {
            type: "MW_SESSION_REQUEST",
            projectRef,
            requestId,
            fromTabId: tabId
          };

          return new Promise(resolve => {
            const timer = window.setTimeout(() => {
              pending.delete(requestId);
              resolve(hasSession(window.sessionStorage));
            }, Math.max(300, Number(timeoutMs) || 900));

            pending.set(requestId, { resolve, timer });

            try { channel?.postMessage(payload); } catch {}
            try {
              if (window.opener && window.opener !== window) {
                window.opener.postMessage(payload, origin);
              }
            } catch {}
          });
        }

        function broadcastAuthState(stateValue) {
          start();
          const payload = {
            type: "MW_AUTH_SYNC",
            projectRef,
            state: stateValue,
            fromTabId: tabId
          };
          try { channel?.postMessage(payload); } catch {}
          try {
            if (window.opener && window.opener !== window) {
              window.opener.postMessage(payload, origin);
            }
          } catch {}
        }

        return {
          projectRef,
          start,
          hasSession,
          clearSession,
          requestSessionCopy,
          broadcastAuthState
        };
      }

      const sessionBridge = createSupabaseSessionBridge(SUPABASE_URL);
      sessionBridge.start();
      await sessionBridge.requestSessionCopy(1200);

      function setStatus(text, tone) {
        dom.statusText.textContent = text || "";
        dom.pillState.className = "pill";
        if (tone === "err") dom.pillState.classList.add("err");
        else if (tone === "warn") dom.pillState.classList.add("warn");
        else dom.pillState.classList.add("ok");

        dom.pillState.textContent =
          tone === "err" ? "ERROR" :
          tone === "warn" ? "WAIT" : "READY";
      }

      function setLoading(on, text) {
        state.loading = !!on;
        dom.btnReload.disabled = !!on;
        dom.btnExportCsv.disabled = !!on;
        dom.btnClearFilters.disabled = !!on;
        if (on) setStatus(text || "불러오는 중...", "warn");
      }

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function normalizeText(v) {
        return String(v ?? "").replace(/\s+/g, " ").trim();
      }

      function normalizeLower(v) {
        return normalizeText(v).toLowerCase();
      }

      function formatDate(v) {
        const s = normalizeText(v);
        if (!s) return "";
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
        if (/^\d{4}\.\d{1,2}\.\d{1,2}$/.test(s)) {
          const [y, m, d] = s.split(".");
          return [
            y.padStart(4, "0"),
            String(m).padStart(2, "0"),
            String(d).padStart(2, "0")
          ].join("-");
        }
        return s;
      }

      function combinedEmergency(row) {
        const p = normalizeText(row.emergency_contact_phone);
        const r = normalizeText(row.emergency_contact_relationship);
        if (p && r) return p + " / " + r;
        return p || r || "";
      }

      function rowValue(row, key) {
        if (key === "hire_date") return formatDate(row.hire_date);
        if (key === "emergency") return combinedEmergency(row);
        return normalizeText(row[key]);
      }

      function isAllowedViewer(email) {
        const em = normalizeLower(email);
        if (!em) return false;
        if (ALLOWED_EMAILS.map(normalizeLower).includes(em)) return true;
        return ALLOWED_EMAIL_SUFFIXES
          .map(normalizeLower)
          .some(suffix => suffix && em.endsWith(suffix));
      }

      function showAccessDenied(email) {
        dom.accessDenied.classList.add("show");
        dom.accessDeniedText.textContent = "이 페이지는 마루웰 벤더 소속 계정만 조회 가능합니다.";
        dom.accessDeniedEmail.textContent = email
          ? "현재 로그인: " + email
          : "현재 로그인 이메일을 확인할 수 없습니다.";
        document.documentElement.style.visibility = "visible";
      }

      async function signOutAndMove() {
        try {
          await supabase?.auth?.signOut();
          sessionBridge.broadcastAuthState("SIGNED_OUT");
        } catch {}
        location.replace(LOGIN_PATH);
      }

      async function requireAuthOrRedirect() {
        if (!supabase || !supabase.auth) {
          alert("설정 오류: Supabase 연결 실패");
          return false;
        }

        try {
          const { data: { session } } = await supabase.auth.getSession();
          if (!session) {
            const next = safeNextPath(location.pathname + location.search + location.hash);
            location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
            return false;
          }

          state.session = session;
          state.viewerEmail = normalizeText(session.user?.email || "");

          supabase.auth.onAuthStateChange((evt, s) => {
            if (evt === "SIGNED_OUT" || !s) {
              sessionBridge.broadcastAuthState("SIGNED_OUT");
              const next = safeNextPath(location.pathname + location.search + location.hash);
              location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
              return;
            }
            if (evt === "SIGNED_IN" || evt === "TOKEN_REFRESHED" || evt === "USER_UPDATED") {
              sessionBridge.broadcastAuthState("SESSION_UPDATED");
            }
          });

          if (!isAllowedViewer(state.viewerEmail)) {
            showAccessDenied(state.viewerEmail);
            return false;
          }

          document.documentElement.style.visibility = "visible";
          return true;
        } catch (e) {
          console.error(e);
          const next = safeNextPath(location.pathname + location.search + location.hash);
          location.replace(`${LOGIN_PATH}?next=${encodeURIComponent(next)}`);
          return false;
        }
      }

      function getActiveFilterCount() {
        let count = 0;
        if (normalizeText(dom.quickSearch.value)) count += 1;
        if (normalizeText(dom.insuranceFilter.value)) count += 1;
        if (normalizeText(dom.waveFilter.value)) count += 1;
        for (const el of dom.filterInputs) {
          if (normalizeText(el.value)) count += 1;
        }
        return count;
      }

      function updatePills() {
        dom.pillRows.textContent = "행 " + state.filteredRows.length;
        dom.pillFilter.textContent = "필터 " + getActiveFilterCount();
      }

      function updateSummary() {
        dom.summaryTotalRows.textContent = String(state.rows.length);
        dom.summaryFilteredRows.textContent = String(state.filteredRows.length);

        const campSet = new Set();
        let insuranceYes = 0;

        for (const row of state.filteredRows) {
          const camp = normalizeText(row.camp_code);
          if (camp) campSet.add(camp);
          if (normalizeText(row.employment_accident_insurance).toUpperCase() === "O") {
            insuranceYes += 1;
          }
        }

        dom.summaryCampCount.textContent = String(campSet.size);
        dom.summaryInsuranceYes.textContent = String(insuranceYes);
      }

      function buildCell(content, extraClass) {
        return `<div class="readonlyCell ${extraClass || ""} ${content ? "" : "empty"}">${content || ""}</div>`;
      }

      function buildInsuranceChip(value) {
        const v = normalizeText(value).toUpperCase();
        if (!v) return buildCell("", "center");
        const cls = v === "O" ? "ok" : "no";
        return `<div class="readonlyCell center"><span class="chip ${cls}">${escapeHtml(v)}</span></div>`;
      }

      function renderTable() {
        if (!state.filteredRows.length) {
          dom.sheetBody.innerHTML = `
            <tr class="emptyDataRow">
              <td colspan="21">조회 결과가 없습니다.</td>
            </tr>
          `;
          updatePills();
          updateSummary();
          return;
        }

        const rowsHtml = state.filteredRows.map((row, index) => {
          const hireDate = formatDate(row.hire_date);
          const emergency = combinedEmergency(row);

          return `
            <tr>
              <td>${buildCell(String(row.pk_id ?? index + 1), "center right code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.person_name)), "")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.contact_phone)), "code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.position_title)), "center")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.camp_code)), "center")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.wave)), "center")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.coupang_id)), "code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.vehicle_plate_number)), "center")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.resident_registration_number)), "code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.transport_qualification_number)), "code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.sub_account_info)), "")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.payroll_bank_name)), "center")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.payroll_account_number)), "code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.business_name)), "")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.business_registration_number)), "code")}</td>
              <td>${buildCell(escapeHtml(hireDate), "center code")}</td>
              <td>${buildCell(escapeHtml(emergency), "")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.fixed_commission_amount)), "right code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.fixed_unit_price)), "right code")}</td>
              <td>${buildCell(escapeHtml(normalizeText(row.dragon_car_commission)), "right code")}</td>
              <td>${buildInsuranceChip(row.employment_accident_insurance)}</td>
            </tr>
          `;
        }).join("");

        dom.sheetBody.innerHTML = rowsHtml;
        updatePills();
        updateSummary();
      }

      function rowMatchesColumnFilters(row) {
        const toolbarInsurance = normalizeLower(dom.insuranceFilter.value);
        const toolbarWave = normalizeLower(dom.waveFilter.value);

        if (toolbarInsurance) {
          const value = normalizeLower(row.employment_accident_insurance);
          if (value !== toolbarInsurance) return false;
        }

        if (toolbarWave) {
          const value = normalizeLower(row.wave);
          if (value !== toolbarWave) return false;
        }

        for (const el of dom.filterInputs) {
          const key = el.dataset.filter;
          const expected = normalizeLower(el.value);
          if (!expected) continue;

          const actual = normalizeLower(rowValue(row, key));
          if (!actual.includes(expected)) return false;
        }

        return true;
      }

      function rowMatchesQuickSearch(row) {
        const q = normalizeLower(dom.quickSearch.value);
        if (!q) return true;

        const bag = [
          row.pk_id,
          row.person_name,
          row.contact_phone,
          row.position_title,
          row.camp_code,
          row.wave,
          row.coupang_id,
          row.vehicle_plate_number,
          row.resident_registration_number,
          row.transport_qualification_number,
          row.sub_account_info,
          row.payroll_bank_name,
          row.payroll_account_number,
          row.business_name,
          row.business_registration_number,
          row.hire_date,
          row.fixed_commission_amount,
          row.fixed_unit_price,
          row.dragon_car_commission,
          row.employment_accident_insurance,
          combinedEmergency(row)
        ].map(normalizeLower).join(" | ");

        return bag.includes(q);
      }

      function applyFilters() {
        state.filteredRows = state.rows.filter(row => {
          return rowMatchesColumnFilters(row) && rowMatchesQuickSearch(row);
        });

        renderTable();

        if (!state.rows.length) {
          setStatus("데이터가 없습니다.", "warn");
          return;
        }

        if (state.filteredRows.length !== state.rows.length) {
          setStatus(`검색 결과 ${state.filteredRows.length}건`, "ok");
        } else {
          setStatus(`전체 ${state.rows.length}건 로드 완료`, "ok");
        }
      }

      function normalizeRow(row) {
        const out = { ...(row || {}) };
        out.hire_date = formatDate(out.hire_date);
        return out;
      }

      async function fetchRows() {
        try {
          setLoading(true, "데이터 불러오는 중...");
          const { data, error } = await supabase
            .from(TABLE)
            .select("*")
            .order("pk_id", { ascending: true });

          if (error) throw error;

          state.rows = Array.isArray(data) ? data.map(normalizeRow) : [];
          applyFilters();
          setStatus(`전체 ${state.rows.length}건 로드 완료`, "ok");
        } catch (e) {
          console.error(e);
          state.rows = [];
          state.filteredRows = [];
          renderTable();
          setStatus("불러오기 실패: " + (e?.message || String(e)), "err");
        } finally {
          setLoading(false);
        }
      }

      function clearFilters() {
        dom.quickSearch.value = "";
        dom.insuranceFilter.value = "";
        dom.waveFilter.value = "";
        dom.filterInputs.forEach(el => {
          if (el.tagName === "SELECT") el.value = "";
          else el.value = "";
        });
        applyFilters();
      }

      function exportCsv() {
        if (!state.filteredRows.length) {
          alert("내보낼 데이터가 없습니다.");
          return;
        }

        const headers = [
          "pk_id",
          "person_name",
          "contact_phone",
          "position_title",
          "camp_code",
          "wave",
          "coupang_id",
          "vehicle_plate_number",
          "resident_registration_number",
          "transport_qualification_number",
          "sub_account_info",
          "payroll_bank_name",
          "payroll_account_number",
          "business_name",
          "business_registration_number",
          "hire_date",
          "emergency_contact_phone",
          "emergency_contact_relationship",
          "fixed_commission_amount",
          "fixed_unit_price",
          "dragon_car_commission",
          "employment_accident_insurance"
        ];

        const lines = [
          headers.join(","),
          ...state.filteredRows.map(row => {
            return headers.map(key => {
              const raw = key === "hire_date"
                ? formatDate(row[key])
                : normalizeText(row[key]);
              const escaped = String(raw ?? "").replaceAll('"', '""');
              return `"${escaped}"`;
            }).join(",");
          })
        ];

        const csv = "\uFEFF" + lines.join("\n");
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        const now = new Date();
        const stamp = [
          now.getFullYear(),
          String(now.getMonth() + 1).padStart(2, "0"),
          String(now.getDate()).padStart(2, "0"),
          "_",
          String(now.getHours()).padStart(2, "0"),
          String(now.getMinutes()).padStart(2, "0")
        ].join("");

        a.href = url;
        a.download = `maroowell_info_${stamp}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }

      function bindEvents() {
        dom.btnReload.addEventListener("click", fetchRows);
        dom.btnExportCsv.addEventListener("click", exportCsv);
        dom.btnClearFilters.addEventListener("click", clearFilters);
        dom.btnLogout.addEventListener("click", signOutAndMove);

        dom.btnDeniedHome.addEventListener("click", () => {
          location.replace(INDEX_PATH);
        });

        dom.btnDeniedLogout.addEventListener("click", signOutAndMove);

        dom.quickSearch.addEventListener("input", applyFilters);
        dom.insuranceFilter.addEventListener("change", applyFilters);
        dom.waveFilter.addEventListener("change", applyFilters);

        dom.filterInputs.forEach(el => {
          const evt = el.tagName === "SELECT" ? "change" : "input";
          el.addEventListener(evt, applyFilters);
        });
      }

      bindEvents();

      if (!(await requireAuthOrRedirect())) {
        return;
      }

      await fetchRows();
    })();
  </script>
</body>
</html>
