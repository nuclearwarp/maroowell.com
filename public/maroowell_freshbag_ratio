    setStatus(e.message || String(e), "bad");
  }

  function run(fn) {
    fn().catch(handleError);
  }

  initOptions();

  $("campFilter").addEventListener("change", () => {
    syncWaveFromCamp();

    if (clean($("campFilter").value)) {
      run(loadData);
    } else {
      setStatus("캠프를 선택하세요.", "warn");
    }
  });

  ["yearFilter", "monthFilter"].forEach(id => {
    $(id).addEventListener("change", updatePeriodHint);
  });

  $("routeFilter").addEventListener("keydown", e => {
    if (e.key === "Enter") run(loadData);
  });

  $("loadBtn").addEventListener("click", () => run(loadData));
  $("clearBtn").addEventListener("click", clearAll);
  $("copyTotalImageBtn").addEventListener("click", () => run(() => copyElementImage($("totalCaptureTarget"), "월 누적 회수율")));

  $("weekContainer").addEventListener("click", e => {
    const btn = e.target.closest(".copyWeekImageBtn");
    if (!btn) return;

    const week = btn.dataset.week;
    run(() => copyElementImage($(`weekCaptureTarget${week}`), `${week}주차 회수율`, { trimEmptyWeekColumns:true }));
  });

  $("deniedHomeBtn").addEventListener("click", () => {
    location.href = cfg.PATHS?.index || "/zipcode_search";
  });

  $("deniedLogoutBtn").addEventListener("click", () => {
    if (supabaseClient) {
      supabaseClient.auth.signOut().finally(() => {
        location.href = cfg.PATHS?.login || "/";
      });
    } else {
      location.href = cfg.PATHS?.login || "/";
    }
  });

  try {
    initSupabase();

    run(async () => {
      const ok = await checkMaroowellAccess();
      if (!ok) return;

      initRatioUploadSwitchIfAllowed();
      renderTotalTable();
      renderWeeklyTables();
      renderSummary();

      setStatus("백엔드 분리 모드 준비 완료. 조회는 maroowellfreshbag Worker를 통해 실행됩니다.", "ok");
    });
  } catch (e) {
    document.documentElement.style.visibility = "visible";
    handleError(e);
  }
})();
</script>

<script src="/board-menu.js"></script>
</body>
</html>
