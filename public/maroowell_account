<!doctype html>
<html lang="ko">
<head>
  <style>html{visibility:hidden}</style>
  <script src="/config.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="referrer" content="origin" />
  <title>정산 통계 조회</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="/board-menu.js" defer></script>

  <style>
    :root{--bg:#081120;--panel:#101b2f;--panel2:#0d1728;--line:rgba(255,255,255,.11);--line2:rgba(255,255,255,.18);--txt:#eaf2ff;--muted:#9fb0d0;--blue:#2563eb;--green:#16a34a;--red:#b91c1c;--yellow:#f59e0b;--cyan:#0891b2;--shadow:0 16px 42px rgba(0,0,0,.28)}
    *{box-sizing:border-box}
    html,body{margin:0;min-height:100%;background:var(--bg);color:var(--txt);font-family:system-ui,-apple-system,"Noto Sans KR",Segoe UI,Roboto,Arial,sans-serif}
    body{overflow:auto}button,input,select{font-family:inherit}
    .app{min-height:100vh;min-height:100dvh;background:linear-gradient(180deg,var(--bg),#060b13)}
    .topbar{position:sticky;top:0;z-index:40;display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid var(--line);background:linear-gradient(180deg,#0b1424,#07101d)}
    .brand{display:flex;align-items:center;gap:10px;min-width:0}.logoButton{width:34px;height:34px;border:1px solid transparent;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;flex:0 0 auto;cursor:pointer;background:rgba(255,255,255,.03)}.logoButton:hover{background:rgba(255,255,255,.10);border-color:rgba(255,255,255,.18)}.logoButton img{width:28px;height:28px;display:block}.brandText{min-width:0}.brandText h1{margin:0;font-size:22px;line-height:1.05;letter-spacing:-.04em}.brandText p{margin:4px 0 0;color:var(--muted);font-size:12px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topSpacer{flex:1}
    .userBadge{display:inline-flex;align-items:center;min-height:34px;max-width:260px;padding:0 12px;border-radius:999px;border:1px solid var(--line2);background:rgba(255,255,255,.05);color:#bfdbfe;font-size:12px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .btn{height:38px;padding:0 13px;border-radius:999px;border:1px solid var(--line2);background:rgba(255,255,255,.07);color:var(--txt);font-size:13px;font-weight:900;cursor:pointer;white-space:nowrap;touch-action:manipulation}.btn:hover{background:rgba(255,255,255,.11)}.btn.primary{background:rgba(37,99,235,.75);border-color:rgba(147,197,253,.45)}.btn.ok{background:rgba(22,163,74,.55);border-color:rgba(134,239,172,.35)}.btn.copy{background:rgba(14,116,144,.55);border-color:rgba(103,232,249,.35)}.btn.danger{background:rgba(185,28,28,.42);border-color:rgba(252,165,165,.35);color:#fecaca}.btn:disabled{opacity:.55;cursor:not-allowed}
    .wrap{max-width:1760px;margin:0 auto;padding:16px 14px 44px}.card{border:1px solid var(--line2);border-radius:18px;background:rgba(16,27,47,.88);box-shadow:var(--shadow);overflow:hidden;margin-bottom:14px}.cardHead{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:14px 16px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.04)}.cardHead h2{margin:0;font-size:17px;letter-spacing:-.03em}.cardBody{padding:16px}
    .toolbar{display:grid;grid-template-columns:120px 120px 120px 120px 140px 130px 140px minmax(180px,1fr) minmax(240px,1.3fr) auto auto auto;gap:10px;align-items:end}.field{display:flex;flex-direction:column;gap:6px;min-width:0}.field label{color:#bfdbfe;font-size:12px;font-weight:900}.input,.select{width:100%;height:42px;border-radius:12px;border:1px solid var(--line2);background:#0b1220;color:var(--txt);padding:0 12px;font-size:14px;font-weight:800;outline:none}.input:focus,.select:focus{border-color:rgba(96,165,250,.75);box-shadow:0 0 0 3px rgba(96,165,250,.12)}.select option{background:#0b1220;color:#fff}
    .status{font-size:13px;font-weight:800;line-height:1.55;color:#b7c7e6;white-space:pre-wrap;margin-top:10px}.status.ok{color:#bbf7d0}.status.warn{color:#fde68a}.status.err{color:#fecaca}.muted{color:var(--muted);font-size:13px;font-weight:800;line-height:1.55}.hint{color:#9fb0d0;font-size:12px;font-weight:800;line-height:1.55;margin-top:8px}.money{color:#bbf7d0;font-weight:950}.warnText{color:#fde68a;font-weight:950}.dangerText{color:#fecaca;font-weight:950}.blueText{color:#bfdbfe;font-weight:950}
    .pillGrid{display:grid;grid-template-columns:repeat(8,minmax(0,1fr));gap:8px;margin-top:12px}.pill{display:flex;flex-direction:column;gap:5px;min-height:58px;border:1px solid var(--line2);border-radius:14px;background:rgba(255,255,255,.045);padding:9px 10px;min-width:0}.pill span{color:var(--muted);font-size:11px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.pill b{font-size:18px;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .grid2{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:14px}.subCard{border:1px solid var(--line);border-radius:16px;overflow:hidden;background:rgba(13,23,40,.78);min-width:0;margin-bottom:14px}.subCardHead{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:12px 14px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.035)}.subCardHead h3{margin:0;font-size:15px;letter-spacing:-.02em}
    .tableWrap{overflow:auto;max-height:560px;background:rgba(0,0,0,.14)}table{width:100%;min-width:980px;border-collapse:separate;border-spacing:0;font-size:12px}th,td{border-right:1px solid rgba(255,255,255,.11);border-bottom:1px solid rgba(255,255,255,.11);padding:8px 8px;text-align:center;vertical-align:middle;white-space:nowrap}th{position:sticky;top:0;z-index:2;background:#27364d;color:#fff;font-size:12px;font-weight:1000}td{background:rgba(255,255,255,.025);font-weight:800}tr:hover td{background:rgba(96,165,250,.08)}.left{text-align:left!important}.right{text-align:right!important;font-variant-numeric:tabular-nums}.emptyBox{padding:44px 12px;text-align:center;color:#cbd5e1;font-size:14px;font-weight:900}
    .accessDenied{position:fixed;inset:0;display:none;align-items:center;justify-content:center;padding:20px;background:linear-gradient(180deg,rgba(11,18,32,.96),rgba(11,18,32,.98));z-index:9999}.accessDenied.show{display:flex}.accessCard{width:min(520px,calc(100vw - 24px));border:1px solid rgba(255,255,255,.10);border-radius:22px;background:#101827;box-shadow:0 24px 60px rgba(0,0,0,.35);padding:24px}.accessCard h2{margin:0 0 8px;font-size:24px}.accessCard p{margin:0;color:#b8c3d9;line-height:1.6;font-size:14px;white-space:pre-wrap}.accessMeta{margin-top:14px;padding:12px 14px;border-radius:14px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.04);color:#e6eefc;font-size:13px;font-weight:800;word-break:break-word;line-height:1.6}.accessActions{margin-top:18px;display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap}
    @media(max-width:1500px){.toolbar{grid-template-columns:repeat(4,minmax(0,1fr))}.toolbar .btn{width:100%}.pillGrid{grid-template-columns:repeat(4,minmax(0,1fr))}}@media(max-width:980px){.brandText h1{font-size:18px}.brandText p,.userBadge{display:none}.topbar{padding:10px}.topbar .btn{height:34px;padding:0 10px;font-size:12px}.toolbar{grid-template-columns:1fr}.pillGrid{grid-template-columns:repeat(2,minmax(0,1fr))}.grid2{grid-template-columns:1fr}.wrap{padding:10px 8px 36px}.cardBody{padding:12px}.tableWrap{max-height:none}}
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <a id="mwBoardMenuToggle" class="logoButton" href="#" title="게시판 열기" aria-label="게시판 열기"><img src="/favicon.ico" alt="Maroowell" /></a>
        <div class="brandText"><h1>정산 통계 조회</h1><p>월별·일별·요일별·노선별 배송/반품 수량 통계</p></div>
      </div>
      <div class="topSpacer"></div><div id="userBadge" class="userBadge">-</div><button id="btnLogout" class="btn danger" type="button">로그아웃</button>
    </header>

    <main class="wrap">
      <section class="card">
        <div class="cardHead"><h2>조회 조건</h2><span id="stateText" class="muted">대기 중</span></div>
        <div class="cardBody">
          <div class="toolbar">
            <div class="field"><label for="yearSelect">정산 연도</label><select id="yearSelect" class="select"></select></div>
            <div class="field"><label for="startMonthSelect">시작 월</label><select id="startMonthSelect" class="select"></select></div>
            <div class="field"><label for="endMonthSelect">종료 월</label><select id="endMonthSelect" class="select"></select></div>
            <div class="field"><label for="campSelect">캠프 필터</label><select id="campSelect" class="select"><option value="">전체 캠프</option></select></div>
            <div class="field"><label for="waveSelect">주/야</label><select id="waveSelect" class="select"><option value="">전체</option><option value="주간">주간</option><option value="야간">야간</option><option value="WAVE2">WAVE2</option><option value="WAVE1">WAVE1</option></select></div>
            <div class="field"><label for="currentCampInput">현재 캠프</label><input id="currentCampInput" class="input" placeholder="예: 대구3" autocomplete="off" /></div>
            <div class="field"><label for="currentRouteInput">현재 노선</label><input id="currentRouteInput" class="input" placeholder="예: 213" autocomplete="off" /></div>
            <div class="field"><label for="pastRoutesInput">과거 캠프/노선</label><input id="pastRoutesInput" class="input" placeholder="예: 대구3/329, 대구2/211" autocomplete="off" /></div>
            <div class="field"><label for="searchInput">통합 검색</label><input id="searchInput" class="input" type="text" placeholder="ID / 캠프 / 노선 / 배송유형" autocomplete="off" /></div>
            <button id="btnLoad" class="btn primary" type="button">조회</button>
            <button id="btnExcel" class="btn ok" type="button">엑셀 다운로드</button>
            <button id="btnReset" class="btn" type="button">초기화</button>
          </div>
          <div class="hint">현재 노선 기준으로 과거 노선을 같이 보고 싶으면 현재 캠프/노선을 입력하고, 과거 캠프/노선에 <b>대구3/329, 대구2/211</b>처럼 입력하세요. 금액은 제외하고 배송/반품 수량만 집계합니다.</div>
          <div id="statusText" class="status">정산 기간을 선택하고 조회를 누르세요.</div>
          <div id="summaryGrid" class="pillGrid"></div>
        </div>
      </section>

      <section class="card">
        <div class="cardHead"><h2>노선별 수량 통계</h2><span id="routeNote" class="muted">-</span></div>
        <div class="tableWrap"><table id="routeTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div>
      </section>

      <div class="grid2">
        <section class="subCard"><div class="subCardHead"><h3>일별 수량 통계</h3><span id="dailyNote" class="muted">-</span></div><div class="tableWrap"><table id="dailyTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section>
        <section class="subCard"><div class="subCardHead"><h3>요일별 수량 통계</h3><span id="weekdayNote" class="muted">-</span></div><div class="tableWrap"><table id="weekdayTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div></section>
      </div>

      <section class="card">
        <div class="cardHead"><h2>월별 수량 통계</h2><span id="monthlyNote" class="muted">-</span></div>
        <div class="tableWrap"><table id="monthlyTable"><thead></thead><tbody><tr><td><div class="emptyBox">조회된 통계가 없습니다.</div></td></tr></tbody></table></div>
      </section>
    </main>
  </div>

  <div id="accessDenied" class="accessDenied"><div class="accessCard"><h2>접근 권한 없음</h2><p id="accessDeniedText">최고관리자 권한이 필요합니다.</p><div id="accessDeniedEmail" class="accessMeta"></div><div class="accessActions"><button id="deniedHomeBtn" class="btn" type="button">홈으로</button><button id="deniedLogoutBtn" class="btn danger" type="button">로그아웃</button></div></div></div>

  <script>
    (async function(){
      "use strict";

      const CONFIG = window.MARUWELL_CONFIG || {};
      const SUPABASE_URL = CONFIG.SUPABASE_URL;
      const SUPABASE_ANON_KEY = CONFIG.SUPABASE_ANON_KEY;
      const LOGIN_PATH = CONFIG.PATHS?.login || "/login.html";
      const HOME_PATH = CONFIG.PATHS?.index || "/zipcode_search";
      const TABLE_NAME = "maroowell_account";
      const WEEKDAYS = ["일","월","화","수","목","금","토"];

      const els = {
        userBadge:document.getElementById("userBadge"),btnLogout:document.getElementById("btnLogout"),yearSelect:document.getElementById("yearSelect"),startMonthSelect:document.getElementById("startMonthSelect"),endMonthSelect:document.getElementById("endMonthSelect"),campSelect:document.getElementById("campSelect"),waveSelect:document.getElementById("waveSelect"),currentCampInput:document.getElementById("currentCampInput"),currentRouteInput:document.getElementById("currentRouteInput"),pastRoutesInput:document.getElementById("pastRoutesInput"),searchInput:document.getElementById("searchInput"),btnLoad:document.getElementById("btnLoad"),btnExcel:document.getElementById("btnExcel"),btnReset:document.getElementById("btnReset"),stateText:document.getElementById("stateText"),statusText:document.getElementById("statusText"),summaryGrid:document.getElementById("summaryGrid"),routeTable:document.getElementById("routeTable"),dailyTable:document.getElementById("dailyTable"),weekdayTable:document.getElementById("weekdayTable"),monthlyTable:document.getElementById("monthlyTable"),routeNote:document.getElementById("routeNote"),dailyNote:document.getElementById("dailyNote"),weekdayNote:document.getElementById("weekdayNote"),monthlyNote:document.getElementById("monthlyNote"),accessDenied:document.getElementById("accessDenied"),accessDeniedText:document.getElementById("accessDeniedText"),accessDeniedEmail:document.getElementById("accessDeniedEmail"),deniedHomeBtn:document.getElementById("deniedHomeBtn"),deniedLogoutBtn:document.getElementById("deniedLogoutBtn")
      };

      const state = {session:null,user:null,access:null,rows:[],rawRows:[],filteredRows:[],stats:null};
      const supabaseClient = SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase ? window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {auth:{storage:window.sessionStorage,persistSession:true,autoRefreshToken:true,detectSessionInUrl:true}}) : null;

      function clean(v){return String(v ?? "").trim()}
      function esc(v){return String(v ?? "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#39;")}
      function num(v){const n=Number(v||0);return Number.isFinite(n)?n:0}
      function int(v){return Math.round(num(v))}
      function count(v){return int(v).toLocaleString("ko-KR")}
      function setStatus(text,type){els.statusText.textContent=text||"";els.statusText.className=type?`status ${type}`:"status"}
      function setBusy(busy){els.btnLoad.disabled=busy;els.btnExcel.disabled=busy;els.stateText.textContent=busy?"처리 중":"READY"}
      function yyyyMm(row){const y=Number(row.date_year||0);const m=Number(row.date_month||0);return y&&m?`${y}-${String(m).padStart(2,"0")}`:clean(row.delivery_date).slice(0,7)}
      function weekdayOf(date){const d=new Date(`${date}T00:00:00`);return Number.isFinite(d.getTime())?d.getDay():-1}
      function weekdayLabel(date){const wd=weekdayOf(date);return wd>=0?WEEKDAYS[wd]:""}
      function normalizeWave(v){const raw=clean(v).toUpperCase();if(raw==="WAVE2"||raw==="2W"||raw==="주간")return "주간";if(raw==="WAVE1"||raw==="1W"||raw==="야간")return "야간";return clean(v)||"-"}
      function isLossRow(row){const source=clean(row.source_sheet).replace(/\s+/g,"").toLowerCase();const classify=clean(row.classify).replace(/\s+/g,"").toLowerCase();return source==="분실파손list"||classify==="분실파손"||classify.includes("분실")||classify.includes("파손")}
      function isRawRow(row){return !isLossRow(row)}
      function routeTokens(value){return clean(value).split(/[,\s/]+/).map(clean).filter(Boolean)}
      function routeBase(value){const token=routeTokens(value)[0]||clean(value);if(!token)return "-";const m=token.match(/^(?:[A-Za-z가-힣_]+)?(\d+)/);return m?m[1]:token}
      function normRoute(v){return routeBase(v).toUpperCase()}
      function normCamp(v){return clean(v).replace(/\s+/g,"")}
      function routePair(camp,route){return `${normCamp(camp)}||${normRoute(route)}`}

      function targetPairs(){
        const currentCamp=clean(els.currentCampInput.value);
        const currentRoute=clean(els.currentRouteInput.value);
        const pairs=[];
        if(currentRoute){pairs.push({camp:currentCamp,route:currentRoute,label:`${currentCamp||"전체"}/${routeBase(currentRoute)}`,canonical:true});}
        clean(els.pastRoutesInput.value).split(",").map(clean).filter(Boolean).forEach(item=>{
          const parts=item.split(/[\/|]/).map(clean).filter(Boolean);
          if(parts.length>=2)pairs.push({camp:parts[0],route:parts[1],label:`${parts[0]}/${routeBase(parts[1])}`,canonical:false});
          else if(parts.length===1)pairs.push({camp:currentCamp,route:parts[0],label:`${currentCamp||"전체"}/${routeBase(parts[0])}`,canonical:false});
        });
        return pairs;
      }

      function selectedPeriod(){
        const y=els.yearSelect.value?Number(els.yearSelect.value):null;
        const sm=els.startMonthSelect.value?Number(els.startMonthSelect.value):null;
        const em=els.endMonthSelect.value?Number(els.endMonthSelect.value):null;
        if(sm&&em&&sm>em)throw new Error("시작 월이 종료 월보다 큽니다.");
        return {year:y,startMonth:sm,endMonth:em};
      }

      function periodText(p){
        const y=p.year?`${p.year}년`:"전체 연도";
        if(!p.startMonth&&!p.endMonth)return `${y} 전체 월`;
        if(p.startMonth&&p.endMonth)return `${y} ${p.startMonth}월~${p.endMonth}월`;
        if(p.startMonth)return `${y} ${p.startMonth}월~`;
        return `${y} ~${p.endMonth}월`;
      }

      function showAccessDenied(message){els.accessDeniedText.textContent=message||"최고관리자 권한이 필요합니다.";els.accessDeniedEmail.textContent=state.user?.email?`현재 계정: ${state.user.email}`:"로그인 계정을 확인할 수 없습니다.";els.accessDenied.classList.add("show");document.documentElement.style.visibility="visible"}
      async function logout(){try{if(supabaseClient)await supabaseClient.auth.signOut()}catch{}location.href=LOGIN_PATH}

      async function checkAccess(){
        if(!supabaseClient){showAccessDenied("Supabase 설정을 찾지 못했습니다. config.js를 확인하세요.");return false}
        const {data:sessionData,error:sessionError}=await supabaseClient.auth.getSession();if(sessionError)throw sessionError;
        state.session=sessionData?.session||null;state.user=state.session?.user||null;
        if(!state.user){location.href=`${LOGIN_PATH}?next=${encodeURIComponent(location.pathname)}`;return false}
        els.userBadge.textContent=state.user.email||state.user.id||"로그인";
        const {data,error}=await supabaseClient.rpc("mw_my_access").maybeSingle();if(error)throw error;
        state.access=data||null;
        const isSuperAdmin=data?.is_maroowell===true&&data?.is_admin===true&&Number(data?.max_role_level||0)>=90;
        if(!isSuperAdmin){showAccessDenied("최고관리자 권한이 필요합니다.\n조건: 마루웰 권한 + 관리자 권한 + role_level 90 이상");return false}
        document.documentElement.style.visibility="visible";return true;
      }

      function initSelects(){
        const now=new Date();const currentYear=now.getFullYear();const currentMonth=now.getMonth()+1;const years=[];for(let y=currentYear+1;y>=currentYear-8;y--)years.push(y);
        els.yearSelect.innerHTML=`<option value="">전체 연도</option>`+years.map(y=>`<option value="${y}">${y}년</option>`).join("");
        const monthOptions=`<option value="">전체 월</option>`+Array.from({length:12},(_,i)=>`<option value="${i+1}">${i+1}월</option>`).join("");
        els.startMonthSelect.innerHTML=monthOptions;els.endMonthSelect.innerHTML=monthOptions;
        els.yearSelect.value=String(currentYear);els.startMonthSelect.value=String(currentMonth);els.endMonthSelect.value=String(currentMonth);
      }

      async function fetchRows(p){
        const pageSize=1000;const out=[];
        for(let from=0;from<100000;from+=pageSize){
          let query=supabaseClient.from(TABLE_NAME).select("*");
          if(p.year)query=query.eq("date_year",p.year);
          if(p.startMonth&&p.endMonth&&p.startMonth===p.endMonth)query=query.eq("date_month",p.startMonth);
          else {if(p.startMonth)query=query.gte("date_month",p.startMonth);if(p.endMonth)query=query.lte("date_month",p.endMonth);}
          query=query.order("date_year",{ascending:true,nullsFirst:false}).order("date_month",{ascending:true,nullsFirst:false}).order("delivery_date",{ascending:true,nullsFirst:false}).range(from,from+pageSize-1);
          const {data,error}=await query;if(error)throw error;const rows=Array.isArray(data)?data:[];out.push(...rows);if(rows.length<pageSize)break;
        }
        return out;
      }

      function rebuildCampOptions(rows){
        const selected=els.campSelect.value;const camps=Array.from(new Set(rows.map(r=>clean(r.camp)).filter(Boolean))).sort((a,b)=>a.localeCompare(b,"ko",{numeric:true,sensitivity:"base"}));
        els.campSelect.innerHTML=`<option value="">전체 캠프</option>`+camps.map(c=>`<option value="${esc(c)}">${esc(c)}</option>`).join("");
        if(selected&&camps.includes(selected))els.campSelect.value=selected;
      }

      function rowMatchesTarget(row,pairs){
        if(!pairs.length)return true;
        const rc=normCamp(row.camp);const rr=normRoute(row.route);
        return pairs.some(p=>{
          const pc=normCamp(p.camp);const pr=normRoute(p.route);
          if(!pr)return false;
          if(pc&&pc!==rc)return false;
          return pr===rr;
        });
      }

      function groupFor(row,pairs){
        const canonical=pairs.find(p=>p.canonical&&clean(p.route));
        if(canonical&&rowMatchesTarget(row,pairs))return {camp:clean(canonical.camp)||clean(row.camp)||"-",route:routeBase(canonical.route),original:`${clean(row.camp)||"-"}/${routeBase(row.route)}`};
        return {camp:clean(row.camp)||"-",route:routeBase(row.route),original:`${clean(row.camp)||"-"}/${routeBase(row.route)}`};
      }

      function newMetric(extra={}){return {rows:0,daysSet:new Set(),routeSet:new Set(),idSet:new Set(),origSet:new Set(),parcel:0,ret:0,qty:0,first_date:"",last_date:"",...extra}}
      function addMetric(m,row,group){
        const date=clean(row.delivery_date);m.rows+=1;m.parcel+=num(row.parcel);m.ret+=num(row.return);m.qty+=num(row.parcel)+num(row.return);
        if(date){m.daysSet.add(date);if(!m.first_date||date<m.first_date)m.first_date=date;if(!m.last_date||date>m.last_date)m.last_date=date;}
        if(clean(row.id))m.idSet.add(clean(row.id));
        if(group){m.routeSet.add(`${group.camp}/${group.route}`);m.origSet.add(group.original);}
      }
      function finalize(m){const days=m.daysSet.size;return {...m,days,route_count:m.routeSet.size,id_count:m.idSet.size,origins:Array.from(m.origSet).sort((a,b)=>a.localeCompare(b,"ko",{numeric:true,sensitivity:"base"})).join(", "),avg:days?m.qty/days:0}}

      function buildStats(){
        const p=selectedPeriod();const campFilter=clean(els.campSelect.value);const waveFilter=clean(els.waveSelect.value);const q=clean(els.searchInput.value).toLowerCase();const pairs=targetPairs();
        const rows=state.rawRows.filter(row=>{
          if(campFilter&&clean(row.camp)!==campFilter)return false;
          if(waveFilter){const wf=normalizeWave(waveFilter);if(normalizeWave(row.wave)!==wf&&clean(row.wave)!==waveFilter)return false;}
          if(!rowMatchesTarget(row,pairs))return false;
          if(q){const hay=[row.classify,row.id,row.route,row.delivery_date,row.camp,row.wave,normalizeWave(row.wave)].map(clean).join(" ").toLowerCase();if(!hay.includes(q))return false;}
          return true;
        });
        state.filteredRows=rows;
        const total=newMetric();const routeMap=new Map();const dailyMap=new Map();const weekdayMap=new Map();const monthlyMap=new Map();
        rows.forEach(row=>{
          const group=groupFor(row,pairs);const wave=normalizeWave(row.wave);const date=clean(row.delivery_date);const month=yyyyMm(row);const wd=weekdayLabel(date);
          addMetric(total,row,group);
          const rk=`${group.camp}||${wave}||${group.route}`;if(!routeMap.has(rk))routeMap.set(rk,newMetric({camp:group.camp,wave,route:group.route}));addMetric(routeMap.get(rk),row,group);
          if(date){const dk=`${date}||${wd}||${group.camp}||${wave}||${group.route}`;if(!dailyMap.has(dk))dailyMap.set(dk,newMetric({date,weekday:wd,camp:group.camp,wave,route:group.route}));addMetric(dailyMap.get(dk),row,group);}
          if(wd){const wdn=weekdayOf(date);const wk=`${wdn}||${wd}||${group.camp}||${wave}||${group.route}`;if(!weekdayMap.has(wk))weekdayMap.set(wk,newMetric({weekday_no:wdn,weekday:wd,camp:group.camp,wave,route:group.route}));addMetric(weekdayMap.get(wk),row,group);}
          if(month){const mk=`${month}||${group.camp}||${wave}||${group.route}`;if(!monthlyMap.has(mk))monthlyMap.set(mk,newMetric({month,camp:group.camp,wave,route:group.route}));addMetric(monthlyMap.get(mk),row,group);}
        });
        const sortCommon=(a,b)=>a.camp.localeCompare(b.camp,"ko",{numeric:true,sensitivity:"base"})||a.wave.localeCompare(b.wave,"ko",{numeric:true,sensitivity:"base"})||a.route.localeCompare(b.route,"ko",{numeric:true,sensitivity:"base"});
        state.stats={total:finalize(total),routeRows:Array.from(routeMap.values()).map(finalize).sort((a,b)=>b.qty-a.qty||sortCommon(a,b)),dailyRows:Array.from(dailyMap.values()).map(finalize).sort((a,b)=>a.date.localeCompare(b.date)||sortCommon(a,b)),weekdayRows:Array.from(weekdayMap.values()).map(finalize).sort((a,b)=>a.weekday_no-b.weekday_no||sortCommon(a,b)),monthlyRows:Array.from(monthlyMap.values()).map(finalize).sort((a,b)=>a.month.localeCompare(b.month)||sortCommon(a,b))};
        renderAll();
      }

      async function loadRows(){
        let p;try{p=selectedPeriod()}catch(e){setStatus(e.message,"err");return}
        setBusy(true);setStatus(`${periodText(p)} 정산 데이터를 조회하는 중입니다...`,"");
        try{
          const rows=await fetchRows(p);state.rows=rows;state.rawRows=rows.filter(isRawRow).filter(r=>clean(r.route)&&clean(r.delivery_date));rebuildCampOptions(state.rawRows);buildStats();
          const lossCount=rows.filter(isLossRow).length;setStatus(`조회 완료: 정산Raw ${state.rawRows.length.toLocaleString("ko-KR")}행 기준으로 통계를 생성했습니다. / 분실·파손 ${lossCount.toLocaleString("ko-KR")}행은 수량 통계에서 제외했습니다.`,state.filteredRows.length?"ok":"warn");
        }catch(err){console.error(err);setStatus(`조회 실패: ${err.message||err}`,"err")}finally{setBusy(false)}
      }

      function pill(label,value,cls=""){return `<div class="pill"><span>${esc(label)}</span><b class="${cls}">${esc(value)}</b></div>`}
      function renderSummary(){const s=state.stats?.total||finalize(newMetric());let p;try{p=selectedPeriod()}catch{p={year:null,startMonth:null,endMonth:null}}els.summaryGrid.innerHTML=[pill("조회 기간",periodText(p),"blueText"),pill("집계 행",count(s.rows)),pill("노선 그룹",count(s.route_count)),pill("일자 수",count(s.days)),pill("배송",count(s.parcel)),pill("반품",count(s.ret)),pill("총수량",count(s.qty),"money"),pill("일평균",s.avg?s.avg.toLocaleString("ko-KR",{maximumFractionDigits:1}):"0","warnText")].join("")}

      function setEmpty(table,col,msg){table.querySelector("tbody").innerHTML=`<tr><td colspan="${col}"><div class="emptyBox">${esc(msg)}</div></td></tr>`}
      function renderRouteTable(){const rows=state.stats?.routeRows||[];const headers=["캠프","주/야","노선","일자 수","배송","반품","총수량","일평균","원본 캠프/노선","기간"];els.routeTable.querySelector("thead").innerHTML=`<tr>${headers.map(h=>`<th>${esc(h)}</th>`).join("")}</tr>`;if(!rows.length){setEmpty(els.routeTable,headers.length,"조회된 노선별 통계가 없습니다.");els.routeNote.textContent="0행";return}els.routeTable.querySelector("tbody").innerHTML=rows.map(r=>`<tr><td>${esc(r.camp)}</td><td>${esc(r.wave)}</td><td class="left">${esc(r.route)}</td><td class="right">${count(r.days)}</td><td class="right">${count(r.parcel)}</td><td class="right">${count(r.ret)}</td><td class="right money">${count(r.qty)}</td><td class="right warnText">${r.avg.toLocaleString("ko-KR",{maximumFractionDigits:1})}</td><td class="left">${esc(r.origins||"-")}</td><td>${esc([r.first_date,r.last_date].filter(Boolean).join(" ~ "))}</td></tr>`).join("");els.routeNote.textContent=`${rows.length.toLocaleString("ko-KR")}행`}
      function renderDailyTable(){const rows=state.stats?.dailyRows||[];const headers=["배송일자","요일","캠프","주/야","노선","배송","반품","총수량"];els.dailyTable.querySelector("thead").innerHTML=`<tr>${headers.map(h=>`<th>${esc(h)}</th>`).join("")}</tr>`;if(!rows.length){setEmpty(els.dailyTable,headers.length,"조회된 일별 통계가 없습니다.");els.dailyNote.textContent="0행";return}els.dailyTable.querySelector("tbody").innerHTML=rows.map(r=>`<tr><td>${esc(r.date)}</td><td>${esc(r.weekday)}</td><td>${esc(r.camp)}</td><td>${esc(r.wave)}</td><td class="left">${esc(r.route)}</td><td class="right">${count(r.parcel)}</td><td class="right">${count(r.ret)}</td><td class="right money">${count(r.qty)}</td></tr>`).join("");els.dailyNote.textContent=`${rows.length.toLocaleString("ko-KR")}행`}
      function renderWeekdayTable(){const rows=state.stats?.weekdayRows||[];const headers=["요일","캠프","주/야","노선","일자 수","배송","반품","총수량","일평균"];els.weekdayTable.querySelector("thead").innerHTML=`<tr>${headers.map(h=>`<th>${esc(h)}</th>`).join("")}</tr>`;if(!rows.length){setEmpty(els.weekdayTable,headers.length,"조회된 요일별 통계가 없습니다.");els.weekdayNote.textContent="0행";return}els.weekdayTable.querySelector("tbody").innerHTML=rows.map(r=>`<tr><td>${esc(r.weekday)}</td><td>${esc(r.camp)}</td><td>${esc(r.wave)}</td><td class="left">${esc(r.route)}</td><td class="right">${count(r.days)}</td><td class="right">${count(r.parcel)}</td><td class="right">${count(r.ret)}</td><td class="right money">${count(r.qty)}</td><td class="right warnText">${r.avg.toLocaleString("ko-KR",{maximumFractionDigits:1})}</td></tr>`).join("");els.weekdayNote.textContent=`${rows.length.toLocaleString("ko-KR")}행`}
      function renderMonthlyTable(){const rows=state.stats?.monthlyRows||[];const headers=["정산월","캠프","주/야","노선","일자 수","배송","반품","총수량","일평균"];els.monthlyTable.querySelector("thead").innerHTML=`<tr>${headers.map(h=>`<th>${esc(h)}</th>`).join("")}</tr>`;if(!rows.length){setEmpty(els.monthlyTable,headers.length,"조회된 월별 통계가 없습니다.");els.monthlyNote.textContent="0행";return}els.monthlyTable.querySelector("tbody").innerHTML=rows.map(r=>`<tr><td>${esc(r.month)}</td><td>${esc(r.camp)}</td><td>${esc(r.wave)}</td><td class="left">${esc(r.route)}</td><td class="right">${count(r.days)}</td><td class="right">${count(r.parcel)}</td><td class="right">${count(r.ret)}</td><td class="right money">${count(r.qty)}</td><td class="right warnText">${r.avg.toLocaleString("ko-KR",{maximumFractionDigits:1})}</td></tr>`).join("");els.monthlyNote.textContent=`${rows.length.toLocaleString("ko-KR")}행`}
      function renderAll(){renderSummary();renderRouteTable();renderDailyTable();renderWeekdayTable();renderMonthlyTable()}
      function resetTables(){state.rows=[];state.rawRows=[];state.filteredRows=[];state.stats=null;els.searchInput.value="";renderAll();setStatus("정산 기간을 선택하고 조회를 누르세요.","")}

      function sheetRows(rows,map){return rows.map((r,i)=>({No:i+1,...map(r)}))}
      function exportExcel(){if(!state.stats||!state.filteredRows.length){setStatus("다운로드할 통계가 없습니다. 먼저 조회하세요.","warn");return}const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(sheetRows(state.stats.routeRows,r=>({캠프:r.camp,주야:r.wave,노선:r.route,일자수:r.days,배송:r.parcel,반품:r.ret,총수량:r.qty,일평균:Number(r.avg.toFixed(1)),원본캠프노선:r.origins,시작일:r.first_date,종료일:r.last_date}))),"노선별");XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(sheetRows(state.stats.dailyRows,r=>({배송일자:r.date,요일:r.weekday,캠프:r.camp,주야:r.wave,노선:r.route,배송:r.parcel,반품:r.ret,총수량:r.qty}))),"일별");XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(sheetRows(state.stats.weekdayRows,r=>({요일:r.weekday,캠프:r.camp,주야:r.wave,노선:r.route,일자수:r.days,배송:r.parcel,반품:r.ret,총수량:r.qty,일평균:Number(r.avg.toFixed(1))}))),"요일별");XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(sheetRows(state.stats.monthlyRows,r=>({정산월:r.month,캠프:r.camp,주야:r.wave,노선:r.route,일자수:r.days,배송:r.parcel,반품:r.ret,총수량:r.qty,일평균:Number(r.avg.toFixed(1))}))),"월별");XLSX.writeFile(wb,"maroowell_account_quantity_stats.xlsx")}

      function bind(){
        els.btnLogout.addEventListener("click",logout);els.deniedLogoutBtn.addEventListener("click",logout);els.deniedHomeBtn.addEventListener("click",()=>{location.href=HOME_PATH});els.btnLoad.addEventListener("click",loadRows);els.btnExcel.addEventListener("click",exportExcel);els.btnReset.addEventListener("click",resetTables);
        [els.campSelect,els.waveSelect,els.currentCampInput,els.currentRouteInput,els.pastRoutesInput,els.searchInput].forEach(el=>{el.addEventListener("input",()=>{if(state.rawRows.length)buildStats()});el.addEventListener("change",()=>{if(state.rawRows.length)buildStats()})});
        [els.yearSelect,els.startMonthSelect,els.endMonthSelect].forEach(el=>el.addEventListener("change",resetTables));
        [els.searchInput,els.currentCampInput,els.currentRouteInput,els.pastRoutesInput].forEach(el=>el.addEventListener("keydown",e=>{if(e.key==="Enter"&&state.rawRows.length)buildStats()}));
      }
      async function boot(){initSelects();bind();renderAll();try{await checkAccess()}catch(err){console.error(err);showAccessDenied(err.message||String(err))}}
      boot();
    })();
  </script>
